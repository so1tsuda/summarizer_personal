      "start": 457.28,
      "duration": 6.319,
      "text": "私は考えております。最後3つ目の自分の"
    },
    {
      "start": 461.16,
      "duration": 5.159,
      "text": "言いたいことが伝わらないという悩みに"
    },
    {
      "start": 463.599,
      "duration": 4.921,
      "text": "ついては皆さん1番あの悩まれてる"
    },
    {
      "start": 466.319,
      "duration": 5.32,
      "text": "ポイントかもしれないんですけども自分"
    },
    {
      "start": 468.52,
      "duration": 6.239,
      "text": "自身では意見を話している伝えてるつもり"
    },
    {
      "start": 471.639,
      "duration": 5.881,
      "text": "なのに相手に全然理解してもらえないと"
    },
    {
      "start": 474.759,
      "duration": 4.601,
      "text": "そういう悩みです。多くの方が伝わらない"
    },
    {
      "start": 477.52,
      "duration": 5.92,
      "text": "という壁にぶつかってるように感じるん"
    },
    {
      "start": 479.36,
      "duration": 6.6,
      "text": "ですけれども、実は比較的簡単なやり方、"
    },
    {
      "start": 483.44,
      "duration": 6.56,
      "text": "技術によってその悩みは解消できるんじゃ"
    },
    {
      "start": 485.96,
      "duration": 7.799,
      "text": "ないかなという風に私は考えております。"
    },
    {
      "start": 490.0,
      "duration": 7.12,
      "text": "そして今ご説明したような3つの異なる"
    },
    {
      "start": 493.759,
      "duration": 6.521,
      "text": "言語化の悩みというものに対してそれぞれ"
    },
    {
      "start": 497.12,
      "duration": 7.4,
      "text": "解消できるかトレーニングはないかなと"
    },
    {
      "start": 500.28,
      "duration": 8.08,
      "text": "いう風に考えてその時に私が着目したのが"
    },
    {
      "start": 504.52,
      "duration": 7.44,
      "text": "具体と抽象を生きするという思考フレーム"
    },
    {
      "start": 508.36,
      "duration": 5.52,
      "text": "でした。具体と抽象を生きするというのは"
    },
    {
      "start": 511.96,
      "duration": 4.519,
      "text": "よくコンサルタントが使う思考の"
    },
    {
      "start": 513.88,
      "duration": 6.12,
      "text": "フレームワークですね。そうですね。あの"
    },
    {
      "start": 516.479,
      "duration": 5.881,
      "text": "、具体中象というテーマの本をすでに"
    },
    {
      "start": 520.0,
      "duration": 4.72,
      "text": "たくさん出ておりますし、どこかで"
    },
    {
      "start": 522.36,
      "duration": 4.84,
      "text": "聞きかじった異なる言葉じゃないかなと"
    },
    {
      "start": 524.72,
      "duration": 5.08,
      "text": "いう風に思うんですけども、具体抽象と"
    },
    {
      "start": 527.2,
      "duration": 5.56,
      "text": "いう思考のフレームワークを言語化の"
    },
    {
      "start": 529.8,
      "duration": 6.4,
      "text": "プロセスに落とし込んでみるというのが"
    },
    {
      "start": 532.76,
      "duration": 6.68,
      "text": "今回の本の1番のチャレンジでした。自分"
    },
    {
      "start": 536.2,
      "duration": 6.92,
      "text": "の頭の中を具体化する、抽傷化する、それ"
    },
    {
      "start": 539.44,
      "duration": 8.24,
      "text": "を生きするというフレームワークを先ほど"
    },
    {
      "start": 543.12,
      "duration": 7.719,
      "text": "の3つの悩みに沿って分けてトレーニング"
    },
    {
      "start": 547.68,
      "duration": 6.12,
      "text": "していくということが皆さんの言語火力を"
    },
    {
      "start": 550.839,
      "duration": 5.881,
      "text": "高めていく上で効果的なんかなという風に"
    },
    {
      "start": 553.8,
      "duration": 4.36,
      "text": "思っております。是非教えてください。"
    },
    {
      "start": 556.72,
      "duration": 4.52,
      "text": "どんなですか?"
    },
    {
      "start": 558.16,
      "duration": 5.32,
      "text": "では早速、え、ステップ1の"
    },
    {
      "start": 561.24,
      "duration": 4.56,
      "text": "家トレーニングからご説明していきたいと"
    },
    {
      "start": 563.48,
      "duration": 5.479,
      "text": "いう風に思います。まず先ほどの悩みです"
    },
    {
      "start": 565.8,
      "duration": 6.92,
      "text": "ね、自分の言いたいことが思いつかないと"
    },
    {
      "start": 568.959,
      "duration": 7.56,
      "text": "いう悩みをなくすために、まずはご自身の"
    },
    {
      "start": 572.72,
      "duration": 6.64,
      "text": "頭の中を一度具体化して自分のモヤモヤを"
    },
    {
      "start": 576.519,
      "duration": 6.361,
      "text": "掴んでいただくというトレーニングになり"
    },
    {
      "start": 579.36,
      "duration": 6.84,
      "text": "ます。続いてステップ2のトレーニングで"
    },
    {
      "start": 582.88,
      "duration": 6.16,
      "text": "は自分が具体化した言いたいことが"
    },
    {
      "start": 586.2,
      "duration": 7.12,
      "text": "たくさん出てきた時にそれらがまとまら"
    },
    {
      "start": 589.04,
      "duration": 7.56,
      "text": "ないんだという悩みに対して頭の中を逆に"
    },
    {
      "start": 593.32,
      "duration": 5.84,
      "text": "抽象化することで、ま、整理していくと"
    },
    {
      "start": 596.6,
      "duration": 5.6,
      "text": "そういうステップになります。では最後"
    },
    {
      "start": 599.16,
      "duration": 6.359,
      "text": "ステップ3ですが、自分の言いたいことが"
    },
    {
      "start": 602.2,
      "duration": 8.36,
      "text": "伝わらないという悩みをなくすために頭の"
    },
    {
      "start": 605.519,
      "duration": 7.88,
      "text": "中の具体と抽象をバランスよく、え、伝え"
    },
    {
      "start": 610.56,
      "duration": 6.48,
      "text": "ていくことで相手にうまく伝えるとその"
    },
    {
      "start": 613.399,
      "duration": 4.961,
      "text": "ためのになります。順番に教えてください"
    },
    {
      "start": 617.04,
      "duration": 3.479,
      "text": "。ステップ1"
    },
    {
      "start": 618.36,
      "duration": 3.28,
      "text": "のトレーニングはどういうものですか?"
    },
    {
      "start": 620.519,
      "duration": 4.121,
      "text": "まずステップ1"
    },
    {
      "start": 621.64,
      "duration": 3.0,
      "text": "頭の中にあるモヤモヤしたものを具体化して言葉にしていくために、え、本書の中では"
    },
    {
      "start": 628.8,
      "duration": 2.92,
      "text": "3"
    },
    {
      "start": 629.04,
      "duration": 4.0,
      "text": "つのトレーニングをご用意しております。"
    },
    {
      "start": 631.72,
      "duration": 4.32,
      "text": "1つ目がY"
    },
    {
      "start": 633.04,
      "duration": 3.0,
      "text": "ソトレーニングと呼んでおります。それはなぜというものを自分に問いかけて頭の中を具体化しです。"
    },
    {
      "start": 641.76,
      "duration": 6.28,
      "text": "2つ目がソアトレーニングと呼んでいるん"
    },
    {
      "start": 645.32,
      "duration": 6.759,
      "text": "ですけども、つまりどういうことという"
    },
    {
      "start": 648.04,
      "duration": 7.84,
      "text": "ことを自分に取り問いかけて頭の中を具体"
    },
    {
      "start": 652.079,
      "duration": 5.961,
      "text": "化していく。最後3つ目ですね。Ow"
    },
    {
      "start": 655.88,
      "duration": 5.36,
      "text": "トレーニングという風に名付けているん"
    },
    {
      "start": 658.04,
      "duration": 8.0,
      "text": "ですけども、5つのWに対してそれぞれ"
    },
    {
      "start": 661.24,
      "duration": 8.0,
      "text": "自分の頭の中を具体化していって最後1"
    },
    {
      "start": 666.04,
      "duration": 6.08,
      "text": "どのようにということでそこも具体的に"
    },
    {
      "start": 669.24,
      "duration": 6.12,
      "text": "ハウの部分も言葉にしてみようという"
    },
    {
      "start": 672.12,
      "duration": 6.2,
      "text": "トレーニングになります。では、え、1つ"
    },
    {
      "start": 675.36,
      "duration": 6.039,
      "text": "目のワソトレーニングのお話です。この"
    },
    {
      "start": 678.32,
      "duration": 7.079,
      "text": "トレーニングでは自分が抱えるある問に"
    },
    {
      "start": 681.399,
      "duration": 6.921,
      "text": "対してそれはなぜというものを自分に"
    },
    {
      "start": 685.399,
      "duration": 5.44,
      "text": "繰り返し問いかけながら深掘りをして具体"
    },
    {
      "start": 688.32,
      "duration": 6.639,
      "text": "化していくというものです。制限時間の中"
    },
    {
      "start": 690.839,
      "duration": 7.12,
      "text": "でそれはなぜというものを5回繰り返し"
    },
    {
      "start": 694.959,
      "duration": 6.761,
      "text": "ながら頭の中にあるモヤモの理由という"
    },
    {
      "start": 697.959,
      "duration": 6.281,
      "text": "ものを明らかにするだけでなくそこで言語"
    },
    {
      "start": 701.72,
      "duration": 5.04,
      "text": "化された言葉に深さを出していく"
    },
    {
      "start": 704.24,
      "duration": 5.08,
      "text": "トレーニングになります。2つ目、"
    },
    {
      "start": 706.76,
      "duration": 5.319,
      "text": "ソワットトレーニングですが、自分が"
    },
    {
      "start": 709.32,
      "duration": 6.079,
      "text": "抱える課題に対してそれってどういうこと"
    },
    {
      "start": 712.079,
      "duration": 6.361,
      "text": "?ということを自分に再び繰り返し"
    },
    {
      "start": 715.399,
      "duration": 5.841,
      "text": "問いかけながら自分の課題の本質という"
    },
    {
      "start": 718.44,
      "duration": 5.76,
      "text": "ものを具体化していくトレーニングになり"
    },
    {
      "start": 721.24,
      "duration": 7.08,
      "text": "ます。制限時間の中でそれってどういう"
    },
    {
      "start": 724.2,
      "duration": 6.8,
      "text": "ことを5回繰り返しながら頭の中にある"
    },
    {
      "start": 728.32,
      "duration": 5.6,
      "text": "モヤモヤの本質を明らかにするだけでなく"
    },
    {
      "start": 731.0,
      "duration": 5.56,
      "text": "、そこで言語化された言葉に高さを出して"
    },
    {
      "start": 733.92,
      "duration": 6.2,
      "text": "いくトレーニングになります。3つ目の"
    },
    {
      "start": 736.56,
      "duration": 9.639,
      "text": "51hトレーニングでは自分が抱える課題"
    },
    {
      "start": 740.12,
      "duration": 10.68,
      "text": "に対して5hつまりいつどこで何を誰が"
    },
    {
      "start": 746.199,
      "duration": 8.841,
      "text": "なぜどうすればという問いかけをしていき"
    },
    {
      "start": 750.8,
      "duration": 6.92,
      "text": "それに沿って自分のモヤモヤを様々な角度"
    },
    {
      "start": 755.04,
      "duration": 5.08,
      "text": "から言葉で具体化していくトレーニングに"
    },
    {
      "start": 757.72,
      "duration": 3.359,
      "text": "なります。制限時間の中で"
    },
    {
      "start": 760.12,
      "duration": 3.959,
      "text": "O1H"
    },
    {
      "start": 761.079,
      "duration": 3.0,
      "text": "に沿った質問を自分に投げかけることで具体化された言葉に広さを出していくトレーニングになります。図にするとこのようなイメージになっております。"
    },
    {
      "start": 771.839,
      "duration": 3.0,
      "text": "トレーニングの具体例がないとどうやるのかよくわからないので"
    },
    {
      "start": 775.72,
      "duration": 3.799,
      "text": "1"
    },
    {
      "start": 776.519,
      "duration": 3.0,
      "text": "倍相トレーニングから例を上げて解説をお願いします。"
    },
    {
      "start": 780.199,
      "duration": 4.08,
      "text": "制限時間は1"
    },
    {
      "start": 781.279,
      "duration": 3.0,
      "text": "分です。では具体的にやっていきましょう。"
    },
    {
      "start": 785.0,
      "duration": 5.6,
      "text": "まず今回の問が仕事にやりがいを求めて"
    },
    {
      "start": 787.92,
      "duration": 6.359,
      "text": "しまうのはなぜというものです。それに"
    },
    {
      "start": 790.6,
      "duration": 7.0,
      "text": "対して1回目のワイソを自分に聞いていき"
    },
    {
      "start": 794.279,
      "duration": 5.601,
      "text": "ます。こっからあの僕の具体的な回答例に"
    },
    {
      "start": 797.6,
      "duration": 5.039,
      "text": "なりますのでもしかしたら皆さんはまた"
    },
    {
      "start": 799.88,
      "duration": 6.079,
      "text": "違う答えが出てくるかと思いますけれども"
    },
    {
      "start": 802.639,
      "duration": 5.76,
      "text": "あくまで僕の回答例として、え、聞いて"
    },
    {
      "start": 805.959,
      "duration": 5.401,
      "text": "いただければと思います。それってなぜと"
    },
    {
      "start": 808.399,
      "duration": 5.521,
      "text": "1回目問いかけたことに対して、せっかく"
    },
    {
      "start": 811.36,
      "duration": 5.8,
      "text": "自分の時間を使うならやりがいを感じたい"
    },
    {
      "start": 813.92,
      "duration": 6.76,
      "text": "からという言葉を、ま、具体化してみまし"
    },
    {
      "start": 817.16,
      "duration": 6.72,
      "text": "た。さらにその1回目出てきた言葉に対し"
    },
    {
      "start": 820.68,
      "duration": 5.56,
      "text": "て再びそれってなぜというものを自分に"
    },
    {
      "start": 823.88,
      "duration": 5.92,
      "text": "問いかけていきます。それと出てきた答え"
    },
    {
      "start": 826.24,
      "duration": 6.08,
      "text": "が仕事は自分の人生において大きな割合を"
    },
    {
      "start": 829.8,
      "duration": 5.839,
      "text": "占めているからという答えが出てきたとし"
    },
    {
      "start": 832.32,
      "duration": 6.28,
      "text": "ます。その答えに対して3回目、それって"
    },
    {
      "start": 835.639,
      "duration": 5.921,
      "text": "なぜという風に問いかけると、例えば仕事"
    },
    {
      "start": 838.6,
      "duration": 5.359,
      "text": "にやりがいが感じられると人生が満たされ"
    },
    {
      "start": 841.56,
      "duration": 5.88,
      "text": "た気がするからという答えが出てきたとし"
    },
    {
      "start": 843.959,
      "duration": 7.24,
      "text": "ます。再びその答えにそれってなぜと自分"
    },
    {
      "start": 847.44,
      "duration": 6.68,
      "text": "自身に問いかけます。そこで仕事で嬉しい"
    },
    {
      "start": 851.199,
      "duration": 6.401,
      "text": "ことがあった日は1日中幸せになれるから"
    },
    {
      "start": 854.12,
      "duration": 6.36,
      "text": "という答えが出てきたとします。最後その"
    },
    {
      "start": 857.6,
      "duration": 7.0,
      "text": "答えに対してもう1度それってなぜという"
    },
    {
      "start": 860.48,
      "duration": 8.32,
      "text": "風に問いかけて例えば仕事を通じて自分が"
    },
    {
      "start": 864.6,
      "duration": 7.599,
      "text": "誰かの役に立っていると実感できるからと"
    },
    {
      "start": 868.8,
      "duration": 6.039,
      "text": "いう答えまでたどり着くとこのように頭の"
    },
    {
      "start": 872.199,
      "duration": 5.961,
      "text": "中をどんどん言葉にしていってこの"
    },
    {
      "start": 874.839,
      "duration": 6.721,
      "text": "トレーニングによってそうか自分を持って"
    },
    {
      "start": 878.16,
      "duration": 6.0,
      "text": "いたんだということに改めて自分で気づく"
    },
    {
      "start": 881.56,
      "duration": 3.839,
      "text": "そういうことをあの実践していただくに"
    },
    {
      "start": 884.16,
      "duration": 4.239,
      "text": "なっております。"
    },
    {
      "start": 885.399,
      "duration": 3.0,
      "text": "確かに深掘りできた感じがします。では"
    },
    {
      "start": 888.8,
      "duration": 3.2,
      "text": "2ソワットトレーニングをお願いします。"
    },
    {
      "start": 891.44,
      "duration": 3.56,
      "text": "では2"
    },
    {
      "start": 892.0,
      "duration": 3.0,
      "text": "つ目のトレーニングです。瞬時にソワット"
    },
    {
      "start": 895.24,
      "duration": 3.159,
      "text": "5"
    },
    {
      "start": 895.399,
      "duration": 3.0,
      "text": "回繰り返すという例を実際にあげてみたいという風に思います。今回、え、取り上げる問いは好きなことを仕事にするってどういうこと?という問になります。"
    },
    {
      "start": 907.16,
      "duration": 4.919,
      "text": "皆さんも、ま、仕事をされていて、ま、"
    },
    {
      "start": 909.759,
      "duration": 4.08,
      "text": "好きな仕事をしたいなと、あの、思われる"
    },
    {
      "start": 912.079,
      "duration": 3.281,
      "text": "方多いんじゃないかなという風に思うん"
    },
    {
      "start": 913.839,
      "duration": 3.721,
      "text": "ですけども、じゃあそれってどういうこと"
    },
    {
      "start": 915.36,
      "duration": 5.08,
      "text": "なんだということを皆さんと一緒に考えて"
    },
    {
      "start": 917.56,
      "duration": 5.76,
      "text": "いきたいなと思います。今回も制限時間1"
    },
    {
      "start": 920.44,
      "duration": 5.319,
      "text": "分でやっていきたいと思います。では、"
    },
    {
      "start": 923.32,
      "duration": 5.079,
      "text": "今回の問いである好きなことを仕事に"
    },
    {
      "start": 925.759,
      "duration": 6.161,
      "text": "するってどういうこと?という問に対して"
    },
    {
      "start": 928.399,
      "duration": 6.36,
      "text": "、まず自分自身にそれってどういうことと"
    },
    {
      "start": 931.92,
      "duration": 5.719,
      "text": "いう問いかけをしていきます。そこで"
    },
    {
      "start": 934.759,
