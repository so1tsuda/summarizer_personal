      "text": "1"
    },
    {
      "start": 691.079,
      "duration": 3.0,
      "text": "年以上どころじゃないな。どんくらいだったかな。あの、"
    },
    {
      "start": 694.12,
      "duration": 3.68,
      "text": "ま、かなり長い間あの"
    },
    {
      "start": 696.44,
      "duration": 4.36,
      "text": "3年ぐらいだったかな。"
