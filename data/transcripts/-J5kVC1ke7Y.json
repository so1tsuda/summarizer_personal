    {
      "start": 625.48,
      "duration": 3.16,
      "text": "2"
    },
    {
      "start": 625.64,
      "duration": 3.0,
      "text": "回行ったんですけど、やっぱすっごく勉強に、勉強というかなんていう、ま、事前にもちろん色々調べていってるんですけど、"
    },
    {
      "start": 633.079,
      "duration": 1.961,
      "text": "あの、"
