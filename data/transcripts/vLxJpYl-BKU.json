    {
      "start": 959.48,
      "duration": 4.159,
      "text": "本日の動画の裏話や動画の中ではちょっと"
    },
    {
      "start": 962.16,
      "duration": 4.159,
      "text": "言いきれない本音をノートの"
    },
    {
      "start": 963.639,
      "duration": 4.88,
      "text": "メンバーシップで発信を始めております。"
    },
    {
      "start": 966.319,
      "duration": 4.401,
      "text": "台本を作りながら考えたことやちょっと"
    },
    {
      "start": 968.519,
      "duration": 5.841,
      "text": "公開動画ではいえないことも楽やトーク的"
    },
    {
      "start": 970.72,
