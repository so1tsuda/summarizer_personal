    },
    {
      "start": 1025.919,
      "duration": 4.841,
      "text": "いうか、むしろこういうような状況だっ"
    },
    {
      "start": 1028.559,
      "duration": 4.041,
      "text": "たら値上げするのは当たり前だっていう"
    },
    {
      "start": 1030.76,
      "duration": 4.039,
      "text": "ことで、すいません。値上げさせて"
    },
    {
      "start": 1032.6,
      "duration": 3.28,
      "text": "くださいて通る時代になってるわけだから"
    },
    {
      "start": 1034.799,
      "duration": 4.081,
      "text": "環境がね。"
    },
    {
      "start": 1035.88,
      "duration": 3.0,
      "text": "だからそれを折り込んだら値上げで乗り切れちゃうっていうような見通しをどこまで企業が出してくるか、そういうところにちょっと注目したいなと思ってますね。"
    },
    {
      "start": 1045.079,
      "duration": 3.24,
      "text": "あの、日経兵器のチャートで見るといかにも"
    },
    {
      "start": 1048.0,
      "duration": 3.319,
      "text": "6"
    },
    {
      "start": 1048.319,
      "duration": 3.0,
      "text": "万円に来たがってるという中でですね、果たして今おっしゃいましたような、ま、日、日銀イランそして、ま、企業績ですね。どういうような形のシグナルが出てくるかでしょうか。"
    },
    {
      "start": 1061.799,
      "duration": 3.081,
      "text": "そんなとこだと思います。"
    },
    {
      "start": 1063.4,
      "duration": 4.48,
      "text": "はい、わかりました。"
    },
    {
      "start": 1064.88,
      "duration": 3.0,
      "text": "ということで今日はここまでヘマネックス証券のチーフストラテジストのひ樹木孝志さんにお話を伺いました。ひ樹木さん今日はどうもありがとうございました。"
    },
    {
      "start": 1073.039,
      "duration": 6.961,
      "text": "ありがとうございました。"
    },
    {
      "start": 1075.799,
      "duration": 7.921,
      "text": "資産形成に取り組みたい全ての人に"
    },
    {
      "start": 1080.0,
      "duration": 7.44,
      "text": "生まれ変わった日経CNBC"
    },
    {
      "start": 1083.72,
      "duration": 7.16,
      "text": "初めの一歩を確かな力にするために深い"
    },
    {
      "start": 1087.44,
