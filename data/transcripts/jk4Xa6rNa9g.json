      "start": 1269.64,
      "duration": 5.56,
      "text": "言い方をするとちょっとライトな"
    },
    {
      "start": 1272.76,
      "duration": 7.519,
      "text": "スタートアップ支援みたいなものから本当"
    },
    {
      "start": 1275.2,
      "duration": 8.04,
      "text": "に国家のシビアでシリアスな要請でも税金"
    },
    {
      "start": 1280.279,
      "duration": 4.4,
      "text": "が投じられるスターアップみたいなものが"
    },
    {
      "start": 1283.24,
      "duration": 3.84,
      "text": "あのディフェンステックやディープテック"
    },
    {
      "start": 1284.679,
      "duration": 3.761,
      "text": "を始めとして相当あのなんていうか"
    },
    {
      "start": 1287.08,
      "duration": 4.64,
      "text": "メインストリームになってくんじゃないか"
    },
    {
      "start": 1288.44,
      "duration": 5.599,
      "text": "なと。ま、その一番大きな象徴という感じ"
    },
    {
      "start": 1291.72,
      "duration": 4.76,
      "text": "でしょうかね。スペースXが。うん。最後"
    },
    {
      "start": 1294.039,
      "duration": 4.841,
      "text": "に今の論点も含めまして、ま、今の日本に"
    },
    {
      "start": 1296.48,
      "duration": 3.52,
      "text": "おける企業家、あと企業予備軍に対して"
    },
    {
      "start": 1298.88,
      "duration": 2.6,
      "text": "メッセージがあるとしたらどんな"
    },
    {
      "start": 1300.0,
      "duration": 3.44,
      "text": "メッセージになりますか?最近なんか"
    },
    {
      "start": 1301.48,
      "duration": 4.679,
      "text": "スタートアップオアコンみたいな議論も出"
    },
    {
      "start": 1303.44,
      "duration": 4.599,
      "text": "てきてですね、ちょっとなんか元気がない"
    },
    {
      "start": 1306.159,
      "duration": 3.681,
      "text": "ようなところもあるんですけど、企業家、"
    },
    {
      "start": 1308.039,
      "duration": 3.961,
      "text": "企業予備国に対して最後メッセージがあり"
    },
    {
      "start": 1309.84,
      "duration": 2.6,
      "text": "ましたらいただきたいと思うんですけど"
    },
    {
      "start": 1312.0,
      "duration": 3.44,
      "text": "はい。"
    },
    {
      "start": 1312.44,
      "duration": 3.0,
      "text": "えっとな、なんて言うですかね、何事もちょっと極端に語られがちだし、こうメインストリームみたいなもの語られるんですけど、で、私もあのスタ、あのディープテック時代であって言うとそれ以外ダメって言ってると別にそんなことはなくてですね。"
    },
    {
      "start": 1326.88,
      "duration": 5.72,
      "text": "ま、別にあの、どんな時代になろうが、"
    },
    {
      "start": 1329.64,
      "duration": 5.039,
      "text": "あの、食べ物や飲み物やレストランや着る"
    },
    {
      "start": 1332.6,
      "duration": 4.72,
      "text": "ものを作って上場する会社だっていっぱい"
    },
    {
      "start": 1334.679,
      "duration": 6.081,
      "text": "あるわけですし、それは別にあの、終わっ"
    },
    {
      "start": 1337.32,
      "duration": 6.32,
      "text": "ても何にもなくて、より優れたものやより"
    },
    {
      "start": 1340.76,
      "duration": 4.36,
      "text": "人々が求めるものを作りさえすれば、別に"
    },
    {
      "start": 1343.64,
      "duration": 3.88,
      "text": "ディープテックじゃなきゃダメだってこと"
    },
    {
      "start": 1345.12,
      "duration": 4.4,
      "text": "を言ってるわけではないと。ただ、えっと"
    },
    {
      "start": 1347.52,
      "duration": 3.88,
      "text": "、今までのそのスタートアップとか"
    },
    {
      "start": 1349.52,
      "duration": 4.639,
      "text": "スタートアップエコシステムとか、その"
    },
    {
      "start": 1351.4,
      "duration": 5.759,
      "text": "スタートアップに対する支援とかあるいは"
    },
    {
      "start": 1354.159,
      "duration": 5.801,
      "text": "そのそこに注がれるべきあのリソース、ま"
    },
    {
      "start": 1357.159,
      "duration": 5.161,
      "text": "、主にはお金ですけど、あるいはあの1番"
    },
    {
      "start": 1359.96,
      "duration": 4.88,
      "text": "重要なのは人材ですね。っていった意味で"
    },
    {
      "start": 1362.32,
      "duration": 5.239,
      "text": "言うと圧倒的にやっぱりこういった"
    },
    {
      "start": 1364.84,
      "duration": 4.4,
      "text": "ディープテックの方にあの流れが行って"
    },
    {
      "start": 1367.559,
      "duration": 4.641,
      "text": "るってことはやっぱり意識せざるを得ない"
    },
    {
      "start": 1369.24,
      "duration": 6.28,
      "text": "ということで、ま、日本でスタートアップ"
    },
    {
      "start": 1372.2,
      "duration": 5.599,
      "text": "やられてる方々も、ま、それはもうかなり"
    },
    {
      "start": 1375.52,
      "duration": 4.84,
      "text": "なんていうか、もうあのファクトとして"
    },
    {
      "start": 1377.799,
      "duration": 5.76,
      "text": "認識されつつあるとは思いますので、それ"
    },
    {
      "start": 1380.36,
      "duration": 5.799,
      "text": "をやってる方々はあのやっぱりD1から"
    },
    {
      "start": 1383.559,
      "duration": 5.48,
      "text": "グローバル見ないとどうしようもないとで"
    },
    {
      "start": 1386.159,
      "duration": 5.52,
      "text": "やっぱりあのJカーブがものすごく深くて"
    },
    {
      "start": 1389.039,
      "duration": 5.481,
      "text": "長いんででかつあのボラティリ"
    },
    {
      "start": 1391.679,
      "duration": 5.961,
      "text": "あの、失敗する確率がものすごく長いと"
    },
    {
      "start": 1394.52,
      "duration": 5.8,
      "text": "いうことは資金調達力が勝負だと。で、"
    },
    {
      "start": 1397.64,
      "duration": 5.519,
      "text": "そうすると国内だけじゃ絶対無理で、あの"
    },
    {
      "start": 1400.32,
      "duration": 4.839,
      "text": "、シンガポールだとか米国やあるいは前に"
    },
    {
      "start": 1403.159,
      "duration": 4.12,
      "text": "よっては中東とかそういうとこまで資金"
    },
    {
      "start": 1405.159,
      "duration": 5.601,
      "text": "調達しに行かなければいけないと。で、"
    },
    {
      "start": 1407.279,
      "duration": 6.481,
      "text": "我々よくあの事業のグローバル化事業の"
    },
    {
      "start": 1410.76,
      "duration": 5.32,
      "text": "外出ばっかり言われますけど、資金調達の"
    },
    {
      "start": 1413.76,
      "duration": 4.64,
      "text": "海外進出頑張りましょうよって結構あの"
    },
    {
      "start": 1416.08,
      "duration": 3.839,
      "text": "我がでは言ってるんですけど、是非、ま、"
    },
    {
      "start": 1418.4,
      "duration": 4.24,
      "text": "私シンガポールにいますから、"
    },
    {
      "start": 1419.919,
      "duration": 4.76,
      "text": "シンガポールの資金調達について何かあの"
    },
    {
      "start": 1422.64,
      "duration": 4.919,
      "text": "おになりたいってことあれば、ま、美力"
    },
    {
      "start": 1424.679,
      "duration": 6.88,
      "text": "ながら教えさし上げられることも、あの、"
    },
    {
      "start": 1427.559,
      "duration": 6.081,
      "text": "ありますし、是非資金調達の海外展開と"
    },
    {
      "start": 1431.559,
      "duration": 3.801,
      "text": "いうもの、海外進出というものを頑張って"
    },
    {
      "start": 1433.64,
      "duration": 2.24,
      "text": "いただきたいなと思います。よくわかり"
    },
    {
      "start": 1435.36,
      "duration": 3.52,
      "text": "ました。"
    },
    {
      "start": 1435.88,
      "duration": 3.0,
      "text": "スタートアップがおわになったよりもゲームのルールがかなり変わってきた。ステージがいろんな意味で変わってきたってそういう風に捉えるのが一番良さそうですね。"
    },
    {
      "start": 1442.799,
      "duration": 3.961,
      "text": "そう思います。"
    },
    {
      "start": 1443.76,
      "duration": 3.0,
      "text": "はい、分かりました。ということで今回は海原さんにお話伺いました。原さんありがとうございました。"
    },
    {
      "start": 1448.36,
      "duration": 3.0,
      "text": "ありがとうございました。"
    },
    {
      "start": 1464.919,
      "duration": 3.0,
      "text": "お"
    }
  ]
}