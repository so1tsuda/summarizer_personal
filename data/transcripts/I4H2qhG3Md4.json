    },
    {
      "start": 373.72,
      "duration": 4.039,
      "text": "と決めて、もうそれを3年以上続けてるん"
    },
    {
      "start": 375.72,
      "duration": 4.68,
      "text": "ですが、アラームなしでも4時半に起きる"
    },
    {
      "start": 377.759,
      "duration": 5.321,
      "text": "体に自然となっています。是非ね、夜の"
    },
    {
      "start": 380.4,
      "duration": 5.16,
      "text": "自分が朝の自分を助けるんだと思って寝る"
    },
    {
      "start": 383.08,
      "duration": 4.44,
      "text": "ための環境を優しく整えてみてください。"
    },
    {
      "start": 385.56,
      "duration": 4.32,
      "text": "そしてですね、大事なことがあって、明日"
    },
    {
      "start": 387.52,
      "duration": 4.48,
      "text": "の朝起きたらあのお気に入りのコーヒーを"
    },
    {
      "start": 389.88,
      "duration": 4.2,
      "text": "飲もうみたいなちょっとしたお楽しみを"
    },
    {
      "start": 392.0,
      "duration": 3.639,
      "text": "用意しておくと自然とね、起きやすくなる"
    },
    {
      "start": 394.08,
      "duration": 3.92,
      "text": "ので、これはね、本当にやった方がいい"
    },
    {
      "start": 395.639,
      "duration": 4.321,
      "text": "です。その30分を楽しみにすることで"
    },
    {
      "start": 398.0,
      "duration": 5.0,
      "text": "早起きが自然とね、やりやすくなるんです"
    },
    {
      "start": 399.96,
      "duration": 5.519,
      "text": "よね。2つ目、バタバタな毎日から"
    },
    {
      "start": 403.0,
      "duration": 5.96,
      "text": "抜け出す朝の最強ルーティンという話です"
    },
    {
      "start": 405.479,
      "duration": 5.961,
      "text": "。現代人で圧倒的に多い悩みがやることが"
    },
    {
      "start": 408.96,
      "duration": 4.48,
      "text": "多すぎて常に時間に追われているという"
    },
    {
      "start": 411.44,
      "duration": 4.08,
      "text": "状態の人。この本ではその人にあった"
    },
    {
      "start": 413.44,
      "duration": 4.64,
      "text": "タイプが5つ紹介されているんですが、"
    },
    {
      "start": 415.52,
      "duration": 5.0,
      "text": "今回のやることが多すぎてバタバタして"
    },
    {
      "start": 418.08,
      "duration": 4.72,
      "text": "いるタイプの人は計画タイプや整理タイプ"
    },
    {
      "start": 420.52,
      "duration": 4.079,
      "text": "の朝の過ごし方を取り入れるのがおすすめ"
    },
    {
      "start": 422.8,
      "duration": 4.28,
      "text": "です。じゃあ一体どうすればいいのか。"
    },
    {
      "start": 424.599,
      "duration": 4.72,
      "text": "ズバり朝の思考がクリアなうちに手帳や"
    },
    {
      "start": 427.08,
      "duration": 4.959,
      "text": "ノートを開いて今日の3つを決めるんです"
    },
    {
      "start": 429.319,
      "duration": 4.44,
      "text": "よ。これがあなたが取るべき具体的な朝の"
    },
    {
      "start": 432.039,
      "duration": 3.88,
      "text": "アクションです。え、やることたくさん"
    },
    {
      "start": 433.759,
      "duration": 4.081,
      "text": "あるのにたった3つでいいのって思うかも"
    },
    {
      "start": 435.919,
      "duration": 4.84,
      "text": "しれませんが、いいんですよ。私たちの"
    },
    {
      "start": 437.84,
      "duration": 5.639,
      "text": "集中力や実際に1日の中で自由に使える"
    },
    {
      "start": 440.759,
      "duration": 5.16,
      "text": "時間を冷静に考えてみると本当に実行"
    },
    {
      "start": 443.479,
      "duration": 4.84,
      "text": "できる大事なことって生3つくらいなん"
    },
    {
      "start": 445.919,
      "duration": 4.441,
      "text": "です。全部やろうとするから予定がパンク"
    },
    {
      "start": 448.319,
      "duration": 4.6,
      "text": "して苦しくなってしまうんですよ。例えば"
    },
    {
      "start": 450.36,
      "duration": 4.959,
      "text": "ですけど午前中にあの資料の下書きを"
    },
    {
      "start": 452.919,
      "duration": 5.12,
      "text": "終わらせる。帰りにスーパーで3日分の"
    },
    {
      "start": 455.319,
      "duration": 4.88,
      "text": "買い物をする。夜は子供とゆっくり話すと"
    },
    {
      "start": 458.039,
      "duration": 4.0,
      "text": "いった感じ。そしてここからが超重要な"
    },
    {
      "start": 460.199,
      "duration": 4.761,
      "text": "ポイントなんですが、この3つを決める時"
    },
    {
      "start": 462.039,
      "duration": 5.961,
      "text": "はもし予定が狂ったらどうするのかの対応"
    },
    {
      "start": 464.96,
      "duration": 5.16,
      "text": "策で考えておきましょう。例えば資料作成"
    },
    {
      "start": 468.0,
      "duration": 4.759,
      "text": "が昼までに終わらなければとりあえず"
    },
    {
      "start": 470.12,
      "duration": 4.919,
      "text": "切り上げて残りは明日やるみたいな感じ。"
    },
    {
      "start": 472.759,
      "duration": 4.321,
      "text": "急な仕事が入ったりして予定通りに行か"
    },
    {
      "start": 475.039,
      "duration": 4.321,
      "text": "ないことなんて日常差半事ですから"
    },
    {
      "start": 477.08,
      "duration": 4.48,
      "text": "あらかじめ太陽作を練っておくことで予定"
    },
    {
      "start": 479.36,
      "duration": 4.36,
      "text": "が狂っても焦らずに住むんですよ。これが"
    },
    {
      "start": 481.56,
      "duration": 4.919,
      "text": "ね心のゆりになっていくんですよね。これ"
    },
    {
      "start": 483.72,
      "duration": 5.08,
      "text": "やるだけでも感情やる気に関係なく思考の"
    },
    {
      "start": 486.479,
      "duration": 4.4,
      "text": "エネルギーを使わずにすっと体が働き"
    },
    {
      "start": 488.8,
      "duration": 4.519,
      "text": "始めるんです。そしてこの3つができた"
    },
    {
      "start": 490.879,
      "duration": 5.32,
      "text": "だけで今日は最低限やるべきことが"
    },
    {
      "start": 493.319,
      "duration": 4.88,
      "text": "ちゃんとできたぞという最高のね満足感が"
    },
    {
      "start": 496.199,
      "duration": 3.96,
      "text": "得られるんですよ。これが続くと"
    },
    {
      "start": 498.199,
      "duration": 4.28,
      "text": "ポジティブループに入ってパチンコでいう"
    },
    {
      "start": 500.159,
      "duration": 3.76,
      "text": "確変状態突入ですね。もしねそれ以外の"
    },
    {
      "start": 502.479,
      "duration": 3.201,
      "text": "タスクもできたらそれは全部"
    },
    {
      "start": 503.919,
      "duration": 3.761,
      "text": "プラスアルファのボーナスみたいなもの"
    },
    {
      "start": 505.68,
      "duration": 4.4,
      "text": "ですから気持ちもめちゃくちゃ前向きに"
    },
    {
      "start": 507.68,
      "duration": 4.719,
      "text": "なっていきます。是非ねのクリアな頭で"
    },
    {
      "start": 510.08,
      "duration": 3.68,
      "text": "今日の3つを決める。騙されたと思って"
    },
    {
      "start": 512.399,
      "duration": 3.401,
      "text": "やってみてください。でもこれなら"
    },
    {
      "start": 513.76,
      "duration": 5.719,
      "text": "ハードル低いんでできる方も多いと思い"
    },
    {
      "start": 515.8,
      "duration": 6.479,
      "text": "ますよ。3つ目。3つの手放と1本の"
    },
    {
      "start": 519.479,
      "duration": 5.401,
      "text": "種巻きという話。この本ではついつい完璧"
    },
    {
      "start": 522.279,
      "duration": 5.081,
      "text": "を求めて自分1人で抱え込んでしまうと"
    },
    {
      "start": 524.88,
      "duration": 4.84,
      "text": "いう生理タイプの人や目の前のことで精"
    },
    {
      "start": 527.36,
      "duration": 4.32,
      "text": "一杯で未来の準備ができていないという"
    },
    {
      "start": 529.72,
      "duration": 3.72,
      "text": "成長タイプの人がいるんですが、もし"
    },
    {
      "start": 531.68,
      "duration": 4.32,
      "text": "あなたがそういった人の場合はこれからの"
    },
    {
      "start": 533.44,
      "duration": 4.16,
      "text": "話とても生きてくると思います。もう耳を"
    },
    {
      "start": 536.0,
      "duration": 3.519,
      "text": "餃子にして聞いていってくださいね。"
    },
    {
      "start": 537.6,
      "duration": 4.359,
      "text": "さっきはですね、今日の3つを決めようっ"
    },
    {
      "start": 539.519,
      "duration": 4.921,
      "text": "て言ったんですが、完璧主義の人や目の前"
    },
    {
      "start": 541.959,
      "duration": 4.281,
      "text": "のことで精一杯の人は基本真面目で"
    },
    {
      "start": 544.44,
      "duration": 3.92,
      "text": "めちゃくちゃ頑張り屋さんなので、あれも"
    },
    {
      "start": 546.24,
      "duration": 4.039,
      "text": "これも自分でやらなきゃとタスクを"
    },
    {
      "start": 548.36,
      "duration": 3.84,
      "text": "抱え込みすぎている状態なんです。でも"
    },
    {
      "start": 550.279,
      "duration": 4.081,
      "text": "もう頑張りすぎなくていいんですよ。"
    },
    {
      "start": 552.2,
      "duration": 4.6,
      "text": "頑張りすぎているから時間に追われる毎日"
    },
    {
      "start": 554.36,
      "duration": 4.719,
      "text": "になっているんですから。そこで心に弱を"
    },
    {
      "start": 556.8,
      "duration": 5.32,
      "text": "作るために絶対にやって欲しいのが捨てる"
    },
    {
      "start": 559.079,
      "duration": 5.361,
      "text": "、任せる、緩めるという3つの手放。具体"
    },
    {
      "start": 562.12,
      "duration": 5.279,
      "text": "的にどうするかと言うと、形だけ続いて"
    },
    {
      "start": 564.44,
      "duration": 5.2,
      "text": "いる習い事や習慣、無駄な会議は思い切っ"
    },
    {
      "start": 567.399,
      "duration": 3.801,
      "text": "て捨てるんです。全部ね、自分でやろうと"
    },
    {
      "start": 569.64,
      "duration": 4.04,
      "text": "しなくていいんですよ。料理やってる人"
    },
    {
      "start": 571.2,
      "duration": 4.6,
      "text": "だったらお弁当に冷凍食品を使ったり、"
    },
    {
      "start": 573.68,
      "duration": 4.96,
      "text": "家事やってる人だったら便利家電に頼っ"
    },
    {
      "start": 575.8,
      "duration": 5.32,
      "text": "たりして何かに任せる。そして毎朝完璧に"
    },
    {
      "start": 578.64,
      "duration": 4.4,
      "text": "やらなきゃという思い込みをて、朝ご飯は"
    },
    {
      "start": 581.12,
      "duration": 4.279,
      "text": "パンでもいいと自分を緩めてみる。こう"
    },
    {
      "start": 583.04,
      "duration": 4.919,
      "text": "やって引き算をする意識を持つことが大事"
    },
    {
      "start": 585.399,
      "duration": 4.801,
      "text": "でこれですね、結構勇気いるんですけど"
    },
    {
      "start": 587.959,
      "duration": 3.841,
      "text": "やってみるとあれ別にやらなくて良かった"
    },
    {
      "start": 590.2,
      "duration": 4.36,
      "text": "じゃんってこともたくさんあるんですよね"
    },
    {
      "start": 591.8,
      "duration": 4.719,
      "text": "。こうやって作った朝の30分で成長"
    },
    {
      "start": 594.56,
      "duration": 4.399,
      "text": "タイプの方に絶対やって欲しいことがあっ"
    },
    {
      "start": 596.519,
      "duration": 5.041,
      "text": "てそれがあなたが本当はやりたいと思って"
    },
    {
      "start": 598.959,
      "duration": 5.241,
      "text": "いる未来への種巻きにたった1分でもいい"
    },
    {
      "start": 601.56,
      "duration": 4.88,
      "text": "から手をつけること。忙しいと資格の勉強"
    },
    {
      "start": 604.2,
      "duration": 4.0,
      "text": "や昔からやりたかった趣味なんかを"
    },
    {
      "start": 606.44,
      "duration": 3.839,
      "text": "まとまった時間ができたらやろうって"
    },
    {
      "start": 608.2,
      "duration": 4.4,
      "text": "後回しにしちゃいますよね。でもやりたい"
    },
    {
      "start": 610.279,
      "duration": 4.641,
      "text": "ことをスルーして自分の本音に蓋をし"
    },
    {
      "start": 612.6,
      "duration": 4.52,
      "text": "続けるとだんだん自分のやりたいことが何"
    },
    {
      "start": 614.92,
      "duration": 4.0,
      "text": "なのかすら分からないという状態になって"
    },
    {
      "start": 617.12,
      "duration": 4.159,
      "text": "しまうんですよ。こういった人多いと思い"
    },
    {
      "start": 618.92,
      "duration": 5.159,
      "text": "ます。だからこそ誰の予定にも振り回され"
    },
    {
      "start": 621.279,
      "duration": 5.201,
      "text": "ない朝の真っさらな時間に1分でも5分で"
    },
    {
      "start": 624.079,
      "duration": 4.921,
      "text": "もいいから自分の未来のたびに時間を使っ"
    },
    {
      "start": 626.48,
      "duration": 5.16,
      "text": "てみてください。すると今日は自分の声を"
    },
    {
      "start": 629.0,
      "duration": 4.6,
      "text": "無視しなかった。自分の人生を後回しにし"
    },
    {
      "start": 631.64,
      "duration": 4.199,
      "text": "なかったと思える体験が増えていって"
    },
    {
      "start": 633.6,
      "duration": 4.52,
      "text": "あなたの日々の自己肯定感が満たされて"
    },
    {
      "start": 635.839,
      "duration": 4.641,
      "text": "いくんですよね。これですね。自己肯定感"
    },
    {
      "start": 638.12,
      "duration": 4.48,
      "text": "高まると自然と頑張る時間が増えていく"
    },
    {
      "start": 640.48,
      "duration": 4.88,
      "text": "仕組みになっているんです。ではここまで"
    },
    {
      "start": 642.6,
      "duration": 4.52,
      "text": "聞いてあなたが今本当はやりたいこと何"
    },
    {
      "start": 645.36,
      "duration": 3.599,
      "text": "でしょうか?コメント欄にね書ける人は"
    },
    {
      "start": 647.12,
      "duration": 4.44,
      "text": "書いて欲しいんですがパッと思い浮かば"
    },
    {
      "start": 648.959,
      "duration": 5.44,
      "text": "ないよって人はどんな人生を送ったら絶対"
    },
    {
      "start": 651.56,
      "duration": 4.839,
      "text": "に後悔するかから逆算して考えてみると"
    },
    {
      "start": 654.399,
      "duration": 4.161,
      "text": "分かりやすくなります。私は死ぬ時に"
    },
    {
      "start": 656.399,
      "duration": 4.961,
      "text": "こんなに仕事しなきゃよかったと後悔し"
    },
    {
      "start": 658.56,
      "duration": 5.079,
      "text": "たくないので1日の仕事量は抑えて子供と"
    },
    {
      "start": 661.36,
      "duration": 4.2,
      "text": "遊ぶ時間に全ベッドしてみます。あなたは"
    },
    {
      "start": 663.639,
      "duration": 3.801,
      "text": "どうですかね?是非コメント欄で教えて"
    },
    {
      "start": 665.56,
      "duration": 4.279,
      "text": "ください。さあ、まとめると今の自分に"
    },
    {
      "start": 667.44,
      "duration": 4.88,
      "text": "合わないタスクはどんどん手放して空いた"
    },
    {
      "start": 669.839,
      "duration": 4.44,
      "text": "朝の時間で自分のやりたいことにたった1"
    },
    {
      "start": 672.32,
      "duration": 4.48,
      "text": "分でも手をつけることが大事で人って"
    },
    {
      "start": 674.279,
      "duration": 4.881,
      "text": "不思議なものでやり始めると集中しちゃう"
    },
    {
      "start": 676.8,
      "duration": 4.64,
      "text": "生き物なんですよね。そして最後に絶対に"
    },
    {
      "start": 679.16,
      "duration": 4.679,
      "text": "やらなきゃって完璧主義になる必要は全く"
    },
    {
      "start": 681.44,
      "duration": 4.56,
      "text": "ありません。たった1日できなくてもまた"
    },
    {
      "start": 683.839,
      "duration": 4.721,
      "text": "明日の朝頑張ればいいやくらいの緩い"
    },
    {
      "start": 686.0,
      "duration": 5.44,
      "text": "気持ちが大事。本当にね、3週間継続すれ"
    },
    {
      "start": 688.56,
      "duration": 6.12,
      "text": "ばそれが癖になっていって1年続ければ1"
    },
    {
      "start": 691.44,
      "duration": 6.44,
      "text": "年前と今のあなた。読されるハンマ刃牙の"
    },
    {
      "start": 694.68,
      "duration": 4.719,
      "text": "前の状態と裏返った後の刃牙くらい変化が"
    },
    {
      "start": 697.88,
      "duration": 4.079,
      "text": "ありますから。いや、どうでしたでしょう"
    },
    {
      "start": 699.399,
      "duration": 5.521,
      "text": "か?この本には他にも1週間の振り返りの"
    },
    {
      "start": 701.959,
      "duration": 5.201,
      "text": "具体的なやり方とか集中力が必要な作業を"
    },
    {
      "start": 704.92,
      "duration": 4.76,
      "text": "朝にサクっと終わらせるためのコツ、"
    },
    {
      "start": 707.16,
      "duration": 5.6,
      "text": "そして今のあなたにあった朝の過ごし方が"
    },
    {
      "start": 709.68,
      "duration": 5.159,
      "text": "分かる5つのタイプ診断など人生の余裕を"
    },
    {
      "start": 712.76,
      "duration": 4.68,
      "text": "取り戻すためのノーハウがたくさん書かれ"
    },
    {
      "start": 714.839,
      "duration": 4.68,
      "text": "ていたので気になる方は説明欄から是非ね"
    },
    {
      "start": 717.44,
      "duration": 4.399,
      "text": "ポチってみてください。ちなみに毎日が"
    },
    {
      "start": 719.519,
      "duration": 4.521,
      "text": "うまくいく朝のスイッチ。これについては"
    },
    {
      "start": 721.839,
      "duration": 4.12,
      "text": "こちらの過去動画でも詳しく解説している"
    },
    {
      "start": 724.04,
      "duration": 5.039,
      "text": "ので説明欄からチェックしてみてください"
    },
    {
      "start": 725.959,
      "duration": 5.56,
      "text": "。いや、朝は本当に大事ですよね。朝って"
    },
    {
      "start": 729.079,
      "duration": 4.681,
      "text": "。あ、寝坊した。急いで朝ご飯作って支度"
    },
    {
      "start": 731.519,
      "duration": 4.481,
      "text": "して子供起こして学校行かせてこうやって"
    },
    {
      "start": 733.76,
      "duration": 4.439,
      "text": "ドタバタした1日ってその後もなんか"
    },
    {
      "start": 736.0,
      "duration": 5.0,
      "text": "めちゃくちゃ使われませんか?でも朝いい"
    },
    {
      "start": 738.199,
      "duration": 4.88,
      "text": "時間を過ごせた日ってその日1日なぜか"
    },
    {
      "start": 741.0,
      "duration": 4.72,
      "text": "いい気分になりません?まさにね、私は"
    },
    {
      "start": 743.079,
      "duration": 5.681,
      "text": "あれが好きで10年近く起きしていてこれ"
    },
    {
      "start": 745.72,
      "duration": 4.359,
      "text": "ですね2019年までは朝5時に起きて"
    },
    {
      "start": 748.76,
      "duration": 3.879,
      "text": "仕事していたんですよ。で、"
    },
    {
      "start": 750.079,
      "duration": 4.76,
      "text": "YouTube始めてからは3時で、今は"
    },
    {
      "start": 752.639,
      "duration": 4.121,
      "text": "だんだん落ち着いてきて、朝4時半に起き"
    },
    {
      "start": 754.839,
      "duration": 4.401,
      "text": "ていて、それがね、継続できてるんですよ"
    },
    {
      "start": 756.76,
      "duration": 5.439,
      "text": "ね。今はですね、前日の夜に次の日の"
    },
    {
      "start": 759.24,
      "duration": 5.52,
      "text": "朝ご飯の下準備とかを終わらせて朝自分の"
    },
    {
      "start": 762.199,
      "duration": 4.681,
      "text": "ために時間が確保できるように前日の夜"
    },
    {
      "start": 764.76,
      "duration": 3.92,
      "text": "から工夫したりしています。でですね、私"
    },
    {
      "start": 766.88,
      "duration": 4.36,
      "text": "、ま、本当10年早起きを続けてるんです"
    },
    {
      "start": 768.68,
      "duration": 4.44,
      "text": "が、前ある人になんでそんな継続できるん"
    },
    {
      "start": 771.24,
      "duration": 4.36,
      "text": "ですかって聞かれて、ちょっと言語化して"
    },
    {
      "start": 773.12,
      "duration": 4.959,
      "text": "みたんですよ。これ私の場合ですよ。私お"
    },
    {
      "start": 775.6,
      "duration": 4.64,
      "text": "得感に幸福を感じる性格なんですよ。"
    },
    {
      "start": 778.079,
      "duration": 4.481,
      "text": "例えば千オ田寿司が半額になっていて、"
    },
    {
      "start": 780.24,
      "duration": 4.44,
      "text": "それを買った時だったり、牛タじゃなくて"
    },
    {
      "start": 782.56,
      "duration": 4.44,
      "text": "安いけど美味しい豚タ、これを買って食べ"
    },
    {
      "start": 784.68,
      "duration": 4.48,
      "text": "た時とかめちゃくちゃ幸福度上がるんです"
    },
    {
      "start": 787.0,
      "duration": 4.959,
      "text": "よ。それで早起きもね、なんだかんだ一緒"
    },
    {
      "start": 789.16,
      "duration": 5.919,
      "text": "で朝5時に起きて2時間仕事したとします"
    },
    {
      "start": 791.959,
      "duration": 5.641,
      "text": "よね。それで朝出社した時周りの人は8"
    },
    {
      "start": 795.079,
      "duration": 4.601,
      "text": "時間の仕事が残っていて、私朝2時間も"
    },
    {
      "start": 797.6,
      "duration": 4.28,
      "text": "やってるんで残り6時間なんですよ。なん"
    },
    {
      "start": 799.68,
      "duration": 4.88,
      "text": "なら朝はゴールデンタイムですから2時間"
    },
    {
      "start": 801.88,
      "duration": 5.04,
      "text": "で3時間分の仕事を終えて残り5時間分"
    },
    {
      "start": 804.56,
      "duration": 4.719,
      "text": "じゃみたいな周りと比較してそんな感じで"
    },
    {
      "start": 806.92,
      "duration": 4.279,
      "text": "お得感じてたんですよ。ま、実際にはね先"
    },
    {
      "start": 809.279,
      "duration": 4.321,
      "text": "に働いてるだけなんですけどそうやってね"
    },
    {
      "start": 811.199,
      "duration": 4.64,
      "text": "感じる性格なんです。でさらに同期に負け"
    },
    {
      "start": 813.6,
      "duration": 4.4,
      "text": "たくないなら定時まで8時間働いたら計"
    },
    {
      "start": 815.839,
      "duration": 5.041,
      "text": "10時間仕事してることになりますよね。"
    },
    {
      "start": 818.0,
      "duration": 5.6,
      "text": "もうこれ物理的に負けよがなくねみたいな"
    },
    {
      "start": 820.88,
      "duration": 4.84,
      "text": "のが最初のきっかけで今でもその習慣続け"
    },
    {
      "start": 823.6,
      "duration": 4.799,
      "text": "ています。これはね、ま、私の場合ですが"
    },
    {
      "start": 825.72,
      "duration": 4.76,
      "text": "大事なのはあなたなりになぜ早起きをする"
    },
    {
      "start": 828.399,
      "duration": 4.081,
      "text": "のか。これをね、自分の中で言語化して"
    },
    {
      "start": 830.48,
      "duration": 3.84,
      "text": "みるとそれが同気になっていくと思うんで"
    },
    {
      "start": 832.48,
      "duration": 4.279,
      "text": "、一度ね、考えてやってみるのがおすすめ"
    },
    {
      "start": 834.32,
      "duration": 5.12,
      "text": "です。そしたらね、継続できる確率上がる"
    },
    {
      "start": 836.759,
      "duration": 5.32,
      "text": "と思いますよ。是非。最後に大事なお"
    },
    {
      "start": 839.44,
      "duration": 4.759,
      "text": "知らせがあります。実は私学天サロンと"
    },
    {
      "start": 842.079,
      "duration": 4.0,
      "text": "いう転職のチャンネルもやってるんです。"
    },
    {
      "start": 844.199,
      "duration": 4.88,
      "text": "このチャンネルではサラリーマンのあなた"
    },
    {
      "start": 846.079,
      "duration": 5.56,
      "text": "が本当に知りたい転職のリアルな情報を"
    },
    {
      "start": 849.079,
      "duration": 5.12,
      "text": "包み隠さずお伝えしています。例えばです"
    },
    {
      "start": 851.639,
      "duration": 4.76,
      "text": "けど、今の給料や環境に不満はあるけど、"
    },
    {
      "start": 854.199,
      "duration": 5.08,
      "text": "具体的に転職で何をすればいいか分から"
    },
    {
      "start": 856.399,
      "duration": 5.481,
      "text": "ない。書類先行とか面接で採用されるコツ"
    },
    {
      "start": 859.279,
      "duration": 4.761,
      "text": "を知りたい。こんな悩みをお持ちの方に私"
    },
    {
      "start": 861.88,
      "duration": 4.639,
      "text": "の転職、そしてマネジメントの経験を"
    },
    {
      "start": 864.04,
      "duration": 4.719,
      "text": "生かして徹底的に解説させていただいてい"
    },
    {
      "start": 866.519,
      "duration": 5.641,
      "text": "ます。あとですね、キャリアパスの書き方"
    },
    {
      "start": 868.759,
      "duration": 5.481,
      "text": "から面接の受かり方まで転職に関する深い"
    },
    {
      "start": 872.16,
      "duration": 4.96,
      "text": "内容をバンバン公開しているので、これ"
    },
    {
      "start": 874.24,
      "duration": 4.959,
      "text": "から本気で転職して1度きりの人生、後悔"
    },
    {
      "start": 877.12,
      "duration": 6.639,
      "text": "のない人生にしたいという方は是非ね、"
    },
    {
      "start": 879.199,
      "duration": 4.56,
      "text": "このチャンネルも活用してみてください。"
    }
  ]
}