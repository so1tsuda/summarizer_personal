    {
      "start": 1148.6,
      "duration": 3.88,
      "text": "段高できるのかどうか、ま、そういった"
    },
    {
      "start": 1150.36,
      "duration": 3.76,
      "text": "ところがですね、注目されてくるのかなと"
    },
    {
      "start": 1152.48,
      "duration": 3.28,
      "text": "いう風に思われます。で、あとちょっと"
    },
    {
      "start": 1154.12,
