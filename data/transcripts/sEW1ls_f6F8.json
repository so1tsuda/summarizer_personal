    {
      "start": 804.079,
      "duration": 5.521,
      "text": "ドルに迫るような動きも見せてますけれどね。"
    },
    {
      "start": 806.6,
      "duration": 3.0,
      "text": "そうなんですよね。今日ね、そう、あの、特に多分そんな材料はなかったとは思うんですけど、朝なんか急になんか原油がね、跳ねるような場面があって、まだまだ全然原油の方はね、あの、"
    },
    {
      "start": 819.079,
      "duration": 3.521,
      "text": "戦闘開始前60ドル台でしたが"
    },
    {
      "start": 821.959,
      "duration": 2.161,
      "text": "遠いですよね。"
    },
    {
      "start": 822.6,
      "duration": 3.039,
      "text": "そうです。そうですね。"
    },
    {
      "start": 824.12,
      "duration": 4.519,
      "text": "ま、イランがまたね、2"
    },
    {
      "start": 825.639,
      "duration": 3.0,
      "text": "席を打したりとか、アメリカの国防総ムズ海峡の機嫌除去に最大半年くらいかかる可能性も報じられていました。"
    },
    {
      "start": 835.88,
      "duration": 3.0,
      "text": "資産形成に取り組みたい全ての人に生まれ変わった日経"
