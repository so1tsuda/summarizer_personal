    {
      "start": 388.88,
      "duration": 5.84,
      "text": "特にエネルギー、食品の影響を除くですね"
    },
    {
      "start": 391.72,
      "duration": 5.68,
      "text": "、え、コア、こちらのPデフレーターが1"
    },
    {
      "start": 394.72,
      "duration": 4.72,
      "text": "月の3.1からですね、低下しているか"
    },
    {
      "start": 397.4,
      "duration": 5.28,
      "text": "どうかところに注目したいと考えています"
    },
    {
      "start": 399.44,
      "duration": 6.039,
      "text": "。え、もしですね、2月分も3%台を維持"
    },
    {
      "start": 402.68,
      "duration": 5.04,
      "text": "、もしくは前回をです、さらに上回る加速"
    },
    {
      "start": 405.479,
      "duration": 4.521,
      "text": "してくるような結果となれば、え、米国の"
    },
    {
      "start": 407.72,
      "duration": 5.599,
      "text": "物価のトレンド、貴重的な流れというのが"
    },
    {
      "start": 410.0,
      "duration": 6.16,
      "text": "ですね、え、戦争イラン情勢が激化する前"
    },
    {
      "start": 413.319,
      "duration": 5.081,
      "text": "の段階から、え、既でにこう粘着的だった"
    },
    {
      "start": 416.16,
      "duration": 5.719,
      "text": "上昇基調にあったという解釈になりますの"
    },
    {
      "start": 418.4,
      "duration": 5.04,
      "text": "で、FRBの高橋姿勢を正当化する要因と"
    },
    {
      "start": 421.879,
      "duration": 3.401,
      "text": "なり得うる、つまりドル高要因と"
    },
    {
      "start": 423.44,
      "duration": 5.0,
      "text": "なり得うると考えられます。え、そして"
    },
    {
      "start": 425.28,
      "duration": 5.759,
      "text": "今週最大の注目点は3月のCPI、え、"
    },
    {
      "start": 428.44,
      "duration": 5.319,
      "text": "こちらは10日金曜日のですね、21時"
    },
    {
      "start": 431.039,
      "duration": 6.401,
      "text": "30分に発表されますが、まず前回の"
    },
    {
      "start": 433.759,
      "duration": 6.84,
      "text": "CPIの結果2月分は総合指数の前月費が"
    },
    {
      "start": 437.44,
      "duration": 6.159,
      "text": "プラスの0.3%、前年費がプラの2.4"
    },
    {
      "start": 440.599,
      "duration": 5.681,
      "text": "でした。そしてCORAのCPIは前月費"
    },
    {
      "start": 443.599,
      "duration": 5.361,
      "text": "のプラの0.2そして前年費がプラの"
    },
    {
      "start": 446.28,
      "duration": 4.639,
      "text": "2.5という結果でした。え、特に前回の"
    },
    {
      "start": 448.96,
      "duration": 4.679,
      "text": "、え、2月につきましては、あ、厚生"
    },
    {
      "start": 450.919,
      "duration": 6.28,
      "text": "ウェイトの高い住居費、ここがですね、"
    },
    {
      "start": 453.639,
      "duration": 5.641,
      "text": "前月費でプラ02.2ということで全体的"
    },
    {
      "start": 457.199,
      "duration": 4.72,
      "text": "にかなり落ち着いた内容でした。え、"
    },
    {
      "start": 459.28,
      "duration": 5.28,
      "text": "しかし今回のですね、3月の数値はどうか"
    },
    {
      "start": 461.919,
      "duration": 5.801,
      "text": "と言いますと、市場予想を見ると総合"
    },
    {
      "start": 464.56,
      "duration": 6.039,
      "text": "CPIが前月費でプラの0.9、前年費で"
    },
    {
      "start": 467.72,
      "duration": 5.8,
      "text": "プラスの3.4、またCoreのCPIは"
    },
    {
      "start": 470.599,
      "duration": 6.961,
      "text": "前月費でプラスの0.2、前年費でプラの"
    },
    {
      "start": 473.52,
      "duration": 6.799,
      "text": "2.7と、ええ、特に総合指数でですね、"
    },
    {
      "start": 477.56,
      "duration": 5.72,
      "text": "ま、当然ながらエネルギー価格上昇の影響"
    },
    {
      "start": 480.319,
      "duration": 5.44,
      "text": "を受ける形で前回からの加速が見込まれて"
    },
    {
      "start": 483.28,
      "duration": 5.039,
      "text": "います。え、ただしコアの伸びはそこまで"
    },
    {
      "start": 485.759,
      "duration": 5.56,
      "text": "でもないので、ま、今回のCPIの市場"
    },
    {
      "start": 488.319,
      "duration": 6.32,
      "text": "予想基本はヘッドライン、エネルギー、"
    },
    {
      "start": 491.319,
      "duration": 5.72,
      "text": "食品も含めた総合指数は戦争の影響なども"
    },
    {
      "start": 494.639,
      "duration": 5.12,
      "text": "含めて跳ね上がるんですけれども、コアの"
    },
    {
      "start": 497.039,
      "duration": 4.88,
      "text": "方はですね、え、まだそこまで大きく現れ"
    },
    {
      "start": 499.759,
      "duration": 3.961,
      "text": "てこないといったような見方になります。"
    },
    {
      "start": 501.919,
      "duration": 4.28,
      "text": "え、そこで今回のですね、注目すべき"
    },
    {
      "start": 503.72,
      "duration": 5.52,
      "text": "ところ、まず1つ目としては総合指数の"
    },
    {
      "start": 506.199,
      "duration": 5.44,
      "text": "上ぶれ、その中で打ち訳けがどの程度が"
    },
    {
      "start": 509.24,
      "duration": 4.76,
      "text": "ガソリン価格の上昇手動なのか。え、"
    },
    {
      "start": 511.639,
      "duration": 4.96,
      "text": "エネルギー価格はですね、当然大幅な上昇"
    },
    {
      "start": 514.0,
      "duration": 4.88,
      "text": "が見込まれますが、これは明らかに戦争"
    },
    {
      "start": 516.599,
      "duration": 5.44,
      "text": "要因であり、え、それはですね、収束すれ"
    },
    {
      "start": 518.88,
      "duration": 5.68,
      "text": "ば物価についてもですね、いずれ収束して"
    },
    {
      "start": 522.039,
      "duration": 5.081,
      "text": "いるものと想定されます。逆にエネルギー"
    },
    {
      "start": 524.56,
      "duration": 5.32,
      "text": "以外の部分でですね、上昇が強く見られる"
    },
    {
      "start": 527.12,
      "duration": 5.08,
      "text": "ようであれば、それは必ずしもこの中東"
    },
    {
      "start": 529.88,
      "duration": 5.28,
      "text": "情勢の要因という風に言いきれませんので"
    },
    {
      "start": 532.2,
      "duration": 5.4,
      "text": "、これは貴重的なですね、え、上昇という"
    },
    {
      "start": 535.16,
      "duration": 5.04,
      "text": "見方から、FRBに対してはですね、え、"
    },
    {
      "start": 537.6,
      "duration": 5.44,
      "text": "利上げを容認する影響となりそうです。え"
    },
    {
      "start": 540.2,
      "duration": 5.8,
      "text": "、そして2つ目の注目点としてはコアです"
    },
    {
      "start": 543.04,
      "duration": 5.12,
      "text": "ね。え、コア指数の方が、え、0.3%"
    },
    {
      "start": 546.0,
      "duration": 4.44,
      "text": "近辺でとまるのか、もしくはプラス"
    },
    {
      "start": 548.16,
      "duration": 4.08,
      "text": "0.4%以上とですね、ま、跳ね上がるの"
    },
    {
      "start": 550.44,
      "duration": 4.519,
      "text": "かどうか。え、もしコアがですね、"
    },
    {
      "start": 552.24,
      "duration": 4.839,
      "text": "0.4%以上など強い数字となるようで"
    },
    {
      "start": 554.959,
      "duration": 5.641,
      "text": "あれば、ま、FRBとしてはですね、ま、"
    },
    {
      "start": 557.079,
      "duration": 5.721,
      "text": "燃料高が貴重的なですね、ま、インフレに"
    },
    {
      "start": 560.6,
      "duration": 4.239,
      "text": "波及していると判断しやすくななりますの"
    },
    {
      "start": 562.8,
      "duration": 4.64,
      "text": "で、この辺りもドル高要因として注意が"
    },
    {
      "start": 564.839,
      "duration": 5.56,
      "text": "必要です。え、そして3つ目、前回してい"
    },
    {
      "start": 567.44,
      "duration": 6.079,
      "text": "た住費。ここが再び粘着性を見せるのか"
    },
    {
      "start": 570.399,
      "duration": 5.761,
      "text": "どうか。え、住費はCPIの全体の1/3"
    },
    {
      "start": 573.519,
      "duration": 5.44,
      "text": "のウェトを占めます。え、前回は住居費が"
    },
    {
      "start": 576.16,
      "duration": 5.52,
      "text": "プラスの0.2%前月費ですね。え、"
    },
    {
      "start": 578.959,
      "duration": 5.56,
      "text": "とまりまして、え、特に家賃こちらの方は"
    },
    {
      "start": 581.68,
      "duration": 4.68,
      "text": "あ、2021年の1月以来の低い伸びに"
    },
    {
      "start": 584.519,
      "duration": 4.32,
      "text": "とまりました。え、ここがですね、今回"
    },
    {
      "start": 586.36,
      "duration": 4.919,
      "text": "再び加速するような動きがあれば、ま、"
    },
    {
      "start": 588.839,
      "duration": 5.041,
      "text": "コア全体を押し上げる形となりますので、"
    },
    {
      "start": 591.279,
      "duration": 4.601,
      "text": "え、この点もインフレ最年の警戒につがる"
    },
    {
      "start": 593.88,
      "duration": 4.959,
      "text": "可能性があります。え、そして最後に3つ"
    },
    {
      "start": 595.88,
      "duration": 5.8,
      "text": "目の指標ミシ願代の消費者信頼感指指数。"
    },
    {
      "start": 598.839,
      "duration": 4.881,
      "text": "こちらですね、え、消費者の足元、また"
    },
    {
      "start": 601.68,
      "duration": 3.76,
      "text": "将来に対する軽感をですね、ま、"
    },
    {
      "start": 603.72,
      "duration": 4.76,
      "text": "ヒアリング調査したものになりますけれど"
    },
    {
      "start": 605.44,
      "duration": 5.76,
      "text": "も、合わせて発表される今後の物価に"
    },
    {
      "start": 608.48,
      "duration": 6.0,
      "text": "対する見方、え、1年後もしくはですね、"
    },
    {
      "start": 611.2,
      "duration": 5.96,
      "text": "5年から10年先の予想価格、インフレの"
    },
    {
      "start": 614.48,
      "duration": 4.88,
      "text": "変化の見通し、ここのですね、え、回答"
    },
    {
      "start": 617.16,
      "duration": 4.72,
      "text": "結果というのが重要となってきます。え、"
    },
    {
      "start": 619.36,
      "duration": 5.039,
      "text": "一時的なですね、原油価格上昇、ガソリン"
    },
    {
      "start": 621.88,
      "duration": 5.639,
      "text": "価格上昇によるインフレというのは"
    },
    {
      "start": 624.399,
      "duration": 5.761,
      "text": "あくまでも消費者がですね、1年後先行き"
    },
    {
      "start": 627.519,
      "duration": 5.361,
      "text": "には収束している、落ち着いているだろう"
    },
    {
      "start": 630.16,
      "duration": 5.239,
      "text": "といったような見方が維持される限りは、"
    },
    {
      "start": 632.88,
      "duration": 5.32,
      "text": "え、本格的な長期的なですね、インフレに"
    },
    {
      "start": 635.399,
      "duration": 6.401,
      "text": "は繋がっていきません。え、ただし消費者"
    },
    {
      "start": 638.2,
      "duration": 6.199,
      "text": "がですね、1年後さらにその先も物価が"
    },
    {
      "start": 641.8,
      "duration": 5.24,
      "text": "上がり続ける、上がり続けるだろうといっ"
    },
    {
      "start": 644.399,
      "duration": 6.641,
      "text": "たような味方にマインドが変化してしまう"
    },
    {
      "start": 647.04,
      "duration": 6.0,
      "text": "と実際に価格が上がる前に、え、消費を"
    },
    {
      "start": 651.04,
      "duration": 4.479,
      "text": "買っておこうといったような消費行動に"
    },
    {
      "start": 653.04,
      "duration": 4.479,
      "text": "移りますので、え、結果的にはインフレが"
    },
    {
      "start": 655.519,
      "duration": 4.201,
      "text": "ですね、実現していってしまうということ"
    },
    {
      "start": 657.519,
      "duration": 4.44,
      "text": "になりますから、FRBとしてはですね、"
    },
    {
      "start": 659.72,
      "duration": 4.359,
      "text": "え、この消費者のですね、マインド、"
    },
    {
      "start": 661.959,
      "duration": 4.401,
      "text": "先行きのインフレ予想というのを非常に"
    },
    {
      "start": 664.079,
      "duration": 6.041,
      "text": "中視をしています。ですから今回市長予想"
    },
    {
      "start": 666.36,
      "duration": 5.56,
      "text": "ですね、1年先の価格変化予想が4.3%"
    },
    {
      "start": 670.12,
      "duration": 3.68,
      "text": "と、ま、前回からですね、引き上がる"
    },
    {
      "start": 671.92,
      "duration": 4.08,
      "text": "見込みとなってはいますが、え、ここが"
    },
    {
      "start": 673.8,
      "duration": 4.92,
      "text": "さらにですね、ま、市場予想よりも強い"
    },
    {
      "start": 676.0,
      "duration": 5.6,
      "text": "結果となるような形となれば、え、ドル円"
    },
    {
      "start": 678.72,
      "duration": 5.16,
      "text": "ですね、ま、再び160円を試す可能性が"
    },
    {
      "start": 681.6,
      "duration": 5.479,
      "text": "ありますので、ま、この辺り材料としては"
    },
    {
      "start": 683.88,
      "duration": 5.84,
      "text": "ですね、やや今週の経済指標、ドル高方向"
    },
    {
      "start": 687.079,
      "duration": 4.601,
      "text": "への影響に警戒したいものという風に考え"
    },
    {
      "start": 689.72,
      "duration": 3.559,
      "text": "ています。え、では私の方からは以上と"
    },
    {
      "start": 691.68,
      "duration": 3.04,
      "text": "なります。動画の方気に入っていただけ"
    },
    {
      "start": 693.279,
      "duration": 3.201,
      "text": "ましたら高評価のいいね、そして"
    },
    {
      "start": 694.72,
      "duration": 6.08,
      "text": "チャンネル登録をよろしくお願いいたし"
    },
    {
      "start": 696.48,
      "duration": 4.32,
      "text": "ます。それでは失礼いたします。"
    }
  ]
}