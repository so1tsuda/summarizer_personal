      "start": 879.32,
      "duration": 5.439,
      "text": "って要するにより小さく、より微細に"
    },
    {
      "start": 882.399,
      "duration": 4.961,
      "text": "作るっていうところなんですよ。カイルを"
    },
    {
      "start": 884.759,
      "duration": 5.44,
      "text": "描くエッチングというところで光を使うん"
    },
    {
      "start": 887.36,
      "duration": 5.479,
      "text": "ですが、通常の光だとこれもうね、小さく"
    },
    {
      "start": 890.199,
      "duration": 4.64,
      "text": "するにあたって波長が大きすぎて十分に"
    },
    {
      "start": 892.839,
      "duration": 4.601,
      "text": "書きれないよというところになってきたん"
    },
    {
      "start": 894.839,
      "duration": 5.601,
      "text": "ですね。そこで活躍するようになったのが"
    },
    {
      "start": 897.44,
      "duration": 5.6,
      "text": "このEUVと言われる局紫外線。要するに"
    },
    {
      "start": 900.44,
      "duration": 5.48,
      "text": "波長がより普通の光よりもさらに細かい"
    },
    {
      "start": 903.04,
      "duration": 5.28,
      "text": "ものだということなんです。それだけまた"
    },
    {
      "start": 905.92,
      "duration": 4.96,
      "text": "どんどん繊細になってくる中で、え、"
    },
    {
      "start": 908.32,
      "duration": 5.0,
      "text": "いかに上ハーに影響を与えずに固定する"
    },
    {
      "start": 910.88,
      "duration": 5.44,
      "text": "かっていうところでこのセラミック同電"
    },
    {
      "start": 913.32,
      "duration": 5.759,
      "text": "セラミックが活躍するようになったという"
    },
    {
      "start": 916.32,
      "duration": 4.72,
      "text": "ところなんです。だからEUのところで"
    },
    {
      "start": 919.079,
      "duration": 4.2,
      "text": "まさにたくさん必要になってきたという"
    },
    {
      "start": 921.04,
      "duration": 5.88,
      "text": "ところがあり、ま、これ豆知識にはなるん"
    },
    {
      "start": 923.279,
      "duration": 6.201,
      "text": "ですが、このEUの路行装置の検査装置"
    },
    {
      "start": 926.92,
      "duration": 5.279,
      "text": "ですねを作っているのがレーザーテックに"
    },
    {
      "start": 929.48,
      "duration": 5.279,
      "text": "なります。なんでこのEUによって大きな"
    },
    {
      "start": 932.199,
      "duration": 5.2,
      "text": "変化が起きているというところは皆さんも"
    },
    {
      "start": 934.759,
      "duration": 4.961,
      "text": "ね、是非ご認識いただけるといろんな反動"
    },
    {
      "start": 937.399,
      "duration": 4.481,
      "text": "体関連の企業を見る時に面白くなってくる"
    },
    {
      "start": 939.72,
      "duration": 4.239,
      "text": "と思うんですね。これから再端反動体と"
    },
    {
      "start": 941.88,
      "duration": 4.12,
      "text": "言ったらもうほぼ間違いなくこのEUVで"
    },
    {
      "start": 943.959,
      "duration": 5.481,
      "text": "作られることになるでしょう。もう1個"
    },
    {
      "start": 946.0,
      "duration": 6.16,
      "text": "重要なのが今度はあの積化という技術なん"
    },
    {
      "start": 949.44,
      "duration": 5.24,
      "text": "です。今反動体ってどんどんちっちゃく"
    },
    {
      "start": 952.16,
      "duration": 4.96,
      "text": "なってるんですけど単純に面積を小さく"
    },
    {
      "start": 954.68,
      "duration": 5.92,
      "text": "するだけだともういよいよ限界があるよね"
    },
    {
      "start": 957.12,
      "duration": 6.36,
      "text": "とこ反動体の線のね細さがもう原子何個分"
    },
    {
      "start": 960.6,
      "duration": 4.4,
      "text": "というんで原子って基本的に1個よりも"
    },
    {
      "start": 963.48,
      "duration": 2.4,
      "text": "小さくはならないじゃないですか"
    },
    {
      "start": 965.0,
      "duration": 2.44,
      "text": "ならないですね"
    },
    {
      "start": 965.88,
      "duration": 3.36,
      "text": "ならないです。だからも限界があると言わ"
    },
    {
      "start": 967.44,
      "duration": 4.04,
      "text": "れていて、じゃあどうやったらこれを"
    },
    {
      "start": 969.24,
      "duration": 5.599,
      "text": "さらに小さくコンパクトにできるかって"
    },
    {
      "start": 971.48,
      "duration": 5.24,
      "text": "なった時に積化複数回に積み上げていくっ"
    },
    {
      "start": 974.839,
      "duration": 4.44,
      "text": "ていう動きをしているんですね。で、そこ"
    },
    {
      "start": 976.72,
      "duration": 4.88,
      "text": "で活躍するのが、ま、まさにまたこれで、"
    },
    {
      "start": 979.279,
      "duration": 4.961,
      "text": "ま、要するにそのたくさんね、上ハを"
    },
    {
      "start": 981.6,
      "duration": 3.76,
      "text": "エッチングする回路を描く回数が増える"
    },
    {
      "start": 984.24,
      "duration": 3.399,
      "text": "わけですよ。こうやってたくさん"
    },
    {
      "start": 985.36,
      "duration": 5.2,
      "text": "積み上がっていくと。だからその回数が"
    },
    {
      "start": 987.639,
      "duration": 3.801,
      "text": "増えるほどこのセラミックのニーズも"
    },
    {
      "start": 990.56,
      "duration": 3.88,
      "text": "高まっていく。"
    },
    {
      "start": 991.44,
      "duration": 3.0,
      "text": "で、それをたくさんどんどん積み上げているのがまさにこれ最新の難度メモリーなんですね。難度メモリー。これ今どこがたくさん作っているか企業で分かりますか?"
    },
    {
      "start": 1000.88,
      "duration": 4.16,
      "text": "記憶屋でしょうか?"
    },
    {
      "start": 1002.04,
      "duration": 3.0,
      "text": "その通りです。記憶シ屋なんかがメモリを作る時に等々の技術が用ちられれているというような話になってきます。それは重要伸びますよね。"
    },
    {
      "start": 1010.72,
      "duration": 5.32,
      "text": "ま、Cって言うならばこの賛同体製造装置"
    },
    {
      "start": 1013.199,
      "duration": 5.32,
      "text": "の中に使われる部材部品ということなので"
    },
    {
      "start": 1016.04,
      "duration": 4.52,
      "text": "、そんなね、しょっちゅね、継続的に重要"
    },
    {
      "start": 1018.519,
      "duration": 3.521,
      "text": "があるわけではないんですが、だからこそ"
    },
    {
      "start": 1020.56,
      "duration": 3.96,
      "text": "ね、こうやってガタガタするんですけれど"
    },
    {
      "start": 1022.04,
      "duration": 4.759,
      "text": "も、ただね、その途中での交換とか"
    },
    {
      "start": 1024.52,
      "duration": 5.24,
      "text": "あるいは新しく投資をするタイミングでは"
    },
    {
      "start": 1026.799,
      "duration": 5.561,
      "text": "引き続き求められる、ニーズが高まる商品"
    },
    {
      "start": 1029.76,
      "duration": 5.4,
      "text": "という風に考えられますので、これからも"
    },
    {
      "start": 1032.36,
      "duration": 3.4,
      "text": "また期待できるということで期待が高まい"
    },
    {
      "start": 1035.16,
      "duration": 2.84,
      "text": "んですね。"
    },
    {
      "start": 1035.76,
      "duration": 5.24,
      "text": "ここまで見てきてどうですか?奥ちゃん"
    },
    {
      "start": 1038.0,
      "duration": 3.0,
      "text": "安定もしているし成長性もあの期待できるイメージが変わってきました。"
    },
    {
      "start": 1043.16,
      "duration": 3.0,
      "text": "そうなんですよ。めちゃくちゃ美味しいように見えますよね。ただね残念ポイントをやっぱちょっと上げるとするならば、ま、少しね、途中でも話がありました。中国ですね。中国の業績が震わないというところがあります。"
    },
    {
      "start": 1056.36,
      "duration": 5.8,
      "text": "こちらが先ほどの日経新聞の続きなんです"
    },
    {
      "start": 1059.16,
      "duration": 5.28,
      "text": "が、ま、米中の売上高営業利益が逆転して"
    },
    {
      "start": 1062.16,
      "duration": 4.399,
      "text": "いるということで、ま、中国ね、ま、これ"
    },
    {
      "start": 1064.44,
      "duration": 4.16,
      "text": "まで日本にどんどんインバウンドとして"
    },
    {
      "start": 1066.559,
      "duration": 4.201,
      "text": "やってきた人が中国に持って帰ってきて"
    },
    {
      "start": 1068.6,
      "duration": 4.12,
      "text": "くれたから中国での売上が伸びてきたって"
    },
    {
      "start": 1070.76,
      "duration": 4.6,
      "text": "いう側面があったんですが、ま、それがね"
    },
    {
      "start": 1072.72,
      "duration": 5.36,
      "text": "、中国で景気が悪くなってついに赤字に"
    },
    {
      "start": 1075.36,
      "duration": 4.48,
      "text": "転落してしまっているというような状況が"
    },
    {
      "start": 1078.08,
      "duration": 4.0,
      "text": "あります。ま、一方でアメリカが伸びて"
    },
    {
      "start": 1079.84,
      "duration": 4.4,
      "text": "るっていうことなんですが、等当の製品"
    },
    {
      "start": 1082.08,
      "duration": 3.76,
      "text": "って日本の場合はもうリフォーム需要が"
    },
    {
      "start": 1084.24,
      "duration": 4.12,
      "text": "伸びてくるっていうところがありましたが"
    },
    {
      "start": 1085.84,
      "duration": 5.12,
      "text": "、中国はもうこれまでバンバンね、新築の"
    },
    {
      "start": 1088.36,
      "duration": 5.04,
      "text": "住宅を作っていたので、その需要が"
    },
    {
      "start": 1090.96,
      "duration": 4.56,
      "text": "やっぱり当面見込めないよねっていう話が"
    },
    {
      "start": 1093.4,
      "duration": 4.32,
      "text": "ありそうなんですね。だから中国は、ま、"
    },
    {
      "start": 1095.52,
      "duration": 4.2,
      "text": "当面厳しいよねっていう、なんなら赤字を"
    },
    {
      "start": 1097.72,
      "duration": 4.28,
      "text": "掘り続けるんじゃないかというところも"
    },
    {
      "start": 1099.72,
      "duration": 4.72,
      "text": "見えていて、ここが1つ残念ポイントには"
    },
    {
      "start": 1102.0,
      "duration": 5.0,
      "text": "なるかと思います。あともう1つ言うなら"
    },
    {
      "start": 1104.44,
      "duration": 4.64,
      "text": "、あんまり収益性高くないんですよね。"
    },
    {
      "start": 1107.0,
      "duration": 5.48,
      "text": "売上高営業利益率。あの、さっき"
    },
    {
      "start": 1109.08,
      "duration": 5.8,
      "text": "セラミック反動体分野は40%の利益率を"
    },
    {
      "start": 1112.48,
      "duration": 5.679,
      "text": "誇ると言ったんですが、トイレの製品自体"
    },
    {
      "start": 1114.88,
      "duration": 5.279,
      "text": "の利益率が必ずしもも45%ということで"
    },
    {
      "start": 1118.159,
      "duration": 4.601,
      "text": "高くないし、中国は赤字だし、え、"
    },
    {
      "start": 1120.159,
      "duration": 5.921,
      "text": "トータルで6%ぐらいになっていると。"
    },
    {
      "start": 1122.76,
      "duration": 7.08,
      "text": "ROEに関しても5.7%というところで"
    },
    {
      "start": 1126.08,
      "duration": 5.959,
      "text": "、これも、ま、平均値合格点とされる8%"
    },
    {
      "start": 1129.84,
      "duration": 4.839,
      "text": "を下回っている状況ですね。相当って"
    },
    {
      "start": 1132.039,
      "duration": 5.241,
      "text": "やっぱ昔ながらの日本企業らしく保守的な"
    },
    {
      "start": 1134.679,
      "duration": 5.281,
      "text": "会社で無駄遣いはしている感じはないん"
    },
    {
      "start": 1137.28,
      "duration": 4.92,
      "text": "ですけれどもやっぱこう収益性の必ずしも"
    },
    {
      "start": 1139.96,
      "duration": 4.76,
      "text": "高くないところをまどんどん切っていっ"
    },
    {
      "start": 1142.2,
      "duration": 5.64,
      "text": "たりとか収益性の高いところにこう大きく"
    },
    {
      "start": 1144.72,
      "duration": 4.4,
      "text": "突っ込むみたいなことは必ずしもできてい"
    },
    {
      "start": 1147.84,
      "duration": 3.44,
      "text": "なくてキャッシュフロー見るとね"
    },
    {
      "start": 1149.12,
      "duration": 4.08,
      "text": "キャッシュフロー自体も安定して黒字で"
    },
    {
      "start": 1151.28,
      "duration": 4.44,
      "text": "それは非常にいいことなんですがま投資も"
    },
    {
      "start": 1153.2,
      "duration": 4.719,
      "text": "ねめでリスクはあんまり取っていないと"
    },
    {
      "start": 1155.72,
      "duration": 4.079,
      "text": "いう印象です。そういったこう残念"
    },
    {
      "start": 1157.919,
      "duration": 4.0,
      "text": "ポイントもあるからこそパリサー"
    },
    {
      "start": 1159.799,
      "duration": 5.281,
      "text": "キャピタルというファンドが等々の価値の"
    },
    {
      "start": 1161.919,
      "duration": 5.361,
      "text": "最大化最も過小評価され見落とされている"
    },
    {
      "start": 1165.08,
      "duration": 5.839,
      "text": "AIメモリによる受益者というような"
    },
    {
      "start": 1167.28,
      "duration": 5.399,
      "text": "こんなレポートを公に公表しての刑事にも"
    },
    {
      "start": 1170.919,
      "duration": 3.921,
      "text": "訴えかけたりしているわけですね。"
    },
    {
      "start": 1172.679,
      "duration": 4.681,
      "text": "アリサーが訴えている3つの価値向上"
    },
    {
      "start": 1174.84,
      "duration": 4.44,
      "text": "プランというのが1競争力とえ、成長"
    },
    {
      "start": 1177.36,
      "duration": 4.28,
      "text": "見通しに関する透明性のためファイン"
    },
    {
      "start": 1179.28,
      "duration": 5.56,
      "text": "セラミックス事業についての開示を改善し"
    },
    {
      "start": 1181.64,
      "duration": 5.56,
      "text": "、その真の価値が株価に適切に反映される"
    },
    {
      "start": 1184.84,
      "duration": 5.0,
      "text": "ことを確かなものとする。2資本コストを"
    },
    {
      "start": 1187.2,
      "duration": 5.08,
      "text": "上回る最大のリターンを生む資本活用を"
    },
    {
      "start": 1189.84,
      "duration": 5.8,
      "text": "確かなものとする。クラス最高の資本配部"
    },
    {
      "start": 1192.28,
      "duration": 5.6,
      "text": "の枠組を導入する。さん、司法構成の最適"
    },
    {
      "start": 1195.64,
      "duration": 4.039,
      "text": "化による資本効率向上ということで、"
    },
    {
      "start": 1197.88,
      "duration": 4.48,
      "text": "やっぱりその保守的な会社で現金を"
    },
    {
      "start": 1199.679,
      "duration": 4.401,
      "text": "溜め込んで、え、いたりして資本効率が"
    },
    {
      "start": 1202.36,
      "duration": 4.799,
      "text": "必ずしも良くなかったりもする。え、それ"
    },
    {
      "start": 1204.08,
      "duration": 5.12,
      "text": "を借入れ金も活用したりしながら成長分野"
    },
    {
      "start": 1207.159,
      "duration": 3.76,
      "text": "、要するにこの、え、セラミックス反動体"
    },
    {
      "start": 1209.2,
      "duration": 3.2,
      "text": "事業の方にもっと力を入れればいいんじゃ"
    },
    {
      "start": 1210.919,
      "duration": 3.601,
      "text": "ないのっていうようなことをファリサー"
    },
    {
      "start": 1212.4,
      "duration": 4.68,
      "text": "キャピタルは言っているわけですね。これ"
    },
    {
      "start": 1214.52,
      "duration": 5.12,
      "text": "から等々が大きく成長するかどうかって"
    },
    {
      "start": 1217.08,
      "duration": 5.36,
      "text": "いうのは結構今分岐点にあるかなと。"
    },
    {
      "start": 1219.64,
      "duration": 6.08,
      "text": "ずっとね、横倍ぐらいの業績が続いていた"
    },
    {
      "start": 1222.44,
      "duration": 5.64,
      "text": "会社ですが、ここでついに成長企業として"
    },
    {
      "start": 1225.72,
      "duration": 4.72,
      "text": "羽たけるかどうか、ま、そんなに立って"
    },
    {
      "start": 1228.08,
      "duration": 5.28,
      "text": "いるという風に感じます。え、現在の"
    },
    {
      "start": 1230.44,
      "duration": 5.32,
      "text": "PERが31倍ということですから、必ず"
    },
    {
      "start": 1233.36,
      "duration": 5.08,
      "text": "しも低くはない、え、とは思うんですが、"
    },
    {
      "start": 1235.76,
      "duration": 5.399,
      "text": "一方で、ま、一部の人は気づいてここに"
    },
    {
      "start": 1238.44,
      "duration": 5.32,
      "text": "投資を始めているっていう話かなと思い"
    },
    {
      "start": 1241.159,
      "duration": 4.801,
      "text": "ます。セラミック事業の利益率が40%"
    },
    {
      "start": 1243.76,
      "duration": 4.68,
      "text": "あってですね、ま、売上に占める割合が"
    },
    {
      "start": 1245.96,
      "duration": 5.16,
      "text": "40%ということですから、例えばね、"
    },
    {
      "start": 1248.44,
      "duration": 5.28,
      "text": "この分野が倍になるというだけでも"
    },
    {
      "start": 1251.12,
      "duration": 5.2,
      "text": "おそらく、ま、40%とか利益が増えて"
    },
    {
      "start": 1253.72,
      "duration": 5.16,
      "text": "いくでしょうし、途中でも説明しました"
    },
    {
      "start": 1256.32,
      "duration": 4.88,
      "text": "北米事業、え、こちらでまあね、さっき"
    },
    {
      "start": 1258.88,
      "duration": 3.96,
      "text": "ウシレットの販売台数が日本に近づいてき"
    },
    {
      "start": 1261.2,
      "duration": 4.04,
      "text": "たということからですね、ま、アメリカの"
    },
    {
      "start": 1262.84,
      "duration": 5.28,
      "text": "方が人口多いですから、ここがまた軍と"
    },
    {
      "start": 1265.24,
      "duration": 5.52,
      "text": "行く可能性も秘めている。そんな状況かな"
    },
    {
      "start": 1268.12,
      "duration": 5.439,
      "text": "と思います。1点懸念点を言うならばこれ"
    },
    {
      "start": 1270.76,
      "duration": 5.399,
      "text": "ですね。があまり手に入らない。ナフサが"
    },
    {
      "start": 1273.559,
      "duration": 4.401,
      "text": "手に入らないということでユニットバスの"
    },
    {
      "start": 1276.159,
      "duration": 4.601,
      "text": "受中をですね、1回停止していたと。ま、"
    },
    {
      "start": 1277.96,
      "duration": 5.4,
      "text": "今最開へという話も出ているんですが、"
    },
    {
      "start": 1280.76,
      "duration": 4.36,
      "text": "ちょっとこのね、ナフさ、原油価格の後等"
    },
    {
      "start": 1283.36,
      "duration": 4.0,
      "text": "というのは、ま、減価の上昇というところ"
    },
    {
      "start": 1285.12,
      "duration": 4.12,
      "text": "も目先ではあるでしょうし、え、物自体が"
    },
    {
      "start": 1287.36,
      "duration": 3.96,
      "text": "作れない、え、可能性があるということは"
    },
    {
      "start": 1289.24,
      "duration": 4.48,
      "text": "頭に置いて、え、置く必要はあるかなと"
    },
    {
      "start": 1291.32,
      "duration": 3.599,
      "text": "思います。等々に関して全体としては"
    },
    {
      "start": 1293.72,
      "duration": 2.199,
      "text": "こんな感じですかね。"
    },
    {
      "start": 1294.919,
      "duration": 4.0,
      "text": "おきちゃんどうですか?"
    },
    {
      "start": 1295.919,
      "duration": 3.0,
      "text": "そうですね、原油価格が今上がってきて、そのちょっとね、生産を中止しているっていうのがあったりはしますけども、ま、一時的なことですよね。面白みがある企業なんじゃないかなとやっぱり思います。"
    },
    {
      "start": 1307.279,
      "duration": 3.0,
      "text": "の、むしろだからこうやって原油価格の高等なので、ま、実際ね、その受中を停止ってなった時には株価ちょっと下がったんですよね。やっぱり今後原油価格の後等で減価が上がって、ま、利益が圧迫されるということがあれば株価としてはやっぱり一時的にでも下落する可能性はあるかなとに思います。"
    },
    {
      "start": 1323.76,
      "duration": 3.0,
      "text": "ただ逆に言うとそういう時ってチャンスになりやすいですよね。"
    },
    {
      "start": 1327.279,
      "duration": 3.681,
      "text": "そうですね。"
    },
    {
      "start": 1327.96,
      "duration": 3.0,
      "text": "だから東々がいい企業だということを知っていて、で、そこで下落したというチャンスがあれば、いよいよそういう時に仕込むチャンスになるんじゃないかなということが言えるんじゃないかなと思います。このようにですね、つばメ投資顧問ではこれ投資の"
    },
    {
      "start": 1340.76,
      "duration": 3.36,
      "text": "MOD"
    },
    {
      "start": 1341.12,
      "duration": 3.0,
      "text": "がありまして、素晴らしい企業を適切な価格で購入し、素晴らしい企業である限り続けること、そういう信念がございます。"
    },
    {
      "start": 1351.84,
      "duration": 4.76,
      "text": "え、そういった投資を行っているのが"
    },
    {
      "start": 1353.919,
      "duration": 4.64,
      "text": "つばメ投資顧問の有料会員サービスになり"
    },
    {
      "start": 1356.6,
      "duration": 5.0,
      "text": "ます。え、もうすぐですね、この4月の"
    },
    {
      "start": 1358.559,
      "duration": 5.321,
      "text": "26日まで、え、入会機半額キャンペーン"
    },
    {
      "start": 1361.6,
      "duration": 4.6,
      "text": "というものを実施していますので、もし"
    },
    {
      "start": 1363.88,
      "duration": 4.279,
      "text": "ですね、このような投資に興味のある方、"
    },
    {
      "start": 1366.2,
      "duration": 4.76,
      "text": "等当に興味のある方もですね、是非この"
    },
    {
      "start": 1368.159,
      "duration": 4.88,
      "text": "機会につメ投資項問へのご入会を検討して"
    },
    {
      "start": 1370.96,
      "duration": 3.959,
      "text": "みてください。ご自身で投資されたいと"
    },
    {
      "start": 1373.039,
      "duration": 4.281,
      "text": "いう方が集まっているそんなコミュニティ"
    },
    {
      "start": 1374.919,
      "duration": 4.201,
      "text": "になっておりますので、詳しくは概要欄に"
    },
    {
      "start": 1377.32,
      "duration": 3.839,
      "text": "ございますホームページご覧になって"
    },
    {
      "start": 1379.12,
      "duration": 4.799,
      "text": "ください。このキャンペーンが過ぎますと"
    },
    {
      "start": 1381.159,
      "duration": 5.64,
      "text": "、つばメ投資顧問の年間会員について、え"
    },
    {
      "start": 1383.919,
      "duration": 5.64,
      "text": "、料金が変更になります。変更前の料金で"
    },
    {
      "start": 1386.799,
      "duration": 5.12,
      "text": "入会できるのは4月の26日までとなって"
    },
    {
      "start": 1389.559,
      "duration": 4.161,
      "text": "おりますので、そちらも合わせてご確認"
    },
    {
      "start": 1391.919,
      "duration": 3.521,
      "text": "いただければと思います。この動画ね、"
    },
    {
      "start": 1393.72,
      "duration": 3.839,
      "text": "キャンペーン終了後もご覧にある方もいる"
    },
    {
      "start": 1395.44,
      "duration": 4.719,
      "text": "と思います。つばメ投資顧問や長期投資に"
    },
    {
      "start": 1397.559,
      "duration": 4.401,
      "text": "ついて詳しく知りたいという方は詳細欄に"
    },
    {
      "start": 1400.159,
      "duration": 4.601,
      "text": "ございます。無料のメールマガジンにも"
    },
    {
      "start": 1401.96,
      "duration": 5.48,
      "text": "是非ご登録ください。私が書いた電子書籍"
    },
    {
      "start": 1404.76,
      "duration": 4.64,
      "text": "を始め様々な長期投資に関する役立つ情報"
    },
    {
      "start": 1407.44,
      "duration": 3.92,
      "text": "を発信しています。是非ご覧になって"
    },
    {
      "start": 1409.4,
      "duration": 3.92,
      "text": "ください。この動画がいいねと思ったら"
    },
    {
      "start": 1411.36,
      "duration": 4.08,
      "text": "グッドボタンを気になることやご質問、"
    },
    {
      "start": 1413.32,
      "duration": 4.16,
      "text": "今後の分析のリクエストなどございまし"
    },
    {
      "start": 1415.44,
      "duration": 3.8,
      "text": "たらコメント欄にお願いいたします。それ"
    },
    {
      "start": 1417.48,
      "duration": 5.36,
      "text": "ではご視聴ありがとうございました。また"
    },
    {
      "start": 1419.24,
      "duration": 3.6,
      "text": "お会いしましょう。"
    }
  ]
}