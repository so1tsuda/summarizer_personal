      "start": 459.8,
      "duration": 5.0,
      "text": "じゃないかというですね。年所には2回の"
    },
    {
      "start": 462.16,
      "duration": 4.999,
      "text": "利下げが折り込まれていたところが一気に"
    },
    {
      "start": 464.8,
      "duration": 5.76,
      "text": "利上げ観測が高まっていたところ金利低下"
    },
    {
      "start": 467.159,
      "duration": 5.841,
      "text": "は株価にとって安心ですよね。3月を"
    },
    {
      "start": 470.56,
      "duration": 6.16,
      "text": "振り返ってみてください。日経平均は3月"
    },
    {
      "start": 473.0,
      "duration": 6.8,
      "text": "だけで7786円も下がりました。35年"
    },
    {
      "start": 476.72,
      "duration": 7.039,
      "text": "ぶりの月刊下落幅。原因は3月だけで"
    },
    {
      "start": 479.8,
      "duration": 7.72,
      "text": "60%以上休動して過去最大の月刊上昇率"
    },
    {
      "start": 483.759,
      "duration": 6.761,
      "text": "を記録。その原因の大部分がイラン戦争と"
    },
    {
      "start": 487.52,
      "duration": 6.119,
      "text": "原油高だったわけです。それが今巻き戻し"
    },
    {
      "start": 490.52,
      "duration": 6.04,
      "text": "をし始めています。まだ終戦ではない"
    },
    {
      "start": 493.639,
      "duration": 5.881,
      "text": "けれど今回は違うと見ている可能性があり"
    },
    {
      "start": 496.56,
      "duration": 6.4,
      "text": "ます。それでは本日の失き3つ目に参り"
    },
    {
      "start": 499.52,
      "duration": 6.72,
      "text": "ましょう。我々の心理さ、生活にどう影響"
    },
    {
      "start": 502.96,
      "duration": 6.12,
      "text": "するのか。ここからが皆さん1番知りたい"
    },
    {
      "start": 506.24,
      "duration": 5.639,
      "text": "ところですよね。じゃあ我々の資産にどう"
    },
    {
      "start": 509.08,
      "duration": 4.36,
      "text": "影響するのか。S&ビグ100やオルカン"
    },
    {
      "start": 511.879,
      "duration": 4.201,
      "text": "、NASダック100やファングプラス"
    },
    {
      "start": 513.44,
      "duration": 4.76,
      "text": "など新認差で人気の投資信託を持ってる方"
    },
    {
      "start": 516.08,
      "duration": 5.839,
      "text": "にとっては今回のニュースはポジティブ"
    },
    {
      "start": 518.2,
      "duration": 7.04,
      "text": "です。なぜか3月にハイテが大きく下がっ"
    },
    {
      "start": 521.919,
      "duration": 6.561,
      "text": "た最大の原因は金利未投資の180°転換"
    },
    {
      "start": 525.24,
      "duration": 7.039,
      "text": "でした。年は利下げ2回の期待だったのが"
    },
    {
      "start": 528.48,
      "duration": 6.919,
      "text": "原油高でインフレ再年利上げ観測52%"
    },
    {
      "start": 532.279,
      "duration": 6.761,
      "text": "まで急上昇。これがファングプラスを-"
    },
    {
      "start": 535.399,
      "duration": 6.68,
      "text": "22%まで叩き落としました。原油価格が"
    },
    {
      "start": 539.04,
      "duration": 5.44,
      "text": "落ち着きを取り戻せばこの逆回転が始まる"
    },
    {
      "start": 542.079,
      "duration": 5.161,
      "text": "可能性が高まります。インフレ圧力が"
    },
    {
      "start": 544.48,
      "duration": 5.4,
      "text": "柔らかくつまりは利上げ観測が交代。"
    },
    {
      "start": 547.24,
      "duration": 5.24,
      "text": "つまりは金利が下がる方向、つまりは"
    },
    {
      "start": 549.88,
      "duration": 5.44,
      "text": "ハイテ株に追い風です。S&P500や"
    },
    {
      "start": 552.48,
      "duration": 6.039,
      "text": "NASダ100は恩恵を受けます。次に"
    },
    {
      "start": 555.32,
      "duration": 6.28,
      "text": "為せの問題。3月に1ドル160円を突破"
    },
    {
      "start": 558.519,
      "duration": 6.081,
      "text": "しましたよね。円安で投資信託の基準価格"
    },
    {
      "start": 561.6,
      "duration": 6.0,
      "text": "が支えられていたけど低線で円高になっ"
    },
    {
      "start": 564.6,
      "duration": 5.44,
      "text": "たら基準価格が下がるんじゃないの?こう"
    },
    {
      "start": 567.6,
      "duration": 5.239,
      "text": "心配する方いらっしゃるかと思います。"
    },
    {
      "start": 570.04,
      "duration": 5.799,
      "text": "結論から言うと多少の巻き戻しはあっても"
    },
    {
      "start": 572.839,
      "duration": 5.921,
      "text": "構造的な円安は簡単には変わりません。"
    },
    {
      "start": 575.839,
      "duration": 5.801,
      "text": "なぜか円安の原因は原油高だけじゃないん"
    },
    {
      "start": 578.76,
      "duration": 5.92,
      "text": "ですよね。日米の金利さ。日本の金利が"
    },
    {
      "start": 581.64,
      "duration": 5.759,
      "text": "低くてアメリカの金利が高い。この構造は"
    },
    {
      "start": 584.68,
      "duration": 5.8,
      "text": "低線で原油が下がっても大きくは変わり"
    },
    {
      "start": 587.399,
      "duration": 6.521,
      "text": "ません。さらに日本はエネルギー持給率が"
    },
    {
      "start": 590.48,
      "duration": 6.72,
      "text": "わずか13%で構造的にエネルギーを輸入"
    },
    {
      "start": 593.92,
      "duration": 6.599,
      "text": "し続けます。つまり円安圧力は残り続ける"
    },
    {
      "start": 597.2,
      "duration": 6.36,
      "text": "。またそれ以外にも新入による年間"
    },
    {
      "start": 600.519,
      "duration": 5.961,
      "text": "10兆円ほどの円売りドルガイや年間5"
    },
    {
      "start": 603.56,
      "duration": 6.399,
      "text": "から56兆円のデジタル赤字の存在なども"
    },
    {
      "start": 606.48,
      "duration": 6.0,
      "text": "円安のおしになってますよね。低線で多少"
    },
    {
      "start": 609.959,
      "duration": 5.12,
      "text": "円高に触れる可能性はありますが、大幅に"
    },
    {
      "start": 612.48,
      "duration": 5.16,
      "text": "円高が済むかというと現状は可能性が低"
    },
    {
      "start": 615.079,
      "duration": 5.521,
      "text": "そう。川わせヘッ置をしていない投資信託"
    },
    {
      "start": 617.64,
      "duration": 5.36,
      "text": "を持っている方は基準価格が多少調整する"
    },
    {
      "start": 620.6,
      "duration": 5.84,
      "text": "可能性はありますが慌てて売るほどでは"
    },
    {
      "start": 623.0,
      "duration": 6.0,
      "text": "ありません。そして何より3月に握り続け"
    },
    {
      "start": 626.44,
      "duration": 5.68,
      "text": "た皆さん、あの恐怖の中で売らなかった"
    },
    {
      "start": 629.0,
      "duration": 6.839,
      "text": "判断が少しずつ報われ始めています。ガチ"
    },
    {
      "start": 632.12,
      "duration": 6.8,
      "text": "補税の優勝です。それでは本日の品き最後"
    },
    {
      "start": 635.839,
      "duration": 6.401,
      "text": "に参りましょう。戦争開始から5週間僕が"
    },
    {
      "start": 638.92,
      "duration": 6.159,
      "text": "思う雑観をご紹介します。3月1日に"
    },
    {
      "start": 642.24,
      "duration": 5.32,
      "text": "イラン戦争が始まってから5週間。本当に"
    },
    {
      "start": 645.079,
      "duration": 4.641,
      "text": "長い5週間でしたよね。ま、まだ戦争は"
    },
    {
      "start": 647.56,
      "duration": 5.12,
      "text": "終わってないんですけども一旦は低戦です"
    },
    {
      "start": 649.72,
      "duration": 5.76,
      "text": "。あの、恐怖の中で売らなかった皆さん、"
    },
    {
      "start": 652.68,
      "duration": 5.0,
      "text": "今日のニュースは皆さんの握力への最初の"
    },
    {
      "start": 655.48,
      "duration": 4.479,
      "text": "ご褒美です。今後の注目ポイントなんです"
    },
    {
      "start": 657.68,
      "duration": 5.44,
      "text": "けども、なんと言っても4月10日の"
    },
    {
      "start": 659.959,
      "duration": 6.0,
      "text": "イスラムバードでの対面交渉で溝が埋まる"
    },
    {
      "start": 663.12,
      "duration": 6.76,
      "text": "かどうかが次の焦点です。イランの10"
    },
    {
      "start": 665.959,
      "duration": 6.641,
      "text": "項目には制裁解除や賠償金など簡単には"
    },
    {
      "start": 669.88,
      "duration": 6.32,
      "text": "決まらない条件が含まれています。2週間"
    },
    {
      "start": 672.6,
      "duration": 6.88,
      "text": "後に再び緊張が高まる可能性はまた残って"
    },
    {
      "start": 676.2,
      "duration": 6.36,
      "text": "います。つまり今の状況は光が見え始めた"
    },
    {
      "start": 679.48,
      "duration": 7.28,
      "text": "けどまだトンネルの中ここで興奮をして"
    },
    {
      "start": 682.56,
      "duration": 7.079,
      "text": "全力をして2週間後に交渉決列で再びくと"
    },
    {
      "start": 686.76,
      "duration": 4.879,
      "text": "いうシナリオもありますので全力など極端"
    },
    {
      "start": 689.639,
      "duration": 5.2,
      "text": "な行動を取るタイミングではないかと思い"
    },
    {
      "start": 691.639,
      "duration": 5.841,
      "text": "ます。最後に少し個人的なお話をさせて"
    },
    {
      "start": 694.839,
      "duration": 4.881,
      "text": "ください。3月1日の朝イラン攻撃の"
    },
    {
      "start": 697.48,
      "duration": 5.28,
      "text": "ニュースを見て僕は急いでこのチャンネル"
    },
    {
      "start": 699.72,
      "duration": 5.96,
      "text": "で速報を出しました。あの日から5週間、"
    },
    {
      "start": 702.76,
      "duration": 6.4,
      "text": "日経平均は35年ぶりの下落を記録し、"
    },
    {
      "start": 705.68,
      "duration": 9.159,
      "text": "原因は60%急し、ファングプラスは-"
    },
    {
      "start": 709.16,
      "duration": 8.119,
      "text": "22%。SNSには毎日終わった売ったN"
    },
    {
      "start": 714.839,
      "duration": 5.041,
      "text": "じゃなかったという言葉が流れてきた。"
    },
    {
      "start": 717.279,
      "duration": 5.8,
      "text": "正直に言います。僕もきつかった。大丈夫"
    },
    {
      "start": 719.88,
      "duration": 5.92,
      "text": "だと頭では分かっていても自分の資産が"
    },
    {
      "start": 723.079,
      "duration": 5.521,
      "text": "毎日減っていくのを見るのはやっぱり心が"
    },
    {
      "start": 725.8,
      "duration": 5.24,
      "text": "削られんですよね。でも皆さん思い出して"
    },
    {
      "start": 728.6,
      "duration": 5.52,
      "text": "ください。あの、5週間皆さんは何をし"
    },
    {
      "start": 731.04,
      "duration": 6.52,
      "text": "ましたか?占かったんです。毎朝ニュース"
    },
    {
      "start": 734.12,
      "duration": 6.2,
      "text": "を見て不安になって証券講座を開いて赤い"
    },
    {
      "start": 737.56,
      "duration": 5.76,
      "text": "数字を見てそれでも売るボタンを押さ"
    },
    {
      "start": 740.32,
      "duration": 5.519,
      "text": "なかった。SNSで逃げろと言われても"
    },
    {
      "start": 743.32,
      "duration": 6.12,
      "text": "ニュースで暴落と書かれてもじっと耐えた"
    },
    {
      "start": 745.839,
      "duration": 6.481,
      "text": "。それがどれだけすごいことかとして"
    },
    {
      "start": 749.44,
      "duration": 5.04,
      "text": "上がってる時は誰でも続けられるんです。"
    },
    {
      "start": 752.32,
      "duration": 5.44,
      "text": "含み駅が増えていく。画面を見るのは"
    },
    {
      "start": 754.48,
      "duration": 6.08,
      "text": "楽しいですよね。SNSで今年も好調です"
    },
    {
      "start": 757.76,
      "duration": 5.92,
      "text": "と投稿するのは気持ちいい。でもそれは"
    },
    {
      "start": 760.56,
      "duration": 6.279,
      "text": "投資とは言えません。本当の投資は逆風の"
    },
    {
      "start": 763.68,
      "duration": 6.399,
      "text": "中で立ち続けること。恐怖で足がすんでも"
    },
    {
      "start": 766.839,
      "duration": 6.041,
      "text": "一歩も動かないこと。あの5週間にそれを"
    },
    {
      "start": 770.079,
      "duration": 6.401,
      "text": "やった皆さんは間違いなく強い投資家です"
    },
    {
      "start": 772.88,
      "duration": 5.759,
      "text": "。今日低線合意が発表されて日経平均が"
    },
    {
      "start": 776.48,
      "duration": 4.2,
      "text": "2800円上がっています。原油が"
    },
    {
      "start": 778.639,
      "duration": 5.361,
      "text": "100ドルを終わっています。これは僕"
    },
    {
      "start": 780.68,
      "duration": 6.44,
      "text": "たちの握力へのご褒美の最初の一歩です。"
    },
    {
      "start": 784.0,
      "duration": 5.399,
      "text": "でもね、仮にこの戦が2週間後に"
    },
    {
      "start": 787.12,
      "duration": 5.2,
      "text": "ひっくり返ったとしても皆さんがやること"
    },
    {
      "start": 789.399,
      "duration": 5.641,
      "text": "は変わらないはずです。あの、5週間で"
    },
    {
      "start": 792.32,
      "duration": 6.12,
      "text": "証明したじゃないですか。自分は恐怖の中"
    },
    {
      "start": 795.04,
      "duration": 5.359,
      "text": "でも占い人間だって。長期投資の本質は"
    },
    {
      "start": 798.44,
      "duration": 4.72,
      "text": "マーケットの予測が当たることじゃあり"
    },
    {
      "start": 800.399,
      "duration": 5.481,
      "text": "ません。どんな結果になっても自分の計画"
    },
    {
      "start": 803.16,
      "duration": 5.56,
      "text": "を信じて立ち続けられるかどうか、僕らは"
    },
    {
      "start": 805.88,
      "duration": 5.84,
      "text": "もうそれを5週間かけて証明してきました"
    },
    {
      "start": 808.72,
      "duration": 5.4,
      "text": "よね。だからこれからも一緒に乗り越えて"
    },
    {
      "start": 811.72,
      "duration": 5.88,
      "text": "いきましょう。嵐が来ても晴れ間が見えて"
    },
    {
      "start": 814.12,
      "duration": 6.159,
      "text": "も淡々とそれが僕たち長期投資家のやり方"
    },
    {
      "start": 817.6,
      "duration": 5.08,
      "text": "です。今日も最後までご視聴いただき"
    },
    {
      "start": 820.279,
      "duration": 4.961,
      "text": "ありがとうございました。週末の相場"
    },
    {
      "start": 822.68,
      "duration": 4.599,
      "text": "まとめで交渉の結果も含めてしっかりと"
    },
    {
      "start": 825.24,
      "duration": 3.959,
      "text": "フォローしていきます。見逃さないよう"
    },
    {
      "start": 827.279,
      "duration": 4.48,
      "text": "チャンネル登録よろしくお願いいたします"
    },
    {
      "start": 829.199,
      "duration": 5.2,
      "text": "。このチャンネルでは前向きに投資に挑戦"
    },
    {
      "start": 831.759,
      "duration": 5.08,
      "text": "する方を応援しています。是非またご視聴"
    },
    {
      "start": 834.399,
      "duration": 4.761,
      "text": "ください。本日も最後までご視聴いただき"
    },
    {
      "start": 836.839,
      "duration": 4.8,
      "text": "ましてありがとうございました。本日の"
    },
    {
      "start": 839.16,
      "duration": 4.679,
      "text": "動画の裏話や動画の中ではちょっと言い"
    },
    {
      "start": 841.639,
      "duration": 4.88,
      "text": "きれない本音をノートのメンバーシップで"
    },
    {
      "start": 843.839,
      "duration": 4.92,
      "text": "発信を始めております。台本を作りながら"
    },
    {
      "start": 846.519,
      "duration": 5.201,
      "text": "考えたことやちょっと公開動画では得ない"
    },
    {
      "start": 848.759,
      "duration": 5.841,
      "text": "ことも楽ヤトーク的に有力発信中です。気"
    },
    {
      "start": 851.72,
      "duration": 5.6,
      "text": "になる方は概要欄かこちらのQRコードを"
    },
    {
      "start": 854.6,
      "duration": 4.76,
      "text": "読み込むとノートに登録できますので是非"
    },
    {
      "start": 857.32,
      "duration": 4.519,
      "text": "チェックをしてみてください。概要欄に"
    },
    {
      "start": 859.36,
      "duration": 5.0,
      "text": "LINEXインスタメルマガのURLが"
    },
    {
      "start": 861.839,
      "duration": 5.761,
      "text": "あります。私自身が取り組んでいる資産"
    },
    {
      "start": 864.36,
      "duration": 6.039,
      "text": "形成や生続との工夫は今後LINEで配信"
    },
    {
      "start": 867.6,
      "duration": 5.2,
      "text": "予定ご興味ある方はご登録ください。"
    },
    {
      "start": 870.399,
      "duration": 5.601,
      "text": "メルマガでは日々の経済ニュースを分かり"
    },
    {
      "start": 872.8,
      "duration": 5.959,
      "text": "やすく解説しています。インスタやXでは"
    },
    {
      "start": 876.0,
      "duration": 7.279,
      "text": "より短時間で情報インプットができます。"
    },
    {
      "start": 878.759,
      "duration": 4.52,
      "text": "是非ご登録をお願いします。"
    }
  ]
}