    },
    {
      "start": 721.72,
      "duration": 1.72,
      "text": "ジャンプとかですか?"
    },
    {
      "start": 722.639,
      "duration": 1.88,
      "text": "いえい。[笑い]"
    },
    {
      "start": 723.44,
      "duration": 3.0,
      "text": "漫画。"
    },
    {
      "start": 724.519,
      "duration": 3.194,
      "text": "漫画すごい。"
    },
    {
      "start": 726.44,
      "duration": 3.16,
      "text": "いや、だったら人安心ですけど。なんか新金感あるわてあるけど。"
    },
    {
      "start": 727.713,
      "duration": 2.407,
      "text": "[笑い]"
    },
    {
      "start": 729.6,
      "duration": 3.52,
      "text": "はい。"
    },
    {
      "start": 730.12,
      "duration": 3.0,
      "text": "読んでまたこうちょっと頭リフレッシュしてインプットして"
    },
    {
      "start": 734.92,
      "duration": 2.359,
      "text": "うん。"
    },
    {
      "start": 735.56,
      "duration": 2.44,
      "text": "午後の仕事に向かう。うん。です。"
    },
    {
      "start": 737.279,
      "duration": 2.961,
      "text": "へえ。"
    },
    {
      "start": 738.0,
      "duration": 3.72,
      "text": "ああ、そういうことか。"
    },
    {
      "start": 740.24,
      "duration": 3.193,
      "text": "すごいな。"
    },
    {
      "start": 741.72,
      "duration": 2.239,
      "text": "いや、何にも参考になんないわ。"
    },
    {
      "start": 743.433,
      "duration": 1.007,
      "text": "[笑い]"
    },
    {
      "start": 743.959,
      "duration": 3.081,
      "text": "うん。"
    },
    {
      "start": 744.44,
      "duration": 3.92,
      "text": "いやいや、参加すればいいじゃん。朝から。"
    },
    {
      "start": 747.04,
      "duration": 4.32,
      "text": "朝が。[笑い]"
    },
    {
      "start": 748.36,
      "duration": 3.0,
      "text": "あ、でも確かに共通してるのはあれですよね。不裕送の方々みんなおっしゃるけどとにかく早く起きてまずインプット体は動かす。だからもう朝のうちに大事なことはやっておこうっていうことですよね。"
    },
    {
      "start": 761.76,
      "duration": 3.0,
      "text": "本ん当そうです。朝しか頭かないなと思ってまして。"
    },
    {
      "start": 764.88,
      "duration": 4.8,
      "text": "ああ。え。"
    },
    {
      "start": 766.68,
      "duration": 3.0,
      "text": "共通で日本の動産ていうのは今どう見てるんですか?相当上がりしてると思うんですけども。"
    },
    {
      "start": 772.6,
      "duration": 3.0,
      "text": "うん。あの、値上がりしてるかどうかっていうのって過去と比べちゃいけないんですよ。"
    },
    {
      "start": 777.079,
      "duration": 2.361,
      "text": "あ、そっか。"
    },
    {
      "start": 777.92,
      "duration": 2.159,
      "text": "他の年と比べるんですよ。"
    },
    {
      "start": 779.44,
      "duration": 1.6,
      "text": "へえ。"
    },
    {
      "start": 780.079,
      "duration": 2.641,
      "text": "ああ。"
    },
    {
      "start": 781.04,
      "duration": 2.52,
      "text": "他の都と比べるんだ。"
    },
    {
      "start": 782.72,
      "duration": 3.2,
      "text": "そうなんだ。"
    },
    {
      "start": 783.56,
      "duration": 2.639,
      "text": "今の価格で他の年がどうなってるか。"
    },
    {
      "start": 785.92,
      "duration": 2.68,
      "text": "はい。"
    },
    {
      "start": 786.199,
      "duration": 3.281,
      "text": "え、他の年と比べたらや、まだった。"
    },
    {
      "start": 788.6,
      "duration": 2.16,
      "text": "安い。安い。"
    },
    {
      "start": 789.48,
      "duration": 3.64,
      "text": "まだ安いですね。"
    },
    {
      "start": 790.76,
      "duration": 4.36,
      "text": "まだ安いですか?リアルにこ時点でも。"
    },
    {
      "start": 793.12,
      "duration": 2.959,
      "text": "うん。まだ割り安だと思います。"
    },
    {
      "start": 795.12,
      "duration": 3.959,
      "text": "ああ。"
    },
    {
      "start": 796.079,
      "duration": 3.0,
      "text": "もあるけどね、ちょっとはい。あの、全体で見ればまだ安い。うん。安いですね。その基本的には不動産も株も資本主義っていう仕組みの中で上がるんですよ。"
    },
    {
      "start": 806.32,
      "duration": 2.4,
      "text": "ああ、"
    },
    {
      "start": 807.12,
      "duration": 4.6,
      "text": "長期で見ると"
    },
    {
      "start": 808.72,
      "duration": 3.0,
      "text": "なのでこれは絶対に持っておかなきゃいけないエクスポージャーなんですね。"
    },
    {
      "start": 812.88,
      "duration": 3.48,
      "text": "人生において。"
    },
    {
      "start": 814.199,
      "duration": 3.361,
      "text": "だからやってないっていうこと自体がありえない。"
    },
    {
      "start": 816.36,
      "duration": 2.479,
      "text": "はあ。"
    },
    {
      "start": 817.56,
      "duration": 2.16,
      "text": "買った時点で勝ち。"
    },
    {
      "start": 818.839,
      "duration": 2.68,
      "text": "はい。"
    },
    {
      "start": 819.72,
      "duration": 3.624,
      "text": "ああ。だから買った方がいいんだね。"
    },
    {
      "start": 821.519,
      "duration": 5.241,
      "text": "そうなんだ。"
    },
    {
      "start": 823.344,
      "duration": 3.416,
      "text": "[音楽]heヘ"
    },
    {
      "start": 829.894,
      "duration": 2.02,
      "text": "[音楽]"
    },
    {
      "start": 841.44,
      "duration": 2.92,
      "text": "あ。"
    }
  ]
}