    {
      "start": 719.16,
      "duration": 6.16,
      "text": "は動いていないということをですね、考え"
    },
    {
      "start": 721.6,
      "duration": 5.84,
      "text": "ていく必要があります。では長期の話で"
    },
    {
      "start": 725.32,
      "duration": 6.6,
      "text": "いきますと、中央銀行なんですね。え、"
    },
    {
      "start": 727.44,
      "duration": 7.0,
      "text": "こちらにつきましてはあの2010年以降"
    },
    {
      "start": 731.92,
      "duration": 5.279,
      "text": "ずっと毎年ですね、え、買越しが続いて"
    },
    {
      "start": 734.44,
      "duration": 6.88,
      "text": "いるんですね。買しにつきましては全体と"
