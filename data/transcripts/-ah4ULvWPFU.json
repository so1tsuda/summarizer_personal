    {
      "start": 881.56,
      "duration": 7.199,
      "text": "が大きく増えてきていまして世界全体の"
    },
    {
      "start": 884.56,
      "duration": 6.199,
      "text": "地球温暖化対策ESGえ等のですね考え方"
    },
    {
      "start": 888.759,
      "duration": 5.601,
      "text": "がどんどんと世界に広まっていけばいく"
    },
    {
      "start": 890.759,
      "duration": 6.481,
      "text": "ほどですねえの需要が増えていって需要が"
