      "start": 764.0,
      "duration": 6.6,
      "text": "今回13月は102月期にあった米国政府"
    },
    {
      "start": 767.8,
      "duration": 6.24,
      "text": "機関の閉鎖の影響とというのが、ま、解消"
    },
    {
      "start": 770.6,
      "duration": 6.28,
      "text": "されることで1.2%成長と、ま、10、"
    },
    {
      "start": 774.04,
      "duration": 5.12,
      "text": "12月からや成長が加速すると見込まれて"
    },
    {
      "start": 776.88,
      "duration": 4.56,
      "text": "いますが、え、原油価格の高等の影響で"
    },
    {
      "start": 779.16,
      "duration": 4.44,
      "text": "ですね、え、育分の悪影響が出始めている"
    },
    {
      "start": 781.44,
      "duration": 3.959,
      "text": "のかどうか、ま、この辺りは中視する必要"
    },
    {
      "start": 783.6,
      "duration": 4.56,
      "text": "があると見ています。ま、ということで、"
    },
    {
      "start": 785.399,
      "duration": 6.361,
      "text": "え、マーケット1段の上昇に向けては、ま"
    },
    {
      "start": 788.16,
      "duration": 6.239,
      "text": "、大手ハテ企業の高決算待ち、ま、少なく"
    },
    {
      "start": 791.76,
      "duration": 4.879,
      "text": "ともここ最近これらの企業軍というのは"
    },
    {
      "start": 794.399,
      "duration": 4.761,
      "text": "あまり株価が上昇していませんでしたので"
    },
    {
      "start": 796.639,
      "duration": 4.64,
      "text": "、その意味ではハードルは必ずしも高く"
    },
    {
      "start": 799.16,
      "duration": 4.44,
      "text": "ないかもしれません。え、ポジティブ目の"
    },
    {
      "start": 801.279,
      "duration": 4.881,
      "text": "サプライズがあれば、え、指数は1段高"
    },
    {
      "start": 803.6,
      "duration": 5.599,
      "text": "期待できる一方で、え、決算内容が想定"
    },
    {
      "start": 806.16,
      "duration": 5.359,
      "text": "ラインにとまった場合、または30日発表"
    },
    {
      "start": 809.199,
      "duration": 5.0,
      "text": "のGDPに原則の気兆しが出たり、え、"
    },
    {
      "start": 811.519,
      "duration": 6.521,
      "text": "また同じく30日に発表される米国の個人"
    },
    {
      "start": 814.199,
      "duration": 6.44,
      "text": "消費支出の原則や個人消費支出物価指数に"
    },
    {
      "start": 818.04,
      "duration": 5.52,
      "text": "おける物価の上昇圧力、ま、こうしたもの"
    },
    {
      "start": 820.639,
      "duration": 4.921,
      "text": "が確認された場合には、え、一旦の調整"
    },
    {
      "start": 823.56,
      "duration": 4.079,
      "text": "含みとなる可能性はありますので、え、"
    },
    {
      "start": 825.56,
      "duration": 5.16,
      "text": "その場合は、え、3度P500で、え、"
    },
    {
      "start": 827.639,
      "duration": 5.521,
      "text": "複数の移動平均線が収束する6800前後"
    },
    {
      "start": 830.72,
      "duration": 4.6,
      "text": "まで調整する可能性は頭に置いていく必要"
    },
    {
      "start": 833.16,
      "duration": 4.039,
      "text": "があると見ています。え、それでは私の方"
    },
    {
      "start": 835.32,
      "duration": 3.439,
      "text": "からは以上となります。動画の方気に入っ"
    },
    {
      "start": 837.199,
      "duration": 3.401,
      "text": "ていただけましたら高評価のいいね、"
    },
    {
      "start": 838.759,
      "duration": 6.481,
      "text": "そしてチャンネル登録をよろしくお願い"
    },
    {
      "start": 840.6,
      "duration": 4.64,
      "text": "いたします。それでは失礼いたします。"
    }
  ]
}