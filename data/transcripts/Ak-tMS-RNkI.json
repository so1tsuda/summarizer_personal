    {
      "start": 536.959,
      "duration": 5.201,
      "text": "動きが付いてるのかなという感じがしてい"
    },
    {
      "start": 539.839,
      "duration": 4.56,
      "text": "ます。"
    },
    {
      "start": 542.16,
      "duration": 5.72,
      "text": "で、アメリカのマーケットなんですけども"
    },
    {
      "start": 544.399,
      "duration": 5.521,
      "text": "、こちら"
    },
    {
      "start": 547.88,
      "duration": 5.199,
      "text": "ね、ダウダウはプラスだとニューヨーク"
    },
    {
      "start": 549.92,
      "duration": 6.039,
      "text": "ダウの方はアメリカ入った反動体関連は"
    },
    {
      "start": 553.079,
      "duration": 8.081,
      "text": "下がったんですけど、それ以外の生活必需"
    },
    {
      "start": 555.959,
      "duration": 7.12,
      "text": "品だとか、あ、素材だとか、あ、反転する"
    },
    {
      "start": 561.16,
      "duration": 3.679,
      "text": "業種も多かったんですね。反動体以外の"
    },
    {
      "start": 563.079,
      "duration": 3.721,
      "text": "ところでは。ま、そういったこともあって"
    },
    {
      "start": 564.839,
      "duration": 5.481,
      "text": "、若干"
    },
    {
      "start": 566.8,
      "duration": 7.52,
      "text": "ではあるんですが、ま、昨日昨いと株"
    },
    {
      "start": 570.32,
      "duration": 6.44,
      "text": "大きく下げたところで、ま、少しこういっ"
    },
    {
      "start": 574.32,
      "duration": 6.56,
      "text": "た買入ってきたのかなぐらいな感じはして"
    },
    {
      "start": 576.76,
      "duration": 8.28,
      "text": "います。そしてナスダック0.73%安と"
    },
    {
      "start": 580.88,
      "duration": 7.36,
      "text": "いうことでね、ここ連日続落というところ"
    },
    {
      "start": 585.04,
      "duration": 6.64,
      "text": "で安値をつけてきています。"
    },
    {
      "start": 588.24,
      "duration": 7.92,
      "text": "SP500もマイナスということで戻りの"
    },
    {
      "start": 591.68,
      "duration": 6.32,
      "text": "安値というところをつけてきています。"
    },
    {
      "start": 596.16,
      "duration": 4.6,
      "text": "ま、年所安値を更新してい"
    },
    {
      "start": 598.0,
      "duration": 6.079,
      "text": "るっていうことですね。"
    },
    {
      "start": 600.76,
      "duration": 6.4,
      "text": "そして、え、さっき言ったアメリカの方で"
    },
    {
      "start": 604.079,
      "duration": 5.121,
      "text": "ね、WTI原油なんですけど、終わりで"
    },
    {
      "start": 607.16,
      "duration": 6.239,
      "text": "102.85ドル"
    },
    {
      "start": 609.2,
      "duration": 7.8,
      "text": "とね、102.88ドルというとこで3%"
    },
    {
      "start": 613.399,
      "duration": 6.88,
      "text": "上がって初めてですよね。ケネベースでの"
    },
    {
      "start": 617.0,
      "duration": 5.36,
      "text": "アメリカ時間での100ドル超えと、ま、"
    },
    {
      "start": 620.279,
      "duration": 4.761,
      "text": "日本時間ちょこちょっとね、あの、さっき"
    },
    {
      "start": 622.36,
      "duration": 5.36,
      "text": "のトランプさんの話で、え、原価格も"
    },
    {
      "start": 625.04,
      "duration": 5.76,
      "text": "下がったりもしたようなんですが、ま、"
    },
    {
      "start": 627.72,
      "duration": 6.359,
      "text": "まだまだ、あ、戦争に対してですね、え、"
    },
    {
      "start": 630.8,
      "duration": 5.36,
      "text": "不安な心理もたくさんあるんだなという風"
    },
    {
      "start": 634.079,
      "duration": 5.081,
      "text": "に感じます。"
    },
    {
      "start": 636.16,
      "duration": 3.0,
      "text": "そして、ま、先ほどお話したように"
    },
    {
      "start": 639.959,
      "duration": 3.481,
      "text": "FRB"
    },
    {
      "start": 640.44,
      "duration": 3.0,
      "text": "議長の公演の中で、まあね、え、戦争でインフレが進むんじゃないかね、ヨーロッパみたいに利上げするんじゃないかという見方もある中で、そういったことに対しては極的な感じだったということで金利は一気に下がったということで、ま、一気に下がったもね、随分こんとこ高くなってたのがちょっと落ち着いた水準というような感じかなと思い"
    },
    {
      "start": 667.48,
      "duration": 3.0,
      "text": "で、こちらはソック指数、フィラデルフィア反動体質数なんですが、"
    },
    {
      "start": 672.16,
      "duration": 4.16,
      "text": "4.2%"
    },
    {
      "start": 673.32,
      "duration": 3.0,
      "text": "下がって、え、こちらもね、え、比較的しっかりしたんですけど、ま、安値をつけてきました。"
    },
    {
      "start": 682.519,
      "duration": 3.44,
      "text": "で、え、個別の方を見ていきたいと思うん"
    },
    {
      "start": 684.399,
      "duration": 4.24,
      "text": "ですが、アメリカのマイクロン"
    },
    {
      "start": 685.959,
      "duration": 6.44,
      "text": "テクノロジーね、ここ毎回お話してます"
    },
    {
      "start": 688.639,
      "duration": 7.961,
      "text": "けど、この3月18日に決算発表して、"
    },
    {
      "start": 692.399,
      "duration": 7.44,
      "text": "非常にいい決算内容だったんですが、"
    },
    {
      "start": 696.6,
      "duration": 6.08,
      "text": "え、月ベースで言うと伸びがいまいだった"
    },
    {
      "start": 699.839,
      "duration": 6.201,
      "text": "。あの、前年同期じゃなくて前月費って"
    },
    {
      "start": 702.68,
      "duration": 5.839,
      "text": "いうことですよね。前期費、全市販期って"
    },
    {
      "start": 706.04,
      "duration": 5.239,
      "text": "いうことで言うと、ま、伸びがいまいだっ"
    },
    {
      "start": 708.519,
      "duration": 5.12,
      "text": "たという見方もあったようなんですが、"
    },
    {
      "start": 711.279,
      "duration": 6.721,
      "text": "ずっとこっから下がってきて、昨日は"
    },
    {
      "start": 713.639,
      "duration": 7.481,
      "text": "10%近く下げたということで、ま、最後"
    },
    {
      "start": 718.0,
      "duration": 6.16,
      "text": "の最後までね、買われてたセクターついに"
    },
    {
      "start": 721.12,
      "duration": 5.32,
      "text": "ちょっとこれもおかしいぞと安いとこで"
    },
    {
      "start": 724.16,
      "duration": 4.88,
      "text": "買う、買いたいっていうんではなくてです"
    },
    {
      "start": 726.44,
      "duration": 5.48,
      "text": "ね、ついに逃げ出し売りが出てきたそんな"
    },
    {
      "start": 729.04,
      "duration": 9.08,
      "text": "動きのようにも見えます。ウエスタン"
    },
    {
      "start": 731.92,
      "duration": 8.52,
      "text": "デジタルも7%安。そして、えね、記憶者"
    },
    {
      "start": 738.12,
      "duration": 7.64,
      "text": "と日本で協業してる3ディスク、こちらも"
    },
    {
      "start": 740.44,
      "duration": 8.199,
      "text": "7%安ということで、え、いよいよおね、"
    },
    {
      "start": 745.76,
      "duration": 6.319,
      "text": "唯一に近いぐらいの強いセクターも安く"
    },
    {
      "start": 748.639,
      "duration": 7.56,
      "text": "なってきたと。そしてコーニング。こちら"
    },
    {
      "start": 752.079,
      "duration": 7.641,
      "text": "は光イバーの会社。光ファイバーの企業な"
    },
    {
      "start": 756.199,
      "duration": 5.521,
      "text": "んですけど6%安ということでこれもね"
    },
    {
      "start": 759.72,
      "duration": 5.16,
      "text": "直近"
    },
    {
      "start": 761.72,
      "duration": 7.08,
      "text": "あの今言った反動体製造だったりメモリー"
    },
    {
      "start": 764.88,
      "duration": 6.68,
      "text": "よりも強かったんですよね。直近のでもね"
    },
    {
      "start": 768.8,
      "duration": 6.92,
      "text": "高値を取ることができないで結局下がって"
    },
    {
      "start": 771.56,
      "duration": 9.24,
      "text": "は6%安ということでした。ま、この流れ"
    },
    {
      "start": 775.72,
      "duration": 7.679,
      "text": "を受けて日本市場も朝から安くなったと。"
    },
    {
      "start": 780.8,
      "duration": 6.279,
      "text": "一方でアメリカの使用で比較的強かったの"
    },
    {
      "start": 783.399,
      "duration": 6.161,
      "text": "はこういったあ、"
    },
    {
      "start": 787.079,
      "duration": 5.841,
      "text": "ウォールマートだったりですね。チャート"
    },
    {
      "start": 789.56,
      "duration": 5.399,
      "text": "もそんなに崩れてないですよね。ま、安、"
    },
    {
      "start": 792.92,
      "duration": 6.56,
      "text": "高値から安くなってますけども、こういっ"
    },
    {
      "start": 794.959,
      "duration": 6.201,
      "text": "た生活品、コストコホールディングスなん"
    },
    {
      "start": 799.48,
      "duration": 5.32,
      "text": "かも"
    },
    {
      "start": 801.16,
      "duration": 6.6,
      "text": "ね、昨日は1.2%上がってるという"
    },
    {
      "start": 804.8,
      "duration": 5.839,
      "text": "ところでね、え、ちょっとこう物価も"
    },
    {
      "start": 807.76,
      "duration": 6.0,
      "text": "上がってきて、え、少し節約しようかな"
    },
    {
      "start": 810.639,
      "duration": 6.081,
      "text": "みたいな動きも出ているのかもしれません"
    },
    {
      "start": 813.76,
      "duration": 5.04,
      "text": "。"
    },
    {
      "start": 816.72,
      "duration": 4.799,
      "text": "ま、そういった動きの中で日本でも反動体"
    },
    {
      "start": 818.8,
      "duration": 6.76,
      "text": "関連株は下がりました。あ、記憶者"
    },
    {
      "start": 821.519,
      "duration": 7.041,
      "text": "4.7%安いところで、え、ね、これが"
    },
    {
      "start": 825.56,
      "duration": 7.0,
      "text": "日本の株を牽引してたんですけども、ここ"
    },
    {
      "start": 828.56,
      "duration": 8.079,
      "text": "んところは要線ではあるんですけど、続落"
    },
    {
      "start": 832.56,
      "duration": 7.519,
      "text": "ということですね。そしてソフトバンク"
    },
    {
      "start": 836.639,
      "duration": 6.481,
      "text": "グループ、え、先日アームの決算の時ね、"
    },
    {
      "start": 840.079,
      "duration": 5.481,
      "text": "こうやって買われたんですけど、アームも"
    },
    {
      "start": 843.12,
      "duration": 4.399,
      "text": "確か16%ぐらい上がったんですかね。"
    },
    {
      "start": 845.56,
      "duration": 5.76,
      "text": "ですけど、今行ってこいの水準に戻ってき"
    },
    {
      "start": 847.519,
      "duration": 7.041,
      "text": "てしまったということで、まあ、ソフト"
    },
    {
      "start": 851.32,
      "duration": 6.36,
      "text": "バンクグループも行ってこいの動き。"
    },
    {
      "start": 854.56,
      "duration": 6.04,
      "text": "え、エレクトロンも4%安、"
    },
    {
      "start": 857.68,
      "duration": 7.48,
      "text": "アドバンテストも2.8%"
    },
    {
      "start": 860.6,
      "duration": 7.52,
      "text": "安、レーザーテックも5.5%安という"
    },
    {
      "start": 865.16,
      "duration": 5.76,
      "text": "とこで、ま、チャート的にね、あの、他の"
    },
    {
      "start": 868.12,
      "duration": 5.36,
      "text": "銘柄に比べるとまだ下げ幅は小さいように"
    },
    {
      "start": 870.92,
      "duration": 4.88,
      "text": "も見えるんですが、"
    },
    {
      "start": 873.48,
      "duration": 5.84,
      "text": "いよいよこういった最後の砦出みたいな"
    },
    {
      "start": 875.8,
      "duration": 7.76,
      "text": "感じで買われてた反動体も下がってきた。"
    },
    {
      "start": 879.32,
      "duration": 8.16,
      "text": "そして、え、コーニングが売られて藤倉。"
    },
    {
      "start": 883.56,
      "duration": 6.0,
      "text": "これも90%近い下げ"
    },
    {
      "start": 887.48,
      "duration": 5.08,
      "text": "フルカー電も7%"
    },
    {
      "start": 889.56,
      "duration": 3.0,
      "text": "ぐらい下げて、ま、これがでもハンド体以上にね、直近強かったのはこのデータセンター関連電線株ですよね。だったんですけど、ちょっと下がってきましたよ。"
    },
    {
      "start": 903.959,
      "duration": 3.0,
      "text": "ま、値動きが大きいのでなかなか"
    },
    {
      "start": 908.68,
      "duration": 4.079,
      "text": "ね、7%"
    },
    {
      "start": 909.759,
      "duration": 3.0,
      "text": "下がったつってもなんか高機のがそんなに大きく動いてる感じもしないんですけどどうなんでしょう?わやとちょっとこの辺にもメスが入ってきたつったら変なんですけど、そんな感じの動きに見えます。あと一方で強いセクターは東京会場ホールディングスですね。"
    },
    {
      "start": 928.319,
      "duration": 6.08,
      "text": "保険今日業種別で、え、上がったん業種"
    },
    {
      "start": 932.639,
      "duration": 5.721,
      "text": "ってのもいくつかあるんですけど、ま、"
    },
    {
      "start": 934.399,
      "duration": 6.0,
      "text": "東京会場保険も上位に入ってましたとは"
    },
    {
      "start": 938.36,
      "duration": 4.599,
      "text": "言っても高期なんですが、東京会場"
    },
    {
      "start": 940.399,
      "duration": 6.0,
      "text": "ホールディング先日バークハザードウェ、"
    },
    {
      "start": 942.959,
      "duration": 5.961,
      "text": "え、この会社がファッション業務提したと"
    },
    {
      "start": 946.399,
      "duration": 4.761,
      "text": "いうことでストップ高して買われたんです"
    },
    {
      "start": 948.92,
      "duration": 7.12,
      "text": "けど、ま、ちょっとその後はね、下がって"
    },
    {
      "start": 951.16,
      "duration": 8.359,
      "text": "たんですが、やはりね、え、前例照者の件"
    },
    {
      "start": 956.04,
      "duration": 6.599,
      "text": "もあるということで、え、下値では買が"
    },
    {
      "start": 959.519,
      "duration": 7.12,
      "text": "入ってきていると。そして勝者のように"
    },
    {
      "start": 962.639,
      "duration": 6.56,
      "text": "幅広い銘柄にも買が入ねえ、同じ保険、ま"
    },
    {
      "start": 966.639,
      "duration": 6.041,
      "text": "、こちらは正保、さっきの東京会場は倉保"
    },
    {
      "start": 969.199,
      "duration": 5.521,
      "text": "ですけど、ま、そういった、あ、他の会社"
    },
    {
      "start": 972.68,
      "duration": 5.959,
      "text": "にも入ってくるんじゃないかということで"
    },
    {
      "start": 974.72,
      "duration": 7.4,
      "text": "第1生命なんかも1%上がってました。ま"
    },
    {
      "start": 978.639,
      "duration": 6.68,
      "text": "、MS&ADなんかね、え、損害保険の別"
    },
    {
      "start": 982.12,
      "duration": 5.56,
      "text": "の会社なんかもプラスでしたので、ま、"
    },
    {
      "start": 985.319,
      "duration": 5.2,
      "text": "今日800円下がって安い中では比較的"
    },
    {
      "start": 987.68,
      "duration": 5.0,
      "text": "強いかなという動きだったかなと思います"
    },
    {
      "start": 990.519,
      "duration": 4.8,
      "text": "。"
    },
    {
      "start": 992.68,
      "duration": 6.12,
      "text": "あと一貫して強いのはこのJSBですよね"
    },
    {
      "start": 995.319,
      "duration": 5.96,
      "text": "。え、ここんとこ毎回お話ししてるんです"
    },
    {
      "start": 998.8,
      "duration": 5.479,
      "text": "けど、学生量の会社です。"
    },
    {
      "start": 1001.279,
      "duration": 3.0,
      "text": "え、これストップ高して、次の日も寄りついてからストップ高して押しをつけることなく、今日また電車高値を取ってきたということなんですけど"
    },
    {
      "start": 1012.839,
      "duration": 3.0,
      "text": "ね、あの、どっかで材料が判明するんじゃないかっていう話はしてきたんですけど、今んとこ材料は特にないというところです。ま、この後出てくるかもしれませんけどね、こういった相場の中でちょっと遺を放ってるなという感じはしますね。"
    },
    {
      "start": 1029.76,
      "duration": 3.0,
      "text": "ちょっと調整も長かったんでどっかでこうシグナルみたいなのも出てきて、え、そん時は動きも大きくなるかなという風にも見てたんですけど、何の材料も今んとこ在化してない、え、強い株の動きですね。"
    },
    {
      "start": 1046.52,
      "duration": 3.0,
      "text": "あと下げてた株の中でもちょっとこう戻してきてる株がありましたね。"
    },
    {
      "start": 1051.4,
      "duration": 5.76,
      "text": "今日プラスなった株があってNEC"
    },
    {
      "start": 1053.559,
      "duration": 6.921,
      "text": "1.5%だ。ま、チャート見るとトレンド"
    },
    {
      "start": 1057.16,
      "duration": 5.84,
      "text": "が変わったというところまではいかないと"
    },
    {
      "start": 1060.48,
      "duration": 5.76,
      "text": "いうか全くいかないんですけど今日はこう"
    },
    {
      "start": 1063.0,
      "duration": 8.6,
      "text": "いった株いくつか上がってまして富士通も"
    },
    {
      "start": 1066.24,
      "duration": 9.12,
      "text": "1.63%や。あ、1.63%だか。え、"
    },
    {
      "start": 1071.6,
      "duration": 8.8,
      "text": "OLCオリエンタルランドも2.36%だ"
    },
    {
      "start": 1075.36,
      "duration": 5.36,
      "text": "というところで、え、ね、3月"
    },
    {
      "start": 1080.4,
      "duration": 3.32,
      "text": "はい。"
    },
    {
      "start": 1080.72,
      "duration": 3.0,
      "text": "優取りなんかでもあんまり盛り上がんなかった感じはするんですけど、ましね、そのまま"
    },
    {
      "start": 1087.159,
      "duration": 3.201,
      "text": "3"
    },
    {
      "start": 1087.36,
      "duration": 3.0,
      "text": "月相場が終わって今日を終わってか今日までだったんですけど、今日は"
    },
    {
      "start": 1092.52,
      "duration": 6.76,
      "text": "2.3%上昇しました。"
    },
    {
      "start": 1096.48,
      "duration": 7.36,
      "text": "そして下がった銘柄の方で言うと反動体"
    },
    {
      "start": 1099.28,
      "duration": 7.759,
      "text": "以外で言うと今日は三菱重事"
    },
    {
      "start": 1103.84,
      "duration": 7.959,
      "text": "えっと防衛関連が下がってましたね"
    },
    {
      "start": 1107.039,
      "duration": 8.0,
      "text": "数まさっきのねトランプさんが戦争を集結"
    },
    {
      "start": 1111.799,
      "duration": 7.281,
      "text": "する用意があるということもあったのかも"
    },
    {
      "start": 1115.039,
      "duration": 7.401,
      "text": "しれませんね。一方で、え、ね、え、多く"
    },
    {
      "start": 1119.08,
      "duration": 5.36,
      "text": "の軍人を中東に向かわしてるという報道も"
    },
    {
      "start": 1122.44,
      "duration": 5.64,
      "text": "あるんで、この先の見通しっていうのは"
    },
    {
      "start": 1124.44,
      "duration": 8.239,
      "text": "分かりづらいんですが、それでも随分相場"
    },
    {
      "start": 1128.08,
      "duration": 10.64,
      "text": "作った重厚ですね。こちらの方も4%安、"
    },
    {
      "start": 1132.679,
      "duration": 9.12,
      "text": "IHは5%安ということです。あと"
    },
    {
      "start": 1138.72,
      "duration": 5.8,
      "text": "全線株と同じ秘鉄グループに入るところも"
    },
    {
      "start": 1141.799,
      "duration": 5.36,
      "text": "安い銘柄が"
    },
    {
      "start": 1144.52,
      "duration": 6.12,
      "text": "多かったかなと思いますね。ま、否鉄関連"
    },
    {
      "start": 1147.159,
      "duration": 6.681,
      "text": "がこう今年入ってから相は引っ張ってたと"
    },
    {
      "start": 1150.64,
      "duration": 5.6,
      "text": "いうところで、ま、この辺も電線カ保と"
    },
    {
      "start": 1153.84,
      "duration": 6.56,
      "text": "同じようについに売りが出てきたのかなと"
    },
    {
      "start": 1156.24,
      "duration": 8.84,
      "text": "いうところで、え、三井金属5%安、住友"
    },
    {
      "start": 1160.4,
      "duration": 8.279,
      "text": "金属4.27%安というところで、これで"
    },
    {
      "start": 1165.08,
      "duration": 6.0,
      "text": "ほぼほぼ全ての業種が売られたという"
    },
    {
      "start": 1168.679,
      "duration": 5.561,
      "text": "ところです。"
    },
    {
      "start": 1171.08,
      "duration": 5.04,
      "text": "日本の方はまだ投げ出し売りとは言わない"
    },
    {
      "start": 1174.24,
      "duration": 4.36,
      "text": "のかもしれませんね。スタンでは買って"
    },
    {
      "start": 1176.12,
      "duration": 7.36,
      "text": "くるんで、え、先ほど日で見てもらった"
    },
    {
      "start": 1178.6,
      "duration": 7.64,
      "text": "ようにちょっとこう下ひのつける下げた日"
    },
    {
      "start": 1183.48,
      "duration": 6.52,
      "text": "は下ひをつけるよう下髭をつける日が多い"
    },
    {
      "start": 1186.24,
      "duration": 6.0,
      "text": "ということもあるんですが、ま、でも今で"
    },
    {
      "start": 1190.0,
      "duration": 4.039,
      "text": "強かったところもついに売りが出てきまし"
    },
    {
      "start": 1192.24,
      "duration": 4.12,
      "text": "た。"
    },
    {
      "start": 1194.039,
      "duration": 7.081,
      "text": "で、え、日本以上に強かった韓国も今日は"
    },
    {
      "start": 1196.36,
      "duration": 7.64,
      "text": "4%下げてますね。4.2%安数。え、"
    },
    {
      "start": 1201.12,
      "duration": 7.679,
      "text": "メモリーの採用艇、え、SKハイニックス"
    },
    {
      "start": 1204.0,
      "duration": 9.64,
      "text": "も7.5%安いところで、え、下がってき"
    },
    {
      "start": 1208.799,
      "duration": 6.641,
      "text": "たということです。一応"
    },
    {
      "start": 1213.64,
      "duration": 4.36,
      "text": "終わり値ベースじゃないんですけど、高値"
    },
    {
      "start": 1215.44,
      "duration": 8.16,
      "text": "と安値、直近の高値でと安値を見るとダブ"
    },
    {
      "start": 1218.0,
      "duration": 8.24,
      "text": "が10.5%安、え、Nスダックが、あ、"
    },
    {
      "start": 1223.6,
      "duration": 5.6,
      "text": "13%、1313.7%"
    },
    {
      "start": 1226.24,
      "duration": 5.0,
      "text": "安ですね。SP500は9.8。ま、ほぼ"
    },
    {
      "start": 1229.2,
      "duration": 6.68,
      "text": "ほぼ10%ぐらいアメリカも下がってき"
    },
    {
      "start": 1231.24,
      "duration": 7.84,
      "text": "ました。え、日経平均は13.4%"
    },
    {
      "start": 1235.88,
      "duration": 6.48,
      "text": "。トピックスも11.5。お、そしてこの"
    },
    {
      "start": 1239.08,
      "duration": 6.32,
      "text": "韓国も20%下がってきたということで、"
    },
    {
      "start": 1242.36,
      "duration": 5.559,
      "text": "ま、チャート的にはあ、一旦いいところ"
    },
    {
      "start": 1245.4,
      "duration": 6.44,
      "text": "まで下がってきたようにも見えますし、"
    },
    {
      "start": 1247.919,
      "duration": 7.561,
      "text": "こちらね、以前見てもらった恐怖と貪欲室"
    },
    {
      "start": 1251.84,
      "duration": 7.079,
      "text": "1桁に入ってきました。まあ、過去の経験"
    },
    {
      "start": 1255.48,
      "duration": 7.079,
      "text": "則言うと1桁で、え、下がってきたところ"
    },
    {
      "start": 1258.919,
      "duration": 6.0,
      "text": "で買えば後でね、え、指数、指数ですけど"
    },
    {
      "start": 1262.559,
      "duration": 5.041,
      "text": "ね、個別株はいろんな動きがあるんで、え"
    },
    {
      "start": 1264.919,
      "duration": 6.281,
      "text": "、儲かることが多いということなんですが"
    },
    {
      "start": 1267.6,
      "duration": 6.24,
      "text": "、この1桁を数日続けることもあるんです"
    },
    {
      "start": 1271.2,
      "duration": 6.24,
      "text": "よね。ですから、ま、どうなんでしょう?"
    },
    {
      "start": 1273.84,
      "duration": 6.319,
      "text": "それでもね、株価水準的には戦争の流れ"
    },
    {
      "start": 1277.44,
      "duration": 6.04,
      "text": "云々っていうのは分からないですけども、"
    },
    {
      "start": 1280.159,
      "duration": 6.0,
      "text": "お、ここまでの株価の動きとしては一旦"
    },
    {
      "start": 1283.48,
      "duration": 6.84,
      "text": "いい水準まで下がってきたということも"
    },
    {
      "start": 1286.159,
      "duration": 7.12,
      "text": "言えるのかなと思ってます。え、ま、今お"
    },
    {
      "start": 1290.32,
      "duration": 5.04,
      "text": "話したようにですね、え、うん、なんつう"
    },
    {
      "start": 1293.279,
      "duration": 5.361,
      "text": "んですかね、テクニカル的には水準的に"
    },
    {
      "start": 1295.36,
      "duration": 7.88,
      "text": "いいところ株価一通りの銘柄が下がりまし"
    },
    {
      "start": 1298.64,
      "duration": 7.56,
      "text": "た。え、強かった日本株や韓国株も下がっ"
    },
    {
      "start": 1303.24,
      "duration": 5.679,
      "text": "てきたと。え、日柄的にはいいところなん"
    },
    {
      "start": 1306.2,
      "duration": 5.8,
      "text": "ですけど、戦争の行はどうなんだという"
    },
    {
      "start": 1308.919,
      "duration": 5.88,
      "text": "ところなので、ま、打信外も含めながらで"
    },
    {
      "start": 1312.0,
      "duration": 5.64,
      "text": "も慎重に見ていきたいそんな相場なのかな"
    },
    {
      "start": 1314.799,
      "duration": 6.12,
      "text": "と思っております。"
    },
    {
      "start": 1317.64,
      "duration": 5.68,
      "text": "え、本日の式放送は以上です。本日もご"
    },
    {
      "start": 1320.919,
      "duration": 6.801,
      "text": "視聴ありがとうございました。ついに"
    },
    {
      "start": 1323.32,
      "duration": 7.92,
      "text": "ついに本物の朝倉系のLINEを作りまし"
    },
    {
      "start": 1327.72,
      "duration": 6.559,
      "text": "。作りましたからね。ここではうちからの"
    },
    {
      "start": 1331.24,
      "duration": 4.88,
      "text": "ね、この1ね、レポートですよと、"
    },
    {
      "start": 1334.279,
      "duration": 3.961,
      "text": "セミナーですよとか、それからモーニング"
    },
    {
      "start": 1336.12,
      "duration": 4.64,
      "text": "ニュースですよとね、そういったことを"
    },
    {
      "start": 1338.24,
      "duration": 4.6,
      "text": "CDですよというニュースを送らせて"
    },
    {
      "start": 1340.76,
      "duration": 5.36,
      "text": "いただきますので、それを参考にしてです"
    },
    {
      "start": 1342.84,
      "duration": 6.12,
      "text": "ね、申し込んでみてくださいね。世界経済"
    },
    {
      "start": 1346.12,
      "duration": 5.2,
      "text": "の裏を知る、真実を知"
    },
    {
      "start": 1348.96,
      "duration": 6.64,
      "text": "るっていうことなんですよね。朝倉系"
    },
    {
      "start": 1351.32,
      "duration": 7.479,
      "text": "セミナー政治経済旬のテーマをですね、"
    },
    {
      "start": 1355.6,
      "duration": 6.48,
      "text": "その時の旬の話をですね、私がね、"
    },
    {
      "start": 1358.799,
      "duration": 5.801,
      "text": "目いっぱい話しますから、これ是非聞いて"
    },
    {
      "start": 1362.08,
      "duration": 4.76,
      "text": "みてくださいね。え、すでにですね、え、"
    },
    {
      "start": 1364.6,
      "duration": 4.92,
      "text": "ま、ホームページ上でセミナー公開して"
    },
    {
      "start": 1366.84,
      "duration": 6.199,
      "text": "ますけど、これ見ていいなと思ったら是非"
    },
    {
      "start": 1369.52,
      "duration": 5.519,
      "text": "来てですね、皆さんのビジネス、投資"
    },
    {
      "start": 1373.039,
      "duration": 5.0,
      "text": "役立ててみてください。待ってますからね"
    },
    {
      "start": 1375.039,
      "duration": 3.0,
      "text": "。"
    },
    {
      "start": 1390.44,
      "duration": 2.04,
      "text": "ສ"
    }
  ]
}