    {
      "start": 668.92,
      "duration": 4.84,
      "text": "に一気に作業まで完了してくれるのが"
    },
    {
      "start": 671.32,
      "duration": 4.48,
      "text": "エージェント型AIのパワーです。メタの"
    },
    {
      "start": 673.76,
      "duration": 5.0,
      "text": "グループということもありマナスとても"
    },
    {
      "start": 675.8,
      "duration": 5.719,
      "text": "使いやすいですね。続いては本日の失き"
    },
    {
      "start": 678.76,
      "duration": 5.639,
      "text": "最後に参りましょう。AIを使う時に意識"
    },
    {
      "start": 681.519,
      "duration": 6.0,
      "text": "すべきことまとめです。さて、最後に"
    },
    {
      "start": 684.399,
      "duration": 5.961,
      "text": "マナスに限らずAIを使う際に長期投資化"
    },
    {
      "start": 687.519,
      "duration": 5.281,
      "text": "目線で抑えておきたい点をこの書で解説し"
    },
    {
      "start": 690.36,
      "duration": 4.52,
      "text": "ていきます。まずAIには"
    },
    {
      "start": 692.8,
      "duration": 5.4,
      "text": "ハルシネーションというものが起こり得"
    },
    {
      "start": 694.88,
      "duration": 6.199,
      "text": "ます。全てが正しい情報ではない、必ず"
    },
    {
      "start": 698.2,
      "duration": 5.52,
      "text": "ダブルチェックは必要です。私もAIを"
