    {
      "start": 714.6,
      "duration": 5.76,
      "text": "も個人的な品情報を入力する必要はあり"
    },
    {
      "start": 717.519,
      "duration": 6.201,
      "text": "ません。十分使えます。どんなツールを"
    },
    {
      "start": 720.36,
      "duration": 5.64,
      "text": "使う際も自分の金融資産情報をどこまで"
    },
    {
      "start": 723.72,
      "duration": 5.32,
      "text": "システムに入力するかはっきりと選引き"
    },
    {
      "start": 726.0,
      "duration": 5.04,
      "text": "することを強く推奨します。特にAIでは"
    },
    {
      "start": 729.04,
      "duration": 4.159,
      "text": "ですね、どのように情報が漏れていくか"
    },
    {
      "start": 731.04,
      "duration": 4.52,
      "text": "分からない部分もありますので、自分の"
    },
    {
      "start": 733.199,
      "duration": 4.721,
      "text": "個人情報などは入力しない。これは"
    },
    {
      "start": 735.56,
      "duration": 5.24,
      "text": "しっかりと覚えておきましょう。さらに"
    },
    {
      "start": 737.92,
      "duration": 6.039,
      "text": "投資判断そのものをAIに丸投げしない"
    },
    {
      "start": 740.8,
      "duration": 5.719,
      "text": "こと。AIは材料を提供してくれるだけ"
    },
    {
      "start": 743.959,
      "duration": 5.0,
      "text": "です。ちゃんと自分で判断していき"
    },
    {
      "start": 746.519,
      "duration": 4.521,
      "text": "ましょう。今日はマナスというですね、"
    },
    {
      "start": 748.959,
      "duration": 4.641,
      "text": "AIエージェントを使った長期投資家の"
    },
    {
      "start": 751.04,
      "duration": 5.239,
      "text": "活用法について解説してきました。気に"
    },
    {
      "start": 753.6,
      "duration": 5.32,
      "text": "なるなという方はですね、概要欄のリンク"
    },
    {
      "start": 756.279,
      "duration": 5.521,
      "text": "よりマナスの無料クレジットが獲得でき"
    },
    {
      "start": 758.92,
