    {
      "start": 701.079,
      "duration": 4.961,
      "text": "使う時には必ず複数のAIでダブル"
    },
    {
      "start": 703.72,
      "duration": 4.799,
      "text": "チェックなどを行うことにしています。"
    },
    {
      "start": 706.04,
      "duration": 6.44,
      "text": "そして続いて注意して欲しいことが資産額"
    },
    {
      "start": 708.519,
      "duration": 6.081,
      "text": "や口座情報など個人情報はですね、入力す"
    },
    {
      "start": 712.48,
      "duration": 5.039,
