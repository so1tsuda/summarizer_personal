      "start": 886.68,
      "duration": 3.24,
      "text": "うん。"
    },
    {
      "start": 887.16,
      "duration": 3.72,
      "text": "中村警察署のあたりとかもどうですかね。"
    },
    {
      "start": 889.92,
      "duration": 3.479,
      "text": "聖地を巡るという。"
    },
    {
      "start": 890.88,
      "duration": 2.959,
      "text": "聖地巡るって名古屋にお客さん集まんじゃないですか。"
    },
    {
      "start": 893.399,
      "duration": 3.281,
      "text": "うん。"
    },
    {
      "start": 893.839,
      "duration": 3.601,
      "text": "なんだかんだ言っても名古屋に愛知県に"
