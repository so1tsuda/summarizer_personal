    {
      "start": 898.36,
      "duration": 1.839,
      "text": "うん。"
    },
    {
      "start": 898.8,
      "duration": 2.0,
      "text": "あ田神軍も行ってもいいですよね。"
    },
    {
      "start": 900.199,
      "duration": 2.0,
      "text": "行ってもいいし。"
    },
