      "start": 498.84,
      "duration": 5.28,
      "text": "特に、ま、引き締める気がないわけだから"
    },
    {
      "start": 502.159,
      "duration": 4.241,
      "text": "金融引き締める機なんか全くないわけだ"
    },
    {
      "start": 504.12,
      "duration": 5.519,
      "text": "からね。ええ、ま、利上げはするって言っ"
    },
    {
      "start": 506.4,
      "duration": 5.56,
      "text": "たって西0.25で1じゃ間に合わない"
    },
    {
      "start": 509.639,
      "duration": 5.84,
      "text": "わけだから。ええ、そもそもそういうとこ"
    },
    {
      "start": 511.96,
      "duration": 6.439,
      "text": "を考えると大きな相場の中にあるわけです"
    },
    {
      "start": 515.479,
      "duration": 6.081,
      "text": "。日本株っていうのはものすごく大きな"
    },
    {
      "start": 518.399,
      "duration": 5.801,
      "text": "相場の中にあってその一コマとして上げ"
    },
    {
      "start": 521.56,
      "duration": 6.32,
      "text": "たり下げたりしてるんだよということなん"
    },
    {
      "start": 524.2,
      "duration": 7.079,
      "text": "です。今回たまたまこういう風に低戦合意"
    },
    {
      "start": 527.88,
      "duration": 6.519,
      "text": "ということになったんだがそこで一気に"
    },
    {
      "start": 531.279,
      "duration": 5.481,
      "text": "3000円上がるとこの力が強いわけよ。"
    },
    {
      "start": 534.399,
      "duration": 6.12,
      "text": "ここを見なきゃだめなんです。うん。"
    },
    {
      "start": 536.76,
      "duration": 6.72,
      "text": "合意為なったなと思った瞬間に3000円"
    },
    {
      "start": 540.519,
      "duration": 6.801,
      "text": "も一気に上げてしまうんだなということに"
    },
    {
      "start": 543.48,
      "duration": 8.359,
      "text": "日本株上昇のエネルギーを感じる必要が"
    },
    {
      "start": 547.32,
      "duration": 6.36,
      "text": "あるわけです。これはこれは相場でいたら"
    },
    {
      "start": 551.839,
      "duration": 4.44,
      "text": "だから言ってるじゃないですか。相場で"
    },
    {
      "start": 553.68,
      "duration": 5.12,
      "text": "いれば感じませんかってね。去年から"
    },
    {
      "start": 556.279,
      "duration": 6.201,
      "text": "ものすごく大相場の指を感じないって。"
    },
    {
      "start": 558.8,
      "duration": 6.12,
      "text": "相場にいれば感じない。ええね。"
    },
    {
      "start": 562.48,
      "duration": 3.599,
      "text": "いろんな人がいやどうなるかわかんない。"
    },
    {
      "start": 564.92,
      "duration": 5.0,
      "text": "下げますよ。"
    },
    {
      "start": 566.079,
      "duration": 5.641,
      "text": "ありますよね。ね、まめ、聞いてもしょう"
    },
    {
      "start": 569.92,
      "duration": 4.52,
      "text": "がないんだって。え、聞いてもしょうが"
    },
    {
      "start": 571.72,
      "duration": 4.92,
      "text": "ないんだって。感性の問題なんですよ。え"
    },
    {
      "start": 574.44,
      "duration": 6.24,
      "text": "、相場から見る感性がないとダメなんです"
    },
    {
      "start": 576.64,
      "duration": 7.68,
      "text": "。え、相場っていうのは感性、完成の中で"
    },
    {
      "start": 580.68,
      "duration": 5.88,
      "text": "分かるな、下がるなって感性が鈍い人は"
    },
    {
      "start": 584.32,
      "duration": 5.32,
      "text": "いくらやってもダメなところがあるんです"
    },
    {
      "start": 586.56,
      "duration": 5.8,
      "text": "。それ、ま、こういう風に言っちゃうと身"
    },
    {
      "start": 589.64,
      "duration": 5.52,
      "text": "もないですけれども完成なんですよ。だ"
    },
    {
      "start": 592.36,
      "duration": 6.0,
      "text": "からね、分かるでしょね。いや、これは"
    },
    {
      "start": 595.16,
      "duration": 6.32,
      "text": "下がるとかうん。なんてね、完成の問題な"
    },
    {
      "start": 598.36,
      "duration": 6.0,
      "text": "のよ。感性のそういうとこを皆さんは見て"
    },
    {
      "start": 601.48,
      "duration": 5.2,
      "text": "、え、相場を語る人についてはこの人感"
    },
    {
      "start": 604.36,
      "duration": 5.96,
      "text": "いいのかな、悪いのかというところも見"
    },
    {
      "start": 606.68,
      "duration": 5.96,
      "text": "ながら見たっていうと自分の話みたいに"
    },
    {
      "start": 610.32,
      "duration": 4.88,
      "text": "なっちゃうけど、まあね、ええ、そういう"
    },
    {
      "start": 612.64,
      "duration": 5.08,
      "text": "ところがあの基本的にあるわけですよ。"
    },
    {
      "start": 615.2,
      "duration": 4.72,
      "text": "おばっていうのは、え、ね、見てりゃ"
    },
    {
      "start": 617.72,
      "duration": 3.88,
      "text": "ウイクスおばちゃんって何考えてんのって"
    },
    {
      "start": 619.92,
      "duration": 4.32,
      "text": "いうのが私なんか思ってることなんだけど"
    },
    {
      "start": 621.6,
      "duration": 4.799,
      "text": "も、え、そん中で動いてるだけの話"
    },
    {
      "start": 624.24,
      "duration": 4.039,
      "text": "でしょっていうことなんだけどもね、"
    },
    {
      "start": 626.399,
      "duration": 4.56,
      "text": "みんな感覚が違うから違うんでしょう"
    },
    {
      "start": 628.279,
      "duration": 5.601,
      "text": "けれども、基本的にはでかい相場の中に"
    },
    {
      "start": 630.959,
      "duration": 7.041,
      "text": "あるわけよ。ええ、ね。さあ、その流れを"
    },
    {
      "start": 633.88,
      "duration": 6.24,
      "text": "今日は一旦証明しただけで話でまた今後"
    },
    {
      "start": 638.0,
      "duration": 5.16,
      "text": "上下上下はあるんです。上下上下はあるん"
    },
    {
      "start": 640.12,
      "duration": 5.44,
      "text": "だけれども、もう2/3戻ったよという"
    },
    {
      "start": 643.16,
      "duration": 6.799,
      "text": "ことで、日本株大相場の流れというのは"
    },
    {
      "start": 645.56,
      "duration": 8.959,
      "text": "普遍だっていうか、日本株大相場の条件が"
    },
    {
      "start": 649.959,
      "duration": 8.44,
      "text": "整ってるんだって根本を見ろよということ"
    },
    {
      "start": 654.519,
      "duration": 6.0,
      "text": "ですね。え、そういうことで、まあ、個別"
    },
    {
      "start": 658.399,
      "duration": 6.88,
      "text": "見てみましょうよ。やっぱりね、そん中で"
    },
    {
      "start": 660.519,
      "duration": 9.76,
      "text": "もすごいよね。記憶しや一気にここは"
    },
    {
      "start": 665.279,
      "duration": 8.321,
      "text": "19%上がっちゃったね。今度は配当実施"
    },
    {
      "start": 670.279,
      "duration": 5.481,
      "text": "するって言うんだけど、配当もりすぎ"
    },
    {
      "start": 673.6,
      "duration": 4.56,
      "text": "ちゃってね、ものすごい配当になるかも"
    },
    {
      "start": 675.76,
      "duration": 6.519,
      "text": "しれないみたいなこと言っちゃってね、"
    },
    {
      "start": 678.16,
      "duration": 7.919,
      "text": "すごいことになっちゃってまし産業っての"
    },
    {
      "start": 682.279,
      "duration": 7.401,
      "text": "はすごいなと改めて思いますけどね。PR"
    },
    {
      "start": 686.079,
      "duration": 6.081,
      "text": "1倍だったのね。こんな1400円だった"
    },
    {
      "start": 689.68,
      "duration": 7.2,
      "text": "のこんな株価になっちゃうなかったね。"
    },
    {
      "start": 692.16,
      "duration": 7.04,
      "text": "もう上場時のことが忘れられませんね。"
    },
    {
      "start": 696.88,
      "duration": 6.92,
      "text": "こんなことになるとは思いませんでしたね"
    },
    {
      "start": 699.2,
      "duration": 6.28,
      "text": "。私も全く予想を立じる。藤倉もまた今日"
    },
    {
      "start": 703.8,
      "duration": 3.92,
      "text": "上がってまた死んで取る動きじゃないです"
    },
    {
      "start": 705.48,
      "duration": 5.32,
      "text": "か。藤倉だってね。もう業績がいいやつは"
    },
    {
      "start": 707.72,
      "duration": 5.6,
      "text": "強いね。業績いいやつは。ええ、古川電カ"
    },
    {
      "start": 710.8,
      "duration": 5.36,
      "text": "もね、これ見てくださいよ。あっという間"
    },
    {
      "start": 713.32,
      "duration": 6.84,
      "text": "にこんなんなっちゃってね。い吹を"
    },
    {
      "start": 716.16,
      "duration": 7.32,
      "text": "感じろって材料に待ってるんだって。買い"
    },
    {
      "start": 720.16,
      "duration": 6.08,
      "text": "たくてしょうがない金が世界中に待ってる"
    },
    {
      "start": 723.48,
      "duration": 4.159,
      "text": "んだよ。ええ、国際なんか買うわけない"
    },
    {
      "start": 726.24,
      "duration": 3.839,
      "text": "じゃん。関係なんか買うわけないじゃん。"
    },
    {
      "start": 727.639,
      "duration": 5.0,
      "text": "インフレなんだから。"
    },
    {
      "start": 730.079,
      "duration": 4.44,
      "text": "えー、ソフトバンクグループ。あ、これ"
    },
    {
      "start": 732.639,
      "duration": 3.64,
      "text": "やっぱりまだ低名ですけど、今日は上がり"
    },
    {
      "start": 734.519,
      "duration": 4.521,
      "text": "ました。アドバンテスト上がりましたね。"
    },
    {
      "start": 736.279,
      "duration": 7.36,
      "text": "え、気持ちよく上がってきましたね。ま、"
    },
    {
      "start": 739.04,
      "duration": 7.0,
      "text": "トヨタも今日は若干上がりとさすがに今日"
    },
    {
      "start": 743.639,
      "duration": 3.88,
      "text": "はね、石油関連は下がりましたということ"
    },
    {
      "start": 746.04,
      "duration": 5.479,
      "text": "で石油カプは下がりました。インペックス"
    },
    {
      "start": 747.519,
      "duration": 6.32,
      "text": "ね。だけど住友山の方はしっかりバーンと"
    },
    {
      "start": 751.519,
      "duration": 4.721,
      "text": "上げてきましたよと。あ、銀行はガ板です"
    },
    {
      "start": 753.839,
      "duration": 5.0,
      "text": "ね。バーンと上げてきましたよということ"
    },
    {
      "start": 756.24,
      "duration": 5.8,
      "text": "なんですね。"
    },
    {
      "start": 758.839,
      "duration": 6.041,
      "text": "はあ。は、というわけでね、え、色々ある"
    },
    {
      "start": 762.04,
      "duration": 5.76,
      "text": "わけなんです。色々あるわけなんだけども"
    },
    {
      "start": 764.88,
      "duration": 6.759,
      "text": "ね。ええ、日本株はね、見れば分かります"
    },
    {
      "start": 767.8,
      "duration": 7.599,
      "text": "よね。やっぱり上に行くんだなと。え、よ"
    },
    {
      "start": 771.639,
      "duration": 6.921,
      "text": "な人ご苦労さんでしたとね。結末は見えて"
    },
    {
      "start": 775.399,
      "duration": 6.641,
      "text": "ますよ。ということでね、日本株は"
    },
    {
      "start": 778.56,
      "duration": 6.44,
      "text": "まずますずいいですよ。こんにちは。"
    },
    {
      "start": 782.04,
      "duration": 7.72,
      "text": "え、それではですね、当社もいよいよこれ"
    },
    {
      "start": 785.0,
      "duration": 9.72,
      "text": "本問です。本問のLINEを作りましたの"
    },
    {
      "start": 789.76,
      "duration": 8.68,
      "text": "で、これこそ本物の、え、このASK1の"
    },
    {
      "start": 794.72,
      "duration": 6.799,
      "text": "ね、朝倉系のASK1のLINE、え、"
    },
    {
      "start": 798.44,
      "duration": 5.8,
      "text": "これを始めましたんで、え、私がこれ喋っ"
    },
    {
      "start": 801.519,
      "duration": 7.081,
      "text": "てるもの以外は偽物になりますので、これ"
    },
    {
      "start": 804.24,
      "duration": 7.279,
      "text": "が本物ですね。ね、やっぱりね、LINE"
    },
    {
      "start": 808.6,
      "duration": 5.479,
      "text": "って何で始めたのかな?便利じゃないです"
    },
    {
      "start": 811.519,
      "duration": 6.32,
      "text": "か。で、このAS1っていうのは情報"
    },
    {
      "start": 814.079,
      "duration": 6.841,
      "text": "発信会社だから、だからあのセミナーとか"
    },
    {
      "start": 817.839,
      "duration": 5.161,
      "text": "それからレポートとかそれからCDとか"
    },
    {
      "start": 820.92,
      "duration": 4.479,
      "text": "あとモーニングニュースね。え、これを"
    },
    {
      "start": 823.0,
      "duration": 5.199,
      "text": "色々まあやってるわけじゃないですか。だ"
    },
    {
      "start": 825.399,
      "duration": 4.0,
      "text": "からこ今回はこんな相場になっちゃったん"
    },
    {
      "start": 828.199,
      "duration": 5.481,
      "text": "で、こんなニュースですよ。こんな"
    },
    {
      "start": 829.399,
      "duration": 6.36,
      "text": "レポートですよとか、今回の、ま、あの、"
    },
    {
      "start": 833.68,
      "duration": 4.44,
      "text": "セミナーではこんな話をしたいですねとか"
    },
    {
      "start": 835.759,
      "duration": 4.601,
      "text": "ね。あとはね、ま、セミナーとグルメ情報"
    },
    {
      "start": 838.12,
      "duration": 4.32,
      "text": "があるから今度はこんなグルメ行くんです"
    },
    {
      "start": 840.36,
      "duration": 5.0,
      "text": "よとかいろんな情報が発信できるじゃない"
    },
    {
      "start": 842.44,
      "duration": 5.48,
      "text": "ですか。やっぱりそれが簡単に発信できる"
    },
    {
      "start": 845.36,
      "duration": 4.88,
      "text": "んで、便利だなと思ってたんでやりたいな"
    },
    {
      "start": 847.92,
      "duration": 4.08,
      "text": "とは思ってたんですよね。ただ偽物がここ"
    },
    {
      "start": 850.24,
      "duration": 4.88,
      "text": "にわあわあわ出てきてしまったんですけど"
    },
    {
      "start": 852.0,
      "duration": 5.72,
      "text": "も、ま、今度は偽物が出るとこちらの本物"
    },
    {
      "start": 855.12,
      "duration": 5.6,
      "text": "が警谷も出せるということになってる"
    },
    {
      "start": 857.72,
      "duration": 4.4,
      "text": "みたいですね。まあ今回これでね、本問の"
    },
    {
      "start": 860.72,
      "duration": 5.359,
      "text": "LINEっていうのをオープンすることに"
    },
    {
      "start": 862.12,
      "duration": 7.32,
      "text": "なりました。で、このLINE登録して"
    },
    {
      "start": 866.079,
      "duration": 9.361,
      "text": "くれた方に対しての得典なんですけれども"
    },
    {
      "start": 869.44,
      "duration": 10.88,
      "text": "、ま、まずは私のそうですね、あの25の"
    },
    {
      "start": 875.44,
      "duration": 8.519,
      "text": "時のね、証券会社入って2年"
    },
    {
      "start": 880.32,
      "duration": 7.0,
      "text": "半そこイラだな。これは私、あの、この時"
    },
    {
      "start": 883.959,
      "duration": 5.521,
      "text": "に大勝負をかけて、その勝負をうまくいっ"
    },
    {
      "start": 887.32,
      "duration": 5.48,
      "text": "て独立することができるできたんです"
    },
    {
      "start": 889.48,
      "duration": 6.84,
      "text": "けれども、今楽待ちで私の失敗話とかって"
    },
    {
      "start": 892.8,
      "duration": 6.44,
      "text": "いうのをこう色々あの、まあ、再談って"
    },
    {
      "start": 896.32,
      "duration": 6.519,
      "text": "いうのをやって、それ結構見られてる動画"
    },
    {
      "start": 899.24,
      "duration": 6.159,
      "text": "ですけども、この成功しっていうので、え"
    },
    {
      "start": 902.839,
      "duration": 5.721,
      "text": "、この25の時にあったので、その後また"
    },
    {
      "start": 905.399,
      "duration": 6.68,
      "text": "失敗話があるんですけど、え、それもね、"
    },
    {
      "start": 908.56,
      "duration": 6.8,
      "text": "結構な面白い話なんで、え、この話を、あ"
    },
    {
      "start": 912.079,
      "duration": 5.76,
      "text": "あの、口で言ったんじゃなくて文章で、"
    },
    {
      "start": 915.36,
      "duration": 4.88,
      "text": "それ昔本に書いたんで、それベースに、え"
    },
    {
      "start": 917.839,
      "duration": 5.12,
      "text": "、書いてましたんで、その話をそのままお"
    },
    {
      "start": 920.24,
      "duration": 5.599,
      "text": "送りしますんで、ああ、朝倉こんなことが"
    },
    {
      "start": 922.959,
      "duration": 5.88,
      "text": "あったんだなっていう若い頃の話ですね。"
    },
    {
      "start": 925.839,
      "duration": 5.041,
      "text": "ま、昔から勝負してやっぱり勝負師だった"
    },
    {
      "start": 928.839,
      "duration": 6.24,
      "text": "んだなってことが結構分かると思うんです"
    },
    {
      "start": 930.88,
      "duration": 6.36,
      "text": "けども、あのね、面白いね、人生って"
    },
    {
      "start": 935.079,
      "duration": 5.721,
      "text": "やっぱり決める瞬間っていうのがあるわけ"
    },
    {
      "start": 937.24,
      "duration": 5.56,
      "text": "じゃないですか。あの、ずっとこう変に"
    },
    {
      "start": 940.8,
      "duration": 5.24,
      "text": "行く人もいるかもしれませんけど、ある"
    },
    {
      "start": 942.8,
      "duration": 5.2,
      "text": "程度の決断とかそれからとにかく会社を"
    },
    {
      "start": 946.04,
      "duration": 4.64,
      "text": "やめる時なんていうのは大決断じゃない"
    },
    {
      "start": 948.0,
      "duration": 5.759,
      "text": "ですか?ええ、やっぱりその私は会社"
    },
    {
      "start": 950.68,
      "duration": 5.44,
      "text": "やめる時はそれなりの習当な準備をして"
    },
    {
      "start": 953.759,
      "duration": 5.601,
      "text": "独立したんですよね。え、そのことについ"
    },
    {
      "start": 956.12,
      "duration": 5.8,
      "text": "て書いたんで、え、それがまず1点得典と"
    },
    {
      "start": 959.36,
      "duration": 7.44,
      "text": "してお送りします。それからもう1つはね"
    },
    {
      "start": 961.92,
      "duration": 6.719,
      "text": "、当社西野、西野の初心者向けの動画結構"
    },
    {
      "start": 966.8,
      "duration": 5.519,
      "text": "長いですよ。1分以上だと思いましたけど"
    },
    {
      "start": 968.639,
      "duration": 7.2,
      "text": "ね。これがね、プレゼントしますのでね、"
    },
    {
      "start": 972.319,
      "duration": 5.52,
      "text": "登録してたくれた方が面白い話がね、"
    },
    {
      "start": 975.839,
      "duration": 2.841,
      "text": "いっぱいくから、え、それやったらいいと"
    },
    {
      "start": 977.839,
      "duration": 3.641,
      "text": "思いますよ。"
    },
    {
      "start": 978.68,
      "duration": 2.959,
      "text": "で、登録してくれた後、あ、まあ、"
    },
    {
      "start": 981.48,
      "duration": 3.159,
      "text": "1"
    },
    {
      "start": 981.639,
      "duration": 3.0,
      "text": "の方でそういったいろんな情報発信っていうのは、あ、今度セミナーですよ、今度、あ、"
    },
    {
      "start": 986.44,
      "duration": 4.56,
      "text": "CDですよ。こんな話ですよっていうのは"
    },
    {
      "start": 988.519,
      "duration": 5.32,
      "text": "ありますんで。で、今詐欺は色々あって、"
    },
    {
      "start": 991.0,
      "duration": 5.399,
      "text": "まあ何千万振り込めとか、ま、うちでもね"
    },
    {
      "start": 993.839,
      "duration": 5.48,
      "text": "、そういうあの騙されたって話いっぱい来"
    },
    {
      "start": 996.399,
      "duration": 7.201,
      "text": "てんですけども、このK1の商材っていう"
    },
    {
      "start": 999.319,
      "duration": 6.96,
      "text": "のはね、せぜ、ま、あの、あのセミナーが"
    },
    {
      "start": 1003.6,
      "duration": 5.239,
      "text": "1万2000円、1万3000円とか、ま"
    },
    {
      "start": 1006.279,
      "duration": 5.56,
      "text": "、レポートだったら1回、え、3300円"
    },
    {
      "start": 1008.839,
      "duration": 6.56,
      "text": "とか、ま、そういうは、まあ、ちょっとし"
    },
    {
      "start": 1011.839,
      "duration": 5.881,
      "text": "た、ま、ま、多くても数万円っていう程度"
    },
    {
      "start": 1015.399,
      "duration": 4.8,
      "text": "の、ま、クレジット決済の話ですから、"
    },
    {
      "start": 1017.72,
      "duration": 5.84,
      "text": "それ以外は別にやりませんので、え、それ"
    },
    {
      "start": 1020.199,
      "duration": 8.281,
      "text": "から双方で話ができるのでことによったら"
    },
    {
      "start": 1023.56,
      "duration": 7.279,
      "text": "、ま、当社の若手の黒米コメとか、あ、ま"
    },
    {
      "start": 1028.48,
      "duration": 4.28,
      "text": "、がですね、そういった話でこう応じる"
    },
    {
      "start": 1030.839,
      "duration": 3.561,
      "text": "ことはできるかもしれないので、ま、そう"
    },
    {
      "start": 1032.76,
      "duration": 3.679,
      "text": "いったことも考えてますんで、ま、"
    },
    {
      "start": 1034.4,
      "duration": 4.6,
      "text": "とにかくLINEをオープンしました。あ"
    },
    {
      "start": 1036.439,
      "duration": 4.921,
      "text": "、是非とりあえずですね、え、登録して"
    },
    {
      "start": 1039.0,
      "duration": 6.839,
      "text": "ですね、え、このね、あの、楽しんで"
    },
    {
      "start": 1041.36,
      "duration": 4.479,
      "text": "いただければという風に思います。"
    },
    {
      "start": 1049.0,
      "duration": 5.88,
      "text": "世界経済の裏側を知る。真実を知"
    },
    {
      "start": 1052.559,
      "duration": 6.601,
      "text": "るっていうことなんですよね。朝倉系"
    },
    {
      "start": 1054.88,
      "duration": 7.48,
      "text": "セミナー政治経済旬のテーマをですね、"
    },
    {
      "start": 1059.16,
      "duration": 6.6,
      "text": "その時の旬の話をですね、私がね、"
    },
    {
      "start": 1062.36,
      "duration": 6.28,
      "text": "目いっぱい話しますからこれ是非聞いてみ"
    },
    {
      "start": 1065.76,
      "duration": 4.799,
      "text": "てくださいね。え、すでにですね、え、ま"
    },
    {
      "start": 1068.64,
      "duration": 4.6,
      "text": "、ホームページ上でセミナー公開してます"
    },
    {
      "start": 1070.559,
      "duration": 6.681,
      "text": "けど、これ見ていいなと思ったら是非来て"
    },
    {
      "start": 1073.24,
      "duration": 8.36,
      "text": "ですね、皆さんのビジネス、投資役立てて"
    },
    {
      "start": 1077.24,
      "duration": 4.36,
      "text": "みてください。待ってますからね。"
    }
  ]
