    {
      "start": 638.399,
      "duration": 5.841,
      "text": "このようなプロセスでした。しかし今後は"
    },
    {
      "start": 641.44,
      "duration": 5.6,
      "text": "メールでの認証ではなく電話での認証に"
    },
    {
      "start": 644.24,
      "duration": 6.08,
      "text": "変わります。メールで来ていたのが電話"
    },
    {
      "start": 647.04,
      "duration": 6.16,
      "text": "番号の発信による認証に変更になるんです"
    },
    {
      "start": 650.32,
      "duration": 5.84,
      "text": "よね。メールよりもセキュリティは強固に"
    },
    {
      "start": 653.2,
      "duration": 5.079,
      "text": "なりそうですけども、わざわざ取引の電話"
    },
    {
      "start": 656.16,
      "duration": 5.32,
      "text": "するのってちょっと手間が増えますよね。"
    },
    {
      "start": 658.279,
      "duration": 5.8,
      "text": "システムが怪しい共同だぞと判断したその"
    },
    {
      "start": 661.48,
      "duration": 4.799,
      "text": "ようなリスクが確認された時だけ電話が"
    },
    {
      "start": 664.079,
      "duration": 5.721,
      "text": "必要になりますけども、それでもやっぱり"
    },
    {
      "start": 666.279,
      "duration": 6.721,
      "text": "手間は増える印象です。重要なのはSBI"
    },
    {
      "start": 669.8,
      "duration": 5.719,
      "text": "証券に登録されている電話番号が今は使っ"
