    {
      "start": 789.959,
      "duration": 6.161,
      "text": "されます世代セキュリティ方式パスキー"
    },
    {
      "start": 793.079,
      "duration": 5.721,
      "text": "認証がスタートをしました。2025年"
    },
    {
      "start": 796.12,
      "duration": 5.2,
      "text": "10月25日よりパスキ認証開始をして"
    },
    {
      "start": 798.8,
      "duration": 4.159,
      "text": "おります。SBI証券のこれまでの認証"
    },
    {
      "start": 801.32,
      "duration": 3.92,
      "text": "方式、ユーザーネームとログイン"
    },
    {
      "start": 802.959,
      "duration": 4.921,
      "text": "パスワード、ログイン追加認証は残るん"
    },
    {
      "start": 805.24,
      "duration": 5.399,
      "text": "ですけれども、パスキ認証、新しく誕生し"
    },
    {
      "start": 807.88,
      "duration": 6.04,
      "text": "たこれを設定するのが絶対におすすめです"
    },
    {
      "start": 810.639,
      "duration": 5.481,
      "text": "。設定はスマホもしくはパソコンの"
    },
    {
      "start": 813.92,
      "duration": 5.2,
      "text": "ブラウザーから行いましょう。SBI証券"
    },
    {
      "start": 816.12,
      "duration": 5.2,
      "text": "の公式ページにアクセスします。まずは"
    },
    {
      "start": 819.12,
      "duration": 5.2,
      "text": "ログインからです。久しぶりログインを"
    },
    {
      "start": 821.32,
      "duration": 5.92,
      "text": "する人はデバイス認証が外れている可能性"
    },
    {
      "start": 824.32,
      "duration": 5.24,
      "text": "があります。一定期間ログインしないと再"
    },
    {
      "start": 827.24,
      "duration": 4.88,
      "text": "登録が必要になります。と言ってもEメで"
    },
    {
      "start": 829.56,
      "duration": 5.44,
      "text": "確認するだけですので1分で完了します。"
    },
    {
      "start": 832.12,
      "duration": 5.6,
      "text": "デバイス認証まずは完了させましょう。で"
    },
    {
      "start": 835.0,
      "duration": 5.16,
      "text": "は設定をしていきましょう。まずは"
    },
    {
      "start": 837.72,
      "duration": 5.0,
      "text": "ステップ1としてSBI証券にログインし"
    },
    {
      "start": 840.16,
      "duration": 5.4,
      "text": "た後にセキュリティ設定こちらをクリック"
    },
    {
      "start": 842.72,
      "duration": 6.239,
      "text": "してください。続いてはセキュリティ関連"
    },
    {
      "start": 845.56,
      "duration": 5.719,
      "text": "の1番上にパスキー認証とありますよね。"
    },
    {
      "start": 848.959,
      "duration": 6.041,
      "text": "ここ未設定になってるかと思いますので"
    },
    {
      "start": 851.279,
      "duration": 6.841,
      "text": "この赤枠の変更をクリックします。続いて"
    },
    {
      "start": 855.0,
      "duration": 5.72,
      "text": "準備をしている取引パスワードをこの赤枠"
    },
    {
      "start": 858.12,
      "duration": 6.04,
      "text": "のところに入力しパスキーを設定していき"
    },
    {
      "start": 860.72,
      "duration": 6.0,
      "text": "ましょう。続いては登録メールアドレスに"
    },
    {
      "start": 864.16,
      "duration": 4.56,
      "text": "認証コードが送られてきます。この認証"
    },
    {
      "start": 866.72,
      "duration": 5.76,
      "text": "コードというのは6桁の数字なんですけど"
    },
    {
      "start": 868.72,
      "duration": 6.0,
      "text": "も、これを確認してこの認証コードの欄に"
    },
    {
      "start": 872.48,
      "duration": 5.32,
      "text": "入力をして認証ボタンをクリックし"
    },
    {
      "start": 874.72,
      "duration": 5.919,
      "text": "ましょう。さてここからが少し人によって"
    },
    {
      "start": 877.8,
      "duration": 5.36,
      "text": "表示が変わる部分慎重に行きましょう。"
    },
    {
      "start": 880.639,
      "duration": 5.12,
      "text": "例えば私はiPhoneで試したところ、"
    },
    {
      "start": 883.16,
      "duration": 5.72,
      "text": "普段iPhoneで利用している生態認証"
    },
    {
      "start": 885.759,
      "duration": 6.161,
      "text": "が発動しました。その生態認証を登録すれ"
    },
    {
      "start": 888.88,
      "duration": 6.0,
      "text": "ばOKでした。生態認証ではなくピンでも"
    },
    {
      "start": 891.92,
      "duration": 5.68,
      "text": "登録できます。例えばピンで登録する場合"
    },
    {
      "start": 894.88,
      "duration": 4.639,
      "text": "はこのようにピンを入力していきます。"
    },
    {
      "start": 897.6,
      "duration": 4.44,
      "text": "WindowsPCなどこのようにピンを"
    },
    {
      "start": 899.519,
      "duration": 6.081,
      "text": "入力することもあるかと思います。ちなみ"
    },
    {
      "start": 902.04,
      "duration": 5.28,
      "text": "にですね、パソコンで生体認証やピを使用"
    },
    {
      "start": 905.6,
      "duration": 3.599,
      "text": "していない場合はスマートフォンと"
    },
    {
      "start": 907.32,
      "duration": 4.319,
      "text": "組み合わせることでパスキーを利用する"
    },
    {
      "start": 909.199,
      "duration": 6.401,
      "text": "ことができます。例えばお使いのパソコン"
    },
    {
      "start": 911.639,
      "duration": 6.12,
      "text": "でサインや画面ロック回路時に生態認証や"
    },
    {
      "start": 915.6,
      "duration": 4.52,
      "text": "ピンを使用したことがない場合は以下の"
    },
    {
      "start": 917.759,
      "duration": 5.121,
      "text": "画像のようにこのパスキーの保存場所を"
    },
    {
      "start": 920.12,
      "duration": 6.12,
      "text": "選択というような画面でスマートフォンと"
    },
    {
      "start": 922.88,
      "duration": 5.879,
      "text": "セキュリティキーかこ物理キーの選択肢"
    },
    {
      "start": 926.24,
      "duration": 4.399,
      "text": "のみが表示されます。ここでスマート"
    },
    {
      "start": 928.759,
      "duration": 5.361,
      "text": "フォンを選択することによってパスキー"
    },
    {
      "start": 930.639,
      "duration": 6.12,
      "text": "認証を設定することができます。PC環境"
    },
    {
      "start": 934.12,
      "duration": 5.8,
      "text": "のみでパスキー認証を設定したい場合は"
    },
    {
      "start": 936.759,
      "duration": 6.921,
      "text": "パソコンで生体認証かピンの設定が必要"
    },
    {
      "start": 939.92,
      "duration": 7.359,
      "text": "です。これでSBI証券でのパスキー認証"
    },
    {
      "start": 943.68,
      "duration": 6.44,
      "text": "設定完了です。なお失敗ケースについて"
    },
    {
      "start": 947.279,
      "duration": 5.401,
      "text": "公式で2つのケースが紹介をされていまし"
    },
    {
      "start": 950.12,
      "duration": 5.92,
      "text": "た。失敗ケースの丸1としては"
    },
    {
      "start": 952.68,
      "duration": 5.68,
      "text": "セキュリティ機外部USB挿入の案内"
    },
    {
      "start": 956.04,
      "duration": 4.64,
      "text": "ポップアップが出てパスキー登録ができ"
    },
    {
      "start": 958.36,
      "duration": 4.32,
      "text": "ない。このような自称が出るケースがある"
    },
    {
      "start": 960.68,
      "duration": 5.24,
      "text": "ようなんですよね。どういう時に出る"
    },
    {
      "start": 962.68,
      "duration": 6.04,
      "text": "かって言うと事前に端末側でパスキーを"
    },
    {
      "start": 965.92,
      "duration": 6.68,
      "text": "登録しないとこの表示になるようです。"
    },
    {
      "start": 968.72,
      "duration": 7.88,
      "text": "この場合は端末側で生態認証かピンなどの"
    },
    {
      "start": 972.6,
      "duration": 6.64,
      "text": "登録をした上で再度設定を試みましょう。"
    },
    {
      "start": 976.6,
      "duration": 4.799,
      "text": "続いて失敗例の2つ目はWindows"
    },
    {
      "start": 979.24,
      "duration": 4.88,
      "text": "セキュリティのポップアップが隠れている"
    },
    {
      "start": 981.399,
      "duration": 4.961,
      "text": "場合です。これ隠れているだけですので"
    },
    {
      "start": 984.12,
      "duration": 4.56,
      "text": "画面下のバーを確認してアイコンを"
    },
    {
      "start": 986.36,
      "duration": 5.599,
      "text": "クリックすることでポップアップ確認する"
    },
    {
      "start": 988.68,
      "duration": 5.68,
      "text": "ことができます。これで設定は完了です。"
    },
    {
      "start": 991.959,
      "duration": 4.761,
      "text": "設定完了したら試しにログインをしてみ"
    },
    {
      "start": 994.36,
      "duration": 4.68,
      "text": "ましょう。トップページにIDと"
    },
    {
      "start": 996.72,
      "duration": 4.4,
      "text": "パスワードを入力する箇所今なくなってる"
    },
    {
      "start": 999.04,
      "duration": 5.2,
      "text": "んですよね。このログインをクリックし"
    },
    {
      "start": 1001.12,
      "duration": 6.12,
      "text": "ましょう。IDとパスワード入力をする"
    },
    {
      "start": 1004.24,
      "duration": 6.279,
      "text": "ことなくパスキー認証こちらでログインを"
    },
    {
      "start": 1007.24,
      "duration": 5.519,
      "text": "選択します。登録したパスキー認証でログ"
    },
    {
      "start": 1010.519,
      "duration": 4.8,
      "text": "インをするだけめっちゃ簡単になりました"
    },
    {
      "start": 1012.759,
      "duration": 5.721,
      "text": "。これでパスキー認証の設定は完了。"
    },
    {
      "start": 1015.319,
      "duration": 5.161,
      "text": "かなり快適かつ関になったはず。本日も"
    },
    {
      "start": 1018.48,
      "duration": 5.24,
      "text": "最後までご視聴いただきありがとうござい"
    },
    {
      "start": 1020.48,
      "duration": 5.04,
      "text": "ました。本日の動画の裏話や動画の中では"
    },
    {
      "start": 1023.72,
      "duration": 4.28,
      "text": "ちょっと言いきれない本音をノートの"
    },
    {
      "start": 1025.52,
      "duration": 4.679,
      "text": "メンバーシップで発信を始めております。"
    },
    {
      "start": 1028.0,
      "duration": 4.16,
      "text": "台本を作りながら考えていたことや"
    },
    {
      "start": 1030.199,
      "duration": 4.76,
      "text": "ちょっと公開動画で言えないことも楽ヤ"
    },
    {
      "start": 1032.16,
      "duration": 5.08,
      "text": "トーク的に有力発信中です。気になる方は"
    },
    {
      "start": 1034.959,
      "duration": 4.521,
      "text": "概要欄かこちらのQRコードを読み込むと"
    },
    {
      "start": 1037.24,
      "duration": 4.92,
      "text": "ノートに登録できます。是非ご活用"
    },
    {
      "start": 1039.48,
      "duration": 5.199,
      "text": "ください。概要欄にLINEXInstタ"
    },
    {
      "start": 1042.16,
      "duration": 5.639,
      "text": "MLMガのURLがあります。私自身が"
    },
    {
      "start": 1044.679,
      "duration": 5.921,
      "text": "取り組んでいる資産形成や製造との工夫は"
    },
    {
      "start": 1047.799,
      "duration": 5.481,
      "text": "今後LINEで配信予定ご興味ある方はご"
    },
    {
      "start": 1050.6,
      "duration": 5.4,
      "text": "登録ください。メルマガでは日々の経済"
    },
    {
      "start": 1053.28,
      "duration": 5.519,
      "text": "ニュースを分かりやすく解説しています。"
    },
    {
      "start": 1056.0,
      "duration": 5.24,
      "text": "インスタやXではより短時間で情報"
    },
    {
      "start": 1058.799,
      "duration": 5.88,
      "text": "インプットができます。是非ご登録をお"
    },
    {
      "start": 1061.24,
      "duration": 3.439,
      "text": "願いします。"
    }
  ]
}