    {
      "start": 675.519,
      "duration": 5.601,
      "text": "SBI証券に登録されてる場合はそもそも"
    },
    {
      "start": 678.56,
      "duration": 5.16,
      "text": "認証ができません。認証ができないという"
    },
    {
      "start": 681.12,
      "duration": 5.719,
      "text": "ことは取引が完了できないということに"
    },
    {
      "start": 683.72,
      "duration": 5.679,
      "text": "直結します。まずはこの動画を見た人は"
    },
    {
      "start": 686.839,
      "duration": 5.44,
      "text": "電話番号を確認しましょう。それでは本日"
    },
    {
      "start": 689.399,
      "duration": 6.201,
      "text": "の品き4つ目に参りましょう。電話番号の"
    },
    {
      "start": 692.279,
      "duration": 5.881,
      "text": "確認や変更を1分で終わらせる超簡単な"
    },
    {
      "start": 695.6,
      "duration": 5.56,
      "text": "方法をご紹介いたします。1分出てきます"
    },
    {
      "start": 698.16,
      "duration": 6.32,
      "text": "。具体的なSBI証券に登録されている"
    },
    {
      "start": 701.16,
      "duration": 6.4,
      "text": "電話番号の確認方法がこちらです。まずは"
    },
    {
      "start": 704.48,
      "duration": 6.599,
      "text": "SBI証券にログインをマ設定からお客様"
    },
    {
      "start": 707.56,
      "duration": 6.44,
      "text": "情報、設定変更をしましょう。お客様基本"
    },
    {
      "start": 711.079,
      "duration": 6.361,
      "text": "情報。ここに電話番号がありますので最新"
    },
    {
      "start": 714.0,
      "duration": 5.959,
      "text": "かどうか必ずご確認ください。さらに絶対"
    },
    {
      "start": 717.44,
      "duration": 5.32,
      "text": "注意したいのが今調べてみた結果ですね、"
    },
    {
      "start": 719.959,
      "duration": 5.56,
      "text": "SBI証券に登録されてる電話番号が古い"
    },
    {
      "start": 722.76,
      "duration": 6.28,
      "text": "電話番号だったという人、この人はすごく"
    },
    {
      "start": 725.519,
      "duration": 6.521,
      "text": "注意です。12月より電話番号変更には"
    },
    {
      "start": 729.04,
      "duration": 5.28,
      "text": "本人確認書類が必須になっています。この"
    },
    {
      "start": 732.04,
      "duration": 5.799,
      "text": "ように公式ページでもアナウンスされてい"
    },
    {
      "start": 734.32,
      "duration": 6.04,
      "text": "ます。もし最新じゃない場合は先ほどのマ"
    },
    {
      "start": 737.839,
      "duration": 4.761,
      "text": "設定のページから手続きを進めていけば"
    },
    {
      "start": 740.36,
      "duration": 5.599,
      "text": "電話番号変更まではいけるんですけれども"
    },
    {
      "start": 742.6,
      "duration": 5.84,
      "text": "、しかしWebで完結させる場合も本人"
    },
    {
      "start": 745.959,
      "duration": 5.361,
      "text": "確認書類のアップロードがこのように求め"
    },
    {
      "start": 748.44,
      "duration": 5.44,
      "text": "られます。これ必須で2営業日かかると"
    },
    {
      "start": 751.32,
      "duration": 5.24,
      "text": "いうことですので、Webで行う場合も2"
    },
    {
      "start": 753.88,
      "duration": 5.12,
      "text": "営業日かかるとこれは必ず覚えておいて"
    },
    {
      "start": 756.56,
      "duration": 5.76,
      "text": "ください。ちょっとこれはかなり面倒です"
    },
    {
      "start": 759.0,
      "duration": 6.399,
      "text": "よね。投資で放置しているという人にこそ"
    },
    {
      "start": 762.32,
      "duration": 5.48,
      "text": "絶対に確認して欲しい内容です。番号が"
    },
    {
      "start": 765.399,
      "duration": 5.401,
      "text": "変更になってる人は電話番号変更をするの"
    },
    {
      "start": 767.8,
      "duration": 5.279,
      "text": "ですが、本人確認書類のアップロードが"
    },
    {
      "start": 770.8,
      "duration": 5.159,
      "text": "必須にこれは覚えておきましょう。お手元"
    },
    {
      "start": 773.079,
      "duration": 5.641,
      "text": "に本人確認書類をご準備の上、電話番号"
    },
    {
      "start": 775.959,
      "duration": 5.841,
      "text": "変更を早急に実施しましょう。それでは、"
    },
    {
      "start": 778.72,
      "duration": 5.4,
      "text": "本日の品き最後に参りましょう。超便利。"
    },
    {
      "start": 781.8,
      "duration": 5.479,
      "text": "IDやパスワードが不要なパスキー認証の"
    },
    {
      "start": 784.12,
      "duration": 5.839,
      "text": "設定方法ご紹介いたします。SBI証券の"
    },
    {
      "start": 787.279,
      "duration": 5.8,
      "text": "ログインの時、ついにパスワードから解放"
