      "start": 402.24,
      "duration": 4.399,
      "text": "もちろんこれはこれで副作用があるのだが"
    },
    {
      "start": 404.08,
      "duration": 5.92,
      "text": "、"
    },
    {
      "start": 406.639,
      "duration": 5.84,
      "text": "日銀が国際をガンガンまた買いまくるしか"
    },
    {
      "start": 410.0,
      "duration": 5.479,
      "text": "ないんじゃないかと。ま、またそしたら"
    },
    {
      "start": 412.479,
      "duration": 4.681,
      "text": "今度円安になるんだけどで、上く崩"
    },
    {
      "start": 415.479,
      "duration": 3.12,
      "text": "シナリオというのがいよいよないでもない"
    },
    {
      "start": 417.16,
      "duration": 4.8,
      "text": "。ま、上く崩ってちょっと大げさな言い方"
    },
    {
      "start": 418.599,
      "duration": 6.361,
      "text": "なんだけどそういう気がしなくもないん"
    },
    {
      "start": 421.96,
      "duration": 6.679,
      "text": "ですよね。上田さんなんかが今1番誰が誰"
    },
    {
      "start": 424.96,
      "duration": 5.48,
      "text": "が頭いたいって上田さんですよ。上田総裁"
    },
    {
      "start": 428.639,
      "duration": 3.12,
      "text": "どうすんだとか日銀のスタッフとか財務所"
    },
    {
      "start": 430.44,
      "duration": 3.759,
      "text": "とか今ちょっとしたパニックになってても"
    },
    {
      "start": 431.759,
      "duration": 4.321,
      "text": "おかしくないぐらいのま、中はちょっとし"
    },
    {
      "start": 434.199,
      "duration": 4.041,
      "text": "た蜂のをついたような大騒ぎぐらいになっ"
    },
    {
      "start": 436.08,
      "duration": 4.0,
      "text": "ててもおかしくないぐらい今日ちょっと"
    },
    {
      "start": 438.24,
      "duration": 4.079,
      "text": "起こったことっていうのはこれ衝撃的な"
    },
    {
      "start": 440.08,
      "duration": 4.799,
      "text": "ことだとみんな株式投しかまだ認識して"
    },
    {
      "start": 442.319,
      "duration": 6.361,
      "text": "ないかもしんないけど私は一応言っとき"
    },
    {
      "start": 444.879,
      "duration": 6.76,
      "text": "ますよという思いでこの動画を撮ってます"
    },
    {
      "start": 448.68,
      "duration": 5.12,
      "text": "。"
    },
    {
      "start": 451.639,
      "duration": 3.601,
      "text": "まあ、インフレになってね、物価が上がっ"
    },
    {
      "start": 453.8,
      "duration": 3.28,
      "text": "てくんだから、ある程度金利が上が"
    },
    {
      "start": 455.24,
      "duration": 5.16,
      "text": "るってことはこれ自然なことではあるのだ"
    },
    {
      "start": 457.08,
      "duration": 7.0,
      "text": "が、ちょっとこの上がり方がのトリガーに"
    },
    {
      "start": 460.4,
      "duration": 8.199,
      "text": "なってんのが消費税減税とかね、食料品の"
    },
    {
      "start": 464.08,
      "duration": 6.839,
      "text": "税率0にとかあれマジで"
    },
    {
      "start": 468.599,
      "duration": 4.16,
      "text": "投資家とか、ま、そこそこ分かってる"
    },
    {
      "start": 470.919,
      "duration": 4.68,
      "text": "ビジネスマンの方とかあんなも求めてる人"
    },
    {
      "start": 472.759,
      "duration": 4.641,
      "text": "いませんよ。ま、てか誰もあれ本気でやる"
    },
    {
      "start": 475.599,
      "duration": 3.0,
      "text": "と思ってないにお互い本気でやらない前提"
    },
    {
      "start": 477.4,
      "duration": 3.12,
      "text": "でいい。とりあえず言っとこうみたいな"
    },
    {
      "start": 478.599,
      "duration": 3.6,
      "text": "感じで。でもその、とりあえず言っとこっ"
    },
    {
      "start": 480.52,
      "duration": 4.48,
      "text": "ていうのは投資家ってのは最悪を常に"
    },
    {
      "start": 482.199,
      "duration": 5.481,
      "text": "折り込むんで、もし本当にそういうのでも"
    },
    {
      "start": 485.0,
      "duration": 4.759,
      "text": "なってみたらっていう感じで、ま、リスク"
    },
    {
      "start": 487.68,
      "duration": 4.4,
      "text": "が散らつくだけで国際なんか特に30年"
    },
    {
      "start": 489.759,
      "duration": 5.72,
      "text": "40年資金をロックされるわけだからね、"
    },
    {
      "start": 492.08,
      "duration": 5.239,
      "text": "そこにこれ本当にどうなんのみたい。帰っ"
    },
    {
      "start": 495.479,
      "duration": 4.641,
      "text": "てくる時には物価推どうなってたみたいな"
    },
    {
      "start": 497.319,
      "duration": 4.801,
      "text": "ところで当然"
    },
    {
      "start": 500.12,
      "duration": 6.199,
      "text": "折り合いをつけさせられるというところで"
    },
    {
      "start": 502.12,
      "duration": 6.4,
      "text": "今まこの責任ある積極財政と言って"
    },
    {
      "start": 506.319,
      "duration": 4.681,
      "text": "インフレゼだって言ってたけどまそうは"
    },
    {
      "start": 508.52,
      "duration": 5.12,
      "text": "と案が下ろさないという形で今最建村の"
    },
    {
      "start": 511.0,
      "duration": 5.599,
      "text": "住民の人たちが消費税の減税はせめてやめ"
    },
    {
      "start": 513.64,
      "duration": 4.959,
      "text": "てくれねえかという形で絶叫してるという"
    },
    {
      "start": 516.599,
      "duration": 5.12,
      "text": "のがまあ"
    },
    {
      "start": 518.599,
      "duration": 5.201,
      "text": "今の状況すかね。"
    },
    {
      "start": 521.719,
      "duration": 5.961,
      "text": "いや、あちら立てればこちら立たつと言い"
    },
    {
      "start": 523.8,
      "duration": 7.44,
      "text": "ますけれども、本当に市場とか株とか経済"
    },
    {
      "start": 527.68,
      "duration": 7.08,
      "text": "って面白いすね。そんなインフレ勢で全て"
    },
    {
      "start": 531.24,
      "duration": 5.12,
      "text": "が丸く収まるだなんてことはありません。"
    },
    {
      "start": 534.76,
      "duration": 5.519,
      "text": "まあ、笑うしかないぐらいになってるん"
    },
    {
      "start": 536.36,
      "duration": 5.4,
      "text": "ですけども、ちょっとね、まあ、明日今日"
    },
    {
      "start": 540.279,
      "duration": 4.521,
      "text": "の、ま、今日から少しギクシャクして出"
    },
    {
      "start": 541.76,
      "duration": 5.6,
      "text": "てるけど、ちょっともしかしたら"
    },
    {
      "start": 544.8,
      "duration": 5.599,
      "text": "一来るかもなというムードかもしれんし、"
    },
    {
      "start": 547.36,
      "duration": 6.84,
      "text": "特にこれがね、何が立ちが悪いって今選挙"
    },
    {
      "start": 550.399,
      "duration": 6.081,
      "text": "戦の最中じゃないですか?だから今更食料"
    },
    {
      "start": 554.2,
      "duration": 5.199,
      "text": "消費税、減税やめるというのは少なくと"
    },
    {
      "start": 556.48,
      "duration": 4.52,
      "text": "選挙勝つまで言えないと思うんですよ。"
    },
    {
      "start": 559.399,
      "duration": 3.241,
      "text": "なんでもう言い出したこと引っ込めるわけ"
    },
    {
      "start": 561.0,
      "duration": 5.64,
      "text": "にもいかないんだけど本当にお前大丈夫"
    },
    {
      "start": 562.64,
      "duration": 6.84,
      "text": "かって形で金融市場特に最建市場から今"
    },
    {
      "start": 566.64,
      "duration": 5.439,
      "text": "猛烈な高一さんにしてのおいマジかいい"
    },
    {
      "start": 569.48,
      "duration": 5.24,
      "text": "加減に勘弁してくれよっていうビンタが今"
    },
    {
      "start": 572.079,
      "duration": 4.721,
      "text": "高一さんの横つらに"
    },
    {
      "start": 574.72,
      "duration": 6.04,
      "text": "入ったというのが今日の状況じゃないです"
    },
    {
      "start": 576.8,
      "duration": 7.719,
      "text": "かね。ま、そんなこ感じなんで是非株式"
    },
    {
      "start": 580.76,
      "duration": 6.24,
      "text": "投資家の皆さんも必ず"
    },
    {
      "start": 584.519,
      "duration": 5.401,
      "text": "画面の片隅の長期金利見続けた方がいい"
    },
    {
      "start": 587.0,
      "duration": 5.12,
      "text": "ですよ。ま、10年もぐらいでいいのかも"
    },
    {
      "start": 589.92,
      "duration": 4.72,
      "text": "しれん。30年40年ちょっと普通の個別"
    },
    {
      "start": 592.12,
      "duration": 6.56,
      "text": "株投資がやるには極端かもなことかもしれ"
    },
    {
      "start": 594.64,
      "duration": 7.52,
      "text": "ないけど、ま、10年でも2.3でしょ。"
    },
    {
      "start": 598.68,
      "duration": 5.8,
      "text": "ソフトバンクの7年をまあ、ま、もちろん"
    },
    {
      "start": 602.16,
      "duration": 3.88,
      "text": "期間が違うってのはあるんだが、ソフト"
    },
    {
      "start": 604.48,
      "duration": 4.56,
      "text": "バンク"
    },
    {
      "start": 606.04,
      "duration": 5.96,
      "text": "の、ま、7年のね、俺が買った3.98、"
    },
    {
      "start": 609.04,
      "duration": 4.96,
      "text": "え、30年、40年の日本国際が金利で"
    },
    {
      "start": 612.0,
      "duration": 5.32,
      "text": "利息であの、利回りで上回り出したって"
    },
    {
      "start": 614.0,
      "duration": 5.56,
      "text": "いう。これはまあもうそれだけ要は超長期"
    },
    {
      "start": 617.32,
      "duration": 6.16,
      "text": "に見た時のインフレ期待が上がってしまっ"
    },
    {
      "start": 619.56,
      "duration": 8.04,
      "text": "てるということをどうお落し前つけるのが"
    },
    {
      "start": 623.48,
      "duration": 8.44,
      "text": "問題っていうのはまあ出てきますわな。"
    },
    {
      "start": 627.6,
      "duration": 8.64,
      "text": "まあだから何らか日銀とか財務省が出動せ"
    },
    {
      "start": 631.92,
      "duration": 9.8,
      "text": "ざるを負えない感じが下手したらあるね。"
    },
    {
      "start": 636.24,
      "duration": 7.36,
      "text": "是非皆様株やる上で企業業績と金利と"
    },
    {
      "start": 641.72,
      "duration": 5.04,
      "text": "単数でございますんで金利が上がって"
    },
    {
      "start": 643.6,
      "duration": 5.919,
      "text": "るってことには1mmも株にとっていい"
    },
    {
      "start": 646.76,
      "duration": 5.6,
      "text": "ことは基本ありません。そういったことが"
    },
    {
      "start": 649.519,
      "duration": 5.041,
      "text": "ひたヒタと今進んでたのが今日は結構"
    },
    {
      "start": 652.36,
      "duration": 4.12,
      "text": "ボキッてなんかもう"
    },
    {
      "start": 654.56,
      "duration": 3.839,
      "text": "背骨が骨が折れるというか心が折れたよう"
    },
    {
      "start": 656.48,
      "duration": 4.28,
      "text": "な最近村人たちの心が折れたような形の"
    },
    {
      "start": 658.399,
      "duration": 5.88,
      "text": "入札結果が出たというところなので是非皆"
    },
    {
      "start": 660.76,
      "duration": 5.84,
      "text": "様注目してください。株やる時に株しか見"
    },
    {
      "start": 664.279,
      "duration": 5.401,
      "text": "ないってのは基本2流、3流の投資家の"
    },
    {
      "start": 666.6,
      "duration": 4.84,
      "text": "態度です。ではまた明日の朝のライブとか"
    },
    {
      "start": 669.68,
      "duration": 5.2,
      "text": "寄りつきの気配も見たいと思います。"
    },
    {
      "start": 671.44,
      "duration": 3.44,
      "text": "よろしく。"
    }
  ]
}