    {
      "start": 1039.039,
      "duration": 3.0,
      "text": "あの年金だけだったらそこはもう分かりきってるだろうとね。"
    },
    {
      "start": 1043.48,
      "duration": 2.599,
      "text": "そういう伝え方したりするじゃないですか。"
