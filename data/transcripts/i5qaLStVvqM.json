    },
    {
      "start": 457.36,
      "duration": 5.239,
      "text": "その量を減らすわけにはいかず、かと言っ"
    },
    {
      "start": 460.199,
      "duration": 6.641,
      "text": "てNAフサとガソリン両方の需要を満たす"
    },
    {
      "start": 462.599,
      "duration": 7.201,
      "text": "量を原油を輸入すると今度は経油や重油、"
    },
    {
      "start": 466.84,
      "duration": 4.84,
      "text": "灯油といった石油製品が大量にダぶついて"
    },
    {
      "start": 469.8,
      "duration": 4.2,
      "text": "しまいます。"
    },
    {
      "start": 471.68,
      "duration": 4.799,
      "text": "すでに経由などは国内で消費しきれない"
    },
    {
      "start": 474.0,
      "duration": 5.759,
      "text": "ため輸出に回している分も多くあるわけ"
    },
    {
      "start": 476.479,
      "duration": 5.12,
      "text": "ですが、経済的な観点からするとNAFさ"
    },
    {
      "start": 479.759,
      "duration": 4.681,
      "text": "のためだけに原因を輸入するというのは"
    },
    {
      "start": 481.599,
      "duration": 4.841,
      "text": "非効率であり、プラントの処理能力の問題"
    },
    {
      "start": 484.44,
      "duration": 4.4,
      "text": "もあります。"
    },
    {
      "start": 486.44,
      "duration": 5.719,
      "text": "なので足りない分のさを輸入するというの"
    },
    {
      "start": 488.84,
      "duration": 6.319,
      "text": "が最適となってくるわけです。"
    },
    {
      "start": 492.159,
      "duration": 6.241,
      "text": "またナフサや基礎価格品は大型のプラント"
    },
    {
      "start": 495.159,
      "duration": 6.6,
      "text": "があれば世界中どこでも作れるため最終的"
    },
    {
      "start": 498.4,
      "duration": 5.84,
      "text": "にはコスト勝負になる面が大きく原油が"
    },
    {
      "start": 501.759,
      "duration": 6.641,
      "text": "湧いて出たそばから生成できプラントが"
    },
    {
      "start": 504.24,
      "duration": 6.72,
      "text": "充実していて大量生産が容易でかつ出稼ぎ"
    },
    {
      "start": 508.4,
      "duration": 5.439,
      "text": "意味による安価な労働力を確保できる"
    },
    {
      "start": 510.96,
      "duration": 6.24,
      "text": "中東産のものが価格的にも有意性があり"
    },
    {
      "start": 513.839,
      "duration": 5.481,
      "text": "ます。このような背景からナフサはその"
    },
    {
      "start": 517.2,
      "duration": 5.519,
      "text": "半分以上を輸入している状況になっている"
    },
    {
      "start": 519.32,
      "duration": 3.399,
      "text": "と言えます。"
    },
    {
      "start": 522.88,
      "duration": 6.959,
      "text": "そして残りの40%の国内生成分が国産"
    },
    {
      "start": 527.279,
      "duration": 6.24,
      "text": "なさということになりますが、当然こちら"
    },
    {
      "start": 529.839,
      "duration": 7.401,
      "text": "も原油から作られるものです。過去の動画"
    },
    {
      "start": 533.519,
      "duration": 7.0,
      "text": "でも紹介した通り日本は原油の約9割を"
    },
    {
      "start": 537.24,
      "duration": 5.96,
      "text": "中東から輸入しているため結局日本で使わ"
    },
    {
      "start": 540.519,
      "duration": 5.88,
      "text": "れるNAFAの大半は中東さんの原油に"
    },
    {
      "start": 543.2,
      "duration": 5.6,
      "text": "依存する構造になっているわけです。"
    },
    {
      "start": 546.399,
      "duration": 4.601,
      "text": "原油には国家備蓄区がありますが、"
    },
    {
      "start": 548.8,
      "duration": 5.44,
      "text": "NAFサは民間企業の在庫があるだけと"
    },
    {
      "start": 551.0,
      "duration": 6.76,
      "text": "なっていて、これが約20日分と言われて"
    },
    {
      "start": 554.24,
      "duration": 6.44,
      "text": "いました。つまりナフサはガソリンと非常"
    },
    {
      "start": 557.76,
      "duration": 6.079,
      "text": "に近しい存在でありながら、その供給体制"
    },
    {
      "start": 560.68,
      "duration": 5.279,
      "text": "はガソリンと比べかなり脆弱であり、急に"
    },
    {
      "start": 563.839,
      "duration": 4.601,
      "text": "入ってこなくなったという事態に弱い構造"
    },
    {
      "start": 565.959,
      "duration": 4.601,
      "text": "になっていると言えます。"
    },
    {
      "start": 568.44,
      "duration": 5.16,
      "text": "このような背景があるため、イラン危機が"
    },
    {
      "start": 570.56,
      "duration": 5.44,
      "text": "長期化するとともに日本の石油科学産業の"
    },
    {
      "start": 573.6,
      "duration": 5.88,
      "text": "混乱が表立って取り立たされるようになっ"
    },
    {
      "start": 576.0,
      "duration": 6.88,
      "text": "てきたわけです。"
    },
    {
      "start": 579.48,
      "duration": 5.599,
      "text": "ここからは実際に今何が起きているのか"
    },
    {
      "start": 582.88,
      "duration": 5.48,
      "text": "現在のナフサショックの状況を見ていき"
    },
    {
      "start": 585.079,
      "duration": 6.041,
      "text": "たいと思います。過去の動画でも繰り返し"
    },
    {
      "start": 588.36,
      "duration": 5.8,
      "text": "お伝えしてきた通りアメリカとイスラエル"
    },
    {
      "start": 591.12,
      "duration": 5.959,
      "text": "によるイラン攻撃をきっかけに3月初島"
    },
    {
      "start": 594.16,
      "duration": 5.04,
      "text": "からホルムズ海峡が事実上の封鎖状態に"
    },
    {
      "start": 597.079,
      "duration": 5.361,
      "text": "入りました。"
    },
    {
      "start": 599.2,
      "duration": 6.879,
      "text": "日本が原油の約9割、NAFAの約4割を"
    },
    {
      "start": 602.44,
      "duration": 6.2,
      "text": "依存するこの世界物流の大動脈が実績的に"
    },
    {
      "start": 606.079,
      "duration": 5.081,
      "text": "止まっています。"
    },
    {
      "start": 608.64,
      "duration": 5.759,
      "text": "当初トランプ大統領が示した1ヶ月という"
    },
    {
      "start": 611.16,
      "duration": 6.32,
      "text": "期間をすでに超えて未だ紛争解決の糸口は"
    },
    {
      "start": 614.399,
      "duration": 5.281,
      "text": "見つかっていない状況です。"
    },
    {
      "start": 617.48,
      "duration": 4.68,
      "text": "エネルギーの危機についてはこれまでにも"
    },
    {
      "start": 619.68,
      "duration": 4.48,
      "text": "触れてきましたが、NAフサについても"
    },
    {
      "start": 622.16,
      "duration": 5.6,
      "text": "非常に厳しい見通しが示されるようになり"
    },
    {
      "start": 624.16,
      "duration": 6.48,
      "text": "、日本の石油価格産業は供給懸念に直面"
    },
    {
      "start": 627.76,
      "duration": 7.12,
      "text": "することになりました。"
    },
    {
      "start": 630.64,
      "duration": 7.4,
      "text": "まず起きたのがNAF価格の球筒です。"
    },
    {
      "start": 634.88,
      "duration": 5.519,
      "text": "2月末の時点で1t600ドル台後半だっ"
    },
    {
      "start": 638.04,
      "duration": 4.72,
      "text": "たナフサのスポット価格はわずか2"
    },
    {
      "start": 640.399,
      "duration": 4.88,
      "text": "週間余りで1100ドル前後にまで"
    },
    {
      "start": 642.76,
      "duration": 5.92,
      "text": "跳ね上がりました。"
    },
    {
      "start": 645.279,
      "duration": 6.761,
      "text": "石油価格メーカーの取引指標となる国産な"
    },
    {
      "start": 648.68,
      "duration": 7.48,
      "text": "基準価格も2025年10月から12月期"
    },
    {
      "start": 652.04,
      "duration": 7.0,
      "text": "の6万5600円と比べて2026年4月"
    },
    {
      "start": 656.16,
      "duration": 6.16,
      "text": "から6月期は10万円に迫る水準となる"
    },
    {
      "start": 659.04,
      "duration": 5.32,
      "text": "見通しで過去最高額を大幅に更新する勢い"
    },
    {
      "start": 662.32,
      "duration": 4.8,
      "text": "となっています。"
    },
    {
      "start": 664.36,
      "duration": 6.64,
      "text": "価格急を踏まえNAFAの調達が困難に"
    },
    {
      "start": 667.12,
      "duration": 7.959,
      "text": "なったことで国内のエレン製造設備のうち"
    },
    {
      "start": 671.0,
      "duration": 7.32,
      "text": "半数近くが原産体制に入りました。"
    },
    {
      "start": 675.079,
      "duration": 6.121,
      "text": "3月中に稼働率は5割2まで低下し、"
    },
    {
      "start": 678.32,
      "duration": 5.84,
      "text": "いよいよナNAフサの川しである中間製品"
    },
    {
      "start": 681.2,
      "duration": 5.0,
      "text": "や最終製品の価格に影響が及ぶことは避け"
    },
    {
      "start": 684.16,
      "duration": 4.0,
      "text": "られないだろうという認識が強まっていき"
    },
    {
      "start": 686.2,
      "duration": 4.48,
      "text": "ました。"
    },
    {
      "start": 688.16,
      "duration": 5.0,
      "text": "そして3月末から4月にかけて科学"
    },
    {
      "start": 690.68,
      "duration": 4.12,
      "text": "メーカーが一斉に値上げに踏み切りました"
    },
    {
      "start": 693.16,
      "duration": 5.32,
      "text": "。"
    },
    {
      "start": 694.8,
      "duration": 6.8,
      "text": "旭日火星、三井科学、鉱山、三菱ケミカル"
    },
    {
      "start": 698.48,
      "duration": 6.08,
      "text": "、新越科学といった大手からナフサを出発"
    },
    {
      "start": 701.6,
      "duration": 5.799,
      "text": "原料とする製品の緊急値上げが次々と発表"
    },
    {
      "start": 704.56,
      "duration": 5.68,
      "text": "されています。"
    },
    {
      "start": 707.399,
      "duration": 6.361,
      "text": "一方で各社はNAフサ不足の解消を目指し"
    },
    {
      "start": 710.24,
      "duration": 7.2,
      "text": "、アメリカ、中南米、インドなど非中東"
    },
    {
      "start": 713.76,
      "duration": 5.879,
      "text": "からの緊急調達に動くなど必要量の調達に"
    },
    {
      "start": 717.44,
      "duration": 5.6,
      "text": "本送しています。"
    },
    {
      "start": 719.639,
      "duration": 6.601,
      "text": "政府もこれを後押ししていて4月以降赤"
    },
    {
      "start": 723.04,
      "duration": 5.68,
      "text": "経済産業大臣は我が国全体として必要と"
    },
    {
      "start": 726.24,
      "duration": 6.279,
      "text": "なるは確保できていると繰り返し説明し"
    },
    {
      "start": 728.72,
      "duration": 6.239,
      "text": "ながらも流通の部分で出荷などの目詰まり"
    },
    {
      "start": 732.519,
      "duration": 5.241,
      "text": "が起きているとしてこれに対応していく"
    },
    {
      "start": 734.959,
      "duration": 6.0,
      "text": "姿勢を示しています。"
    },
    {
      "start": 737.76,
      "duration": 5.84,
      "text": "大手科学メーカーも日本全体で6月中旬"
    },
    {
      "start": 740.959,
      "duration": 5.68,
      "text": "から6月末ぐらいまでのNAフサ確保には"
    },
    {
      "start": 743.6,
      "duration": 5.799,
      "text": "目度が立ったと述べつつ、残念ながら価格"
    },
    {
      "start": 746.639,
      "duration": 6.0,
      "text": "は倍近くになっているとして、値上げは"
    },
    {
      "start": 749.399,
      "duration": 6.88,
      "text": "避けられないとの見方を示しました。"
    },
    {
      "start": 752.639,
      "duration": 7.0,
      "text": "業界では先機は届かないから高すぎる上"
    },
    {
      "start": 756.279,
      "duration": 6.36,
      "text": "映ってきたと表現されるなど3月末から4"
    },
    {
      "start": 759.639,
      "duration": 6.161,
      "text": "月上旬にかけて量の問題は一旦落ち着き"
    },
    {
      "start": 762.639,
      "duration": 5.121,
      "text": "つつあるものの、今後は価格が高止まりし"
    },
    {
      "start": 765.8,
      "duration": 4.24,
      "text": "ていく可能性が高い状況が見込まれてい"
    },
    {
      "start": 767.76,
      "duration": 5.319,
      "text": "ます。"
    },
    {
      "start": 770.04,
      "duration": 6.599,
      "text": "ではこのNAF価格の高等が私たちの生活"
    },
    {
      "start": 773.079,
      "duration": 5.601,
      "text": "にどのように波及していくのか、時間差で"
    },
    {
      "start": 776.639,
      "duration": 4.121,
      "text": "段階的に影響が出てくると考えられてい"
    },
    {
      "start": 778.68,
      "duration": 5.2,
      "text": "ます。"
    },
    {
      "start": 780.76,
      "duration": 5.92,
      "text": "まず第一波はすでに説明したもので3月"
    },
    {
      "start": 783.88,
      "duration": 5.72,
      "text": "から4月にかけて科学メーカーから加工"
    },
    {
      "start": 786.68,
      "duration": 4.959,
      "text": "業者への原料の出荷価格の値上げとして"
    },
    {
      "start": 789.6,
      "duration": 4.599,
      "text": "起こりました。"
    },
    {
      "start": 791.639,
      "duration": 4.64,
      "text": "食品ラップ、ストレッチフィルム、塗料、"
    },
    {
      "start": 794.199,
      "duration": 4.041,
      "text": "シンナーなどで値上げの発表が相ついでい"
    },
    {
      "start": 796.279,
      "duration": 4.201,
      "text": "ます。"
    },
    {
      "start": 798.24,
      "duration": 4.719,
      "text": "直接消費者に触れるのは食品ラップぐらい"
    },
    {
      "start": 800.48,
      "duration": 5.44,
      "text": "であり、まだ目に見えるような値上げの波"
    },
    {
      "start": 802.959,
      "duration": 5.961,
      "text": "ではないと言えますが、一部の素材では"
    },
    {
      "start": 805.92,
      "duration": 5.64,
      "text": "深刻な供給懸念を引き起こしていて、住宅"
    },
    {
      "start": 808.92,
      "duration": 5.719,
      "text": "設備メーカーがユニットバスなど一部製品"
    },
    {
      "start": 811.56,
      "duration": 6.36,
      "text": "の受中停止を一時発表し、市場に混乱と"
    },
    {
      "start": 814.639,
      "duration": 7.0,
      "text": "懸念を引き起こしました。"
    },
    {
      "start": 817.92,
      "duration": 6.08,
      "text": "第2波は数週間から数ヶ月後、大体4月"
    },
    {
      "start": 821.639,
      "duration": 4.281,
      "text": "下旬から夏頃にかけて現れると見られてい"
    },
    {
      "start": 824.0,
      "duration": 4.399,
      "text": "ます。"
    },
    {
      "start": 825.92,
      "duration": 5.599,
      "text": "加工業者から小売り業者へのおろし価格が"
    },
    {
      "start": 828.399,
      "duration": 6.0,
      "text": "上がり、スーパーで使われる食品トレー袋"
    },
    {
      "start": 831.519,
      "duration": 5.56,
      "text": "、ペットボトル飲料、シャンプーボトル、"
    },
    {
      "start": 834.399,
      "duration": 7.841,
      "text": "紙オムや日用品全般に波及していく見通し"
    },
    {
      "start": 837.079,
      "duration": 8.241,
      "text": "です。また顕在の塩美間、断熱剤、塗料、"
    },
    {
      "start": 842.24,
      "duration": 4.92,
      "text": "接着剤なども値上がりし、住宅価格や"
    },
    {
      "start": 845.32,
      "duration": 4.16,
      "text": "リフォーム費用にも影響が出てくると予想"
    },
    {
      "start": 847.16,
      "duration": 5.88,
      "text": "されます。"
    },
    {
      "start": 849.48,
      "duration": 6.96,
      "text": "第3波はさらにその先、数ヶ月後から1年"
    },
    {
      "start": 853.04,
      "duration": 6.56,
      "text": "程度の時間軸で現れると見られています。"
    },
    {
      "start": 856.44,
      "duration": 6.16,
      "text": "医療品の合成繊維、タイヤ、自動車部品、"
    },
    {
      "start": 859.6,
      "duration": 6.599,
      "text": "家電製品にまで影響が及び医療用品にも"
    },
    {
      "start": 862.6,
      "duration": 6.2,
      "text": "波及する可能性があります。この時間差は"
    },
    {
      "start": 866.199,
      "duration": 5.32,
      "text": "主に製品の在庫量の違いから生じるもので"
    },
    {
      "start": 868.8,
      "duration": 5.719,
      "text": "、生産から販売までのリードタイムが短い"
    },
    {
      "start": 871.519,
      "duration": 6.721,
      "text": "ものは早く、長いものは遅く影響が出て"
    },
    {
      "start": 874.519,
      "duration": 6.521,
      "text": "くるという流れが反映されたものです。"
    },
    {
      "start": 878.24,
      "duration": 6.2,
      "text": "掃じて一時総然としていたナフ崎機のよう"
    },
    {
      "start": 881.04,
      "duration": 5.919,
      "text": "な状態からは出していて当量は確保できて"
    },
    {
      "start": 884.44,
      "duration": 5.92,
      "text": "いるものの調達の厳しさは続いていく"
    },
    {
      "start": 886.959,
      "duration": 6.24,
      "text": "見通しです。もはや第2波は避けがい女性"
    },
    {
      "start": 890.36,
      "duration": 7.039,
      "text": "であり、第3波の到来も現実身を増してい"
    },
    {
      "start": 893.199,
      "duration": 6.961,
      "text": "ます。また当面の確保というのも6月まで"
    },
    {
      "start": 897.399,
      "duration": 5.12,
      "text": "ということなので中東情勢が緩和しなけれ"
    },
    {
      "start": 900.16,
      "duration": 5.28,
      "text": "ば日に日に苦しくなっていくことが予想さ"
    },
    {
      "start": 902.519,
      "duration": 5.68,
      "text": "れます。"
    },
    {
      "start": 905.44,
      "duration": 5.48,
      "text": "見通しは決して明るくない中、イラン危機"
    },
    {
      "start": 908.199,
      "duration": 5.921,
      "text": "は早期に収束するだろうという味方が市場"
    },
    {
      "start": 910.92,
      "duration": 5.4,
      "text": "を中心になお根強く受給緩和への期待も"
    },
    {
      "start": 914.12,
      "duration": 4.92,
      "text": "あります。"
    },
    {
      "start": 916.32,
      "duration": 5.319,
      "text": "しかしここで抑えておきたいのは危機が"
    },
    {
      "start": 919.04,
      "duration": 5.359,
      "text": "解消したとしても価格がすんなり元に戻る"
    },
    {
      "start": 921.639,
      "duration": 5.521,
      "text": "わけではないということです。"
    },
    {
      "start": 924.399,
      "duration": 7.281,
      "text": "まず中東を起点とする流通が再開したとし"
    },
    {
      "start": 927.16,
      "duration": 7.08,
      "text": "ても各国各企業は今回の教訓を踏まえて"
    },
    {
      "start": 931.68,
      "duration": 6.32,
      "text": "すに中東依存を見直しする動きに入ってい"
    },
    {
      "start": 934.24,
      "duration": 6.36,
      "text": "ます。そのため供給体制は元の形には戻ら"
    },
    {
      "start": 938.0,
      "duration": 5.319,
      "text": "ずコスト構造そのものが変わってしまう"
    },
    {
      "start": 940.6,
      "duration": 5.239,
      "text": "可能性があります。"
    },
    {
      "start": 943.319,
      "duration": 6.08,
      "text": "また価格には1度上がったらそう簡単には"
    },
    {
      "start": 945.839,
      "duration": 6.641,
      "text": "下がらないという過法硬直性があり、状況"
    },
    {
      "start": 949.399,
      "duration": 7.041,
      "text": "がある程度改善したとしても元の価格には"
    },
    {
      "start": 952.48,
      "duration": 6.52,
      "text": "戻りきらないことが予想されます。"
    },
    {
      "start": 956.44,
      "duration": 6.399,
      "text": "そもそもイラン危機事態がどのように収束"
    },
    {
      "start": 959.0,
      "duration": 6.6,
      "text": "するのかもなお不透明な状況です。"
    },
    {
      "start": 962.839,
      "duration": 5.841,
      "text": "4月8日にアメリカとイランが2週間の"
    },
    {
      "start": 965.6,
      "duration": 6.08,
      "text": "戦闘停止で合意しましたが、直後から不"
    },
    {
      "start": 968.68,
      "duration": 6.92,
      "text": "安定な展開が続いていて、トランプ大統領"
    },
    {
      "start": 971.68,
      "duration": 7.159,
      "text": "は4月12日にホルムズ海峡に関して逆"
    },
    {
      "start": 975.6,
      "duration": 6.52,
      "text": "風鎖を表明しました。"
    },
    {
      "start": 978.839,
      "duration": 5.881,
      "text": "米軍は4月13日からイランの公案に"
    },
    {
      "start": 982.12,
      "duration": 5.44,
      "text": "出入りする船舶を対象とした海場風鎖を"
    },
    {
      "start": 984.72,
      "duration": 4.479,
      "text": "発動し、イランへの浪攻めを開始しました"
    },
    {
      "start": 987.56,
      "duration": 3.839,
      "text": "。"
    },
    {
      "start": 989.199,
      "duration": 4.921,
      "text": "直近で停戦が延長されたというニュースも"
    },
    {
      "start": 991.399,
      "duration": 6.161,
      "text": "入ってきていますが、完全な収束までには"
    },
    {
      "start": 994.12,
      "duration": 5.8,
      "text": "まだまだ時間がかかる可能性があります。"
    },
    {
      "start": 997.56,
      "duration": 4.92,
      "text": "仮にトランプ政権が戦闘から手を引いたと"
    },
    {
      "start": 999.92,
      "duration": 5.96,
      "text": "しても、ホルムズ海峡を巡る問題そのもの"
    },
    {
      "start": 1002.48,
      "duration": 5.96,
      "text": "はそう簡単には解決しません。"
    },
    {
      "start": 1005.88,
      "duration": 5.48,
      "text": "イランにとってホルムズ海峡は国際社会に"
    },
    {
      "start": 1008.44,
      "duration": 5.0,
      "text": "対する重要な人質のような存在で、そう"
    },
    {
      "start": 1011.36,
      "duration": 4.2,
      "text": "簡単には使い切ることができない最後の"
    },
    {
      "start": 1013.44,
      "duration": 4.399,
      "text": "切り札です。"
    },
    {
      "start": 1015.56,
      "duration": 5.12,
      "text": "戦闘が終わってもイランによる通行量の"
    },
    {
      "start": 1017.839,
      "duration": 5.761,
      "text": "徴収や保険料の上昇といった物流コストの"
    },
    {
      "start": 1020.68,
      "duration": 5.159,
      "text": "増加など解決が難しい課題が残ると見られ"
    },
    {
      "start": 1023.6,
      "duration": 5.239,
      "text": "ています。"
    },
    {
      "start": 1025.839,
      "duration": 5.6,
      "text": "すでに国際エネルギー機関を始め、各専門"
    },
    {
      "start": 1028.839,
      "duration": 5.761,
      "text": "家からは市場最大のエネルギー機器である"
    },
    {
      "start": 1031.439,
      "duration": 5.88,
      "text": "と明言されていて、戦闘開始からもう2"
    },
    {
      "start": 1034.6,
      "duration": 4.959,
      "text": "ヶ月、単なる懸念ではなくなってきている"
    },
    {
      "start": 1037.319,
      "duration": 4.321,
      "text": "のが現状です。"
    },
    {
      "start": 1039.559,
      "duration": 5.201,
      "text": "パニックになる必要はありませんが、ある"
    },
    {
      "start": 1041.64,
      "duration": 7.52,
      "text": "程度の値上げや経済的混乱の継続は覚悟し"
    },
    {
      "start": 1044.76,
      "duration": 4.4,
      "text": "なければならないと言えそうです。"
    },
    {
      "start": 1050.16,
      "duration": 6.399,
      "text": "それでは今回のまとめです。NAFAは"
    },
    {
      "start": 1053.52,
      "duration": 5.8,
      "text": "原油から生成される蘇生ガソリンで"
    },
    {
      "start": 1056.559,
      "duration": 6.0,
      "text": "プラスチック、合成繊維、合成ゴム、塗料"
    },
    {
      "start": 1059.32,
      "duration": 5.599,
      "text": "、洗剤などあらゆる石油価格製品の出発点"
    },
    {
      "start": 1062.559,
      "duration": 5.24,
      "text": "となる素材です。"
    },
    {
      "start": 1064.919,
      "duration": 6.241,
      "text": "日本のNAフサは実質的に中東への依存度"
    },
    {
      "start": 1067.799,
      "duration": 7.12,
      "text": "が高く、今回のホルムズ海峡風鎖でナフサ"
    },
    {
      "start": 1071.16,
      "duration": 7.04,
      "text": "価格は急し、その結果4月以降大手科学"
    },
    {
      "start": 1074.919,
      "duration": 6.521,
      "text": "メーカーの大型値上げが連鎖し、今後は"
    },
    {
      "start": 1078.2,
      "duration": 7.12,
      "text": "日用品、県材、医療品などに時間差で波及"
    },
    {
      "start": 1081.44,
      "duration": 5.52,
      "text": "していく見込みだということでした。"
    },
    {
      "start": 1085.32,
      "duration": 3.839,
      "text": "それでは今回も最後まで見てくれて"
    },
    {
      "start": 1086.96,
      "duration": 5.44,
      "text": "ありがとうございました。またお会いし"
    },
    {
      "start": 1089.159,
      "duration": 3.241,
      "text": "ましょう。"
    }
  ]
}