      "start": 1201.52,
      "duration": 3.399,
      "text": "ましたみたいなね。ちょっとこれ極端な話"
    },
    {
      "start": 1203.4,
      "duration": 4.72,
      "text": "ですけど、そういうことがあり得るわけ"
    },
    {
      "start": 1204.919,
      "duration": 5.601,
      "text": "ですよ。それはまさに複数の路線を描いて"
    },
    {
      "start": 1208.12,
      "duration": 5.12,
      "text": "どれが正しいかっていうのを常に模索して"
    },
    {
      "start": 1210.52,
      "duration": 5.12,
      "text": "いるからこそいったことが起きるわけです"
    },
    {
      "start": 1213.24,
      "duration": 5.16,
      "text": "ね。外から見たらね、調礼簿解みたいな"
    },
    {
      "start": 1215.64,
      "duration": 4.56,
      "text": "感じに見えるけれども、それを常にやって"
    },
    {
      "start": 1218.4,
      "duration": 3.68,
      "text": "いる。で、結果として、ま、今日ね、"
    },
    {
      "start": 1220.2,
      "duration": 4.959,
      "text": "タイミングの話と言いましたけれども、"
    },
    {
      "start": 1222.08,
      "duration": 5.12,
      "text": "結果として下手なタイミングで動かずいい"
    },
    {
      "start": 1225.159,
      "duration": 3.961,
      "text": "タイミングで動けている。ま、何より失敗"
    },
    {
      "start": 1227.2,
      "duration": 4.24,
      "text": "を避けているんですね。失敗を避けている"
    },
    {
      "start": 1229.12,
      "duration": 4.76,
      "text": "からこそ、え、うまい結果が出ていると"
    },
    {
      "start": 1231.44,
      "duration": 2.84,
      "text": "いう話ではないかと、え、いう風に思い"
    },
    {
      "start": 1233.88,
      "duration": 3.4,
      "text": "ます。"
    },
    {
      "start": 1234.28,
      "duration": 3.0,
      "text": "こういう思考の癖をトレーニングしていくことが投資会にとって求められることなんじゃないかなと思いますね。おきちゃんいかがでしょうか?"
    },
    {
      "start": 1241.2,
      "duration": 3.0,
      "text": "逆を考えるっていうところが自分的に響いてやっぱり考えることの重要性となんとなくなんですけどなんか自分に謙虚でいることの考えました思いますよ。"
    },
    {
      "start": 1252.24,
      "duration": 5.04,
      "text": "投資って人間力だなって人間力を鍛える"
    },
    {
      "start": 1254.919,
      "duration": 4.841,
      "text": "ことで結果的にうまくいくっていうような"
    },
    {
      "start": 1257.28,
      "duration": 4.2,
      "text": "そんな話もここに拡大解釈としてはね、"
    },
    {
      "start": 1259.76,
      "duration": 4.399,
      "text": "あるかなと思うんで、皆さんもね、是非"
    },
    {
      "start": 1261.48,
      "duration": 4.12,
      "text": "自分の心に手を当てて、え、考えて"
    },
    {
      "start": 1264.159,
      "duration": 3.321,
      "text": "いただけるといいんじゃないかなと思い"
    },
    {
      "start": 1265.6,
      "duration": 3.439,
      "text": "ます。テクニックとしてはね、AIに"
    },
    {
      "start": 1267.48,
      "duration": 3.96,
      "text": "まさに聞いてみるといいんですよ。自分は"
    },
    {
      "start": 1269.039,
      "duration": 5.041,
      "text": "今こう考えてるけど、逆に考えたらどう"
    },
    {
      "start": 1271.44,
      "duration": 4.239,
      "text": "なりますかって。この一言言えばね、具体"
    },
    {
      "start": 1274.08,
      "duration": 3.76,
      "text": "的にもう出してくれるじゃないですか。"
    },
    {
      "start": 1275.679,
      "duration": 3.6,
      "text": "それってめちゃくちゃ大事なんで、AI"
    },
    {
      "start": 1277.84,
      "duration": 3.56,
      "text": "ってこういうとこに使うべきかなと思い"
    },
    {
      "start": 1279.279,
      "duration": 4.201,
      "text": "ますね。投資判断をしようとした時に"
    },
    {
      "start": 1281.4,
      "duration": 4.32,
      "text": "ちょっと聞いてみる。この1手間があなた"
    },
    {
      "start": 1283.48,
      "duration": 4.12,
      "text": "を救うことになるかもしれません。この"
    },
    {
      "start": 1285.72,
      "duration": 4.12,
      "text": "ようにですね、つばメ投資顧問では投資に"
    },
    {
      "start": 1287.6,
      "duration": 4.72,
      "text": "関する大事な議論をやっています。え、"
    },
    {
      "start": 1289.84,
      "duration": 5.079,
      "text": "先ほどもお案内いたしました通り、つば"
    },
    {
      "start": 1292.32,
      "duration": 4.88,
      "text": "年駒の投資助言サービスですね。こちら"
    },
    {
      "start": 1294.919,
      "duration": 5.521,
      "text": "現在入会機半額キャンペーンをやっており"
    },
    {
      "start": 1297.2,
      "duration": 6.16,
      "text": "ます。4月26日まで通常3万3000円"
    },
    {
      "start": 1300.44,
      "duration": 4.88,
      "text": "の入会金が1万6500円となる。非常に"
    },
    {
      "start": 1303.36,
      "duration": 4.4,
      "text": "お得な機会となっておりますし、この"
    },
    {
      "start": 1305.32,
      "duration": 5.239,
      "text": "キャンペーン後ですね、新たに入られる方"
    },
    {
      "start": 1307.76,
      "duration": 4.76,
      "text": "に関しては現在の料金から、ま、変更です"
    },
    {
      "start": 1310.559,
      "duration": 4.0,
      "text": "ね、結果的にちょっと上がることになるか"
    },
    {
      "start": 1312.52,
      "duration": 4.12,
      "text": "なと思います。年間会員についてですね、"
    },
    {
      "start": 1314.559,
      "duration": 4.321,
      "text": "そういった状況もありますので、詳しくは"
    },
    {
      "start": 1316.64,
      "duration": 4.12,
      "text": "ホームページご覧になっていただけたらと"
    },
    {
      "start": 1318.88,
      "duration": 4.12,
      "text": "思います。また、あの、つまみの投資もや"
    },
    {
      "start": 1320.76,
      "duration": 4.24,
      "text": "長期投資についてもっと詳しく知りたいと"
    },
    {
      "start": 1323.0,
      "duration": 4.159,
      "text": "いう方がいらっしゃいましたら下の詳細欄"
    },
    {
      "start": 1325.0,
      "duration": 5.279,
      "text": "にございます無料のメールマガジンにご"
    },
    {
      "start": 1327.159,
      "duration": 6.321,
      "text": "登録ください。ここで私が書いた電子書籍"
    },
    {
      "start": 1330.279,
      "duration": 5.681,
      "text": "株式市場の歯者になる前に読む本も無料で"
    },
    {
      "start": 1333.48,
      "duration": 4.559,
      "text": "お届けしていますので是非ご覧になって"
    },
    {
      "start": 1335.96,
      "duration": 4.199,
      "text": "いただけたらと思います。この動画がいい"
    },
    {
      "start": 1338.039,
      "duration": 3.76,
      "text": "ねと思ったらグッドボタンやスマート"
    },
    {
      "start": 1340.159,
      "duration": 3.64,
      "text": "フォンからでしたらハイプボタンというの"
    },
    {
      "start": 1341.799,
      "duration": 4.76,
      "text": "がありますのでね、え、是非そちらも押し"
    },
    {
      "start": 1343.799,
      "duration": 5.081,
      "text": "ていただけたらなと思います。ご感想やご"
    },
    {
      "start": 1346.559,
      "duration": 4.081,
      "text": "質問はコメント欄にお寄せください。それ"
    },
    {
      "start": 1348.88,
      "duration": 5.64,
      "text": "では皆さんご視聴ありがとうございました"
    },
    {
      "start": 1350.64,
      "duration": 3.88,
      "text": "。またお会いしましょう。"
    }
  ]
}