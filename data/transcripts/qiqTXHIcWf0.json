      "start": 361.199,
      "duration": 4.28,
      "text": "買おうかと思ったら割とあっさりすぐ最初"
    },
    {
      "start": 362.88,
      "duration": 4.56,
      "text": "の募集金額締め切られたりとかファンド"
    },
    {
      "start": 365.479,
      "duration": 3.801,
      "text": "ノートに講座を直接開けないといけないの"
    },
    {
      "start": 367.44,
      "duration": 2.64,
      "text": "がめどくさいなとか色々なんか住民表取っ"
    },
    {
      "start": 369.28,
      "duration": 3.44,
      "text": "てこないといけないとかなんかそういうの"
    },
    {
      "start": 370.08,
      "duration": 6.16,
      "text": "があってもやってなかったんですけどもま"
    },
    {
      "start": 372.72,
      "duration": 5.28,
      "text": "か実はねこれ第3者の第3の投資家個人"
    },
    {
      "start": 376.24,
      "duration": 4.64,
      "text": "投資家関係ねえやと思ってる皆さんにも"
    },
    {
      "start": 378.0,
      "duration": 6.28,
      "text": "関係あるかもしれないのがこの後おそらく"
    },
    {
      "start": 380.88,
      "duration": 6.12,
      "text": "こういう状況になるとイ村さんのファンド"
    },
    {
      "start": 384.28,
      "duration": 5.08,
      "text": "に対してじゃあイ村さんがやめるかもしん"
    },
    {
      "start": 387.0,
      "duration": 3.4,
      "text": "ないんだったらいいよつってまかなり"
    },
    {
      "start": 389.36,
      "duration": 4.399,
      "text": "パフォーマンスが上がってるってことも"
    },
    {
      "start": 390.4,
      "duration": 5.96,
      "text": "含めて解約売りが解約が膨らむ可能性が"
    },
    {
      "start": 393.759,
      "duration": 4.201,
      "text": "あります。投資信託の受益者から。で、"
    },
    {
      "start": 396.36,
      "duration": 3.239,
      "text": "これはもちろん個人投資家としては当然の"
    },
    {
      "start": 397.96,
      "duration": 3.12,
      "text": "権利なんで別にそのこと自体をもう誰も"
    },
    {
      "start": 399.599,
      "duration": 4.521,
      "text": "止めることはできないんですけども悪い"
    },
    {
      "start": 401.08,
      "duration": 6.2,
      "text": "ことでもないんだけどもそうするとパンド"
    },
    {
      "start": 404.12,
      "duration": 4.639,
      "text": "ノートはイ村さんとの契約が続くのかこの"
    },
    {
      "start": 407.28,
      "duration": 3.44,
      "text": "後続かないのかはっきりまだしないんです"
    },
    {
      "start": 408.759,
      "duration": 3.961,
      "text": "けども"
    },
    {
      "start": 410.72,
      "duration": 4.319,
      "text": "裏ざるを終えなくなるんですよね。当然"
    },
    {
      "start": 412.72,
      "duration": 6.36,
      "text": "監禁しないとお金返さないといけない。"
    },
    {
      "start": 415.039,
      "duration": 9.081,
      "text": "信託でも解約したら何日かでそれに対して"
    },
    {
      "start": 419.08,
      "duration": 8.08,
      "text": "の解約売りそして今えっと投資信託"
    },
    {
      "start": 424.12,
      "duration": 6.479,
      "text": "運用会社としてのファンドノートの12月"
    },
    {
      "start": 427.16,
      "duration": 5.479,
      "text": "末時点の預かりしさを見るとま9割型実は"
    },
    {
      "start": 430.599,
      "duration": 3.641,
      "text": "解放なんですよ。この要するにイ村"
    },
    {
      "start": 432.639,
      "duration": 5.0,
      "text": "ファンドなんですよ。イ村ファンドが"
    },
    {
      "start": 434.24,
      "duration": 6.32,
      "text": "384億円。あけぼ28億円。これ川"
    },
    {
      "start": 437.639,
      "duration": 6.4,
      "text": "ファンドですね。で、最高11.6億円。"
    },
    {
      "start": 440.56,
      "duration": 6.68,
      "text": "これ神やファンドですよ。なんで"
    },
    {
      "start": 444.039,
      "duration": 5.84,
      "text": "川井ファンドと神ファンドを足してそれで"
    },
    {
      "start": 447.24,
      "duration": 5.48,
      "text": "やっとイ村ファンドの1/1ぐらいという"
    },
    {
      "start": 449.879,
      "duration": 5.04,
      "text": "ような状況になってます。で、これは別に"
    },
    {
      "start": 452.72,
      "duration": 5.199,
      "text": "不安を煽るわけじゃないけど、一般論とし"
    },
    {
      "start": 454.919,
      "duration": 5.361,
      "text": "て会社運営、投資アセットマネジメント"
    },
    {
      "start": 457.919,
      "duration": 5.0,
      "text": "会社の運営ってのは資産残高に対して信託"
    },
    {
      "start": 460.28,
      "duration": 5.0,
      "text": "報酬が、ま、ざっくり1%とかね、かかっ"
    },
    {
      "start": 462.919,
      "duration": 3.441,
      "text": "て、その残高からそのいろんなシステムの"
    },
    {
      "start": 465.28,
      "duration": 2.24,
      "text": "運用費だったりとか、ファンド"
    },
    {
      "start": 466.36,
      "duration": 2.72,
      "text": "マネージャーの給料だったりとか、"
    },
    {
      "start": 467.52,
      "duration": 4.88,
      "text": "オフィスの家賃だったりとか出てると思う"
    },
    {
      "start": 469.08,
      "duration": 5.119,
      "text": "んで、イ村ファンドから"
    },
    {
      "start": 472.4,
      "duration": 3.44,
      "text": "ごそっとこれからもしこれわかんないです"
    },
    {
      "start": 474.199,
      "duration": 5.521,
      "text": "よ。わかんないんだけど、お金が抜けてく"
    },
    {
      "start": 475.84,
      "duration": 7.759,
      "text": "んだとすると当然ファンドノートの経営に"
    },
    {
      "start": 479.72,
      "duration": 6.919,
      "text": "も重大な影響が出る可能性があり、え、"
    },
    {
      "start": 483.599,
      "duration": 4.361,
      "text": "特にCIOの川さんとかは、ま、もちろん"
    },
    {
      "start": 486.639,
      "duration": 4.481,
      "text": "役員でもいらっしゃるわけだから、"
    },
    {
      "start": 487.96,
      "duration": 5.0,
      "text": "ファンドノートの会社としての、ま、自分"
    },
    {
      "start": 491.12,
      "duration": 3.479,
      "text": "のファンドの運用どころじゃなくなるん"
    },
    {
      "start": 492.96,
      "duration": 4.959,
      "text": "じゃないかみたいな懸念が出てくるのも、"
    },
    {
      "start": 494.599,
      "duration": 6.841,
      "text": "まあ、大人の推測として、え、普通かなと"
    },
    {
      "start": 497.919,
      "duration": 5.96,
      "text": "も思ってます。で、そんな状況の中でこれ"
    },
    {
      "start": 501.44,
      "duration": 5.12,
      "text": "から反動ノートどうなるんやってことなん"
    },
    {
      "start": 503.879,
      "duration": 4.28,
      "text": "でしょうけども、ま、いろんなこういうね"
    },
    {
      "start": 506.56,
      "duration": 3.52,
      "text": "、ジョイントベンチャーとか、ま、"
    },
    {
      "start": 508.159,
      "duration": 3.921,
      "text": "ベンチャーの創業チームの、ま、ある種の"
    },
    {
      "start": 510.08,
      "duration": 4.36,
      "text": "仲間みたいなことを見てきた人間からする"
    },
    {
      "start": 512.08,
      "duration": 4.759,
      "text": "と、"
    },
    {
      "start": 514.44,
      "duration": 4.399,
      "text": "まあ、この前の1年前の動画見てもらって"
    },
    {
      "start": 516.839,
      "duration": 3.76,
      "text": "も分かるんですけど、大体なんかうん。"
    },
    {
      "start": 518.839,
      "duration": 3.281,
      "text": "これうまくいったらうまくいったで喧嘩"
    },
    {
      "start": 520.599,
      "duration": 5.481,
      "text": "するバンドみたいにパターンだろうなって"
    },
    {
      "start": 522.12,
      "duration": 5.88,
      "text": "のは僕からしてみたら僕の想像で"
    },
    {
      "start": 526.08,
      "duration": 3.92,
      "text": "イ村さんは本当にすごい方だと思います。"
    },
    {
      "start": 528.0,
      "duration": 4.72,
      "text": "運用に関してすごい方だと思うんですけど"
    },
    {
      "start": 530.0,
      "duration": 5.279,
      "text": "も、僕今さんはめちゃくちゃ尊敬してるし"
    },
    {
      "start": 532.72,
      "duration": 5.52,
      "text": "、そういったなんかな、彼の個人投資会の"
    },
    {
      "start": 535.279,
      "duration": 4.601,
      "text": "思いみたいなところは全然まも間違って"
    },
    {
      "start": 538.24,
      "duration": 2.92,
      "text": "ないし、僕なんかよりもよっぽど立派な"
    },
    {
      "start": 539.88,
      "duration": 2.88,
      "text": "思いで取り組まれてるっていうのは"
    },
    {
      "start": 541.16,
      "duration": 3.359,
      "text": "いろんな意味で、その能力、心志しとか"
    },
    {
      "start": 542.76,
      "duration": 3.56,
      "text": "そういった意味ではそうなんだけども、"
    },
    {
      "start": 544.519,
      "duration": 5.521,
      "text": "イ村さんってよくも悪くも普通の会社"
    },
    {
      "start": 546.32,
      "duration": 6.24,
      "text": "務めると意見ないんですよね。で、こう"
    },
    {
      "start": 550.04,
      "duration": 4.32,
      "text": "いう状況になるとおそらく水面でファンド"
    },
    {
      "start": 552.56,
      "duration": 3.16,
      "text": "ノットの渡辺さんとイ村さんってもう何回"
    },
    {
      "start": 554.36,
      "duration": 3.08,
      "text": "かさすがに話してはいると思うんですよ。"
    },
    {
      "start": 555.72,
      "duration": 4.64,
      "text": "ま、それLINEとか対面なかわからん"
    },
    {
      "start": 557.44,
      "duration": 5.28,
      "text": "けど。こういう時に僕が渡辺さんの立場"
    },
    {
      "start": 560.36,
      "duration": 3.719,
      "text": "だったらまあまあまあまあい村さんの言う"
    },
    {
      "start": 562.72,
      "duration": 4.2,
      "text": "こともめちゃくちゃよく分かるし"
    },
    {
      "start": 564.079,
      "duration": 4.561,
      "text": "おっしゃる通りなんだけども現実色々大人"
    },
    {
      "start": 566.92,
      "duration": 3.88,
      "text": "の事情があってこうであーデこうでああで"
    },
    {
      "start": 568.64,
      "duration": 4.759,
      "text": "なんでいきなり100点か0かみたいな"
    },
    {
      "start": 570.8,
      "duration": 5.719,
      "text": "こと求められても我々も困るんでまあまあ"
    },
    {
      "start": 573.399,
      "duration": 4.921,
      "text": "まあせか合わせ飲んで大人の対応で本当"
    },
    {
      "start": 576.519,
      "duration": 5.721,
      "text": "ここは1つお願いしますよ。こんなことを"
    },
    {
      "start": 578.32,
      "duration": 6.4,
      "text": "改立ずに行った言って俺が渡辺さんの立場"
    },
    {
      "start": 582.24,
      "duration": 3.8,
      "text": "だったら頭下げまくってると思う正直で"
    },
    {
      "start": 584.72,
      "duration": 3.2,
      "text": "おそらく渡辺さんもそういうことやってん"
    },
    {
      "start": 586.04,
      "duration": 4.28,
      "text": "じゃないかと思うんだけどもそれに対して"
    },
    {
      "start": 587.92,
      "duration": 5.0,
      "text": "イ村さんは髪の毛1本落ちてることすら"
    },
    {
      "start": 590.32,
      "duration": 3.84,
      "text": "許せない。そんな妥協すら許せないと個人"
    },
    {
      "start": 592.92,
      "duration": 3.24,
      "text": "投資家のためになってない。で、これも"
    },
    {
      "start": 594.16,
      "duration": 5.919,
      "text": "これで間違いじゃないんだよ。間違いじゃ"
    },
    {
      "start": 596.16,
      "duration": 6.239,
      "text": "ないんだけども、ちょっと理想にこだわり"
    },
    {
      "start": 600.079,
      "duration": 4.921,
      "text": "すぎた結果、その折り合いがつかずに別れ"
    },
    {
      "start": 602.399,
      "duration": 4.841,
      "text": "てしまうというな状況になってて、で、僕"
    },
    {
      "start": 605.0,
      "duration": 6.12,
      "text": "が、ま、渡辺さんみたいな立場からしてみ"
    },
    {
      "start": 607.24,
      "duration": 6.8,
      "text": "たら、ああ、1回も普通の会社務めした"
    },
    {
      "start": 611.12,
      "duration": 4.839,
      "text": "ことない人間のその、ま、弱点って言っ"
    },
    {
      "start": 614.04,
      "duration": 5.08,
      "text": "たらちょっと語弊があるけど、そういう"
    },
    {
      "start": 615.959,
      "duration": 5.281,
      "text": "特徴が出てしまったかなみたいなとこで、"
    },
    {
      "start": 619.12,
      "duration": 4.839,
      "text": "ま、普通の妥協が許されないわけですよね"
    },
    {
      "start": 621.24,
      "duration": 4.599,
      "text": "。要するに。で、妥協を許さず色々投資先"
    },
    {
      "start": 623.959,
      "duration": 4.081,
      "text": "の金曜にも改善を迫ってたと思うし、それ"
    },
    {
      "start": 625.839,
      "duration": 4.601,
      "text": "はもう全然悪いことじゃないんだけども、"
    },
    {
      "start": 628.04,
      "duration": 4.64,
      "text": "まあまあまあまあまあっていうところとか"
    },
    {
      "start": 630.44,
      "duration": 6.04,
      "text": "さすがに表で揉め出したらもう2度と引け"
    },
    {
      "start": 632.68,
      "duration": 6.56,
      "text": "ないってところとかも含めて、え、村さん"
    },
    {
      "start": 636.48,
      "duration": 4.76,
      "text": "がどういう認識でいるのかなと。で、僕が"
    },
    {
      "start": 639.24,
      "duration": 4.52,
      "text": "さんの立場だったらことここまで荒立てる"
    },
    {
      "start": 641.24,
      "duration": 5.48,
      "text": "んだったら逆に乗り換え先の投資信託が"
    },
    {
      "start": 643.76,
      "duration": 5.04,
      "text": "もう1ヶ月以内ぐらいにできてる準備が"
    },
    {
      "start": 646.72,
      "duration": 5.239,
      "text": "できてんのかなと。そうじゃなかったら"
    },
    {
      "start": 648.8,
      "duration": 4.88,
      "text": "おそらくさんってまだそこまで準備ができ"
    },
    {
      "start": 651.959,
      "duration": 4.56,
      "text": "てないんじゃないかっていう可能性も"
    },
    {
      "start": 653.68,
      "duration": 5.599,
      "text": "感じるんですよ。そしたら1番困るのは"
    },
    {
      "start": 656.519,
      "duration": 5.241,
      "text": "イ村ファンドにお金384億円の残が預け"
    },
    {
      "start": 659.279,
      "duration": 4.081,
      "text": "てる受益者投資家じゃないですか?投資家"
    },
    {
      "start": 661.76,
      "duration": 3.639,
      "text": "からしてみたらどうしたらええやねん。"
    },
    {
      "start": 663.36,
      "duration": 3.44,
      "text": "解約してじゃあ今村さんがオリジナルの別"
    },
    {
      "start": 665.399,
      "duration": 3.68,
      "text": "の感動すぐ立ち上げるんだったらそっち"
    },
    {
      "start": 666.8,
      "duration": 4.92,
      "text": "映れますと。で、それならそれでいいん"
    },
    {
      "start": 669.079,
      "duration": 6.32,
      "text": "ですけど、僕が村さんの立ったらイ村さん"
    },
    {
      "start": 671.72,
      "duration": 6.4,
      "text": "は動画でみんなの前でここまでファンド"
    },
    {
      "start": 675.399,
      "duration": 4.841,
      "text": "ノートと揉める時にもうすぐ乗り換え先の"
    },
    {
      "start": 678.12,
      "duration": 4.839,
      "text": "新しい船がもう用意できてんのかなっての"
    },
    {
      "start": 680.24,
      "duration": 4.68,
      "text": "は僕からしてみたら1番気になるところで"
    },
    {
      "start": 682.959,
      "duration": 3.961,
      "text": "、そこまでできてる可能性もちろんある。"
    },
    {
      "start": 684.92,
      "duration": 4.24,
      "text": "そうだとしたら手回しがいいのでさすが"
    },
    {
      "start": 686.92,
      "duration": 4.08,
      "text": "イ村さんと運用だけじゃなくていろんな"
    },
    {
      "start": 689.16,
      "duration": 4.239,
      "text": "そのビジネスの取り回し切り回しって意味"
    },
    {
      "start": 691.0,
      "duration": 5.48,
      "text": "でも分かってますねってところなんだけど"
    },
    {
      "start": 693.399,
      "duration": 5.761,
      "text": "もそれは正直よくわからない。そうすると"
    },
    {
      "start": 696.48,
      "duration": 4.4,
      "text": "結局1番困るのは個人投資家じゃないです"
    },
    {
      "start": 699.16,
      "duration": 3.96,
      "text": "か?重益者じゃないですか。で、そういっ"
    },
    {
      "start": 700.88,
      "duration": 4.92,
      "text": "たところで言うとその乗り換え先ができる"
    },
    {
      "start": 703.12,
      "duration": 4.959,
      "text": "までも、ま、面重複入ってんですか"
    },
    {
      "start": 705.8,
      "duration": 4.719,
      "text": "?りくらりのらりくらいファンドノートに"
    },
    {
      "start": 708.079,
      "duration": 5.2,
      "text": "言いながら準備だけしといて、ある日突然"
    },
    {
      "start": 710.519,
      "duration": 4.76,
      "text": "スパッて喧嘩別れしてクーデターのように"
    },
    {
      "start": 713.279,
      "duration": 4.24,
      "text": "出てって、で、動画とかYouTubeと"
    },
    {
      "start": 715.279,
      "duration": 5.961,
      "text": "かTwitterとかで、私の新しい"
    },
    {
      "start": 717.519,
      "duration": 5.841,
      "text": "ファンドはこれですと言って、ま、それも"
    },
    {
      "start": 721.24,
      "duration": 4.68,
      "text": "ちょっとそれで買いが殺頭しすぎたら無"
    },
    {
      "start": 723.36,
      "duration": 4.12,
      "text": "責任になるのかもしれないんだけどもで、"
    },
    {
      "start": 725.92,
      "duration": 5.44,
      "text": "やったりするのかなとか、これはなんか"
    },
    {
      "start": 727.48,
      "duration": 5.84,
      "text": "非常にね。うん。今さんってのも僕にはし"
    },
    {
      "start": 731.36,
      "duration": 3.919,
      "text": "たら本当のブランド人だと思うんで、"
    },
    {
      "start": 733.32,
      "duration": 4.199,
      "text": "ブランド人と組織の関係みたいの考える上"
    },
    {
      "start": 735.279,
      "duration": 5.201,
      "text": "でものすごくこれ面白いというか興味深い"
    },
    {
      "start": 737.519,
      "duration": 5.56,
      "text": "論点があるテーマだなと思ってます。で、"
    },
    {
      "start": 740.48,
      "duration": 6.12,
      "text": "最後にとにかく関係ない第3者としては"
    },
    {
      "start": 743.079,
      "duration": 6.081,
      "text": "これでイ村ファンドや川井ファンドや、え"
    },
    {
      "start": 746.6,
      "duration": 5.799,
      "text": "、上やファンドからは特にイ村ファンド"
    },
    {
      "start": 749.16,
      "duration": 5.479,
      "text": "からは換金売りが膨らむ可能性があるので"
    },
    {
      "start": 752.399,
      "duration": 5.56,
      "text": "その銘柄のファンダメンタルズとかに関係"
    },
    {
      "start": 754.639,
      "duration": 5.521,
      "text": "なく短期的な受給には悪い影響を及ぼす"
    },
    {
      "start": 757.959,
      "duration": 3.56,
      "text": "ようなことになるのかなと。で、さんも俺"
    },
    {
      "start": 760.16,
      "duration": 3.799,
      "text": "バカじゃないから、そんなこと分かった上"
    },
    {
      "start": 761.519,
      "duration": 5.081,
      "text": "でこのカードを切ったってことは自体は"
    },
    {
      "start": 763.959,
      "duration": 6.521,
      "text": "相当極、見積まってんだろうなとは思い"
    },
    {
      "start": 766.6,
      "duration": 6.16,
      "text": "ます。で、株のM&Aみたいに別の投資"
    },
    {
      "start": 770.48,
      "duration": 4.44,
      "text": "信託会社が、ま、SBIでも楽天でもどこ"
    },
    {
      "start": 772.76,
      "duration": 5.519,
      "text": "でもいいよ。にレオスでもどこでもいいん"
    },
    {
      "start": 774.92,
      "duration": 5.719,
      "text": "だけど、そういうところが現れて投資信託"
    },
    {
      "start": 778.279,
      "duration": 3.761,
      "text": "ごと監禁売り合併できたりしたらいいと"
    },
    {
      "start": 780.639,
      "duration": 4.601,
      "text": "思うんだけど、そういう立つけって基本的"
    },
    {
      "start": 782.04,
      "duration": 6.359,
      "text": "にないと思うんで、投し、今イ村ファンド"
    },
    {
      "start": 785.24,
      "duration": 5.039,
      "text": "持ってる人は、ま、多分問い合わせ殺当だ"
    },
    {
      "start": 788.399,
      "duration": 5.761,
      "text": "と思うよ。パンドどうするんすか?この後"
    },
    {
      "start": 790.279,
      "duration": 7.841,
      "text": "みたいな。まあ、現実問題解約して出てく"
    },
    {
      "start": 794.16,
      "duration": 5.56,
      "text": "しかないのかな。で、さんはイ村さんで"
    },
    {
      "start": 798.12,
      "duration": 3.92,
      "text": "もちろんその受益社員の責任ってことは"
    },
    {
      "start": 799.72,
      "duration": 4.679,
      "text": "感じられてると思うんだけども、その渡辺"
    },
    {
      "start": 802.04,
      "duration": 6.239,
      "text": "さんとかファンドノートへの義じゃなくて"
    },
    {
      "start": 804.399,
      "duration": 7.44,
      "text": "、この状況に至った陥ってる今の状況の中"
    },
    {
      "start": 808.279,
      "duration": 5.201,
      "text": "でどういう形が個人投資家重益者にとって"
    },
    {
      "start": 811.839,
      "duration": 4.36,
      "text": "ベストなのかってことは、ま、こんなこと"
    },
    {
      "start": 813.48,
      "duration": 5.28,
      "text": "俺なんかに言われなくても皆さんも今村"
    },
    {
      "start": 816.199,
      "duration": 5.2,
      "text": "さんも考えてると思うんだけども1つ"
    },
    {
      "start": 818.76,
      "duration": 5.96,
      "text": "クールダウンしてお互いのメンツとか感情"
    },
    {
      "start": 821.399,
      "duration": 6.041,
      "text": "的なりっていうのは分けにおいて受益者の"
    },
    {
      "start": 824.72,
      "duration": 4.679,
      "text": "ために個人投資家のために、ま、別にもう"
    },
    {
      "start": 827.44,
      "duration": 4.639,
      "text": "俺ここまで来たらもう正直喧嘩は避けられ"
    },
    {
      "start": 829.399,
      "duration": 7.041,
      "text": "ないと思うんだけども、うまい具合のね、"
    },
    {
      "start": 832.079,
      "duration": 7.56,
      "text": "南着陸を飛行機がね、今日の夜俺千歳空港"
    },
    {
      "start": 836.44,
      "duration": 6.639,
      "text": "飛行機飛ぶから心配なんだけども、乗客が"
    },
    {
      "start": 839.639,
      "duration": 6.281,
      "text": "もう今何百384億円分の個人都市家のお"
    },
    {
      "start": 843.079,
      "duration": 6.281,
      "text": "金を乗せた飛行機が"
    },
    {
      "start": 845.92,
      "duration": 7.44,
      "text": "とそ空を飛びながら"
    },
    {
      "start": 849.36,
      "duration": 6.079,
      "text": "パイロットと服装重視が揉めてるのが"
    },
    {
      "start": 853.36,
      "duration": 2.64,
      "text": "機内に向けて放送されてしまったみたい"
    },
    {
      "start": 855.439,
      "duration": 3.4,
      "text": "[笑い]"
    },
    {
      "start": 856.0,
      "duration": 4.72,
      "text": "正直僕の例え話で今の状況だと思うんで、"
    },
    {
      "start": 858.839,
      "duration": 4.841,
      "text": "乗客としてはそれ正直めちゃくちゃ不安だ"
    },
    {
      "start": 860.72,
      "duration": 5.119,
      "text": "と思いますよ。なんでそこはね、是非着陸"
    },
    {
      "start": 863.68,
      "duration": 3.56,
      "text": "うまい具合に着陸できるようにそこは"
    },
    {
      "start": 865.839,
      "duration": 3.36,
      "text": "ちょっと今村さんと渡辺さんも色々"
    },
    {
      "start": 867.24,
      "duration": 3.68,
      "text": "もちろんもうここまで来たらもう色々お"
    },
    {
      "start": 869.199,
      "duration": 3.44,
      "text": "互いの思いとかもう言えないような話も"
    },
    {
      "start": 870.92,
      "duration": 3.479,
      "text": "いっぱいあるんだと思うんですよ。で、"
    },
    {
      "start": 872.639,
      "duration": 4.401,
      "text": "それぞれにそれぞれの立場があると思うし"
    },
    {
      "start": 874.399,
      "duration": 3.8,
      "text": "分かる分かる。それぐらいのことが色々"
    },
    {
      "start": 877.04,
      "duration": 3.52,
      "text": "言えないことがあるだろうなっていうのは"
    },
    {
      "start": 878.199,
      "duration": 4.961,
      "text": "推測はつくんですけども、本当に誰のため"
    },
    {
      "start": 880.56,
      "duration": 4.959,
      "text": "にって言うと、お互い本当にまだこれから"
    },
    {
      "start": 883.16,
      "duration": 4.0,
      "text": "多分日本の運用、資産運用の業界でね、"
    },
    {
      "start": 885.519,
      "duration": 7.361,
      "text": "何十年も30年も40年もやってかれる"
    },
    {
      "start": 887.16,
      "duration": 9.4,
      "text": "方ちだと思うんで、是非いい具合の着陸を"
    },
    {
      "start": 892.88,
      "duration": 6.68,
      "text": "できるように願ってます。収益者個人投資"
    },
    {
      "start": 896.56,
      "duration": 6.6,
      "text": "家を最優先でお願いできればなというのが"
    },
    {
      "start": 899.56,
      "duration": 7.76,
      "text": "1位個人投資家田慎太郎からイ村さんと"
    },
    {
      "start": 903.16,
      "duration": 5.84,
      "text": "パンドノートのえ渡辺さんや川井さんに"
    },
    {
      "start": 907.32,
      "duration": 3.959,
      "text": "対してのお願いでございました。ま、"
    },
    {
      "start": 909.0,
      "duration": 5.04,
      "text": "それぞれ皆さん僕また会ったこともある中"
    },
    {
      "start": 911.279,
      "duration": 6.601,
      "text": "でもあるので、え、1部害者ではあるの"
    },
    {
      "start": 914.04,
      "duration": 8.479,
      "text": "ですが、そういう風に思っております。"
    },
    {
      "start": 917.88,
      "duration": 4.639,
      "text": "それではまた。"
    }
  ]
}