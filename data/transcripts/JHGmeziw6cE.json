      "start": 789.6,
      "duration": 3.72,
      "text": "Micクrosoftがずっと下がってた"
    },
    {
      "start": 791.24,
      "duration": 4.399,
      "text": "んですよね。ま、直近は少し戻してました"
    },
    {
      "start": 793.32,
      "duration": 5.319,
      "text": "けど、こちらも3.64%"
    },
    {
      "start": 795.639,
      "duration": 5.801,
      "text": "だか、ま、なんとなく今ね、クロードの話"
    },
    {
      "start": 798.639,
      "duration": 6.401,
      "text": "しましたけど、"
    },
    {
      "start": 801.44,
      "duration": 6.079,
      "text": "え、ね、Googleアンソロピックに"
    },
    {
      "start": 805.04,
      "duration": 4.28,
      "text": "対してOpenAIに1番ね、投資してた"
    },
    {
      "start": 807.519,
      "duration": 4.481,
      "text": "のがMicクrosoftで、そのOP"
    },
    {
      "start": 809.32,
      "duration": 6.28,
      "text": "AIがどうも劣静だぞっていう風な感じに"
    },
    {
      "start": 812.0,
      "duration": 7.079,
      "text": "なってきて、株価が下がった、下がってい"
    },
    {
      "start": 815.6,
      "duration": 6.799,
      "text": "たのかなと思うんですけど、今日は、あ、"
    },
    {
      "start": 819.079,
      "duration": 5.721,
      "text": "ま、他のね、え、ハイスケラーも良かった"
    },
    {
      "start": 822.399,
      "duration": 5.88,
      "text": "んですけど、そん中で圧倒的に動きが"
    },
    {
      "start": 824.8,
      "duration": 6.32,
      "text": "良かったのがMicクrosoft。あと"
    },
    {
      "start": 828.279,
      "duration": 6.081,
      "text": "成長株ですね。やっぱりそうやってリスク"
    },
    {
      "start": 831.12,
      "duration": 5.44,
      "text": "オフみたいな状況になると値国の洗いとこ"
    },
    {
      "start": 834.36,
      "duration": 5.08,
      "text": "には投資できないということなんですけど"
    },
    {
      "start": 836.56,
      "duration": 4.959,
      "text": "、今日は総ファが5%だ、サークル"
    },
    {
      "start": 839.44,
      "duration": 4.8,
      "text": "インターネット12%だか、スノー"
    },
    {
      "start": 841.519,
      "duration": 6.76,
      "text": "フレーク10%だか、アップラビン"
    },
    {
      "start": 844.24,
      "duration": 7.519,
      "text": "6.6%だかというとこで、あの、こう"
    },
    {
      "start": 848.279,
      "duration": 5.48,
      "text": "いうね、値動きが激しい株、チャートも"
    },
    {
      "start": 851.759,
      "duration": 5.0,
      "text": "こんな風に随分崩れてたんですけど、そう"
    },
    {
      "start": 853.759,
      "duration": 5.561,
      "text": "いったところが大幅上昇したと。そして"
    },
    {
      "start": 856.759,
      "duration": 5.76,
      "text": "ダウ関連でも、ま、先ほどにセールソース"
    },
    {
      "start": 859.32,
      "duration": 5.199,
      "text": "が1番、え、値上がりしたんですけど、"
    },
    {
      "start": 862.519,
      "duration": 4.161,
      "text": "それ以外だとアメリカンエクスプレスでも"
    },
    {
      "start": 864.519,
      "duration": 4.201,
      "text": "チャート見るとこんなね、下がってたんだ"
    },
    {
      "start": 866.68,
      "duration": 4.079,
      "text": "なと。"
    },
    {
      "start": 868.72,
      "duration": 5.239,
      "text": "IBMも"
    },
    {
      "start": 870.759,
      "duration": 6.841,
      "text": "ね、え、ね、急落してた株なんですね。"
    },
    {
      "start": 873.959,
      "duration": 6.401,
      "text": "こう見ると3%だというところで、ま、"
    },
    {
      "start": 877.6,
      "duration": 6.08,
      "text": "成長みたいに大きく動くわけじゃないので"
    },
    {
      "start": 880.36,
      "duration": 5.159,
      "text": "ですけども3%だかということでこういう"
    },
    {
      "start": 883.68,
      "duration": 4.48,
      "text": "今まで"
    },
    {
      "start": 885.519,
      "duration": 5.841,
      "text": "いつが損なるか分からない手をつけられな"
    },
    {
      "start": 888.16,
      "duration": 6.479,
      "text": "いっていう株がですね買われたっていうの"
    },
    {
      "start": 891.36,
      "duration": 5.479,
      "text": "はリスクオンになってきた証拠じゃないか"
    },
    {
      "start": 894.639,
      "duration": 5.361,
      "text": "な。ま、今日1日で判断できないですけど"
    },
    {
      "start": 896.839,
      "duration": 6.24,
      "text": "、ま、まずそういった動きがありましたと"
    },
    {
      "start": 900.0,
      "duration": 6.079,
      "text": "いうことです。そして今まで強かった反動"
    },
    {
      "start": 903.079,
      "duration": 6.241,
      "text": "体関連株ですね。3ディスクが11.8%"
    },
    {
      "start": 906.079,
      "duration": 7.0,
      "text": "だかというとこで大幅に高値を更新したと"
    },
    {
      "start": 909.32,
      "duration": 5.6,
      "text": "。ま、最もこちらはですね、"
    },
    {
      "start": 913.079,
      "duration": 4.921,
      "text": "え、"
    },
    {
      "start": 914.92,
      "duration": 6.2,
      "text": "NASダ100に採用されたということで"
    },
    {
      "start": 918.0,
      "duration": 5.68,
      "text": "、え、パッシ分用するファンドが大量に買"
    },
    {
      "start": 921.12,
      "duration": 4.639,
      "text": "を入れなきゃいけないということがあった"
    },
    {
      "start": 923.68,
      "duration": 4.44,
      "text": "と。で、それは多分予想されてたっていう"
    },
    {
      "start": 925.759,
      "duration": 6.2,
      "text": "こともここまで株価を上げてきたっていう"
    },
    {
      "start": 928.12,
      "duration": 7.44,
      "text": "ことの要因の1つだと思う。思うので、ま"
    },
    {
      "start": 931.959,
      "duration": 6.0,
      "text": "、ね、今日以降どうなっていくのかね、"
    },
    {
      "start": 935.56,
      "duration": 7.079,
      "text": "その辺の重した部分もあるんですけど、で"
    },
    {
      "start": 937.959,
      "duration": 7.841,
      "text": "もね、え、11%も上がったということが"
    },
    {
      "start": 942.639,
      "duration": 6.161,
      "text": "、あ、ま、安心感につがった。今まで"
    },
    {
      "start": 945.8,
      "duration": 5.56,
      "text": "良かった株も悪かった株も買われましたよ"
    },
    {
      "start": 948.8,
      "duration": 5.44,
      "text": "というそばだったかなと思います。で、"
    },
    {
      "start": 951.36,
      "duration": 5.64,
      "text": "ウエスタンデジタルなんかも2%近い高値"
    },
    {
      "start": 954.24,
      "duration": 7.0,
      "text": "。高値は抜けな。あ、終わりにて高値です"
    },
    {
      "start": 957.0,
      "duration": 8.319,
      "text": "ね。コーニングなんかも2%だかという"
    },
    {
      "start": 961.24,
      "duration": 8.519,
      "text": "ことで、ま、強い動きがあ、高い株、安い"
    },
    {
      "start": 965.319,
      "duration": 6.281,
      "text": "株に見られて、え、非常に安心感が出てき"
    },
    {
      "start": 969.759,
      "duration": 4.32,
      "text": "た。あまり"
    },
    {
      "start": 971.6,
      "duration": 4.84,
      "text": "そうですね、原油価格もちょっと下落した"
    },
    {
      "start": 974.079,
      "duration": 5.721,
      "text": "んですけど、あまりそういった影響を受け"
    },
    {
      "start": 976.44,
      "duration": 5.92,
      "text": "なくて、え、株の方に中ね、注意深い、"
    },
    {
      "start": 979.8,
      "duration": 6.64,
      "text": "注意、注意を向けていられる相場になった"
    },
    {
      "start": 982.36,
      "duration": 8.0,
      "text": "のかなという感じが今日のアメリカ部でし"
    },
    {
      "start": 986.44,
      "duration": 6.959,
      "text": "た。あ、あとそうですね。で、もう1つ"
    },
    {
      "start": 990.36,
      "duration": 4.919,
      "text": "コーニングとかも強かったんですけど、ま"
    },
    {
      "start": 993.399,
      "duration": 5.56,
      "text": "、直近は上がってるんですけどね、出遅れ"
    },
    {
      "start": 995.279,
      "duration": 6.56,
      "text": "てたブロードコムだとかINTなんかも"
    },
    {
      "start": 998.959,
      "duration": 5.841,
      "text": "大きく上がってきていまして、ま、そう"
    },
