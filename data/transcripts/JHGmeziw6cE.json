      "duration": 8.439,
      "text": "けど、来週から主力株なんかも出てきます"
    },
    {
      "start": 1487.24,
      "duration": 10.319,
      "text": "し、再来週はあ、大手ITの決算なんかも"
    },
    {
      "start": 1492.799,
      "duration": 8.081,
      "text": "出てくるということで、そうですね。え、"
    },
    {
      "start": 1497.559,
      "duration": 7.441,
      "text": "ま、日本ともう1つ違うのはアメリカは"
    },
    {
      "start": 1500.88,
      "duration": 6.72,
      "text": "12月決算の銘柄が多いので今回第1試期"
    },
    {
      "start": 1505.0,
      "duration": 7.52,
      "text": "の決算なんですよね。ですから、ま、重要"
    },
    {
      "start": 1507.6,
      "duration": 6.92,
      "text": "性っていうのは期末の決算、ま、年、年末"
    },
    {
      "start": 1512.52,
      "duration": 5.2,
      "text": "、年度末っていうかですね、そういう決算"
    },
    {
      "start": 1514.52,
      "duration": 8.24,
      "text": "が重要になってくるので、日本はまさに"
    },
    {
      "start": 1517.72,
      "duration": 8.559,
      "text": "それに当たるんですけど、ま、日本ね、え"
    },
    {
      "start": 1522.76,
      "duration": 5.639,
      "text": "、日本の決算は来週ディスコとか出てくる"
    },
    {
      "start": 1526.279,
      "duration": 5.64,
      "text": "、ファナックとか決算出てくるんですけど"
    },
    {
      "start": 1528.399,
      "duration": 6.561,
      "text": "、メインは再来週以降"
    },
    {
      "start": 1531.919,
      "duration": 5.321,
      "text": "そしてね、4月末から連休もあったりする"
    },
    {
      "start": 1534.96,
      "duration": 6.52,
      "text": "んで、5月入ってからということになるの"
    },
    {
      "start": 1537.24,
      "duration": 6.799,
      "text": "で、まだ先ということで"
    },
    {
      "start": 1541.48,
      "duration": 4.6,
      "text": "ね、株価もそういった意味ではどうなん"
    },
    {
      "start": 1544.039,
      "duration": 5.12,
      "text": "でしょうね。こういった状況ですから"
    },
    {
      "start": 1546.08,
      "duration": 4.959,
      "text": "おそらくAIおそらくというか反動体関連"
    },
    {
      "start": 1549.159,
      "duration": 3.961,
      "text": "はいい決算を出してくるんだろうと思い"
    },
    {
      "start": 1551.039,
      "duration": 5.841,
      "text": "ます。それに対して株価がどう反応するか"
    },
    {
      "start": 1553.12,
      "duration": 6.799,
      "text": "ということと日本特有の"
    },
    {
      "start": 1556.88,
      "duration": 6.039,
      "text": "こととして"
    },
    {
      "start": 1559.919,
      "duration": 5.841,
      "text": "通期の見通し、今期の見通しを弱く見てく"
    },
    {
      "start": 1562.919,
      "duration": 6.081,
      "text": "最初は出してくるとだんだんだんだん、え"
    },
    {
      "start": 1565.76,
      "duration": 5.76,
      "text": "、情報修正してくるっていうことが多いん"
    },
    {
      "start": 1569.0,
      "duration": 6.799,
      "text": "ですよね。ですから、特に今、あ、イラン"
    },
    {
      "start": 1571.52,
      "duration": 6.96,
      "text": "の問題があるわけで、その決算発表の時、"
    },
    {
      "start": 1575.799,
      "duration": 5.24,
      "text": "再来週以降どうなってるか分からないです"
    },
    {
      "start": 1578.48,
      "duration": 5.439,
      "text": "けど、え"
    },
    {
      "start": 1581.039,
      "duration": 5.721,
      "text": "ね、状況次第ではさらに"
    },
    {
      "start": 1583.919,
      "duration": 5.321,
      "text": "発表してくるとなると"
    },
    {
      "start": 1586.76,
      "duration": 5.44,
      "text": "株価にとってはちょっとこう難しいそばに"
    },
    {
      "start": 1589.24,
      "duration": 5.6,
      "text": "なってくる可能性もあるかなという風に"
    },
    {
      "start": 1592.2,
      "duration": 5.199,
      "text": "思います。ただまあね、今アメリカね、"
    },
    {
      "start": 1594.84,
      "duration": 5.319,
      "text": "海外投資家がもう積極的日本の株を見てて"
    },
    {
      "start": 1597.399,
      "duration": 6.561,
      "text": "、え、海外の状況を見ながらというところ"
    },
    {
      "start": 1600.159,
      "duration": 6.0,
      "text": "で強いそばが続く可動性もあるし、え、"
    },
    {
      "start": 1603.96,
      "duration": 6.599,
      "text": "しっかり見ていきたいなという風に思って"
    },
    {
      "start": 1606.159,
      "duration": 6.88,
      "text": "います。え、本日の子放送は以上です。"
    },
    {
      "start": 1610.559,
      "duration": 6.6,
      "text": "本日もご視聴ありがとうございました。"
    },
    {
      "start": 1613.039,
      "duration": 6.601,
      "text": "ついについに本物の朝倉系のLINEを"
    },
    {
      "start": 1617.159,
      "duration": 6.76,
      "text": "作りますからな。作りましたからね。ここ"
    },
    {
      "start": 1619.64,
      "duration": 6.32,
      "text": "ではうちからのね、この1ね、レポート"
    },
    {
      "start": 1623.919,
      "duration": 4.24,
      "text": "ですよと、セミナーですよとか、それから"
    },
    {
      "start": 1625.96,
      "duration": 4.719,
      "text": "モーニングニュースですよとね、そういっ"
    },
    {
      "start": 1628.159,
      "duration": 4.801,
      "text": "たことをCDですよというニュースを送ら"
    },
    {
      "start": 1630.679,
      "duration": 5.36,
      "text": "せていただきますので、それを参考にして"
    },
    {
      "start": 1632.96,
      "duration": 6.28,
      "text": "ですね、申し込んでみてくださいね。世界"
    },
    {
      "start": 1636.039,
      "duration": 5.52,
      "text": "経済の裏側を知る、真実を知"
    },
    {
      "start": 1639.24,
      "duration": 6.6,
      "text": "るっていうことなんですよね。朝倉系"
    },
    {
      "start": 1641.559,
      "duration": 7.72,
      "text": "セミナー政治経済旬のテーマをですね、"
    },
    {
      "start": 1645.84,
      "duration": 6.6,
      "text": "その時の旬の話をですね、私がね、目"
    },
    {
      "start": 1649.279,
      "duration": 6.041,
      "text": "いっぱい話しますから、これ是非聞いてみ"
    },
    {
      "start": 1652.44,
      "duration": 4.8,
      "text": "てくださいね。え、すでにですね、え、ま"
    },
    {
      "start": 1655.32,
      "duration": 4.64,
      "text": "、ホームページ上でセミナー公開してます"
    },
    {
      "start": 1657.24,
      "duration": 6.679,
      "text": "けど、これ見ていいなと思ったら是非来て"
    },
    {
      "start": 1659.96,
      "duration": 8.319,
      "text": "ですね、皆さんのビジネス、投資役立てて"
    },
    {
      "start": 1663.919,
      "duration": 4.36,
      "text": "みてください。待ってますからね。"
    }
  ]
}