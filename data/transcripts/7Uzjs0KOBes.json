    },
    {
      "start": 935.36,
      "duration": 4.64,
      "text": "。ありがとうございました。じゃあ続いて"
    },
    {
      "start": 937.759,
      "duration": 4.921,
      "text": "、えっと、私から、あの、今日のまとめな"
    },
    {
      "start": 940.0,
      "duration": 5.199,
      "text": "んですけど、ちょっとまとめにあたって、"
    },
    {
      "start": 942.68,
      "duration": 5.959,
      "text": "え、見ていただきたいのがこちらのあの"
    },
    {
      "start": 945.199,
      "duration": 7.521,
      "text": "グラフなんですけども、これ長期金利、え"
    },
    {
      "start": 948.639,
      "duration": 8.161,
      "text": "、審発10年も国際リバーリーですよね。"
    },
    {
      "start": 952.72,
      "duration": 8.919,
      "text": "え、これと、え、東京証券取引場の、え、"
    },
    {
      "start": 956.8,
      "duration": 7.76,
      "text": "株の配当利回りの平均、え、これを比較し"
    },
    {
      "start": 961.639,
      "duration": 6.12,
      "text": "た、え、チャートなんですけれども、これ"
    },
    {
      "start": 964.56,
      "duration": 6.0,
      "text": "1993年のとこ見ていただくと、え、"
    },
    {
      "start": 967.759,
      "duration": 5.721,
      "text": "10年国際の利回りが5%もあったんです"
    },
    {
      "start": 970.56,
      "duration": 6.519,
      "text": "よね。え、で、この時には、あの、株の"
    },
    {
      "start": 973.48,
      "duration": 6.64,
      "text": "配当利回りは1%もなかったと、え、いう"
    },
    {
      "start": 977.079,
      "duration": 5.88,
      "text": "ところなんですけども、これ実は世界で"
    },
    {
      "start": 980.12,
      "duration": 5.399,
      "text": "見ると普通なんですよね。消期金利の方が"
    },
    {
      "start": 982.959,
      "duration": 5.281,
      "text": "、え、株の配当より高いというのは世界で"
    },
    {
      "start": 985.519,
      "duration": 5.401,
      "text": "見たら普通の当たり前のことなんですけど"
    },
    {
      "start": 988.24,
      "duration": 5.56,
      "text": "も、そっから日本の長期金利がずっと"
    },
    {
      "start": 990.92,
      "duration": 5.399,
      "text": "下がり、さらに異次元緩和もやったという"
    },
    {
      "start": 993.8,
      "duration": 5.959,
      "text": "ことで長期金利0まで下がってしまったと"
    },
    {
      "start": 996.319,
      "duration": 7.2,
      "text": "いうとこで、ま、2008年ぐらいから"
    },
    {
      "start": 999.759,
      "duration": 7.721,
      "text": "長期金利の方が株の利回りよりも低いって"
    },
    {
      "start": 1003.519,
      "duration": 7.401,
      "text": "いう、え、異常事態になったわけで、これ"
    },
    {
      "start": 1007.48,
      "duration": 6.719,
      "text": "あのそれがあの足元長金利が上がってまた"
    },
    {
      "start": 1010.92,
      "duration": 6.359,
      "text": "やと長期金利が株のハ取りマりを超えてき"
    },
    {
      "start": 1014.199,
      "duration": 5.361,
      "text": "たというところですよね。資産形成にとっ"
    },
    {
      "start": 1017.279,
      "duration": 4.36,
      "text": "て株式投資って大事だから日本株買い"
    },
    {
      "start": 1019.56,
      "duration": 3.88,
      "text": "ましょうって言うんだけどもただ加熱し"
    },
    {
      "start": 1021.639,
      "duration": 4.361,
      "text": "てる時もどんどんどんどん株ばっかり買っ"
    },
    {
      "start": 1023.44,
      "duration": 5.84,
      "text": "てくると短期的なショックで大変なことに"
    },
    {
      "start": 1026.0,
      "duration": 5.799,
      "text": "なるとだから株と債権を合わせて投資し"
    },
    {
      "start": 1029.28,
      "duration": 6.08,
      "text": "ましょうっていうのがあのオーソドックス"
    },
    {
      "start": 1031.799,
      "duration": 8.16,
      "text": "なあの資産形成の方法なんですけどもそれ"
    },
    {
      "start": 1035.36,
      "duration": 6.719,
      "text": "がこの異源金融緩和で日本株と日本のあの"
    },
    {
      "start": 1039.959,
      "duration": 5.041,
      "text": "債権をセットで持ちましょうって言えなく"
    },
    {
      "start": 1042.079,
      "duration": 5.081,
      "text": "なってしまったわけですよね。それが今"
    },
    {
      "start": 1045.0,
      "duration": 5.039,
      "text": "あの金利が上がってきたことによって"
    },
    {
      "start": 1047.16,
      "duration": 5.879,
      "text": "やっとこう債権の投資魅力っていうものも"
    },
    {
      "start": 1050.039,
      "duration": 6.201,
      "text": "増してきたということで、ま、もう1回"
    },
    {
      "start": 1053.039,
      "duration": 6.52,
      "text": "改めて資産形成にとって、ま、日本株が"
    },
    {
      "start": 1056.24,
      "duration": 7.2,
      "text": "大切です。日本株も大事だけども、国際と"
    },
    {
      "start": 1059.559,
      "duration": 6.281,
      "text": "か、え、とか、え、債権にも、え、分散"
    },
    {
      "start": 1063.44,
      "duration": 5.72,
      "text": "投資してくってことが大切になるという風"
    },
    {
      "start": 1065.84,
      "duration": 5.8,
      "text": "に思います。え、以上です。今日は中島"
    },
    {
      "start": 1069.16,
      "duration": 6.399,
      "text": "さんと一緒にお伝えしました。ありがとう"
    },
    {
      "start": 1071.64,
      "duration": 3.919,
      "text": "ございました。ありがとうございました。"
    }
  ]
}