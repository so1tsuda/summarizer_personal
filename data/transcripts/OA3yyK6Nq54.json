    {
      "start": 433.4,
      "duration": 4.4,
      "text": "の2月とか3月ぐらいまでは持つという、"
    },
    {
      "start": 435.72,
      "duration": 3.72,
      "text": "ま、そういった計算に計算上はなりますと"
    },
    {
      "start": 437.8,
      "duration": 3.119,
      "text": "いうことです。ですけれども、ちょっと"
    },
    {
      "start": 439.44,
      "duration": 4.439,
      "text": "注意をしなきゃいけないのはですね、"
    },
    {
      "start": 440.919,
      "duration": 5.0,
      "text": "先ほど示しした通りアメリカから多くの"
    },
    {
      "start": 443.879,
      "duration": 3.72,
      "text": "原油が単価が来ているという状況です"
    },
    {
      "start": 445.919,
      "duration": 4.441,
      "text": "けれども、おそらくこういった緊急事態"
    },
    {
      "start": 447.599,
      "duration": 4.6,
      "text": "ですので、長期契約とか1年間ですね、"
    },
    {
      "start": 450.36,
      "duration": 3.92,
      "text": "これだけこんだけの単価が常に来るように"
    },
    {
      "start": 452.199,
      "duration": 4.44,
      "text": "してくださいっていう契約ではなくって、"
    },
    {
      "start": 454.28,
      "duration": 4.52,
      "text": "この船の油を買うのでこっちに持ってきて"
    },
    {
      "start": 456.639,
      "duration": 5.921,
      "text": "くださいという個別契約で成り立っている"
    },
    {
      "start": 458.8,
      "duration": 5.56,
      "text": "ものと、ま、推されます。ですので現在今"
    },
    {
      "start": 462.56,
      "duration": 3.479,
      "text": "日本に向かってるアメリカからの単価が"
    },
    {
      "start": 464.36,
      "duration": 5.04,
      "text": "これだけ確保できたということがあります"
    },
    {
      "start": 466.039,
      "duration": 6.56,
      "text": "けれどもこの状態を来月も再来月も維持し"
    },
    {
      "start": 469.4,
      "duration": 6.04,
      "text": "続けられればですね、来年の3月まで持つ"
    },
    {
      "start": 472.599,
      "duration": 5.44,
      "text": "という計算になりますので、仮にですね、"
    },
    {
      "start": 475.44,
      "duration": 4.439,
      "text": "ここが何らか減ってしまうとですね、国内"
    },
    {
      "start": 478.039,
      "duration": 3.401,
      "text": "在庫のなくなるペースっていうのも"
    },
    {
      "start": 479.879,
      "duration": 3.32,
      "text": "タイミングというのも3月、2月になっ"
    },
    {
      "start": 481.44,
      "duration": 4.039,
      "text": "たり、1月になったりという風にですね、"
    },
    {
      "start": 483.199,
      "duration": 4.56,
      "text": "なってしまう可能性があるという風に、え"
    },
    {
      "start": 485.479,
      "duration": 4.241,
      "text": "、考えられます。通常の感覚で申し上げる"
    },
    {
      "start": 487.759,
      "duration": 3.72,
      "text": "とですね、ま、もしこれが長期契約。今"
    },
    {
      "start": 489.72,
      "duration": 4.24,
      "text": "アメリカから日本に向かってるこれだけの"
    },
    {
      "start": 491.479,
      "duration": 4.761,
      "text": "量はもう1年間確保できてるということで"
    },
    {
      "start": 493.96,
      "duration": 4.12,
      "text": "あればですね、そこは3月まで持つという"
    },
    {
      "start": 496.24,
      "duration": 3.959,
      "text": "ことは成り立つんですけれども、そこが"
    },
    {
      "start": 498.08,
      "duration": 5.0,
      "text": "少し懸念点として、え、果たしてどうかと"
    },
    {
      "start": 500.199,
      "duration": 5.0,
      "text": "いったところがあります。で、もう1つは"
    },
    {
      "start": 503.08,
      "duration": 3.64,
      "text": "ですね、ま、原油を売ってるの例えば"
    },
    {
      "start": 505.199,
      "duration": 3.161,
      "text": "エクソンモービルだったりシェブロンだっ"
    },
    {
      "start": 506.72,
      "duration": 3.4,
      "text": "たりですね、それからコンティネンタル"
    },
    {
      "start": 508.36,
      "duration": 5.039,
      "text": "リソーシズとかのシェール企業もあります"
    },
    {
      "start": 510.12,
      "duration": 5.479,
      "text": "けれども、アメリカの原油開発生産企業に"
    },
    {
      "start": 513.399,
      "duration": 4.281,
      "text": "なりますので、そういった会社はですね、"
    },
    {
      "start": 515.599,
      "duration": 4.641,
      "text": "日本に売るのもありますけれども、他の"
