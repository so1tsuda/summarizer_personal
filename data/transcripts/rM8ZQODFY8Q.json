    {
      "start": 1041.559,
      "duration": 6.24,
      "text": "、重要であることは間違いないので、え、"
    },
    {
      "start": 1044.319,
      "duration": 6.161,
      "text": "この今日の国際環境を考えた時には21"
    },
    {
      "start": 1047.799,
      "duration": 6.321,
      "text": "世紀初頭の前半の国際情勢を考えた時には"
    },
    {
      "start": 1050.48,
      "duration": 5.6,
      "text": "ロシアとのあの戦略的な安定性をどう維持"
    },
    {
      "start": 1054.12,
      "duration": 3.679,
      "text": "するか、あの、彼らをどういう風に抑視"
    },
    {
      "start": 1056.08,
      "duration": 5.04,
      "text": "するかってことが大きな商点になると思い"
    },
    {
      "start": 1057.799,
      "duration": 5.161,
