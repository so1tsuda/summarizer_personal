    {
      "start": 1242.72,
      "duration": 5.839,
      "text": "コストを負ずに外交政策安全保障政策上に"
    },
    {
      "start": 1246.64,
      "duration": 4.159,
      "text": "、え、の資産として利用できるかっていう"
    },
    {
      "start": 1248.559,
      "duration": 4.48,
      "text": "ことを考えた時の、あの、グリーンランド"
    },
    {
      "start": 1250.799,
      "duration": 4.481,
      "text": "の人たちがもしくはデンマークの人たちが"
    },
    {
      "start": 1253.039,
      "duration": 4.12,
      "text": "どういう形で形式を受け入れるかって"
    },
    {
      "start": 1255.28,
      "duration": 4.04,
      "text": "ところにかかってくると思いますので、"
    },
    {
      "start": 1257.159,
      "duration": 4.801,
      "text": "あの、将来の展開を見る、見ていきたいと"
    },
    {
      "start": 1259.32,
      "duration": 4.52,
      "text": "思います。1つ言えることは、え、軍事的"
