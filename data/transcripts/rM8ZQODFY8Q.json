    {
      "start": 1294.88,
      "duration": 4.84,
      "text": "した土地ってのは多分フィーピンが1番"
    },
    {
      "start": 1296.88,
      "duration": 5.279,
      "text": "最後なんじゃないですか?職民いわゆる"
    },
    {
      "start": 1299.72,
      "duration": 5.92,
      "text": "職民地統治してますけれどもあのそれ以外"
    },
    {
      "start": 1302.159,
      "duration": 6.561,
      "text": "にもいくつかあの支配をした地域ってのが"
    },
    {
      "start": 1305.64,
      "duration": 6.279,
      "text": "あって中南諸国なんかはあのよく言われる"
