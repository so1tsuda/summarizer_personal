    {
      "start": 1261.96,
      "duration": 4.199,
      "text": "に侵略してグリーンランドを取得するって"
    },
    {
      "start": 1263.84,
      "duration": 5.68,
      "text": "いうのは、あの、本当馬鹿げたあの方法"
    },
    {
      "start": 1266.159,
      "duration": 6.961,
      "text": "ですので、え、あ、そんな臨の中を、あの"
    },
    {
      "start": 1269.52,
      "duration": 6.32,
      "text": "、9割国土が降臨に追われてるですね。え"
    },
    {
      "start": 1273.12,
      "duration": 5.32,
      "text": "、特殊部隊なり軍隊を派遣してもんこう"
    },
    {
      "start": 1275.84,
      "duration": 4.719,
      "text": "あの美しくない世界ですから、そういう"
    },
    {
      "start": 1278.44,
      "duration": 4.32,
      "text": "そういう場合は、え、そういうことはない"
    },
    {
      "start": 1280.559,
      "duration": 6.72,
      "text": "だろうなとは思います。うん。うん。"
    },
    {
      "start": 1282.76,
      "duration": 6.68,
      "text": "ちょっと私にとくごちゃに使ってました"
