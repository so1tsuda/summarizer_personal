    {
      "start": 1438.2,
      "duration": 3.32,
      "text": "はい。"
    },
    {
      "start": 1438.52,
      "duration": 3.0,
      "text": "この利が高くなってくるのをうまく吸収していく銘柄と厳しくなる銘柄に分かれてくる時代ですので、この銘柄選びがすごくポイントになる。"
    },
    {
      "start": 1449.44,
      "duration": 3.8,
      "text": "なるほど。"
    },
    {
      "start": 1450.24,
      "duration": 3.0,
      "text": "で、きっちり銘柄を選べばその取り出した福意を例えばリートの方に持っていって"
    },
    {
      "start": 1456.6,
      "duration": 3.76,
      "text": "そこからちょっともらいながらっていうのは"
    },
    {
      "start": 1458.96,
      "duration": 4.4,
      "text": "選択肢としてありだなという感じですね。"
    },
    {
      "start": 1460.36,
      "duration": 3.0,
      "text": "あのすごくおすすめなのはあの年を取れば取るほどめんどくさくなるんすよね。"
    },
    {
      "start": 1466.76,
      "duration": 3.2,
      "text": "あ、めんどくさくなる。"
    },
    {
      "start": 1468.12,
      "duration": 2.84,
      "text": "物件管理って結構めんどくさくないですか?"
    },
    {
      "start": 1469.96,
      "duration": 4.0,
      "text": "はい。"
    },
    {
      "start": 1470.96,
      "duration": 3.0,
      "text": "で、あの、若いうちはまだいいんですけれども、だんだん年を取ってくるとああ、めんどくさになるんですね。うん。"
    },
    {
      "start": 1476.679,
      "duration": 3.0,
      "text": "離島全然めんどくさいですから。ま、そもそも金融商品ですけど。"
    },
    {
      "start": 1481.159,
      "duration": 3.0,
      "text": "えっと、そういった意味では利回り高い配当をもらいながら配当生活を送るには"
    },
    {
      "start": 1487.08,
      "duration": 3.0,
      "text": "アパートを持つ方も多いですけれどもアパート大変なんですよね。"
    },
    {
      "start": 1491.399,
      "duration": 4.601,
      "text": "あの、手段さも入れ替わるし"
    },
    {
      "start": 1493.96,
      "duration": 3.8,
      "text": "から滑った頃がいっぱいあるんで"
    },
    {
      "start": 1496.0,
      "duration": 2.279,
      "text": "はい。えっと、お金もかかると"
    },
    {
      "start": 1497.76,
      "duration": 3.519,
      "text": "うん。"
    },
    {
      "start": 1498.279,
      "duration": 3.0,
      "text": "ね、リート全然かかんないで全部プロが運用してくれますので、"
    },
    {
      "start": 1501.679,
      "duration": 3.0,
      "text": "え、この含をうん。じゃあリートて配当生活をし、"
    },
    {
      "start": 1506.2,
      "duration": 4.16,
      "text": "あ、全然いいと思います。"
    },
    {
      "start": 1507.36,
      "duration": 3.0,
      "text": "なるほど。わかりました。色々伺かってきましたけれども、ま、人生"
    },
    {
      "start": 1510.52,
      "duration": 2.039,
      "text": "100年時代ということで言うと、ま、"
    },
    {
      "start": 1512.12,
      "duration": 3.439,
      "text": "50"
    },
    {
      "start": 1512.559,
      "duration": 3.0,
      "text": "歳からの不動産戦略ということですけども、まだ半分なんですよね、"
    },
    {
      "start": 1516.88,
      "duration": 2.919,
      "text": "ある意味。そうです。"
    },
    {
      "start": 1517.76,
      "duration": 2.2,
      "text": "はい。あの、これからのその人生"
    },
    {
      "start": 1519.799,
      "duration": 3.161,
      "text": "100"
    },
    {
      "start": 1519.96,
      "duration": 3.0,
      "text": "年時代の、ま、その、そういった方たちに向けて、ま、牧さんからメッセージというか伝えたいことお願いします。"
    },
    {
      "start": 1526.24,
      "duration": 1.96,
      "text": "そうですね。あのと"
    },
    {
      "start": 1527.84,
      "duration": 3.36,
      "text": "50"
    },
    {
      "start": 1528.2,
      "duration": 3.0,
      "text": "歳までの人生皆さん色々あのうん、山谷やりで、え、それぞれ皆さん過ごしてこられたと思うんですけれども、"
    },
    {
      "start": 1536.76,
      "duration": 3.32,
      "text": "50"
    },
    {
      "start": 1537.08,
      "duration": 3.0,
      "text": "からの人生っていうのをやっぱり楽しく考えたいなっていう風に、あの、僕自身も思ってきましたし、えっと、そういった意味では、えっと、今までの価値観が、えっと、これからの"
    },
    {
      "start": 1548.919,
      "duration": 3.441,
      "text": "50"
    },
    {
      "start": 1549.36,
      "duration": 3.0,
      "text": "歳以降の価値観ではないというところをまずティングポイント"
    },
    {
      "start": 1555.64,
      "duration": 3.8,
      "text": "してみませんかっていうですね。もちろん"
    },
    {
      "start": 1557.399,
      "duration": 4.041,
      "text": "今まで成功してきて、今後も成功していく"
    },
    {
      "start": 1559.44,
      "duration": 4.239,
      "text": "人もいらっしゃるんで、その方は変える"
    },
    {
      "start": 1561.44,
      "duration": 6.04,
      "text": "必要ないですけれども、じゃあ会社って"
    },
    {
      "start": 1563.679,
      "duration": 5.961,
      "text": "いう、ま、自分が本当に長年こうここで"
    },
    {
      "start": 1567.48,
      "duration": 7.12,
      "text": "働いてきたっていう器を出るわけですから"
    },
    {
      "start": 1569.64,
      "duration": 8.399,
      "text": "、あの、ま、よくあの会社退職された方が"
    },
    {
      "start": 1574.6,
      "duration": 6.12,
      "text": "、えっと、定年した後も昔の同僚とか先輩"
    },
    {
      "start": 1578.039,
      "duration": 5.36,
      "text": "とか、えっと、飲み会やゴルフ、ま、それ"
    },
    {
      "start": 1580.72,
      "duration": 6.28,
      "text": "はそれで楽しい面もあるんですけれども、"
    },
    {
      "start": 1583.399,
      "duration": 6.601,
      "text": "それだけの人生で過ごすにはまだまだ長い"
    },
    {
      "start": 1587.0,
      "duration": 3.0,
      "text": "月行きますんで、えっと、是非自分の人生後半戦っていうのを丁寧になる直前あるいは直後に考えるのではなく"
    },
    {
      "start": 1596.0,
      "duration": 3.44,
      "text": "50ぐらいから作戦をね、といて"
    },
    {
      "start": 1600.2,
      "duration": 5.16,
      "text": "これでじゃ必要なお金どのぐらい"
    },
    {
      "start": 1602.52,
      "duration": 3.36,
      "text": "だったらマンションの含命ちょっと活用しようか。うん。"
    },
    {
      "start": 1605.36,
      "duration": 3.52,
      "text": "うん。うん。"
    },
    {
      "start": 1605.88,
      "duration": 3.0,
      "text": "ま、もちろんお子さんにどのぐらい残しておくかっていうのも見極めた上で第"
    },
    {
      "start": 1610.679,
      "duration": 5.681,
      "text": "2の人生計画っていうのを"
    },
    {
      "start": 1612.919,
      "duration": 3.441,
      "text": "うん。ま、自分の中で組んでいりしながら"
    },
    {
      "start": 1616.52,
      "duration": 4.279,
      "text": "それから50"
    },
    {
      "start": 1617.799,
      "duration": 3.0,
      "text": "代以降で、え、思いっきり不動産投資なんかにあの大きなローンなんかを背負ってやって仮に失敗するともう人生立て直せませんに従って設けるのはあのわゆるあの大儲けするのは若いうちです。"
    },
    {
      "start": 1637.72,
      "duration": 3.559,
      "text": "え、下50"
    },
    {
      "start": 1638.559,
      "duration": 5.72,
      "text": "歳以降はちょっとは儲けたいんですけれども、"
    },
    {
      "start": 1641.279,
      "duration": 3.0,
      "text": "むしろ自分の生活に、えっと、どれだけのお金をうん、有効に使っていくかっていう風にちょっと考え方をこうリセットしていくと楽しい申請が遅くれんじゃないかなと思います。"
    },
    {
      "start": 1652.32,
      "duration": 3.64,
      "text": "ま、逆に50"
    },
    {
      "start": 1652.96,
      "duration": 3.0,
      "text": "を超えてある程度必要なお金も見えてきた中である意味そういうこと楽しみながら次の人生に向けて考えていくっていう作業が必要なのかもしれませんね。"
    },
    {
      "start": 1661.6,
      "duration": 5.4,
      "text": "はい、わかりました。本日はどうもありがとうございました。"
    },
    {
      "start": 1664.0,
      "duration": 3.0,
      "text": "ありがとうございました。"
    },
    {
      "start": 1681.799,
      "duration": 3.0,
      "text": "お"
    }
  ]
}