    {
      "start": 440.879,
      "duration": 5.561,
      "text": "はないと否定をしています。ここも平行戦"
    },
    {
      "start": 443.479,
      "duration": 5.72,
      "text": "なんですよね。ただし1つ注目すべき情報"
    },
    {
      "start": 446.44,
      "duration": 5.599,
      "text": "があります。イラン外務省の報道官がいく"
    },
    {
      "start": 449.199,
      "duration": 5.641,
      "text": "つかの点では合意に達したが2つの重要な"
    },
    {
      "start": 452.039,
      "duration": 5.521,
      "text": "問題で決裂したとも発表してるんですよね"
    },
    {
      "start": 454.84,
      "duration": 5.32,
      "text": "。今後情報が変わる可能性がありますけど"
    },
    {
      "start": 457.56,
      "duration": 5.4,
      "text": "も、もしこれが事実なら全部がダメだった"
    },
    {
      "start": 460.16,
      "duration": 5.64,
      "text": "わけじゃない。各とホルムズ以外の部分で"
    },
    {
      "start": 462.96,
      "duration": 5.679,
      "text": "は前に進んだ可能性があります。それでは"
    },
    {
      "start": 465.8,
      "duration": 5.359,
      "text": "本日の品き3つ目に割りましょう。今後は"
    },
    {
      "start": 468.639,
      "duration": 5.361,
      "text": "どうなる?4つのシナリオと株価の動き"
    },
    {
      "start": 471.159,
      "duration": 5.561,
      "text": "です。ここまでの内容を踏まえて低戦期限"
    },
    {
      "start": 474.0,
      "duration": 5.28,
      "text": "である残り10日間起こりよる4つの"
    },
    {
      "start": 476.72,
      "duration": 5.199,
      "text": "シナリオを整理をしていきます。まず1つ"
    },
    {
      "start": 479.28,
      "duration": 5.68,
      "text": "目はイランがアメリカの最終案を"
    },
    {
      "start": 481.919,
      "duration": 5.361,
      "text": "受け入れるです。バンス大統領は最終的"
    },
    {
      "start": 484.96,
      "duration": 5.32,
      "text": "かつ最前のオファーを置いてきたと言い"
    },
    {
      "start": 487.28,
      "duration": 6.199,
      "text": "ました。イランがこれを受け入れれば低線"
    },
    {
      "start": 490.28,
      "duration": 5.759,
      "text": "が延長されてホルムズ海峡が単階的に解放"
    },
    {
      "start": 493.479,
      "duration": 5.4,
      "text": "されていきます。ホルムズ海峡が開く。"
    },
    {
      "start": 496.039,
      "duration": 5.361,
      "text": "そうすると原油価格が下がる。そうすると"
    },
    {
      "start": 498.879,
      "duration": 5.72,
      "text": "インフレ記念が交代する。そうしますと"
    },
    {
      "start": 501.4,
      "duration": 6.479,
      "text": "金利が下がって株価が上がる。川わせも"
    },
    {
      "start": 504.599,
      "duration": 5.961,
      "text": "有時のドルガが巻き戻ってや円高に動く"
    },
    {
      "start": 507.879,
      "duration": 5.481,
      "text": "はずです。ただし正直に言ってこの"
    },
    {
      "start": 510.56,
      "duration": 6.08,
      "text": "シナリオの可能性は低いと思っています。"
    },
    {
      "start": 513.36,
      "duration": 5.919,
      "text": "各とホルムズの主験でイランが大幅に情報"
    },
    {
      "start": 516.64,
      "duration": 5.879,
      "text": "する必要があるんですよね。21時間かけ"
    },
    {
      "start": 519.279,
      "duration": 6.201,
      "text": "てもダメだったものが持ち帰って急にOK"
    },
    {
      "start": 522.519,
      "duration": 7.121,
      "text": "になるとはちょっと考えにくいですよね。"
    },
    {
      "start": 525.48,
      "duration": 7.56,
      "text": "続いて2つ目は部分合意ホルムズ解決は"
    },
    {
      "start": 529.64,
      "duration": 6.8,
      "text": "棚げこのパターンですね。核問題は置いて"
    },
    {
      "start": 533.04,
      "duration": 6.96,
      "text": "おいてホルムズの安全通行だけ先に合意"
    },
    {
      "start": 536.44,
      "duration": 6.12,
      "text": "する。訂線を延長して交渉を続ける。僕は"
    },
    {
      "start": 540.0,
      "duration": 5.76,
      "text": "これが1番ありえそうかなと思っています"
    },
    {
      "start": 542.56,
      "duration": 6.32,
      "text": "。なぜかと言うと両者にとってメンツを"
    },
    {
      "start": 545.76,
      "duration": 5.68,
      "text": "保てる落としどなんですよね。アメリカは"
    },
    {
      "start": 548.88,
      "duration": 5.199,
      "text": "ホルムズを開けさせたと言えますよね。"
    },
    {
      "start": 551.44,
      "duration": 5.639,
      "text": "イランは核の権利を守ったと言えますよね"
    },
    {
      "start": 554.079,
      "duration": 5.681,
      "text": "。トランプ大統領もディールメーカーだと"
    },
    {
      "start": 557.079,
      "duration": 5.681,
      "text": "アピールできます。ただこの場合ですね、"
    },
    {
      "start": 559.76,
      "duration": 4.88,
      "text": "そもそもイラン戦争を開しと何も変わって"
    },
    {
      "start": 562.76,
      "duration": 4.519,
      "text": "ないということにもなりますよね。"
    },
    {
      "start": 564.64,
      "duration": 5.48,
      "text": "果たして戦争の意味があったのかともなり"
    },
    {
      "start": 567.279,
      "duration": 6.041,
      "text": "得ますよね。この場合原因はじわじわ"
    },
    {
      "start": 570.12,
      "duration": 5.719,
      "text": "下がるけど急落はしません。株もじわじわ"
    },
    {
      "start": 573.32,
      "duration": 5.68,
      "text": "戻るけど爆上げはしない。アンドラリーで"
    },
    {
      "start": 575.839,
      "duration": 5.721,
      "text": "はなくじわじわ改善の展開なんですよね。"
    },
    {
      "start": 579.0,
      "duration": 4.72,
      "text": "低線ラリーから終戦ラリーに行って欲しい"
    },
    {
      "start": 581.56,
      "duration": 4.92,
      "text": "んですけれども、そこに行くかちょっと"
    },
    {
      "start": 583.72,
      "duration": 6.119,
      "text": "時間がかかりそうなシナリオとなります。"
    },
    {
      "start": 586.48,
      "duration": 6.799,
      "text": "続いては3つ目。低戦機限切れからの攻撃"
    },
    {
      "start": 589.839,
      "duration": 6.721,
      "text": "再開悪夢のパターンですね。これが1番"
    },
    {
      "start": 593.279,
      "duration": 6.8,
      "text": "怖いシナリオ。イランが最終案を拒否米国"
    },
    {
      "start": 596.56,
      "duration": 6.32,
      "text": "も情報しない。4月22日に停戦が自動的"
    },
    {
      "start": 600.079,
      "duration": 6.281,
      "text": "に執行してトランプ大統領が攻撃再開を"
    },
    {
      "start": 602.88,
      "duration": 6.92,
      "text": "宣言。ホルムズが再び完全封鎖。原油が"
    },
    {
      "start": 606.36,
      "duration": 5.88,
      "text": "急闘。連想ゲームが全力で正方向に再起動"
    },
    {
      "start": 609.8,
      "duration": 5.4,
      "text": "します。原油が上がる、インフレが再連"
    },
    {
      "start": 612.24,
      "duration": 5.8,
      "text": "する。そうしますと金利が上がる、株が"
    },
    {
      "start": 615.2,
      "duration": 5.48,
      "text": "売られる。3月の悪夢がもう1度来る。"
    },
    {
      "start": 618.04,
      "duration": 6.52,
      "text": "日本はエネルギー輸入大国だから直撃です"
    },
    {
      "start": 620.68,
      "duration": 7.2,
      "text": "。円安も再加速します。トランプ大統領は"
    },
    {
      "start": 624.56,
      "duration": 6.08,
      "text": "合意しなくても米国の勝利だとすでに布を"
    },
    {
      "start": 627.88,
      "duration": 5.72,
      "text": "打っています。イランの国家安全保障会議"
    },
    {
      "start": 630.64,
      "duration": 5.199,
      "text": "も我々の手はまだ引き金の上にあると言っ"
    },
    {
      "start": 633.6,
      "duration": 5.32,
      "text": "ています。可能性はゼロじゃないんですよ"
    },
    {
      "start": 635.839,
      "duration": 6.481,
      "text": "ね。そして4つ目のシナリオ。米軍が"
    },
    {
      "start": 638.92,
      "duration": 6.359,
      "text": "ホルムズ海峡の強制解放をするこれです。"
    },
    {
      "start": 642.32,
      "duration": 6.28,
      "text": "実はこれもう始まりかけてるんですよね。"
    },
    {
      "start": 645.279,
      "duration": 6.601,
      "text": "トランプ大統領は米軍がホルムズの正解を"
    },
    {
      "start": 648.6,
      "duration": 6.96,
      "text": "開始したと発表しています。さらにイラン"
    },
    {
      "start": 651.88,
      "duration": 5.88,
      "text": "の嫌雷施設戦28は全て海底に沈んだと"
    },
    {
      "start": 655.56,
      "duration": 5.48,
      "text": "主張もしています。ただしこれはトランプ"
    },
    {
      "start": 657.76,
      "duration": 6.24,
      "text": "大統領の発言です。駆逐間席が正解作戦中"
    },
    {
      "start": 661.04,
      "duration": 5.12,
      "text": "です。つまり交渉がまとまらなくても"
    },
    {
      "start": 664.0,
      "duration": 4.92,
      "text": "力づくで開けるるていう選択肢をアメリカ"
    },
    {
      "start": 666.16,
      "duration": 5.359,
      "text": "は持ってるんですよね。実際イランは軍用"
    },
    {
      "start": 668.92,
      "duration": 5.28,
      "text": "官がホルムズを通過しようとすれば強力な"
    },
    {
      "start": 671.519,
      "duration": 5.681,
      "text": "対応を取ると警告をしています。つまり"
    },
    {
      "start": 674.2,
      "duration": 5.6,
      "text": "イランは米軍の動きに対してすに反発の"
    },
    {
      "start": 677.2,
      "duration": 5.0,
      "text": "指定を見せ始めてるんですよね。シナリオ"
    },
    {
      "start": 679.8,
      "duration": 5.2,
      "text": "さんよりも急激にマーケットが動く可能性"
    },
    {
      "start": 682.2,
      "duration": 5.36,
      "text": "があります。一時的なパニックりが来る"
    },
    {
      "start": 685.0,
      "duration": 5.0,
      "text": "可能性もあるんですよね。ま、強制的に"
    },
    {
      "start": 687.56,
      "duration": 4.959,
      "text": "開いたとしてもイランが抵抗してきてそこ"
    },
    {
      "start": 690.0,
      "duration": 5.24,
      "text": "でまたドンパチが始まってしまうとこれも"
    },
    {
      "start": 692.519,
      "duration": 5.56,
      "text": "なかなかに恐ろしいシナリオです。では"
    },
    {
      "start": 695.24,
      "duration": 5.399,
      "text": "もっと短期的に見て週訳の相場がどうなり"
    },
    {
      "start": 698.079,
      "duration": 5.281,
      "text": "そうかそれもまとめておきましょう。それ"
    },
    {
      "start": 700.639,
      "duration": 6.2,
      "text": "では本日の品き4つ目に参りましょう。"
    },
    {
      "start": 703.36,
      "duration": 6.76,
      "text": "週明けの米国株日本株どうなる?まずは"
    },
    {
      "start": 706.839,
      "duration": 6.321,
      "text": "米国株本道が収録時点でサンデーダウが"
    },
    {
      "start": 710.12,
      "duration": 5.56,
      "text": "1%ほど下落をしています。暴落じゃない"
    },
    {
      "start": 713.16,
      "duration": 6.04,
      "text": "んですよね。これが何を意味するかという"
    },
    {
      "start": 715.68,
      "duration": 6.839,
      "text": "と、市場は完全な決裂とは見ていない可能"
    },
    {
      "start": 719.2,
      "duration": 7.12,
      "text": "性があります。もしも低線崩壊攻撃再回"
    },
    {
      "start": 722.519,
      "duration": 6.44,
      "text": "なら3%以上下落してるはずです。1%"
    },
    {
      "start": 726.32,
      "duration": 5.72,
      "text": "マイナスは交渉不調だけどまだ終わってい"
    },
    {
      "start": 728.959,
      "duration": 7.281,
      "text": "ないというそんな温度感の印象です。先週"
    },
    {
      "start": 732.04,
      "duration": 7.64,
      "text": "S&Pは+3%超でしたよね。月曜に-1"
    },
    {
      "start": 736.24,
      "duration": 7.08,
      "text": "から-2%でなら先週の上げの一部を返し"
    },
    {
      "start": 739.68,
      "duration": 6.519,
      "text": "ただけ。本当のリスクは4月22日です。"
    },
    {
      "start": 743.32,
      "duration": 5.24,
      "text": "そこで停戦が切れるかどうか、それまでは"
    },
    {
      "start": 746.199,
      "duration": 4.721,
      "text": "不安定だけど崩壊していないそんなレンジ"
    },
    {
      "start": 748.56,
      "duration": 4.719,
      "text": "になると私は思っています。もう1つ"
    },
    {
      "start": 750.92,
      "duration": 4.4,
      "text": "月曜日からはアメリカの決算シーズンが"
    },
    {
      "start": 753.279,
      "duration": 4.161,
      "text": "始まります。ゴールドマンサックスが月曜"
    },
    {
      "start": 755.32,
      "duration": 4.56,
      "text": "、JPモルガン、ウェルズファーゴ、"
    },
    {
      "start": 757.44,
      "duration": 4.839,
      "text": "シティ、ブラックロックが火曜日です。"
    },
    {
      "start": 759.88,
      "duration": 5.079,
      "text": "企業の実際の数字が出てくるとマーケット"
    },
    {
      "start": 762.279,
      "duration": 4.961,
      "text": "の関心がイランから決算に移る可能性が"
    },
    {
      "start": 764.959,
      "duration": 4.961,
      "text": "あります。特に銀行セクターからまず"
    },
    {
      "start": 767.24,
      "duration": 4.88,
      "text": "始まりますよね。銀行セクターの決算"
    },
    {
      "start": 769.92,
      "duration": 5.159,
      "text": "プライベートクレジット問題がどこまで"
    },
    {
      "start": 772.12,
      "duration": 5.8,
      "text": "反映されるかこれはよう注目です。続いて"
    },
    {
      "start": 775.079,
      "duration": 5.12,
      "text": "は日本株。米国株よりも先に日本"
    },
    {
      "start": 777.92,
      "duration": 5.12,
      "text": "マーケットの方が開きますのでその結果に"
    },
    {
      "start": 780.199,
      "duration": 5.561,
      "text": "要注目です。サンデーダウの状況を見るに"
    },
    {
      "start": 783.04,
      "duration": 5.52,
      "text": "下落スタートの可能性ありそうですよね。"
    },
    {
      "start": 785.76,
      "duration": 6.68,
      "text": "ただしいくつか下田再増量もあります。"
    },
    {
      "start": 788.56,
      "duration": 6.079,
      "text": "まず外国人投資家が先週2.96兆円も"
    },
    {
      "start": 792.44,
      "duration": 5.44,
      "text": "解雇したばかり。大きなお金が入った"
    },
    {
      "start": 794.639,
      "duration": 6.56,
      "text": "ばかりです。次に合わせ定線不安でドルが"
    },
    {
      "start": 797.88,
      "duration": 5.6,
      "text": "進めば円安方向に動きます。円安は輸出"
    },
    {
      "start": 801.199,
      "duration": 4.721,
      "text": "企業にとってはプラスの側面がある。"
    },
    {
      "start": 803.48,
      "duration": 5.159,
      "text": "そしてさっきお話した通りホルムズの通行"
    },
    {
      "start": 805.92,
      "duration": 5.039,
      "text": "はまだ止まってないんですよね。停戦は今"
    },
    {
      "start": 808.639,
      "duration": 5.081,
      "text": "のところは維持されています。機嫌も"
    },
    {
      "start": 810.959,
      "duration": 5.641,
      "text": "始まっています。1ヶ月前に戻るわけじゃ"
    },
    {
      "start": 813.72,
      "duration": 5.84,
      "text": "ないんですよね。むしろ日本株にとっての"
    },
    {
      "start": 816.6,
      "duration": 6.52,
      "text": "1番の大きなイベント4月28日の日銀"
    },
    {
      "start": 819.56,
      "duration": 6.719,
      "text": "政策決定開合昨日の動画でお話をした上野"
    },
    {
      "start": 823.12,
      "duration": 6.64,
      "text": "総裁の金利1%の判断ここのインパクト"
    },
    {
      "start": 826.279,
      "duration": 6.041,
      "text": "結構大きです。それでは本日の品き最後に"
    },
    {
      "start": 829.76,
      "duration": 6.4,
      "text": "参りましょう。結露のニュースで長期投資"
    },
    {
      "start": 832.32,
      "duration": 7.28,
      "text": "家はどう考えるか最後に僕が1番伝えたい"
    },
    {
      "start": 836.16,
      "duration": 6.599,
      "text": "話をします。決裂このニュースを聞いて"
    },
    {
      "start": 839.6,
      "duration": 5.56,
      "text": "怖いと思った方多いかと思います。でも"
    },
    {
      "start": 842.759,
      "duration": 5.601,
      "text": "ちょっと引いてみて欲しいんです。21"
    },
    {
      "start": 845.16,
      "duration": 6.76,
      "text": "時間話し合ったんですよ。1979年以来"
    },
    {
      "start": 848.36,
      "duration": 7.039,
      "text": "始めて直接顔を合わせて両国の代表団が"
    },
    {
      "start": 851.92,
      "duration": 6.479,
      "text": "深山でこれは交代でしょうか?僕は全身だ"
    },
    {
      "start": 855.399,
      "duration": 5.161,
      "text": "と思います。先週トランプ大統領は文明を"
    },
    {
      "start": 858.399,
      "duration": 4.24,
      "text": "滅ぼすと言ってましたよね。イランは"
    },
    {
      "start": 860.56,
      "duration": 5.0,
      "text": "ミサイルを打ち続けると言っていた。それ"
    },
    {
      "start": 862.639,
      "duration": 6.12,
      "text": "が同じテーブルに座った。合意はできませ"
    },
    {
      "start": 865.56,
      "duration": 5.399,
      "text": "んでした。でも座った。バ氏は最終案を"
    },
    {
      "start": 868.759,
      "duration": 5.281,
      "text": "置いてきたと言っています。ドアは閉まっ"
    },
    {
      "start": 870.959,
      "duration": 5.281,
      "text": "ていません。線は4月22日まで今の"
    },
    {
      "start": 874.04,
      "duration": 5.28,
      "text": "ところ続きます。嫌い除去も始まってい"
    },
    {
      "start": 876.24,
      "duration": 6.039,
      "text": "ます。16席がホルムズ海峡を通過し始め"
    },
    {
      "start": 879.32,
      "duration": 5.319,
      "text": "ています。3月中旬恐怖のピークで"
    },
    {
      "start": 882.279,
      "duration": 5.401,
      "text": "アメリカの個人投資家は手を止めました。"
    },
    {
      "start": 884.639,
      "duration": 7.081,
      "text": "購入額が1月から70%も減ったんですよ"
    },
    {
      "start": 887.68,
      "duration": 7.0,
      "text": "ね。でもその直後に市場はS&P7日間も"
    },
    {
      "start": 891.72,
      "duration": 5.16,
      "text": "連続で上昇しました。ホールドを続けた人"
    },
    {
      "start": 894.68,
      "duration": 5.599,
      "text": "は年収リターンプラスに戻ってきています"
    },
    {
      "start": 896.88,
      "duration": 6.399,
      "text": "。怖い時に売りたくなるのは人間誰しも"
    },
    {
      "start": 900.279,
      "duration": 5.24,
      "text": "当たり前です。でも歴史はその瞬間に"
    },
    {
      "start": 903.279,
      "duration": 4.0,
      "text": "ホールドを続けた人のところにリターンが"
    },
    {
      "start": 905.519,
      "duration": 5.12,
      "text": "帰ってくるとそのようにも言ってるんです"
    },
    {
      "start": 907.279,
      "duration": 5.721,
      "text": "よね。あと10日間。この10日間で世界"
    },
    {
      "start": 910.639,
      "duration": 5.0,
      "text": "が動くかもしれないし動かないかもしれ"
    },
    {
      "start": 913.0,
      "duration": 5.68,
      "text": "ない。でも長期投資があることは変わり"
    },
    {
      "start": 915.639,
      "duration": 5.841,
      "text": "ません。淡々と積み立てて淡々とホールド"
    },
    {
      "start": 918.68,
      "duration": 5.32,
      "text": "。本チャンネルでは今後もイラン同行中心"
    },
    {
      "start": 921.48,
      "duration": 4.52,
      "text": "に株価がどのように動くかスピーディに"
    },
    {
      "start": 924.0,
      "duration": 4.04,
      "text": "アップデートをしていきます。気になる方"
    },
    {
      "start": 926.0,
      "duration": 4.199,
      "text": "は是非チャンネル登録をしてお待ち"
    },
    {
      "start": 928.04,
      "duration": 4.479,
      "text": "ください。本日も最後までご視聴いただき"
    },
    {
      "start": 930.199,
      "duration": 4.801,
      "text": "ましてありがとうございました。本日の"
    },
    {
      "start": 932.519,
      "duration": 4.68,
      "text": "動画の裏話や動画の中ではちょっと言い"
    },
    {
      "start": 935.0,
      "duration": 4.839,
      "text": "きれない本音をノートのメンバーシップで"
    },
    {
      "start": 937.199,
      "duration": 4.921,
      "text": "発信を始めております。台本を作りながら"
    },
    {
      "start": 939.839,
      "duration": 5.24,
      "text": "考えたことやちょっと公開動画では得ない"
    },
    {
      "start": 942.12,
      "duration": 5.839,
      "text": "ことも楽ヤトーク的に有力発信中です。気"
    },
    {
      "start": 945.079,
      "duration": 5.601,
      "text": "になる方は概要欄かこちらのQRコードを"
    },
    {
      "start": 947.959,
      "duration": 4.761,
      "text": "読み込むとノートに登録できますので是非"
    },
    {
      "start": 950.68,
      "duration": 4.519,
      "text": "チェックをしてみてください。概要欄に"
    },
    {
      "start": 952.72,
      "duration": 5.0,
      "text": "LINEXインスタメルマガのURLが"
    },
    {
      "start": 955.199,
      "duration": 5.76,
      "text": "あります。私自身が取り組んでいる資産"
    },
    {
      "start": 957.72,
      "duration": 6.039,
      "text": "形成や生続との工夫は今後LINEで配信"
    },
    {
      "start": 960.959,
      "duration": 5.201,
      "text": "予定ご興味ある方はご登録ください。"
    },
    {
      "start": 963.759,
      "duration": 5.601,
      "text": "メルマガでは日々の経済ニュースを分かり"
    },
    {
      "start": 966.16,
      "duration": 5.96,
      "text": "やすく解説しています。インスタやXでは"
    },
    {
      "start": 969.36,
      "duration": 7.279,
      "text": "より短時間で情報インプットができます。"
    },
    {
      "start": 972.12,
      "duration": 4.519,
      "text": "是非ご登録をお願いします。"
    }
  ]
}