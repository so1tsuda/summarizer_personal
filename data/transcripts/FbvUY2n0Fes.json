      "start": 883.8,
      "duration": 4.44,
      "text": "ます。ですんで、ま、これらがうまくいけ"
    },
    {
      "start": 886.16,
      "duration": 5.0,
      "text": "ばですね、全部うまくいけば、あ、この"
