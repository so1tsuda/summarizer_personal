    {
      "start": 979.0,
      "duration": 3.68,
      "text": "ポジティブだって見方もあります。ただ"
    },
    {
      "start": 980.88,
      "duration": 4.92,
      "text": "このポイントはですね、こちらのグラフに"
    },
    {
      "start": 982.68,
      "duration": 7.279,
