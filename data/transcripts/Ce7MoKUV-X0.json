      "start": 583.32,
      "duration": 8.04,
      "text": "なってるわけですよ。え、まさに世界の"
    },
    {
      "start": 586.12,
      "duration": 10.92,
      "text": "資金が日本市場に本格的に参入し始めたん"
    },
    {
      "start": 591.36,
      "duration": 7.919,
      "text": "です。日本株が世界の投資対象に昇格した"
    },
    {
      "start": 597.04,
      "duration": 5.68,
      "text": "んです。"
    },
    {
      "start": 599.279,
      "duration": 6.8,
      "text": "これは大きなことなんだと。今までとは"
    },
    {
      "start": 602.72,
      "duration": 6.84,
      "text": "全然違うことが起きてるんだった。今まで"
    },
    {
      "start": 606.079,
      "duration": 7.641,
      "text": "もそういう流れだったけども、さらに"
    },
    {
      "start": 609.56,
      "duration": 7.88,
      "text": "大きなうりとなってめちゃくちゃな金が"
    },
    {
      "start": 613.72,
      "duration": 7.44,
      "text": "日本市場をうわーっときたわけです。だ"
    },
    {
      "start": 617.44,
      "duration": 5.28,
      "text": "からこんなに綺麗になるの。結局みんな"
    },
    {
      "start": 621.16,
      "duration": 5.76,
      "text": "下がったの結局上がっちゃったじゃない"
    },
    {
      "start": 622.72,
      "duration": 6.32,
      "text": "ですか。え、このまずか2週間であっと"
    },
    {
      "start": 626.92,
      "duration": 5.12,
      "text": "いう間に持っちゃおかしいでしょ。え、だ"
    },
    {
      "start": 629.04,
      "duration": 6.16,
      "text": "から言ってるじゃないですか。大変な"
    },
    {
      "start": 632.04,
      "duration": 7.599,
      "text": "大騒場にあるんだよと。弱気になったら"
    },
    {
      "start": 635.2,
      "duration": 8.439,
      "text": "終わりですよ。弱気な人ご苦労様ね。言っ"
    },
    {
      "start": 639.639,
      "duration": 6.32,
      "text": "てきたでしょ。ええ、大変だな。こんな"
    },
    {
      "start": 643.639,
      "duration": 6.88,
      "text": "もんじゃすまないんだって。我々の待っ"
    },
    {
      "start": 645.959,
      "duration": 8.32,
      "text": "てる先というのは多くの人が考えてるよう"
    },
    {
      "start": 650.519,
      "duration": 9.601,
      "text": "なこととは全く違う世界がこれから我々の"
    },
    {
      "start": 654.279,
      "duration": 10.521,
      "text": "前に現れてくるんだって。これは想像を"
    },
    {
      "start": 660.12,
      "duration": 9.2,
      "text": "超える物価高であり、想像を超える金利か"
    },
    {
      "start": 664.8,
      "duration": 6.24,
      "text": "であり、想像を超える株高それに付随する"
    },
    {
      "start": 669.32,
      "duration": 5.28,
      "text": "円安"
    },
    {
      "start": 671.04,
      "duration": 7.52,
      "text": "多くの人の想定を超えた流れが出てくるん"
    },
    {
      "start": 674.6,
      "duration": 6.0,
      "text": "だって。それを示唆してるんだって。そう"
    },
    {
      "start": 678.56,
      "duration": 5.44,
      "text": "じゃなきゃこんな簡単に戻るわけがない"
    },
    {
      "start": 680.6,
      "duration": 7.039,
      "text": "だろって。ええ、これに詳しく書きました"
    },
    {
      "start": 684.0,
      "duration": 6.92,
      "text": "。何が起こってんだって。何が水面で"
    },
    {
      "start": 687.639,
      "duration": 6.281,
      "text": "起こってんだよということはしっかり書き"
    },
    {
      "start": 690.92,
      "duration": 7.359,
      "text": "ました。ものすごくグツグツしたインフレ"
    },
    {
      "start": 693.92,
      "duration": 7.08,
      "text": "のが次から次へとえ、こようとしてるわけ"
    },
    {
      "start": 698.279,
      "duration": 5.0,
      "text": "よ。"
    },
    {
      "start": 701.0,
      "duration": 3.76,
      "text": "イラン情勢のことばっかり見てる。でも"
    },
    {
      "start": 703.279,
      "duration": 5.521,
      "text": "イラン情勢全然変わってないじゃないです"
    },
    {
      "start": 704.76,
      "duration": 6.519,
      "text": "かねえ。ねえ。ま、一応ね、原油の価格が"
    },
    {
      "start": 708.8,
      "duration": 5.56,
      "text": "87ドルというところまで下がって今日は"
    },
    {
      "start": 711.279,
      "duration": 5.841,
      "text": "交換したんだけれども根本的な情勢は"
    },
    {
      "start": 714.36,
      "duration": 7.159,
      "text": "変わってませんね。これでもこれだけ"
    },
    {
      "start": 717.12,
      "duration": 8.68,
      "text": "上がってしまうということがいいですか?"
    },
    {
      "start": 721.519,
      "duration": 6.921,
      "text": "何かが違うんだなと。え、ことを感じ"
    },
    {
      "start": 725.8,
      "duration": 5.92,
      "text": "なきゃダメなんだって。そうじゃなきゃ"
    },
    {
      "start": 728.44,
      "duration": 6.399,
      "text": "こんな短期で戻るわけがないだろうという"
    },
    {
      "start": 731.72,
      "duration": 6.28,
      "text": "ことなんですよね。"
    },
    {
      "start": 734.839,
      "duration": 6.8,
      "text": "これはいつも一貫して言ってきましたね。"
    },
    {
      "start": 738.0,
      "duration": 7.88,
      "text": "せ、あの3月の私のセミナーね、ちょうど"
    },
    {
      "start": 741.639,
      "duration": 8.081,
      "text": "1番安い時でした。ね、日本株大相場の"
    },
    {
      "start": 745.88,
      "duration": 7.48,
      "text": "条件が整った言ってきましたね。それが"
    },
    {
      "start": 749.72,
      "duration": 7.799,
      "text": "見事に出てますね。ええ、そういう流れな"
    },
    {
      "start": 753.36,
      "duration": 6.2,
      "text": "んです。大きなうりが来てるわけですねえ"
    },
    {
      "start": 757.519,
      "duration": 7.12,
      "text": "。個別銘柄見てみましょうかね。個別銘柄"
    },
    {
      "start": 759.56,
      "duration": 9.32,
      "text": "。うん。全くね。個別銘柄。あ、今行った"
    },
    {
      "start": 764.639,
      "duration": 7.88,
      "text": "記憶屋ですよ。すごいね。"
    },
    {
      "start": 768.88,
      "duration": 5.8,
      "text": "すごい。時価総額20兆円になっちゃって"
    },
    {
      "start": 772.519,
      "duration": 4.521,
      "text": "1400円から3万2000円まで行っ"
    },
    {
      "start": 774.68,
      "duration": 4.279,
      "text": "ちゃ3万6000円まで今日は行っちゃっ"
    },
    {
      "start": 777.04,
      "duration": 6.4,
      "text": "た。"
    },
    {
      "start": 778.959,
      "duration": 6.081,
      "text": "すごい相場だね。これだってPRから見"
    },
    {
      "start": 783.44,
      "duration": 4.6,
      "text": "たらまだ割り安になっちゃうかもしれない"
    },
    {
      "start": 785.04,
      "duration": 6.12,
      "text": "ということなんだから利益の伸びが"
    },
    {
      "start": 788.04,
      "duration": 5.28,
      "text": "すざまじいことになってるとね。こういう"
    },
    {
      "start": 791.16,
      "duration": 6.72,
      "text": "スター銘柄が出るっていうのは大きいん"
    },
    {
      "start": 793.32,
      "duration": 8.0,
      "text": "ですよね。スターが出るってことは世界の"
    },
    {
      "start": 797.88,
      "duration": 5.959,
      "text": "人間が見てるわけよ。すごいなとこれでけ"
    },
    {
      "start": 801.32,
      "duration": 8.28,
      "text": "した後スターが出てきたんですよ。日本の"
    },
    {
      "start": 803.839,
      "duration": 10.0,
      "text": "市場にね。うわーっと日本の金。日本は金"
    },
    {
      "start": 809.6,
      "duration": 10.08,
      "text": "関係ない。世界の金はロットが違うんです"
    },
    {
      "start": 813.839,
      "duration": 8.44,
      "text": "。その金がロットの違う金が退去来てる"
    },
    {
      "start": 819.68,
      "duration": 8.88,
      "text": "わけです。え、"
    },
    {
      "start": 822.279,
      "duration": 6.281,
      "text": "で、いずれ日本の投資家も随"
    },
    {
      "start": 828.72,
      "duration": 8.359,
      "text": "のこれからの流れなんだね。ええ、結局な"
    },
    {
      "start": 833.16,
      "duration": 5.88,
      "text": "人が置いて帰れるだけ。え、まだまだ相場"
    },
    {
      "start": 837.079,
      "duration": 4.401,
      "text": "はこんなもんじゃないんだよということな"
    },
    {
      "start": 839.04,
      "duration": 5.2,
      "text": "んです。ソフトグループありましたね。"
    },
    {
      "start": 841.48,
      "duration": 5.68,
      "text": "もう出遅れてる株がちょっとこれね、違っ"
    },
    {
      "start": 844.24,
      "duration": 5.32,
      "text": "た動きになってきたかもしんないね。"
    },
    {
      "start": 847.16,
      "duration": 5.119,
      "text": "アドバンテストもまた高値取っちゃうかも"
    },
    {
      "start": 849.56,
      "duration": 6.639,
      "text": "しれない。ね、東京エレクトロンもね、"
    },
    {
      "start": 852.279,
      "duration": 7.56,
      "text": "近づいてきましたよと。三菱夕で岩板です"
    },
    {
      "start": 856.199,
      "duration": 6.64,
      "text": "。高値を取るでしょうね。と水ずほもまた"
    },
    {
      "start": 859.839,
      "duration": 7.761,
      "text": "上がってきましたよ。"
    },
    {
      "start": 862.839,
      "duration": 7.521,
      "text": "トヨタもいい動きですと。さすがに藤倉は"
    },
    {
      "start": 867.6,
      "duration": 6.0,
      "text": "ずっと高いから今日はちょっと一服です。"
    },
    {
      "start": 870.36,
      "duration": 5.76,
      "text": "え、三十も一服です。ま、この辺はね、"
    },
    {
      "start": 873.6,
      "duration": 6.64,
      "text": "記憶者も今日下がったけど、ま、この辺は"
    },
    {
      "start": 876.12,
      "duration": 8.2,
      "text": "当たり前の動きで自然に動くということ"
    },
    {
      "start": 880.24,
      "duration": 7.399,
      "text": "ですよね。ええ、とにかく我々が見ている"
    },
    {
      "start": 884.32,
      "duration": 8.04,
      "text": "ことっていうのは歴史的な流れなんです。"
    },
    {
      "start": 887.639,
      "duration": 9.481,
      "text": "その歴史的な流れを主導してるものは日本"
    },
    {
      "start": 892.36,
      "duration": 6.36,
      "text": "のこれから来る想定を超えたインフレです"
    },
    {
      "start": 897.12,
      "duration": 5.56,
      "text": "。"
    },
    {
      "start": 898.72,
      "duration": 8.72,
      "text": "ここを理解しとかなきゃダメなんだとね。"
    },
    {
      "start": 902.68,
      "duration": 9.04,
      "text": "それをばっくり日本株がまだまだ飛躍する"
    },
    {
      "start": 907.44,
      "duration": 9.04,
      "text": "よと。こんなものは単なる女装段階ですね"
    },
    {
      "start": 911.72,
      "duration": 7.88,
      "text": "と。え、全てはレポートに書きましたね。"
    },
    {
      "start": 916.48,
      "duration": 6.12,
      "text": "じっくりこれを読んで先がこうなるんだな"
    },
    {
      "start": 919.6,
      "duration": 6.039,
      "text": "ということをね、知っておいていただき"
    },
    {
      "start": 922.6,
      "duration": 7.08,
      "text": "たいという風に思いますね。というわけで"
    },
    {
      "start": 925.639,
      "duration": 7.041,
      "text": "日本株はわずまずいらしょ。こんにちは。"
    },
    {
      "start": 929.68,
      "duration": 7.719,
      "text": "え、それではですね、当社もいよいよこれ"
    },
    {
      "start": 932.68,
      "duration": 9.68,
      "text": "本問です。本問のLINEを作りましたの"
    },
    {
      "start": 937.399,
      "duration": 8.68,
      "text": "で、これこそ本物の、え、このASK1の"
    },
    {
      "start": 942.36,
      "duration": 6.839,
      "text": "ね、朝倉系のASK1のLINE、え、"
    },
    {
      "start": 946.079,
      "duration": 5.801,
      "text": "これを始めましたんで、え、私がこれ喋っ"
    },
    {
      "start": 949.199,
      "duration": 6.401,
      "text": "てるもの以外は偽物になりますので、これ"
    },
    {
      "start": 951.88,
      "duration": 6.92,
      "text": "が本物ですね。ええ、やっぱりね、"
    },
    {
      "start": 955.6,
      "duration": 5.679,
      "text": "LINEってなんで始めたかったな。便利"
    },
    {
      "start": 958.8,
      "duration": 5.519,
      "text": "じゃないですか。で、このAS1っていう"
    },
    {
      "start": 961.279,
      "duration": 6.321,
      "text": "のは情報発信会社だから、だからあの"
    },
    {
      "start": 964.319,
      "duration": 5.681,
      "text": "セミナーとかそれからレポートとかそれ"
    },
    {
      "start": 967.6,
      "duration": 4.919,
      "text": "からCDとかあとモーニングニュースね。"
    },
    {
      "start": 970.0,
      "duration": 5.639,
      "text": "え、これを色々まあやってるわけじゃない"
    },
    {
      "start": 972.519,
      "duration": 4.281,
      "text": "ですか。だからこ今回はこんな相場になっ"
    },
    {
      "start": 975.639,
      "duration": 4.56,
      "text": "ちゃったんで、こんなニュースですよ。"
    },
    {
      "start": 976.8,
      "duration": 6.2,
      "text": "こんなレポートですよとか、今回のま、"
    },
    {
      "start": 980.199,
      "duration": 5.041,
      "text": "あのセミナーではこんな話をしたいですね"
    },
    {
      "start": 983.0,
      "duration": 4.639,
      "text": "とかね。あとはね、ま、セミナーの後"
    },
    {
      "start": 985.24,
      "duration": 4.36,
      "text": "グルメ情報があるから今度はこんなグルメ"
    },
    {
      "start": 987.639,
      "duration": 4.401,
      "text": "行くんですよとかいろんな情報が発信"
    },
    {
      "start": 989.6,
      "duration": 4.88,
      "text": "できるじゃないですか。やっぱりそれが"
    },
    {
      "start": 992.04,
      "duration": 4.799,
      "text": "簡単に発信できるんで便利だなと思ってた"
    },
    {
      "start": 994.48,
      "duration": 4.799,
      "text": "んでやりたいなとは思ってたんですよね。"
    },
    {
      "start": 996.839,
      "duration": 5.201,
      "text": "ただ偽物がここにわあわ出てきてしまった"
    },
    {
      "start": 999.279,
      "duration": 5.761,
      "text": "んですけども、ま、今度は偽物が出ると"
    },
    {
      "start": 1002.04,
      "duration": 5.239,
      "text": "こちらの本物が警告も出せるということに"
    },
    {
      "start": 1005.04,
      "duration": 4.0,
      "text": "なってるみたいですんでね、まあ今回これ"
    },
    {
      "start": 1007.279,
      "duration": 4.8,
      "text": "でね、本問のLINEっていうのを"
    },
    {
      "start": 1009.04,
      "duration": 7.0,
      "text": "オープンすることになりました。で、この"
    },
    {
      "start": 1012.079,
      "duration": 8.801,
      "text": "LINE登録してくれた方に対しての得典"
    },
    {
      "start": 1016.04,
      "duration": 9.519,
      "text": "なんですけれども、ま、まずは私のそう"
    },
    {
      "start": 1020.88,
      "duration": 7.079,
      "text": "ですね、あの25の時のね、証券会社入っ"
    },
    {
      "start": 1025.559,
      "duration": 6.041,
      "text": "て2年"
    },
    {
      "start": 1027.959,
      "duration": 7.0,
      "text": "半そこイラだな。これは私、あの、この時"
    },
    {
      "start": 1031.6,
      "duration": 5.52,
      "text": "に大勝負をかけて、その勝負をうまくいっ"
    },
    {
      "start": 1034.959,
      "duration": 5.48,
      "text": "て独立することができるできたんです"
    },
    {
      "start": 1037.12,
      "duration": 6.88,
      "text": "けれども、今楽待ちで私の失敗話とかって"
    },
    {
      "start": 1040.439,
      "duration": 6.441,
      "text": "いうのをこう色々あの、ま、再検談って"
    },
    {
      "start": 1044.0,
      "duration": 6.36,
      "text": "いうのをやって、それ結構見られてる動画"
    },
    {
      "start": 1046.88,
      "duration": 5.96,
      "text": "ですけども、この成功ぱシっていうので、"
    },
    {
      "start": 1050.36,
      "duration": 5.28,
      "text": "え、この25の時にあったので、その後"
    },
    {
      "start": 1052.84,
      "duration": 6.6,
      "text": "また失敗話があるんですけど、え、それも"
    },
    {
      "start": 1055.64,
      "duration": 6.919,
      "text": "ね、結構な面白い話なんで、え、この話を"
    },
    {
      "start": 1059.44,
      "duration": 6.0,
      "text": "、ああの、口で言ったんじゃなくて文章で"
    },
    {
      "start": 1062.559,
      "duration": 5.24,
      "text": "、その昔本に書いたんで、それベースに、"
    },
    {
      "start": 1065.44,
      "duration": 5.04,
      "text": "え、書いてましたんで、その話をそのまま"
    },
    {
      "start": 1067.799,
      "duration": 5.12,
      "text": "お送りしますんで、ああ、朝倉こんなこと"
    },
    {
      "start": 1070.48,
      "duration": 5.96,
      "text": "があったんだなっていう若い頃の話ですね"
    },
    {
      "start": 1072.919,
      "duration": 5.481,
      "text": "。ま、昔から勝負してやっぱり勝負師だっ"
    },
    {
      "start": 1076.44,
      "duration": 6.28,
      "text": "たんだなってことが結構分かると思うん"
    },
    {
      "start": 1078.4,
      "duration": 6.48,
      "text": "ですけども、あのね、面白いね、人生って"
    },
    {
      "start": 1082.72,
      "duration": 5.72,
      "text": "やっぱり決める瞬間っていうのがあるわけ"
    },
    {
      "start": 1084.88,
      "duration": 5.56,
      "text": "じゃないですか。あの、ずっとこう変に"
    },
    {
      "start": 1088.44,
      "duration": 5.239,
      "text": "行く人もいるかもしれませんけど、ある"
    },
    {
      "start": 1090.44,
      "duration": 5.2,
      "text": "程度の決断とかそれからとにかく会社を"
    },
    {
      "start": 1093.679,
      "duration": 4.641,
      "text": "やめる時なんていうのは大決断じゃない"
    },
    {
      "start": 1095.64,
      "duration": 6.08,
      "text": "ですか?ええ、やっぱりその私を会社"
    },
    {
      "start": 1098.32,
      "duration": 5.64,
      "text": "やめる時はそれなりの習な準備をして独立"
    },
    {
      "start": 1101.72,
      "duration": 5.4,
      "text": "したんですよね。え、そのことについて"
    },
    {
      "start": 1103.96,
      "duration": 5.839,
      "text": "書いたんで、え、それがまず1点得典とし"
    },
    {
      "start": 1107.12,
      "duration": 7.32,
      "text": "てお送りします。それからもう1つはね、"
    },
    {
      "start": 1109.799,
      "duration": 6.481,
      "text": "当社西野、西野の初心者向けの動画結構"
    },
    {
      "start": 1114.44,
      "duration": 5.52,
      "text": "長いですよ。1分以上だと思いましたけど"
    },
    {
      "start": 1116.28,
      "duration": 7.2,
      "text": "ね。これがね、プレゼントしますのでね、"
    },
    {
      "start": 1119.96,
      "duration": 5.56,
      "text": "登録してたくれた方が面白い話がね、"
    },
    {
      "start": 1123.48,
      "duration": 2.88,
      "text": "いっぱいから、え、それやったらいいと"
    },
    {
      "start": 1125.52,
      "duration": 3.6,
      "text": "思いますよ。"
    },
    {
      "start": 1126.36,
      "duration": 2.92,
      "text": "で、登録してくれた後、あ、まあ、"
    },
    {
      "start": 1129.12,
      "duration": 3.16,
      "text": "1"
    },
    {
      "start": 1129.28,
      "duration": 3.0,
      "text": "の方でそういった、あ、いろんな情報発信っていうのは、あ、今度セミナーですよ、今度、あ、"
    },
    {
      "start": 1134.08,
      "duration": 4.599,
      "text": "CDですよ。こんな話ですよっていうのは"
    },
    {
      "start": 1136.12,
      "duration": 5.36,
      "text": "ありますんで。で、今詐欺は色々あって、"
    },
    {
      "start": 1138.679,
      "duration": 5.401,
      "text": "まあ何千万振り込めとか、ま、うちでもね"
    },
    {
      "start": 1141.48,
      "duration": 5.48,
      "text": "、そういうあの騙されたって話いっぱい来"
    },
    {
      "start": 1144.08,
      "duration": 7.04,
      "text": "てんですけども、このK1の商材っていう"
    },
    {
      "start": 1146.96,
      "duration": 6.36,
      "text": "のはね、せいぜ、ま、あの、あのセミナー"
    },
    {
      "start": 1151.12,
      "duration": 4.6,
      "text": "が1万2000円、1万3000円とか、"
    },
    {
      "start": 1153.32,
      "duration": 5.4,
      "text": "ま、レポートだったら1回、え、"
    },
    {
      "start": 1155.72,
      "duration": 6.76,
      "text": "3300円とか、ま、そういうかは、まあ"
    },
    {
      "start": 1158.72,
      "duration": 6.04,
      "text": "、ちょっとした、ま、ま、多くても数万円"
    },
    {
      "start": 1162.48,
      "duration": 4.559,
      "text": "っていう程度の、ま、クレジット決済の話"
    },
    {
      "start": 1164.76,
      "duration": 5.799,
      "text": "ですから、それ以外は別にやりませんので"
    },
    {
      "start": 1167.039,
      "duration": 7.361,
      "text": "、え、それから双方で話ができるのでこと"
    },
    {
      "start": 1170.559,
      "duration": 7.561,
      "text": "によったら、ま、当社の若手の黒コメとか"
    },
    {
      "start": 1174.4,
      "duration": 5.8,
      "text": "、あ、まがですね、そういった話でこう"
    },
    {
      "start": 1178.12,
      "duration": 3.919,
      "text": "応じることはできるかもしれないので、ま"
    },
    {
      "start": 1180.2,
      "duration": 3.88,
      "text": "、そういったことも考えてますんで、ま、"
    },
    {
      "start": 1182.039,
      "duration": 4.601,
      "text": "とにかくLINEをオープンしました。あ"
    },
    {
      "start": 1184.08,
      "duration": 4.92,
      "text": "、是非とりあえずですね、え、登録して"
    },
    {
      "start": 1186.64,
      "duration": 6.88,
      "text": "ですね、え、このね、あの、楽しんで"
    },
    {
      "start": 1189.0,
      "duration": 4.52,
      "text": "いただければという風に思います。"
    },
    {
      "start": 1196.64,
      "duration": 5.88,
      "text": "世界経済の裏側を知る。真実を知"
    },
    {
      "start": 1200.2,
      "duration": 6.599,
      "text": "るっていうことなんですよね。朝倉系"
    },
    {
      "start": 1202.52,
      "duration": 7.68,
      "text": "セミナー政治経済旬のテーマをですね、"
    },
    {
      "start": 1206.799,
      "duration": 6.601,
      "text": "その時の旬の話をですね、私がね、目"
    },
    {
      "start": 1210.2,
      "duration": 6.08,
      "text": "いっぱい話しますから、これ是非聞いてみ"
    },
    {
      "start": 1213.4,
      "duration": 4.8,
      "text": "てくださいね。え、すでにですね、え、ま"
    },
    {
      "start": 1216.28,
      "duration": 4.639,
      "text": "、ホームページ上でセミナー公開してます"
    },
    {
      "start": 1218.2,
