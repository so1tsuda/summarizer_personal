      "text": "うん。"
    },
    {
      "start": 495.12,
      "duration": 5.16,
      "text": "賃金を払わなければならないわけです。"
    },
    {
      "start": 497.28,
      "duration": 3.0,
      "text": "一般的に言うと政府があの言って"
    },
    {
      "start": 500.72,
      "duration": 5.039,
      "text": "5%にち上げしろっつったからみんなで"
    },
    {
      "start": 503.159,
      "duration": 3.04,
      "text": "5%ち上げしてるかのように見える。"
