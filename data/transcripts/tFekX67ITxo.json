      "start": 482.84,
      "duration": 3.759,
      "text": "はい。"
    },
    {
      "start": 483.599,
      "duration": 3.0,
      "text": "あなたも街歩いてたり運してばかるだろう人が足りないでしょ。"
    },
    {
      "start": 488.28,
      "duration": 2.759,
      "text": "ああ、そうですね。"
    },
