      "start": 478.52,
      "duration": 3.639,
      "text": "番うまくいった時。"
    },
    {
      "start": 479.52,
      "duration": 4.399,
      "text": "行った時がアドレナリン出るんですよ。"
    },
    {
      "start": 482.159,
      "duration": 2.44,
      "text": "これが弁当に意欲になるよんですよ。"
    },
    {
      "start": 483.919,
      "duration": 3.68,
      "text": "うん。うん。うん。"
    },
    {
      "start": 484.599,
      "duration": 3.0,
      "text": "あ、これ取れたらそっかコメンテーターなれんにゃとかイメージするんすよね。どんな生活かって言ったら講演あります。新幹線乗ってなんか見ながら弁ント食べて熱いて講公園会やってホテル止まって飲んででまた次の公園会行ってでめっちゃ楽しいじゃないですか。それイメージするんですよ。"
    },
    {
      "start": 505.08,
      "duration": 3.28,
      "text": "うん。"
    },
    {
      "start": 505.36,
      "duration": 3.0,
      "text": "これがマックスのトレんですよ。取れたらよしってこうなるんですよね。"
    },
    {
      "start": 509.44,
      "duration": 3.759,
      "text": "だ"
    },
    {
      "start": 510.199,
      "duration": 3.0,
      "text": "と下この下の近使いへんのとこ両方見とくっていう株と一緒ですね。勉強して"
    },
    {
      "start": 515.719,
      "duration": 4.24,
      "text": "ルく勉強してだけだし。"
    },
    {
      "start": 516.959,
      "duration": 3.0,
      "text": "そうです。勉強しとくだけだしどうせ取れんかってもためになるしなも傷つきません。なぜなら勝負も"
    },
    {
      "start": 522.159,
      "duration": 4.36,
      "text": "1回も立ってません。"
    },
    {
      "start": 523.8,
      "duration": 5.719,
      "text": "これがもう損切りです。こ一番そこ"
    },
    {
      "start": 526.519,
      "duration": 3.0,
      "text": "で上はもうどこまでも行くんですよ。はい。コメンテーターなりました。"
    },
    {
      "start": 530.44,
      "duration": 3.0,
      "text": "公園会行けますみたいなとこまでのこのここ見たらね、なんか急になんかこう乗ってくるんですよ。"
    },
    {
      "start": 537.36,
      "duration": 3.56,
      "text": "意欲が湧いてくる。"
    },
    {
      "start": 538.079,
      "duration": 5.841,
      "text": "よく湧いてくるんですよ。そういう見方ですよね。"
    },
    {
      "start": 540.92,
      "duration": 3.0,
      "text": "じゃあ合格できるように頑張るぞ"
    },
    {
      "start": 544.64,
      "duration": 3.72,
      "text": "はい。"
    },
    {
      "start": 545.36,
      "duration": 3.0,
      "text": "その後の姿は想像できてないから勉強がしんどくなるとその後のハピネスを"
    },
    {
      "start": 551.16,
      "duration": 1.52,
      "text": "そうそうそうです。"
    },
    {
      "start": 551.959,
      "duration": 3.721,
      "text": "想像する。"
    },
    {
      "start": 552.68,
      "duration": 3.0,
      "text": "そうそうなんです。そこでやっとくことによってこれちょっと入れとこかもあるんですよ。"
    },
    {
      "start": 558.24,
      "duration": 3.0,
      "text": "僕で言うとその、え、お金のガチャ教えますの現稿を書いてたんで、あ、これ絶対本で使えるやんとか、その勉強しながらテスト当日とかは結構使えるんちゃうんって言うて書いてたんが、こんなやつは。"
    },
    {
      "start": 569.16,
      "duration": 3.0,
      "text": "すごいですよ。それだから受かってもないのに本書いてるっていうのも相当珍しいと思います。なるべくしなってますよね。"
    },
    {
      "start": 576.12,
      "duration": 3.08,
      "text": "そうですね。だからそこが美味しいってのも買ってたんですよ。"
    },
    {
      "start": 578.64,
      "duration": 3.56,
      "text": "ですよね。"
    },
    {
      "start": 579.2,
      "duration": 3.0,
      "text": "テスト当日の気持ちは書けないですよ。後で"
    },
    {
      "start": 582.36,
      "duration": 4.36,
      "text": "今書いとかないと。"
    },
    {
      "start": 583.72,
      "duration": 3.0,
      "text": "書いとかないと揺れてるじゃないですか。取れへんかもしれんし。ビビっとく。"
    },
    {
      "start": 587.92,
      "duration": 5.32,
      "text": "ありのままの字って出るんすよ。"
    },
    {
      "start": 590.24,
      "duration": 3.0,
      "text": "だから僕これテスト当日の"
    },
    {
      "start": 593.6,
      "duration": 3.0,
      "text": "やつも乗ってるんですけど、今見ても文章がなんで"
    },
    {
      "start": 597.24,
      "duration": 1.52,
      "text": "はいはいはい。"
    },
    {
      "start": 597.959,
      "duration": 2.921,
      "text": "ちょっと思い出すんですよ。"
    },
    {
      "start": 598.76,
      "duration": 4.0,
      "text": "もうそん時のその日記ですよ。日"
    },
    {
      "start": 600.88,
      "duration": 3.32,
      "text": "期なんでガチすぎて"
    },
    {
      "start": 602.76,
      "duration": 4.44,
      "text": "そういう感じなんですよ。"
    },
    {
      "start": 604.2,
      "duration": 3.0,
      "text": "でも受かったらこの本は発管されますと。"
    },
    {
      "start": 607.24,
      "duration": 1.261,
      "text": "落ちたら没だ。"
    },
    {
      "start": 608.2,
      "duration": 2.12,
      "text": "そう、ボツだ。ボツだっていう時の"
    },
    {
      "start": 608.501,
      "duration": 2.018,
      "text": "[笑い]"
    },
    {
      "start": 610.32,
      "duration": 0.84,
      "text": "3"
    },
    {
      "start": 610.519,
      "duration": 2.161,
      "text": "冊ボツです。"
    },
    {
      "start": 611.16,
      "duration": 3.88,
      "text": "ボツだ。全部ボツなんですよ。"
    },
    {
      "start": 612.68,
      "duration": 5.36,
      "text": "曲をね、聞く時に"
    },
    {
      "start": 615.04,
      "duration": 3.0,
      "text": "高校とか中学校の時に聞いてた時って入ってきませんでした。"
    },
    {
      "start": 618.16,
      "duration": 1.28,
      "text": "入ってきた。"
    },
    {
      "start": 618.88,
      "duration": 1.68,
      "text": "分かります。"
    },
    {
      "start": 619.44,
      "duration": 1.959,
      "text": "分かります。"
    },
    {
      "start": 620.56,
      "duration": 3.48,
      "text": "それなんすよ。"
    },
    {
      "start": 621.399,
      "duration": 5.641,
      "text": "曲聞くと景色思い出しますよね。の"
    },
    {
      "start": 624.04,
      "duration": 3.0,
      "text": "はい。そうでしょ。で、あの時ってぐわって心揺さぶられなかったですか?で、今ももちろんそうなんですけど、僕で言うと"
    },
    {
      "start": 632.079,
      "duration": 3.0,
      "text": "なんかね、ブルハとかね、長渕さんとか中学と高校時に聞いてるんですけど、心が揺さぶられるんですよ。"
    },
    {
      "start": 640.88,
      "duration": 3.0,
      "text": "なぜなら俺どうどうなんだろうな。将来とかなんか"
    },
    {
      "start": 645.56,
      "duration": 3.719,
      "text": "うん。"
    },
    {
      "start": 646.279,
      "duration": 3.0,
      "text": "そういう不安感が耳からぐわ入って曲に入る入るじゃないですか。勉強しなしながら曲聞いたらあの時の感じになるんですよ。あ"
    },
    {
      "start": 657.519,
      "duration": 2.281,
      "text": "あ、なるほど。"
    },
    {
      "start": 658.44,
      "duration": 2.24,
      "text": "それ思い出すとかじゃなくて"
    },
    {
      "start": 659.8,
      "duration": 2.599,
      "text": "はいはい。"
    },
    {
      "start": 660.68,
      "duration": 4.279,
      "text": "精神が揺さぶられるんですよ。"
    },
    {
      "start": 662.399,
      "duration": 5.081,
      "text": "はいはい。あ、こん時大変だったなとか"
    },
    {
      "start": 664.959,
      "duration": 2.961,
      "text": "とかでその時入ってきやすくなるんですよ。"
    },
    {
      "start": 667.48,
      "duration": 3.44,
      "text": "はい。"
    },
    {
      "start": 667.92,
      "duration": 3.0,
      "text": "勉強はなんかこうやることによって多分ゲージ削られてるんでしょうね。脳のゲージが削られてるんで、その時に曲聞いた方が感動できるんですよ。"
    },
    {
      "start": 677.36,
      "duration": 4.08,
      "text": "うん。なるほど。"
    },
    {
      "start": 678.44,
      "duration": 3.0,
      "text": "僕の考えではおにぎり食べてもここでおにぎり食べても別に普通じゃないですか。でも山登りした時におにぎり食べたら"
    },
    {
      "start": 686.72,
      "duration": 3.44,
      "text": "めっちゃ美味しいですよ。あれ多分削られてるんですよ、体力が。"
    },
    {
      "start": 689.48,
      "duration": 3.68,
      "text": "うん。うん。うん。"
    },
    {
      "start": 690.16,
      "duration": 3.0,
      "text": "美味しいおにぎりを食べるには山登りしないとダメじゃないですか。だから感動する曲を聞こうと思ったら自分自身が削られないとだめなんです。"
    },
    {
      "start": 697.36,
      "duration": 2.188,
      "text": "うん。"
    },
    {
      "start": 697.76,
      "duration": 1.879,
      "text": "その削るために勉強するんですよ。"
    },
    {
      "start": 699.548,
      "duration": 3.091,
      "text": "[笑い]"
    },
    {
      "start": 699.639,
      "duration": 3.0,
      "text": "なるほど。今日も曲を聞いて感動するぞと。"
    },
    {
      "start": 702.8,
      "duration": 3.0,
      "text": "そっちなんですよ。だから後半そうなってきてファーストフード行ってこう勉強しててこう問題といてフラフラなってなんか聞いた時にぐわってきてなんかめっちゃ感動して俺中さぐらいのテンションになってるやつ。たんな感じになった。そうそうそれ高な感じになるんですよ。だからそれは僕めっちゃ得やなと思って"
    },
    {
      "start": 717.233,
      "duration": 2.02,
      "text": "[笑い]"
    },
    {
      "start": 724.12,
      "duration": 0.88,
      "text": "1"
    },
    {
      "start": 724.24,
      "duration": 2.52,
      "text": "回やってほしいんですよ。"
    },
    {
      "start": 725.0,
      "duration": 4.76,
      "text": "はい。うん。セルフイメージね。"
    },
    {
      "start": 726.76,
      "duration": 3.0,
      "text": "合格のハッピーまで想像しようと"
    },
    {
      "start": 730.32,
      "duration": 4.519,
      "text": "天井どこまでも行きますかね。"
    },
    {
      "start": 731.839,
      "duration": 3.0,
      "text": "大学受験合格が目標だじゃなくてその後ね外入ってサークル入って彼女作ってそこまで想像しよう。"
    },
    {
      "start": 740.36,
      "duration": 4.159,
      "text": "そなんですよ。"
    },
    {
      "start": 741.519,
      "duration": 3.0,
      "text": "すごい木さんらしい考え方だな。"
    },
    {
      "start": 750.8,
      "duration": 2.68,
      "text": "芸人の仕事と勉強の両立ですね。"
    },
    {
      "start": 753.199,
      "duration": 3.281,
      "text": "そう、"
    },
    {
      "start": 753.48,
      "duration": 3.0,
      "text": "芸人のお仕事がたくさんある中で勉強もしなきゃいけない。これどう両立されていたか?"
    },
    {
      "start": 760.279,
      "duration": 4.92,
      "text": "これ移動ですよね。移動がやっぱ"
    },
    {
      "start": 762.48,
      "duration": 5.719,
      "text": "1番使いやすいですよね。"
    },
    {
      "start": 765.199,
      "duration": 3.0,
      "text": "芸人さんってほらなんかあのやっぱり移動は疲れるから寝て睡眠時間に当ててますっていう方もすごい聞くけど"
    },
    {
      "start": 772.68,
      "duration": 3.0,
      "text": "そこを勉強にチェンジしてあとよくやったテクニックはなんかやっぱりこう乗らない問題ってあるんですよ。しんどいやつあるじゃないですか。しんどいとこは"
    },
    {
      "start": 781.44,
      "duration": 4.04,
      "text": "うん。"
    },
    {
      "start": 782.48,
      "duration": 3.0,
      "text": "わざとしんどいこととセットにするんですよ。これどういうことかと言うと、緑の窓口でめっちゃ増時ないですか?"
    },
    {
      "start": 790.04,
      "duration": 1.919,
      "text": "嫌ですよね、あれ。"
    },
    {
      "start": 791.12,
      "duration": 3.839,
      "text": "嫌でしょ。"
    },
    {
      "start": 791.959,
      "duration": 6.0,
      "text": "あの時に最も難しい問題やるんですよ。"
    },
    {
      "start": 794.959,
      "duration": 3.0,
      "text": "なるほど。緑の窓口街よりも嫌なもんだよと。"
    },
    {
      "start": 798.32,
      "duration": 2.154,
      "text": "そう、そうなんです。ほんならなんかもう緑の窓口が嫌というよりかもっと嫌なは"
    },
    {
      "start": 798.454,
      "duration": 2.02,
      "text": "[笑い]"
    },
    {
      "start": 804.32,
      "duration": 4.04,
      "text": "やつが来るんで"
    },
    {
      "start": 805.88,
      "duration": 5.48,
      "text": "これやってる緑の窓口は消えるんすよ。"
    },
    {
      "start": 808.36,
      "duration": 3.0,
      "text": "緑の窓口なんてもうへでもないです。この問題に比べて。"
    },
    {
      "start": 811.68,
      "duration": 3.32,
      "text": "だってくだけでしょ。より嫌なやつ合わせるんすよ。"
    },
    {
      "start": 814.24,
      "duration": 3.76,
      "text": "なるほど。"
    },
    {
      "start": 815.0,
      "duration": 3.0,
      "text": "これ見つけたんすよ。あとはその無理しないっていうか、そのもちろんロケとかやったら全然勉強できないんですけど、その時ももう"
    },
    {
      "start": 822.839,
      "duration": 3.881,
      "text": "10分だけとか10"
    },
    {
      "start": 824.199,
      "duration": 2.721,
      "text": "分とかで勉強するのってどうやってました?"
    },
    {
      "start": 826.72,
      "duration": 3.0,
      "text": "10"
    },
    {
      "start": 826.92,
      "duration": 4.839,
      "text": "分で勉強する時はもう本当に基礎問題"
    },
    {
      "start": 829.72,
      "duration": 2.239,
      "text": "3つ解くとかそんなんですよね。"
    },
    {
      "start": 831.759,
      "duration": 2.76,
      "text": "うん。10"
    },
    {
      "start": 831.959,
      "duration": 2.721,
      "text": "分でもいいからできるものを触れておく。"
    },
    {
      "start": 834.519,
      "duration": 3.161,
      "text": "はい。"
    },
    {
      "start": 834.68,
      "duration": 3.0,
      "text": "それはなんかやっぱりまたもこう体変になってしまうんだけど先生に足の指構成した時になんかそのトレーニングできない時があってトレーニングできない時はお前それ上半身鍛えるチャンスだぞみたいなんで"
    },
    {
      "start": 847.079,
      "duration": 5.32,
      "text": "そのそこでベスト作す方が大事やでって"
    },
    {
      "start": 849.399,
      "duration": 3.0,
      "text": "ほんなゆくゆくお前そっちがあの長所なるからって"
    },
    {
      "start": 853.36,
      "duration": 3.52,
      "text": "うんうんうん"
    },
    {
      "start": 853.88,
      "duration": 3.0,
      "text": "結構そのパターン多いらしくて忙しいかったらそれは忙しいでいいことやし暇やったら暇ってそのうん"
    },
    {
      "start": 860.48,
      "duration": 3.0,
      "text": "社会人はそうやと思うんですよね時間ずらしていくか"
    },
    {
      "start": 863.759,
      "duration": 4.041,
      "text": "やと思いはい。"
    },
    {
      "start": 864.8,
      "duration": 3.0,
      "text": "通勤とかやったら早くもう時間ずらすって感じですね。早起き"
    },
    {
      "start": 870.32,
      "duration": 2.639,
      "text": "早起きして"
    },
    {
      "start": 871.16,
      "duration": 2.52,
      "text": "早起きして勉強ですね。"
    },
    {
      "start": 872.959,
      "duration": 3.721,
      "text": "はい。"
    },
    {
      "start": 873.68,
      "duration": 3.0,
      "text": "どう短縮化させるかも大事ですよね。逆にそれ以外やってないって感じなんです。飲んでるんですけど飲んでる時間が短いんですよ。"
    },
    {
      "start": 880.399,
      "duration": 2.721,
      "text": "はい。"
    },
    {
      "start": 881.279,
      "duration": 2.68,
      "text": "早く飲むっていう"
    },
    {
      "start": 883.12,
      "duration": 3.839,
      "text": "飲みを短くして"
    },
    {
      "start": 883.959,
      "duration": 3.0,
      "text": "飲みを短くするとかそういう感じしましたね。全部の工程を短くするっていう風にしましたね。"
    },
    {
      "start": 891.0,
      "duration": 4.12,
      "text": "やめはしないけど。"
    },
    {
      "start": 892.12,
      "duration": 3.0,
      "text": "波はしないけどっていうその工夫は僕絶対いると思うんですよね。"
    },
    {
      "start": 896.12,
      "duration": 4.6,
      "text": "そうしたら時間はいくらでもできるよと。"
    },
    {
      "start": 897.72,
      "duration": 3.0,
      "text": "はい。社会人の人と"
    },
    {
      "start": 900.759,
      "duration": 3.841,
      "text": "はい。"
    },
    {
      "start": 901.6,
      "duration": 3.0,
      "text": "学生の特性を冷静に分析した方がいいですね。"
    },
    {
      "start": 906.519,
      "duration": 3.281,
      "text": "はい。"
    },
    {
      "start": 906.8,
      "duration": 3.0,
      "text": "資格試験で学生と社会人に戦いました。"
    },
    {
      "start": 911.04,
      "duration": 1.96,
      "text": "うん。"
    },
    {
      "start": 911.8,
      "duration": 2.959,
      "text": "学生勝つと思います。"
    },
    {
      "start": 913.0,
      "duration": 4.759,
      "text": "学生の方勉強する時間ある。"
    },
    {
      "start": 914.759,
      "duration": 3.0,
      "text": "あるからで、頭もま、若いし勝つと思うんですけどただですよさんとこの試験将来かかってますよねと。"
    },
    {
      "start": 923.279,
      "duration": 3.0,
      "text": "ほんで向こうひよるんですよ。こっち不利ですけども社会人です。落ちても何も明日変わりません。結婚もしてますし、もう食べたいものもある程度食べました。落ちようが別に受かろうが僕どっちでも別に何も変わりませんっていう優だめですよ。"
    },
    {
      "start": 931.42,
      "duration": 2.02,
      "text": "[笑い]"
    },
    {
      "start": 938.519,
      "duration": 2.361,
      "text": "だからはい。"
    },
    {
      "start": 939.48,
      "duration": 2.08,
      "text": "優位ポイント見つけてだめなんです。"
    },
    {
      "start": 940.88,
      "duration": 3.68,
      "text": "俺は大丈夫だ。"
    },
    {
      "start": 941.56,
      "duration": 3.0,
      "text": "落ちても落ちても明日は飯もあるし。俺はあと"
    },
    {
      "start": 944.88,
      "duration": 2.68,
      "text": "3年落ちてもいい。なんたら5"
    },
    {
      "start": 946.399,
      "duration": 2.0,
      "text": "年落ちても大丈夫っていう。"
    },
    {
      "start": 947.56,
      "duration": 2.04,
      "text": "幸せだと"
    },
    {
      "start": 948.399,
      "duration": 2.721,
      "text": "幸せだと[笑い]"
    },
    {
      "start": 949.6,
      "duration": 2.78,
      "text": "何も変わらない"
    },
    {
      "start": 951.12,
      "duration": 3.28,
      "text": "意なことを見つけて戦っていく方です。"
    },
    {
      "start": 952.38,
      "duration": 2.02,
      "text": "[音楽]"
    },
    {
      "start": 954.44,
      "duration": 3.639,
      "text": "なるほど。"
    },
    {
      "start": 955.079,
      "duration": 3.0,
      "text": "偉い方がね、勉強法書いた時に、え、あちにさしてサウナに行ってこいのハイボール揉んでくださいと書けないですよ。"
    },
    {
      "start": 958.931,
      "duration": 2.02,
      "text": "[音楽]"
    },
    {
      "start": 963.44,
      "duration": 3.24,
      "text": "ほんまのこと言うとそうなん"
    }
  ]
}