    },
    {
      "start": 589.399,
      "duration": 5.56,
      "text": "日本側に対して、え、謝罪が示された"
    },
    {
      "start": 592.44,
      "duration": 5.959,
      "text": "ケースはあるのか、え、改めてとなります"
    },
    {
      "start": 594.959,
      "duration": 6.801,
      "text": "が、政府の認識見解を伺います。お尋ねの"
    },
    {
      "start": 598.399,
      "duration": 8.0,
      "text": "事案ですが、3月24日、原職自衛官の男"
    },
    {
      "start": 601.76,
      "duration": 8.36,
      "text": "が在中国大使館の敷地内に侵入し、"
    },
    {
      "start": 606.399,
      "duration": 7.201,
      "text": "警視市長に建造物新入容疑で逮捕され、え"
    },
    {
      "start": 610.12,
      "duration": 8.32,
      "text": "、所用の捜作が行われておりましたが、え"
    },
    {
      "start": 613.6,
      "duration": 7.4,
      "text": "、本日経視庁に重東法違反容疑で再逮捕さ"
    },
    {
      "start": 618.44,
      "duration": 5.36,
      "text": "れたところであります。"
    },
    {
      "start": 621.0,
      "duration": 8.079,
      "text": "え、在中国大使館を含め、え、国内に所"
    },
    {
      "start": 623.8,
      "duration": 8.36,
      "text": "する外国や外交官等の安全を関連の国際法"
    },
    {
      "start": 629.079,
      "duration": 6.281,
      "text": "及び国内法令に従って区画をすることは"
    },
    {
      "start": 632.16,
      "duration": 5.2,
      "text": "当然のことであり、結果として今回の新入"
    },
    {
      "start": 635.36,
      "duration": 6.919,
      "text": "事案が発生したことは遺憾でありあっては"
    },
    {
      "start": 637.36,
      "duration": 7.12,
      "text": "ならないことであります。警察において、"
    },
    {
      "start": 642.279,
      "duration": 4.68,
      "text": "え、事案の解明に向けた操作を引き続き"
    },
    {
      "start": 644.48,
      "duration": 5.08,
      "text": "進めていくものと承知しております。政府"
    },
    {
      "start": 646.959,
      "duration": 7.0,
      "text": "として引き続き関連の国際法及び国内法令"
    },
    {
      "start": 649.56,
      "duration": 7.92,
      "text": "に従って、え、関係省庁で連携し、再発"
    },
    {
      "start": 653.959,
      "duration": 7.521,
      "text": "防止も含め適切に対応してまいります。"
    },
    {
      "start": 657.48,
      "duration": 7.4,
      "text": "またこ談のお尋ねですが、あのご指摘の"
    },
    {
      "start": 661.48,
      "duration": 6.88,
      "text": "会見の時にも申し上げた通りなんですが、"
    },
    {
      "start": 664.88,
      "duration": 8.36,
      "text": "え、我が法中国交換が被害にあった事案に"
    },
    {
      "start": 668.36,
      "duration": 9.96,
      "text": "つき、例えば2012年9月のデモ活動に"
    },
    {
      "start": 673.24,
      "duration": 9.44,
      "text": "関し、え、中国外交部道官からは、え、"
    },
    {
      "start": 678.32,
      "duration": 8.519,
      "text": "中国政府は法律に基づき、中国にある外国"
    },
    {
      "start": 682.68,
      "duration": 4.88,
      "text": "機関及び人員の安全を保護しており、具体"
    },
    {
      "start": 686.839,
      "duration": 3.721,
      "text": "的"
    },
    {
      "start": 687.56,
      "duration": 3.0,
      "text": "に基づき関連の問題を適切に処理していくとの発言があったと承知してます。"
    },
    {
      "start": 697.279,
      "duration": 5.24,
      "text": "よろしいでしょうか?ありがとうございました。"
    },
    {
      "start": 699.519,
      "duration": 3.0,
      "text": "はい。ました。"
    }
  ]
}