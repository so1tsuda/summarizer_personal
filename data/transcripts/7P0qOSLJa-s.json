    },
    {
      "start": 379.919,
      "duration": 5.641,
      "text": "コメントしているようにですね、この景気"
    },
    {
      "start": 382.28,
      "duration": 6.6,
      "text": "の回復基調を示す同向は、ま、見られなく"
    },
    {
      "start": 385.56,
      "duration": 6.52,
      "text": "もないと。ま、例えばこの固定資産投資、"
    },
    {
      "start": 388.88,
      "duration": 4.84,
      "text": "ま、1月から3月期1.7%増ということ"
    },
    {
      "start": 392.08,
      "duration": 3.519,
      "text": "で、ま、1.7大したことないじゃんって"
    },
    {
      "start": 393.72,
      "duration": 4.36,
      "text": "いう感じがしますけれども、昨年はですね"
    },
    {
      "start": 395.599,
      "duration": 4.761,
      "text": "、マイナス成長でした。ま、だから若干で"
    },
    {
      "start": 398.08,
      "duration": 4.679,
      "text": "はあるものの回復基調というのも見られる"
    },
    {
      "start": 400.36,
      "duration": 4.88,
      "text": "と、あとこの不動産開発投資ま、"
    },
    {
      "start": 402.759,
      "duration": 4.401,
      "text": "-11.2でこれ全然大したことないじゃ"
    },
    {
      "start": 405.24,
      "duration": 5.2,
      "text": "んっていう感じですけれども、ただですね"
    },
    {
      "start": 407.16,
      "duration": 5.8,
      "text": "、あのこの下げ幅、この下げ幅はマイナス"
    },
    {
      "start": 410.44,
      "duration": 4.879,
      "text": "成長具合は昨年と比べれば鈍化してい"
    },
    {
      "start": 412.96,
      "duration": 5.0,
      "text": "るっていう状況も見て取れると。あと1番"
    },
    {
      "start": 415.319,
      "duration": 5.521,
      "text": "下CPI、PPI物価関連ですね。これを"
    },
    {
      "start": 417.96,
      "duration": 6.2,
      "text": "見ると、ま、3月、ま、CPIが前年同月"
    },
    {
      "start": 420.84,
      "duration": 5.799,
      "text": "費で1%。え、あとこれまで下落傾向に"
    },
    {
      "start": 424.16,
      "duration": 5.36,
      "text": "あったPPIをですね、ま、前年同期で"
    },
    {
      "start": 426.639,
      "duration": 4.601,
      "text": "0.5ポイント上昇ということで、この"
    },
    {
      "start": 429.52,
      "duration": 3.6,
      "text": "PPIに関しては昨年もずっとマイナス"
    },
    {
      "start": 431.24,
      "duration": 5.28,
      "text": "できてましたから、ま、こう見るとですね"
    },
    {
      "start": 433.12,
      "duration": 6.68,
      "text": "、不動産不教とこのデフレ圧力、ま、この"
    },
    {
      "start": 436.52,
      "duration": 5.28,
      "text": "2つのですね、近年の中国経済を象徴して"
    },
    {
      "start": 439.8,
      "duration": 3.959,
      "text": "きた2つの問題、ま、不動産不教と"
    },
    {
      "start": 441.8,
      "duration": 4.28,
      "text": "デフレススパイラル、ま、この2つの分野"
    },
    {
      "start": 443.759,
      "duration": 4.28,
      "text": "が2026年を通じてどうなっていくのか"
    },
    {
      "start": 446.08,
      "duration": 4.64,
      "text": "というところは注目に値するんじゃないか"
    },
    {
      "start": 448.039,
      "duration": 5.761,
      "text": "なという風に思いますと。一方で出業率を"
    },
    {
      "start": 450.72,
      "duration": 6.44,
      "text": "見てみると、ま、全体あるいは弱年数を"
    },
    {
      "start": 453.8,
      "duration": 6.32,
      "text": "含めて上昇傾向にあるということですね。"
    },
    {
      "start": 457.16,
      "duration": 4.8,
      "text": "3月率。しかもこれ調査ベースで脳損除"
    },
    {
      "start": 460.12,
      "duration": 4.84,
      "text": "くって言ってるわけなんで、ま、要するに"
    },
    {
      "start": 461.96,
      "duration": 4.799,
      "text": "調査できる範囲だけを調査してますと。"
    },
    {
      "start": 464.96,
      "duration": 4.359,
      "text": "しかも脳損含めませんって言ってるわけ"
    },
    {
      "start": 466.759,
      "duration": 5.081,
      "text": "ですね。それで、ま、5.4%っていう"
    },
    {
      "start": 469.319,
      "duration": 4.56,
      "text": "ことですよね。で、ま、中国の場合ですね"
    },
    {
      "start": 471.84,
      "duration": 4.639,
      "text": "、私もな、生活したことありますけれども"
    },
    {
      "start": 473.879,
      "duration": 5.28,
      "text": "、この修業形態っていうのが結構なんて"
    },
    {
      "start": 476.479,
      "duration": 5.12,
      "text": "言うの?ま、よく言えば柔軟的で悪く言え"
    },
    {
      "start": 479.159,
      "duration": 4.801,
      "text": "ば非常にこう、まというかなんかあんまり"
    },
    {
      "start": 481.599,
      "duration": 4.081,
      "text": "こうしっかりしてないというか色々ある"
    },
    {
      "start": 483.96,
      "duration": 3.32,
      "text": "感じなんですよね。で、いわゆるその"
    },
    {
      "start": 485.68,
      "duration": 3.359,
      "text": "フリーターみたい、ま、日本ではこの"
    },
    {
      "start": 487.28,
      "duration": 4.12,
      "text": "フリーターとかニートという言葉あります"
    },
    {
      "start": 489.039,
      "duration": 4.921,
      "text": "けれども、もう中国ではそもそもコロナ禍"
    },
    {
      "start": 491.4,
      "duration": 5.239,
      "text": "前からもうなんかもう個人事業主とか"
    },
    {
      "start": 493.96,
      "duration": 4.84,
      "text": "リモートとかっていうところも結構普通に"
    },
    {
      "start": 496.639,
      "duration": 4.0,
      "text": "あったようなあの感じですし、なんて言う"
    },
    {
      "start": 498.8,
      "duration": 3.359,
      "text": "んですか、日本みたいにこの就寝とかね、"
    },
    {
      "start": 500.639,
      "duration": 4.081,
      "text": "日本でももう今ね、当たり前じゃなくなっ"
    },
    {
      "start": 502.159,
      "duration": 4.681,
      "text": "てますけれども、非常にこう流動的でかつ"
    },
    {
      "start": 504.72,
      "duration": 4.08,
      "text": "その転職とかこのキャリアアップっていう"
    },
    {
      "start": 506.84,
      "duration": 4.16,
      "text": "のも非常にこうダイナミックに動いてる感"
    },
    {
      "start": 508.8,
      "duration": 4.719,
      "text": "があるので、ま、少なくとも日本に比べれ"
    },
    {
      "start": 511.0,
      "duration": 4.519,
      "text": "ばこの失業率の統計ってすごく難しいとは"
    },
    {
      "start": 513.519,
      "duration": 5.241,
      "text": "思うんですけれども、それでこの調査"
    },
    {
      "start": 515.519,
      "duration": 6.44,
      "text": "ベースで脳損除いて5.4%ということ"
    },
    {
      "start": 518.76,
      "duration": 5.12,
      "text": "ですので、ま、私の感覚的にはですね、"
    },
    {
      "start": 521.959,
      "duration": 3.921,
      "text": "あの、ま、あくまでも感覚ですけれども、"
    },
    {
      "start": 523.88,
      "duration": 3.48,
      "text": "少なくともこの倍以上あるでしょうね。て"
    },
    {
      "start": 525.88,
      "duration": 3.8,
      "text": "いうところは言えるんじゃないかなという"
    },
    {
      "start": 527.36,
      "duration": 5.12,
      "text": "風に思います。で、弱年の出業率。これも"
    },
    {
      "start": 529.68,
      "duration": 5.4,
      "text": "在高生、大学で学んでいる人くっていう"
    },
    {
      "start": 532.48,
      "duration": 5.28,
      "text": "ことですけれども、ま、16歳から24歳"
    },
    {
      "start": 535.08,
      "duration": 4.879,
      "text": "が、ま、16.9%ということで、ま、3"
    },
    {
      "start": 537.76,
      "duration": 4.88,
      "text": "月上昇しているというところがあるので、"
    },
    {
      "start": 539.959,
      "duration": 5.481,
      "text": "この実業率、特に若者の出業率問題、これ"
    },
    {
      "start": 542.64,
      "duration": 4.96,
      "text": "はですね、特にこう夏に向かう中で多くの"
    },
    {
      "start": 545.44,
      "duration": 4.24,
      "text": "大学生が卒業していきます。中国6月に"
    },
    {
      "start": 547.6,
      "duration": 5.239,
      "text": "卒業しますので、ま、その中でですね、"
    },
    {
      "start": 549.68,
      "duration": 5.68,
      "text": "こう路島に迷う若者、ま、毎年1000万"
    },
    {
      "start": 552.839,
      "duration": 5.0,
      "text": "人以上が大学を卒業して労働市場に出て"
    },
    {
      "start": 555.36,
      "duration": 5.36,
      "text": "いくわけですから、この彼ら彼女らの同行"
    },
    {
      "start": 557.839,
      "duration": 4.841,
      "text": "次第ではですね、この弱年の出業率も夏に"
    },
    {
      "start": 560.72,
      "duration": 4.239,
      "text": "向かう中でまた一気に高まっていく可能性"
    },
    {
      "start": 562.68,
      "duration": 4.36,
      "text": "もありますし、そうなれば単なるその経済"
    },
    {
      "start": 564.959,
      "duration": 4.32,
      "text": "問題じゃなくてですね、その社会問題場合"
    },
    {
      "start": 567.04,
      "duration": 3.84,
      "text": "によってはその政治問題にまで発展して"
    },
    {
      "start": 569.279,
      "duration": 3.68,
      "text": "いく可能性もあるっていうとこですね。"
    },
    {
      "start": 570.88,
      "duration": 5.0,
      "text": "そしてかなりインパクトのある指標を示し"
    },
    {
      "start": 572.959,
      "duration": 6.32,
      "text": "ていると私が見たのが貿易です。1月から"
    },
    {
      "start": 575.88,
      "duration": 7.24,
      "text": "3月を見てみると、ま、前年同期費で"
    },
    {
      "start": 579.279,
      "duration": 6.56,
      "text": "15%増とうち輸出が11.9%、輸入が"
    },
    {
      "start": 583.12,
      "duration": 4.88,
      "text": "19.6%ということで、ま、それなりの"
    },
    {
      "start": 585.839,
      "duration": 4.961,
      "text": "伸びを見せているわけですけれども、3月"
    },
    {
      "start": 588.0,
      "duration": 5.44,
      "text": "を見てください。3月を見ると輸入は"
    },
    {
      "start": 590.8,
      "duration": 5.56,
      "text": "27.8%ということでさらに伸びている"
    },
    {
      "start": 593.44,
      "duration": 6.68,
      "text": "ものの輸出が2.5%"
    },
    {
      "start": 596.36,
      "duration": 6.4,
      "text": "で全体が9.2%ということで3月の数字"
    },
    {
      "start": 600.12,
      "duration": 4.52,
      "text": "が明らかに1月から3月と比べて悪くなっ"
    },
    {
      "start": 602.76,
      "duration": 4.28,
      "text": "てるっていうことですね。ま、この原因に"
    },
    {
      "start": 604.64,
      "duration": 4.319,
      "text": "関してですけれども、何が考えれるのか"
    },
    {
      "start": 607.04,
      "duration": 4.08,
      "text": "なっていうところをですね、パート3で、"
    },
    {
      "start": 608.959,
      "duration": 6.481,
      "text": "ま、イラン情勢とくっつけてですね、話し"
    },
    {
      "start": 611.12,
      "duration": 4.32,
      "text": "ていきたいという風に思います。はい。"
    },
    {
      "start": 617.64,
      "duration": 6.72,
      "text": "あの、まさにこの輸出が3月単月で見て"
    },
    {
      "start": 621.36,
      "duration": 5.4,
      "text": "2.5%とこう一気にこう悪化していると"
    },
    {
      "start": 624.36,
      "duration": 4.719,
      "text": "いうこの原因にこのイラン情勢、ま、"
    },
    {
      "start": 626.76,
      "duration": 4.44,
      "text": "ホルムズ海峡の風鎖とかですね、含めて"
    },
    {
      "start": 629.079,
      "duration": 4.601,
      "text": "ここが深く影響しているんじゃないかと。"
    },
    {
      "start": 631.2,
      "duration": 4.439,
      "text": "ま、これは仮説とよりも歴史とした理由"
    },
    {
      "start": 633.68,
      "duration": 4.48,
      "text": "背景なんじゃないかなという風に思うと"
    },
    {
      "start": 635.639,
      "duration": 4.561,
      "text": "いう中で、ま、若干整理をしてみると、ま"
    },
    {
      "start": 638.16,
      "duration": 4.119,
      "text": "、2月の28日ですね、もう1ヶ月以上"
    },
    {
      "start": 640.2,
      "duration": 4.72,
      "text": "経ってますけれども、ま、もうすぐ2ヶ月"
    },
    {
      "start": 642.279,
      "duration": 5.24,
      "text": "ですか。で、ま、この米国とイスラエルが"
    },
    {
      "start": 644.92,
      "duration": 4.56,
      "text": "イランに攻撃を始めてイランも徹底光戦の"
    },
    {
      "start": 647.519,
      "duration": 3.841,
      "text": "、ま、様を見せて、ま、それが現在まで"
    },
    {
      "start": 649.48,
      "duration": 3.56,
      "text": "ですね、続いているとなかなか出口も見え"
    },
    {
      "start": 651.36,
      "duration": 3.8,
      "text": "てこないっていうことだと思うんですが、"
    },
    {
      "start": 653.04,
      "duration": 3.72,
      "text": "ま、このイラン情勢の影響をですね、中国"
    },
    {
      "start": 655.16,
      "duration": 3.799,
      "text": "経済向けているということなんだと思い"
    },
    {
      "start": 656.76,
      "duration": 4.639,
      "text": "ます。ま、米国イラン共もにですね、ま、"
    },
    {
      "start": 658.959,
      "duration": 5.201,
      "text": "競技に前向きな姿勢を見せたかと思えば"
    },
    {
      "start": 661.399,
      "duration": 4.56,
      "text": "再び互いをの名知り合う振り出しに戻った"
    },
    {
      "start": 664.16,
      "duration": 4.28,
      "text": "かのような要素も停していてですね、この"
    },
    {
      "start": 665.959,
      "duration": 5.041,
      "text": "ホルムズ海峡の解放問題を含めてですね、"
    },
    {
      "start": 668.44,
      "duration": 4.72,
      "text": "情勢は引き続き余談を許さないという風に"
    },
    {
      "start": 671.0,
      "duration": 4.8,
      "text": "言えると思います。ま、そんな中ですね。"
    },
    {
      "start": 673.16,
      "duration": 5.6,
      "text": "この中国の税関が発表した4月の20日に"
    },
    {
      "start": 675.8,
      "duration": 6.64,
      "text": "発表した貿易統計ドルによればですね、"
    },
    {
      "start": 678.76,
      "duration": 8.96,
      "text": "この3月時点での原油の輸入料は"
    },
    {
      "start": 682.44,
      "duration": 9.04,
      "text": "サウジアラビアが31%、イラクが46%"
    },
    {
      "start": 687.72,
      "duration": 6.52,
      "text": "元、クエイトが52%元となったと。ま、"
    },
    {
      "start": 691.48,
      "duration": 5.28,
      "text": "ロシアは14%像だったんですけれども、"
    },
    {
      "start": 694.24,
      "duration": 6.08,
      "text": "ま、中国はですね、世界最大の原油輸入国"
    },
    {
      "start": 696.76,
      "duration": 5.84,
      "text": "で国内消費の7割約7割を輸入に依存して"
    },
    {
      "start": 700.32,
      "duration": 4.6,
      "text": "いるという状況です。その7割のうちの4"
    },
    {
      "start": 702.6,
      "duration": 4.679,
      "text": "割を中東から輸入しているということなの"
    },
    {
      "start": 704.92,
      "duration": 4.479,
      "text": "で、ま、イラン情勢及びフォルムズ海峡の"
    },
    {
      "start": 707.279,
      "duration": 4.761,
      "text": "同行というのは中国におけるこの"
    },
    {
      "start": 709.399,
      "duration": 4.88,
      "text": "エネルギーの安定供給や国内のガソリン"
    },
    {
      "start": 712.04,
      "duration": 4.4,
      "text": "価格などにも影響を及ぼすのが、ま、必死"
    },
    {
      "start": 714.279,
      "duration": 4.761,
      "text": "であると、ま、当然ですね、この景気同向"
    },
    {
      "start": 716.44,
      "duration": 5.399,
      "text": "や国民生活への影響も懸念されるという"
    },
    {
      "start": 719.04,
      "duration": 5.0,
      "text": "ことだと思います。実際ですね、この個人"
    },
    {
      "start": 721.839,
      "duration": 4.24,
      "text": "消費関連の指標である先ほどの図表にも"
    },
    {
      "start": 724.04,
      "duration": 6.2,
      "text": "ありましたけれども、この小売りの売上高"
    },
    {
      "start": 726.079,
      "duration": 7.161,
      "text": "というのが1月から3月期は2.4%増、"
    },
    {
      "start": 730.24,
      "duration": 6.159,
      "text": "え、3月は1.7%増ということで昨年"
    },
    {
      "start": 733.24,
      "duration": 5.48,
      "text": "通年の3.7%を下回っているということ"
    },
    {
      "start": 736.399,
      "duration": 6.041,
      "text": "ですね。先ほども提期しましたけれども、"
    },
    {
      "start": 738.72,
      "duration": 7.359,
      "text": "ま、昨の中国経済を巡る明白かつ深刻な"
    },
    {
      "start": 742.44,
      "duration": 6.199,
      "text": "構造的問題の1つが過剰供給と事情不足と"
    },
    {
      "start": 746.079,
      "duration": 6.56,
      "text": "いうことですけれども、イラン情勢の緊迫"
    },
    {
      "start": 748.639,
      "duration": 7.0,
      "text": "化を反映する原油高の影響を受けて国民の"
    },
    {
      "start": 752.639,
      "duration": 6.281,
      "text": "生活が引迫し、ま、集金政権としてもです"
    },
    {
      "start": 755.639,
      "duration": 6.161,
      "text": "ね、この目標に掲げる内拡大が進まない"
    },
    {
      "start": 758.92,
      "duration": 4.919,
      "text": "どころかさらに落ち込むシナリオも十分"
    },
    {
      "start": 761.8,
      "duration": 4.24,
      "text": "現実身を帯びているという風に言えると"
    },
    {
      "start": 763.839,
      "duration": 4.841,
      "text": "いう風に思います。ま、少なくとも言える"
    },
    {
      "start": 766.04,
      "duration": 5.159,
      "text": "のはですね、アメリカが深い次元で関与し"
    },
    {
      "start": 768.68,
      "duration": 4.88,
      "text": "ているイラン戦争というものは中国経済に"
    },
    {
      "start": 771.199,
      "duration": 4.32,
      "text": "とっては、ま、若干の誤参だったっていう"
    },
    {
      "start": 773.56,
      "duration": 4.16,
      "text": "ことだと思います。もちろん、あの、こう"
    },
    {
      "start": 775.519,
      "duration": 4.081,
      "text": "いうイラン情勢が金迫化するっていう"
    },
    {
      "start": 777.72,
      "duration": 4.04,
      "text": "シナリオは当然頭にあったと思うんです"
    },
    {
      "start": 779.6,
      "duration": 4.2,
      "text": "けれども、やはりこの中国経済にとっては"
    },
    {
      "start": 781.76,
      "duration": 4.36,
      "text": "、ま、若干の誤参だったのかなという風に"
    },
    {
      "start": 783.8,
      "duration": 4.88,
      "text": "思いますし、その影響をどう見積もって"
    },
    {
      "start": 786.12,
      "duration": 4.56,
      "text": "対応していくかっていうのことが切迫した"
    },
    {
      "start": 788.68,
      "duration": 3.68,
      "text": "課題、切なる課題なんじゃないかなという"
    },
    {
      "start": 790.68,
      "duration": 3.12,
      "text": "風に思います。そういう風に中国政府も"
    },
    {
      "start": 792.36,
      "duration": 3.88,
      "text": "認識しているんじゃないかなという風に"
    },
    {
      "start": 793.8,
      "duration": 4.12,
      "text": "思います。一方で中国政府としてもですね"
    },
    {
      "start": 796.24,
      "duration": 4.48,
      "text": "、手を打っていないわけではなくて、"
    },
    {
      "start": 797.92,
      "duration": 5.919,
      "text": "例えばですけれども石油の国内地区、ま、"
    },
    {
      "start": 800.72,
      "duration": 5.16,
      "text": "180日分、ま、約半年分用意していると"
    },
    {
      "start": 803.839,
      "duration": 5.401,
      "text": "いうことですし、ま、近年ではですね、"
    },
    {
      "start": 805.88,
      "duration": 5.759,
      "text": "この原油の輸入先の多化、エネルギー源"
    },
    {
      "start": 809.24,
      "duration": 4.839,
      "text": "そのものの多化、そして、ま、既でに自動"
    },
    {
      "start": 811.639,
      "duration": 4.64,
      "text": "車販売量の半分を超えるに至っている電気"
    },
    {
      "start": 814.079,
      "duration": 4.241,
      "text": "自動車を普及させたりということですね。"
    },
    {
      "start": 816.279,
      "duration": 4.841,
      "text": "ま、こうやって性学リスクが上昇して"
    },
    {
      "start": 818.32,
      "duration": 5.24,
      "text": "イラン情勢が緊迫しても、ま、その影響を"
    },
    {
      "start": 821.12,
      "duration": 4.6,
      "text": "代々的に受けないように手は打ってきては"
    },
    {
      "start": 823.56,
      "duration": 5.24,
      "text": "いるっていうことですね。一方で、ま、"
    },
    {
      "start": 825.72,
      "duration": 5.679,
      "text": "国家統計局が、ま、外部情勢は従来以上に"
    },
    {
      "start": 828.8,
      "duration": 4.839,
      "text": "複雑かつ流動的で変化が激しいという風に"
    },
    {
      "start": 831.399,
      "duration": 5.44,
      "text": "コメントしているように、イラン情勢が"
    },
    {
      "start": 833.639,
      "duration": 5.0,
      "text": "国民経済に及ぼす影響というのを懸念して"
    },
    {
      "start": 836.839,
      "duration": 3.721,
      "text": "可能な限りダメージコントロールをすべく"
    },
    {
      "start": 838.639,
      "duration": 3.601,
      "text": "、ま、なんとかもがいて本送していると"
    },
    {
      "start": 840.56,
      "duration": 5.12,
      "text": "いうのが、ま、現状なんじゃないかなと"
    },
    {
      "start": 842.24,
      "duration": 5.36,
      "text": "いう風に思います。はい。先週の動画で"
    },
    {
      "start": 845.68,
      "duration": 4.36,
      "text": "ですね、イスラムバード、ま、パキスタン"
    },
    {
      "start": 847.6,
      "duration": 4.96,
      "text": "が仲回する形のね、このイスラムバード"
    },
    {
      "start": 850.04,
      "duration": 4.719,
      "text": "競技、米国とイランの会議、そこで中国は"
    },
    {
      "start": 852.56,
      "duration": 4.56,
      "text": "何を狙うのかっていうその動画を使ったと"
    },
    {
      "start": 854.759,
      "duration": 4.2,
      "text": "思うんですけれども、米国とイランの、ま"
    },
    {
      "start": 857.12,
      "duration": 4.839,
      "text": "、交渉のある意味中会者でもある"
    },
    {
      "start": 858.959,
      "duration": 5.12,
      "text": "パキスタンを中国は背後で支える形で、ま"
    },
    {
      "start": 861.959,
      "duration": 4.481,
      "text": "、事態の鎮生化を図るべく、ま、いろんな"
    },
    {
      "start": 864.079,
      "duration": 6.161,
      "text": "いわゆる外交努力と言われるものを続けて"
    },
    {
      "start": 866.44,
      "duration": 6.12,
      "text": "いるというのもこのイラン情勢が、ま、"
    },
    {
      "start": 870.24,
      "duration": 5.719,
      "text": "イラン情勢でアメリカが消耗していること"
    },
    {
      "start": 872.56,
      "duration": 6.48,
      "text": "は微笑みつつも、たイラン情勢そのものが"
    },
    {
      "start": 875.959,
      "duration": 5.161,
      "text": "制御不能アウトオブコントロールの状況に"
    },
    {
      "start": 879.04,
      "duration": 4.12,
      "text": "陥るのはこれは中国経済にとっても"
    },
    {
      "start": 881.12,
      "duration": 4.399,
      "text": "よろしくないということでそれをま、未然"
    },
    {
      "start": 883.16,
      "duration": 4.2,
      "text": "に防ぐべく動いてると、ま、こういった"
    },
    {
      "start": 885.519,
      "duration": 4.0,
      "text": "ことは伺えるのかなっていう風に思います"
    },
    {
      "start": 887.36,
      "duration": 4.919,
      "text": "。さらに最後ですけれども、ま、イラン"
    },
    {
      "start": 889.519,
      "duration": 5.481,
      "text": "情勢の行方というのは世界最大そして最"
    },
    {
      "start": 892.279,
      "duration": 4.761,
      "text": "重要の2科国間関係とも言える米中関係に"
    },
    {
      "start": 895.0,
      "duration": 5.16,
      "text": "も影響してくるということですね。で、"
    },
    {
      "start": 897.04,
      "duration": 6.159,
      "text": "そもそもですね、元々3月31日から4月"
    },
    {
      "start": 900.16,
      "duration": 6.52,
      "text": "の2日で予定されていたトランプ大統領の"
    },
    {
      "start": 903.199,
      "duration": 7.601,
      "text": "放中訪問は、ま、イラン情勢が原因で延期"
    },
    {
      "start": 906.68,
      "duration": 6.839,
      "text": "となり家5月14から15日で実現すべく"
    },
    {
      "start": 910.8,
      "duration": 4.36,
      "text": "両国当局が、ま、調整を続けている。あと"
    },
    {
      "start": 913.519,
      "duration": 4.401,
      "text": "20日ぐらいっていうことですね。ま、"
    },
    {
      "start": 915.16,
      "duration": 4.679,
      "text": "ただですね、この状況次第では再び延期さ"
    },
    {
      "start": 917.92,
      "duration": 4.279,
      "text": "れる可能性も否定できないという風に思い"
    },
    {
      "start": 919.839,
      "duration": 4.68,
      "text": "ます。で、そもそもですね、この放中期間"
    },
    {
      "start": 922.199,
      "duration": 4.76,
      "text": "、ま、トランプ大統領が中国に滞在する"
    },
    {
      "start": 924.519,
      "duration": 5.24,
      "text": "期間っていうのも、ま、従来の3日間から"
    },
    {
      "start": 926.959,
      "duration": 5.201,
      "text": "2日間に短縮されているということで、ま"
    },
    {
      "start": 929.759,
      "duration": 5.44,
      "text": "、トランプ大統領としてもですね、中国と"
    },
    {
      "start": 932.16,
      "duration": 4.919,
      "text": "の外交に十分な時間や労力を投入すること"
    },
    {
      "start": 935.199,
      "duration": 3.401,
      "text": "ができないと、ま、イラン情勢がそれだけ"
    },
    {
      "start": 937.079,
      "duration": 3.56,
      "text": "切迫しているっていうま、そういうことな"
    },
    {
      "start": 938.6,
      "duration": 4.08,
      "text": "んじゃないかなという風には思いますと。"
    },
    {
      "start": 940.639,
      "duration": 5.521,
      "text": "ま、そしてですね、この私の判断によれば"
    },
    {
      "start": 942.68,
      "duration": 6.76,
      "text": "、中国は5月の中旬にトランプ大統領の"
    },
    {
      "start": 946.16,
      "duration": 5.359,
      "text": "放中を実現させ、米中関係の安定化を図り"
    },
    {
      "start": 949.44,
      "duration": 4.48,
      "text": "たいという風に中国は考えてると思います"
    },
    {
      "start": 951.519,
      "duration": 5.481,
      "text": "。それはなぜかと言うと、これも私もあの"
    },
    {
      "start": 953.92,
      "duration": 5.719,
      "text": "中国で留学していた時に、あの、よく国際"
    },
    {
      "start": 957.0,
      "duration": 5.44,
      "text": "関係関連の学者たちから聞かされました"
    },
    {
      "start": 959.639,
      "duration": 7.241,
      "text": "けれども、やはりですね、中国にとって"
    },
    {
      "start": 962.44,
      "duration": 7.28,
      "text": "この大外関係、外との関係を安定させて"
    },
    {
      "start": 966.88,
      "duration": 5.319,
      "text": "経済成長のための基盤とすると、つまり"
    },
    {
      "start": 969.72,
      "duration": 4.76,
      "text": "外交は経済のためにあるっていうこの考え"
    },
    {
      "start": 972.199,
      "duration": 4.2,
      "text": "方って非常に色濃く反映されているなと"
    },
    {
      "start": 974.48,
      "duration": 4.32,
      "text": "いう風に当時も感じていましたし、ま、"
    },
    {
      "start": 976.399,
      "duration": 3.8,
      "text": "その認識というか考え方というのは現在に"
    },
    {
      "start": 978.8,
      "duration": 3.44,
      "text": "至っても変わっていないんだという風に"
    },
    {
      "start": 980.199,
      "duration": 3.801,
      "text": "思います。ですからこのいかにして大外"
    },
    {
      "start": 982.24,
      "duration": 4.36,
      "text": "関係を安定させて、これは、ま、イラン"
    },
    {
      "start": 984.0,
      "duration": 5.72,
      "text": "情勢も米国との関係もそうです。いかに"
    },
    {
      "start": 986.6,
      "duration": 6.239,
      "text": "大外関係を安定させて、国内の経済が成長"
    },
    {
      "start": 989.72,
      "duration": 5.28,
      "text": "し、治安が安定し、国民国家として成長し"
    },
    {
      "start": 992.839,
      "duration": 4.521,
      "text": "ていく、安定していくっていうその環境を"
    },
    {
      "start": 995.0,
      "duration": 3.88,
      "text": "作るんだと、それが外交の役割なんだって"
    },
    {
      "start": 997.36,
      "duration": 4.159,
      "text": "いう、こういう考え方って非常にこう"
    },
    {
      "start": 998.88,
      "duration": 5.16,
      "text": "根強いと寝深いという風に私は思います。"
    },
    {
      "start": 1001.519,
      "duration": 4.641,
      "text": "ま、そこがですね、おそらく昨今の集金"
    },
    {
      "start": 1004.04,
      "duration": 4.479,
      "text": "国家主席を含めてですね、この政権指導部"
    },
    {
      "start": 1006.16,
      "duration": 3.88,
      "text": "のスタンスであったり、この要望に符合"
    },
    {
      "start": 1008.519,
      "duration": 4.281,
      "text": "するんじゃないかなという風に思います。"
    },
    {
      "start": 1010.04,
      "duration": 4.719,
      "text": "だからこそイラン情勢も不快りはせずとも"
    },
    {
      "start": 1012.8,
      "duration": 3.88,
      "text": "単なる生官ではなくてですね、こうできる"
    },
    {
      "start": 1014.759,
      "duration": 4.52,
      "text": "ことをやっていこうと。ま、その中で、ま"
    },
    {
      "start": 1016.68,
      "duration": 4.24,
      "text": "、イラン情勢、トランプ放中、中国経済、"
    },
    {
      "start": 1019.279,
      "duration": 3.761,
      "text": "ま、これある意味三角形ですよね。この"
    },
    {
      "start": 1020.92,
      "duration": 4.999,
      "text": "イラン情勢、トランプ放中、中国経済。"
    },
    {
      "start": 1023.04,
      "duration": 5.279,
      "text": "この三角形が今後ですね、どう連動して"
    },
    {
      "start": 1025.919,
      "duration": 3.961,
      "text": "いくのか、どう相互に影響し合っていくの"
    },
    {
      "start": 1028.319,
      "duration": 3.401,
      "text": "か、作用し合っていくのかっていうところ"
    },
    {
      "start": 1029.88,
      "duration": 3.76,
      "text": "もですね、これから、ま、1ヶ月ぐらい"
    },
    {
      "start": 1031.72,
      "duration": 3.839,
      "text": "ですかね、まだまだこの3つのテーマ、ま"
    },
    {
      "start": 1033.64,
      "duration": 4.08,
      "text": "、三角形を巡ってもですね、余断を許さ"
    },
    {
      "start": 1035.559,
      "duration": 4.201,
      "text": "ない。見る側としては面白い。ま、ただ"
    },
    {
      "start": 1037.72,
      "duration": 4.76,
      "text": "ですね、この我々の経済だったり生活にも"
    },
    {
      "start": 1039.76,
      "duration": 4.439,
      "text": "ですね、こう直接影響を及ぼしうる壮大な"
    },
    {
      "start": 1042.48,
      "duration": 3.4,
      "text": "テーマだと思いますので、引き続きですね"
    },
    {
      "start": 1044.199,
      "duration": 4.24,
      "text": "、この動画でもフォローアップしていき"
    },
    {
      "start": 1045.88,
      "duration": 4.52,
      "text": "たいという風に思います。はい。楽天証券"
    },
    {
      "start": 1048.439,
      "duration": 4.801,
      "text": "の投資情報メディア投シがお送りしており"
    },
    {
      "start": 1050.4,
      "duration": 4.639,
      "text": "ます。仮に先ほどの私の話少しは面白かっ"
    },
    {
      "start": 1053.24,
      "duration": 3.2,
      "text": "たなと思った方はですね、チャンネル登録"
    },
    {
      "start": 1055.039,
      "duration": 3.481,
      "text": "そしていいね、押していただけると大変"
    },
    {
      "start": 1056.44,
      "duration": 6.359,
      "text": "幸いでございます。まともにかかります。"
    },
    {
      "start": 1058.52,
      "duration": 4.279,
      "text": "ご成聴ありがとうございました。"
    }
  ]
}