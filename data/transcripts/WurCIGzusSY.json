    {
      "start": 504.159,
      "duration": 4.121,
      "text": "ね。ま、あの、これまであの、"
    },
    {
      "start": 507.96,
      "duration": 3.32,
      "text": "40"
    },
    {
      "start": 508.28,
      "duration": 3.0,
      "text": "年ほど働か歴な中で、あの、ビールのなんかやっぱ授業とかってのも変化していたと思うんですよ。"
    },
    {
      "start": 514.2,
      "duration": 3.0,
      "text": "なんかその変化と共にこのビールの開発とかってどういう風に変わってきた?"
    },
    {
      "start": 520.039,
      "duration": 3.0,
      "text": "そうですね、やはりこう、あの、私が入社"
    },
    {
      "start": 523.64,
      "duration": 3.16,
      "text": "10"
    },
    {
      "start": 523.8,
      "duration": 3.0,
      "text": "年間ぐらいはもうビール市場もどんどん成長して、え、ま、キリのシェアも"
    },
    {
      "start": 530.279,
      "duration": 8.601,
      "text": "60%以上あった。非常にこうお右肩がり"
    },
    {
      "start": 535.04,
      "duration": 5.76,
      "text": "の時代がありましたけども、ま、それ以降"
    },
    {
      "start": 538.88,
      "duration": 4.68,
      "text": "特に1994年をピークにですね、"
    },
    {
      "start": 540.8,
      "duration": 7.88,
      "text": "どんどんどんどんあの、え、ビール市場も"
    },
    {
      "start": 543.56,
      "duration": 9.2,
      "text": "、ま、減少の、ま、奇跡に入りまして、で"
    },
    {
      "start": 548.68,
      "duration": 8.08,
      "text": "、やはり人口の現象、そして、え、若い方"
    },
    {
      "start": 552.76,
      "duration": 6.48,
      "text": "の、ま、ある意味ライフスタイルの変化で"
    },
    {
      "start": 556.76,
      "duration": 5.28,
      "text": "アルコールに対するその価値観の違い、ま"
    },
    {
      "start": 559.24,
      "duration": 6.44,
      "text": "、こういったものがどんどん今起きており"
    },
    {
      "start": 562.04,
      "duration": 8.28,
      "text": "まして、やはりこうアルコール主相全体は"
    },
    {
      "start": 565.68,
      "duration": 9.24,
      "text": "非常にこう厳しい状況に、え、なりつつ"
    },
    {
      "start": 570.32,
      "duration": 8.199,
      "text": "あります。ま、やはり当然あの"
    },
    {
      "start": 574.92,
      "duration": 6.0,
      "text": "どの各者もですね、ま、いろんなこう"
    },
    {
      "start": 578.519,
      "duration": 6.921,
      "text": "アプローチでどんどん新商品を出していく"
    },
    {
      "start": 580.92,
      "duration": 8.919,
      "text": "わけですね。でもやはりこう、え、ある"
    },
    {
      "start": 585.44,
      "duration": 8.32,
      "text": "意味コテ先のお新商品っていうのは当然"
    },
    {
      "start": 589.839,
      "duration": 7.801,
      "text": "長続きしませんし、やはりこう従来の"
    },
    {
      "start": 593.76,
      "duration": 6.759,
      "text": "ビールとも違う価値観とか飲み方とかか"
    },
    {
      "start": 597.64,
      "duration": 6.08,
      "text": "価格、ま、ある意味価値を持ったもの提案"
    },
    {
      "start": 600.519,
      "duration": 7.521,
      "text": "していかないと長続きしないと縮小する"
    },
    {
      "start": 603.72,
      "duration": 7.799,
      "text": "市場の中では、え、都角価格競争に落ちり"
    },
    {
      "start": 608.04,
      "duration": 7.4,
      "text": "がちですけども、やっぱりそい"
    },
    {
      "start": 611.519,
      "duration": 6.281,
      "text": "側面とは違うですね、新しいやはり、え、"
    },
    {
      "start": 615.44,
      "duration": 4.839,
      "text": "提案をしていくことでそれなりのやはり"
    },
    {
      "start": 617.8,
      "duration": 6.12,
      "text": "付加価値を"
    },
    {
      "start": 620.279,
      "duration": 5.281,
      "text": "持った商品そしてそれなりの価格で販売"
    },
    {
      "start": 623.92,
      "duration": 4.76,
      "text": "できるっていうことをやっていかないと"
    },
    {
      "start": 625.56,
      "duration": 5.32,
      "text": "ですね、え、こういう縮小する市場の中で"
    },
    {
      "start": 628.68,
      "duration": 5.92,
      "text": "は、え、生き残っていけないという風に"
    },
    {
      "start": 630.88,
      "duration": 7.28,
      "text": "思ってます。いろんな価値観がお客様には"
    },
    {
      "start": 634.6,
      "duration": 6.96,
      "text": "あの存在しますので、まぱ既輪者としては"
    },
    {
      "start": 638.16,
      "duration": 7.76,
      "text": "、え、そういう市場の変化の中でも"
    },
    {
      "start": 641.56,
      "duration": 7.04,
      "text": "いろんなニーズにある意味あった商品を"
    },
    {
      "start": 645.92,
      "duration": 5.56,
      "text": "キリとしては提案してまいりましたし、ま"
    },
    {
      "start": 648.6,
      "duration": 6.08,
      "text": "、これがやっぱりある意味キリ弊社の強み"
    },
    {
      "start": 651.48,
      "duration": 8.28,
      "text": "だという風に私は思っておりますので、ま"
    },
    {
      "start": 654.68,
      "duration": 8.719,
      "text": "、こういうあの市場の変化に合わせた技術"
    },
    {
      "start": 659.76,
      "duration": 6.199,
      "text": "確信、え、新しい飲み方提案、ま、こう"
    },
    {
      "start": 663.399,
      "duration": 6.201,
      "text": "いったものをやってきましたので、ま、"
    },
    {
      "start": 665.959,
      "duration": 6.041,
      "text": "この秋手取税が一本化されますけども、ま"
    },
    {
      "start": 669.6,
      "duration": 5.0,
      "text": "、この以降も"
    },
    {
      "start": 672.0,
      "duration": 5.279,
      "text": "あのしっかりと"
    },
    {
      "start": 674.6,
      "duration": 6.32,
      "text": "高価格体、中華価格、低วก体、そして"
    },
    {
      "start": 677.279,
      "duration": 6.201,
      "text": "あのある意味こう健康に関わるところの"
    },
    {
      "start": 680.92,
      "duration": 5.2,
      "text": "機能性、ま、こういったカテゴリーでです"
    },
    {
      "start": 683.48,
      "duration": 5.88,
      "text": "ね、それぞれらしい提案をしていきたいな"
    },
    {
      "start": 686.12,
      "duration": 3.8,
      "text": "という風に思ってます。そのキリが"
    },
    {
      "start": 689.36,
      "duration": 3.56,
      "text": "2024"
    },
    {
      "start": 689.92,
      "duration": 3.0,
      "text": "年に発売しヒット商品となったのが晴れ風。独自の正法で飲みやすさと飲み応えを両立することで新たなファンを獲得し"
    },
    {
      "start": 700.32,
      "duration": 3.199,
      "text": "1番絞りに継ぐ定番商品に定着。"
    },
    {
      "start": 703.72,
      "duration": 3.72,
      "text": "よりも非常に"
    },
    {
      "start": 704.44,
      "duration": 3.0,
      "text": "その晴れ風をこの春さらにリニューアルしました。"
    },
    {
      "start": 708.44,
      "duration": 3.36,
      "text": "てる。"
    },
    {
      "start": 708.8,
      "duration": 3.0,
      "text": "特にあの今回我々なりの少しやるとしてですね、"
    },
    {
      "start": 716.44,
      "duration": 3.28,
      "text": "AI"
    },
    {
      "start": 716.72,
      "duration": 3.0,
      "text": "を使った味覚の設計というのも今回、え、この晴れ風の、え、公民設計の中にはビルトインしてるといったところも大きな特徴かもしれません。"
    }
  ]
}