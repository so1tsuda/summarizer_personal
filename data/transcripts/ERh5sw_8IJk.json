      "text": "あるいは川がすれ違ったカーっとお互いに牙を出すっていうのは噛みついたらお前を殺させるんだぞと。総合格証破壊はこれと一てると。"
    },
    {
      "start": 433.84,
      "duration": 4.44,
      "text": "総確破壊ね。"
    },
    {
      "start": 435.28,
      "duration": 3.0,
      "text": "あの、ま、それこそ、あの、ベースの、え、あの、核開発競争の時に総合拡証を全滅させることできれば要するにベイトさんはこう言うんです。"
    },
    {
      "start": 445.96,
      "duration": 3.0,
      "text": "言葉が信用できない国家間関係は動物の関係に似てくると。"
    },
    {
      "start": 451.08,
      "duration": 3.44,
      "text": "はい。"
    },
    {
      "start": 451.52,
      "duration": 3.48,
      "text": "だから動物を見ると国際政治は分かるっていうわけですね。"
    },
    {
      "start": 454.52,
      "duration": 2.679,
      "text": "うん。"
    },
    {
      "start": 455.0,
      "duration": 5.199,
      "text": "そうするとですよ、"
    },
    {
      "start": 457.199,
      "duration": 3.0,
      "text": "縄張りを非常に退して水りのところに住んでいて"
    },
    {
      "start": 461.68,
      "duration": 2.919,
      "text": "うん。"
    },
    {
      "start": 462.759,
      "duration": 4.0,
      "text": "それで、え、時速水の中だと"
    },
    {
      "start": 464.599,
      "duration": 2.761,
      "text": "30kmで歩くカバー。"
    },
    {
      "start": 466.759,
      "duration": 2.361,
      "text": "うん。"
    },
    {
      "start": 467.36,
      "duration": 2.36,
      "text": "日本だとムーミンのイメージですよね。"
    },
    {
      "start": 469.12,
      "duration": 3.6,
      "text": "はい。"
    },
    {
      "start": 469.72,
      "duration": 3.0,
      "text": "ところがどうもアフリカではカバによって殺されてる人間の数が"
    },
    {
      "start": 474.8,
      "duration": 2.32,
      "text": "1番多いとも言われてるんですよ。"
    },
    {
      "start": 476.44,
      "duration": 3.68,
      "text": "うん。"
    },
    {
      "start": 477.12,
      "duration": 3.0,
      "text": "カバっていうのは何も考えないの縄張りに来たものはやつけるんですね。で、口も150°開きますからライオン結構カバにやられてるんですよ。"
    },
    {
      "start": 485.28,
      "duration": 1.759,
      "text": "はい。"
    },
    {
      "start": 485.84,
      "duration": 1.72,
      "text": "ナイルワにもやられてる。"
    },
    {
      "start": 487.039,
      "duration": 3.521,
      "text": "うん。"
    },
    {
      "start": 487.56,
      "duration": 3.0,
      "text": "私は見てるとね、これロシアに似てる感じがするんです。"
    },
    {
      "start": 496.599,
      "duration": 3.0,
      "text": "ロシアっていうのは自分たちが勝手に決めた水場"
    },
    {
      "start": 499.96,
      "duration": 1.76,
      "text": "うん。"
    },
    {
      "start": 500.639,
      "duration": 1.361,
      "text": "ウクライナとか"
    },
    {
      "start": 501.72,
      "duration": 3.28,
      "text": "うん。"
    },
    {
      "start": 502.0,
      "duration": 3.0,
      "text": "そういったに来るとものすごい調子になるわけなんです。ところが遠いところのとこはベネズエラでもあれだけ仲かったのは関係ないと"
    },
    {
      "start": 509.759,
      "duration": 3.361,
      "text": "うん。"
    },
    {
      "start": 510.12,
      "duration": 3.0,
      "text": "だ自分たちの水場のところだけ回ってるようなこういったの非常に状況によった危険な動物と"
    },
    {
      "start": 515.839,
      "duration": 4.161,
      "text": "うん。"
    },
    {
      "start": 517.0,
      "duration": 3.0,
      "text": "それ日本のそれでハイエナはね、ライオの残した餌を漁ってるから平和的に共存してるんじゃないかと思って調べたら全く間違えてハイエアナって半分ぐらいライオンに殺されてるんですね。"
    },
    {
      "start": 530.839,
      "duration": 4.081,
      "text": "うん。そらしいですね。"
    },
    {
      "start": 531.92,
      "duration": 3.0,
      "text": "それでハエアナはライオンの子供殺してるんですよね。"
    },
    {
      "start": 534.959,
      "duration": 3.0,
      "text": "同じ餌番を狙ってるんでライバルだってことなんです。"
    },
    {
      "start": 538.48,
      "duration": 3.0,
      "text": "そうするとこの肉食場を選ぶんだけども日本はカバーのような力ないですしね。"
    },
    {
      "start": 543.6,
      "duration": 2.64,
      "text": "うん。"
    },
    {
      "start": 544.16,
      "duration": 2.84,
      "text": "中国はもしかしたら像かもしれませんよ。"
    },
    {
      "start": 546.24,
      "duration": 2.76,
      "text": "うん。"
    },
    {
      "start": 547.0,
      "duration": 2.92,
      "text": "ライオンだって暴れたら近寄ってこないですから。"
    },
    {
      "start": 549.0,
      "duration": 3.92,
      "text": "うん。"
    },
    {
      "start": 549.92,
      "duration": 3.0,
      "text": "そうすると日本はハイエラみたいなこと選ばないで私はひがいいんじゃないかと思うんですよ。は"
    },
    {
      "start": 556.64,
      "duration": 3.0,
      "text": "鼻も非常に良くて逃げ足も早くてとにかくライオンが暴れてるぐらいに近寄らないんです。"
    },
    {
      "start": 562.04,
      "duration": 1.84,
      "text": "うん。うん。"
    },
    {
      "start": 562.72,
      "duration": 4.16,
      "text": "そしてね、S"
    },
    {
      "start": 563.88,
      "duration": 3.0,
      "text": "さんは基本的に木の上に持ってて食べるんですね。"
    },
    {
      "start": 567.36,
      "duration": 3.0,
      "text": "そうするとですよ船出せとか言われたら憲法ありますからって木の上乗っかっちゃえばいいんですよ。"
    },
    {
      "start": 572.36,
      "duration": 4.8,
      "text": "うん。なるほど。"
    },
    {
      "start": 574.16,
      "duration": 3.0,
      "text": "それで一応肉食の側にはいるから食われることはないとだ。今日本のこの高一総理を見てるとなんか兵のような選択をしてると思うんですね。"
    },
    {
      "start": 585.68,
      "duration": 4.44,
      "text": "だ、とりあえずはこれで逃げ切れてる感じがすると思うんです。"
    },
    {
      "start": 588.519,
      "duration": 3.921,
      "text": "うん。"
    },
    {
      "start": 590.12,
      "duration": 5.32,
      "text": "これからこの先はどうですかね?"
    },
    {
      "start": 592.44,
      "duration": 3.0,
      "text": "この先の情勢っていうのは、あの、本当に予測は非常に難しくて、予測が難しい要因は"
    },
    {
      "start": 599.76,
      "duration": 4.12,
      "text": "2つありまして、1"
    },
    {
      "start": 601.079,
      "duration": 4.641,
      "text": "つはイランの民衆の動きに関して、"
    },
    {
      "start": 603.88,
      "duration": 2.24,
      "text": "これはどこの国もきちんと調査してない。"
    },
    {
      "start": 605.72,
      "duration": 3.4,
      "text": "はい。"
    },
    {
      "start": 606.12,
      "duration": 3.0,
      "text": "またアメリカもイスラエルも革命を起こそうっていうのは工作はしてない。"
    },
    {
      "start": 610.72,
      "duration": 2.679,
      "text": "だからどうなるかそこは全く読めない。"
    },
    {
      "start": 613.04,
      "duration": 0.84,
      "text": "うん。"
    },
    {
      "start": 613.399,
      "duration": 3.481,
      "text": "あともう1"
    },
    {
      "start": 613.88,
      "duration": 3.0,
      "text": "つはこれはモサドの友人が言ってたんですけどね。"
    },
    {
      "start": 617.017,
      "duration": 2.583,
      "text": "[鼻息]"
    },
    {
      "start": 617.16,
      "duration": 4.4,
      "text": "トランプは言うことが"
    },
    {
      "start": 619.6,
      "duration": 2.84,
      "text": "30分で180度か変わると"
    },
    {
      "start": 621.56,
      "duration": 3.88,
      "text": "うん。"
    },
    {
      "start": 622.44,
      "duration": 3.0,
      "text": "こういう対国指導者がいるということはインテリジェンスは想定してないと。"
    },
    {
      "start": 627.44,
      "duration": 3.839,
      "text": "はい。"
    },
    {
      "start": 628.279,
      "duration": 3.0,
      "text": "だからこのイランの民衆の動きとトランプの心の中っていう"
    },
    {
      "start": 633.079,
      "duration": 3.2,
      "text": "2"
    },
    {
      "start": 633.279,
      "duration": 3.0,
      "text": "つのことが読めないんで情勢読みが非常に難しくなってると。"
    },
    {
      "start": 638.16,
      "duration": 3.0,
      "text": "ただ日本の場合にはひグとの戦いが今ありますからね。ひグマって"
    },
    {
      "start": 643.839,
      "duration": 6.041,
      "text": "はい。池神さん何考えてんですかね?"
    },
    {
      "start": 646.88,
      "duration": 3.0,
      "text": "ひグねえ餌のことしか考えてないのかな?"
    },
    {
      "start": 651.12,
      "duration": 3.0,
      "text": "餌のことしか考えてでも人間と遭遇したら逃げてくひグもいれば"
    },
    {
      "start": 655.92,
      "duration": 4.28,
      "text": "ま、大体人間は怖いから逃げてくはずなんですけどね。"
    },
    {
      "start": 658.44,
      "duration": 3.16,
      "text": "うん。最近ってくるの見ます。"
    },
    {
      "start": 660.2,
      "duration": 3.28,
      "text": "最近向かってくるの見ますね。"
    },
    {
      "start": 661.6,
      "duration": 2.32,
      "text": "だよく考えてるわかんないですよね。"
    },
    {
      "start": 663.48,
      "duration": 3.44,
      "text": "うん。"
    },
    {
      "start": 663.92,
      "duration": 3.0,
      "text": "しかし確実に言えることは竹棒機でひグの目つかない方がいいんですよね。"
    },
    {
      "start": 669.32,
      "duration": 4.12,
      "text": "うん。"
    },
    {
      "start": 670.44,
      "duration": 3.0,
      "text": "だからスペインがやってるようなことっていうのは竹ボきてひグの目ついてることなんです。"
    },
    {
      "start": 674.959,
      "duration": 1.88,
      "text": "なるほど。"
    },
    {
      "start": 675.44,
      "duration": 1.8,
      "text": "カナがやったのはそういうこと。"
    },
    {
      "start": 676.839,
      "duration": 3.401,
      "text": "うん。"
    },
    {
      "start": 677.24,
      "duration": 3.0,
      "text": "日本はそういうことだけしないでとにかくひグマの同性をよく見とくっていうことだと思うんですよね。"
    },
    {
      "start": 684.079,
      "duration": 3.601,
      "text": "うん。"
    },
    {
      "start": 684.68,
      "duration": 3.0,
      "text": "それで状況対応型でやってくしか当面ないと思います。"
    },
    {
      "start": 687.76,
      "duration": 0.84,
      "text": "うん。"
    },
    {
      "start": 688.04,
      "duration": 3.56,
      "text": "ただもう1"
    },
    {
      "start": 688.6,
      "duration": 3.0,
      "text": "回考えてみるとトランプがやってることが本当に悪いのかっていうことですよね。"
    },
    {
      "start": 693.079,
      "duration": 3.601,
      "text": "うん。"
    },
    {
      "start": 693.68,
      "duration": 3.0,
      "text": "北朝鮮とベラルーシの共同生命ですよね。"
    },
    {
      "start": 697.24,
      "duration": 3.0,
      "text": "これ非常に大な共同生命がベラル大統領のホームページに出てるんです。朝鮮数の短いんですけども。それで結局我々は大国の有りにはならないと一見のように見える方明らかにロシア意識してるです。"
    },
    {
      "start": 704.788,
      "duration": 2.02,
      "text": "[鼻息]"
    },
    {
      "start": 713.079,
      "duration": 2.281,
      "text": "ます。"
    }
  ]
}