      "start": 603.279,
      "duration": 7.56,
      "text": "相場効果となって株高と金高の大きな要因"
    },
    {
      "start": 607.88,
      "duration": 6.8,
      "text": "になってると考えています。"
    },
    {
      "start": 610.839,
      "duration": 6.641,
      "text": "SNSAIドローンは確かに社会に大きな"
    },
    {
      "start": 614.68,
      "duration": 7.399,
      "text": "プラスの様子を与えています。これは事実"
    },
    {
      "start": 617.48,
      "duration": 7.24,
      "text": "です。一方でSNSもAIもドローンも"
    },
    {
      "start": 622.079,
      "duration": 6.801,
      "text": "マイナスの側面を持っています。例えば"
    },
    {
      "start": 624.72,
      "duration": 7.359,
      "text": "軍事においては情報線が拡大、格覧浸透、"
    },
    {
      "start": 628.88,
      "duration": 6.199,
      "text": "分断の工作が横行しています。そして配テ"
    },
    {
      "start": 632.079,
      "duration": 5.801,
      "text": "化が進んでいっていることによって抑視力"
    },
    {
      "start": 635.079,
      "duration": 6.44,
      "text": "の高め合いが横行し、なかなか戦争が"
    },
    {
      "start": 637.88,
      "duration": 6.24,
      "text": "終わらないという状況も起きています。"
    },
    {
      "start": 641.519,
      "duration": 6.161,
      "text": "こういったことは民主主義の交代や世界"
    },
    {
      "start": 644.12,
      "duration": 7.279,
      "text": "分断進化につがっていると言えます。一般"
    },
    {
      "start": 647.68,
      "duration": 7.839,
      "text": "、個人、国においてはSNSAIが情報の"
    },
    {
      "start": 651.399,
      "duration": 7.44,
      "text": "受けて情報の発信者の関係を大きく変化さ"
    },
    {
      "start": 655.519,
      "duration": 7.241,
      "text": "せました。こういった状況の中で真実です"
    },
    {
      "start": 658.839,
      "duration": 6.761,
      "text": "ね、乱立するはずがない真実が乱立したり"
    },
    {
      "start": 662.76,
      "duration": 6.04,
      "text": "情報の受けての需要力が下がったりしてい"
    },
    {
      "start": 665.6,
      "duration": 7.4,
      "text": "ます。こういった点はポピリズム人気取り"
    },
    {
      "start": 668.8,
      "duration": 8.479,
      "text": "を加速させていると言えます。"
    },
    {
      "start": 673.0,
      "duration": 6.839,
      "text": "一般にも格覧や浸透や分断工策が横行して"
    },
    {
      "start": 677.279,
      "duration": 4.881,
      "text": "います。広がっています。政治におきまし"
    },
    {
      "start": 679.839,
      "duration": 5.68,
      "text": "てはポピリズムで表を稼ぐ政治家が増えて"
    },
    {
      "start": 682.16,
      "duration": 7.0,
      "text": "きているということですね。一般大衆の"
    },
    {
      "start": 685.519,
      "duration": 9.44,
      "text": "クレクレに対しばら巻きを行うという動き"
    },
    {
      "start": 689.16,
      "duration": 9.239,
      "text": "も世界で目立っています。市場においては"
    },
    {
      "start": 694.959,
      "duration": 6.721,
      "text": "資金があれば株価は上がるというですね、"
    },
    {
      "start": 698.399,
      "duration": 7.321,
      "text": "2010年頃以降の大きな変化があって"
    },
    {
      "start": 701.68,
      "duration": 6.36,
      "text": "その資金を求めるつまり金融緩和を求める"
    },
    {
      "start": 705.72,
      "duration": 6.44,
      "text": "市場とま、こういった動きが目立っていた"
    },
    {
      "start": 708.04,
      "duration": 7.2,
      "text": "と見ています。各種川的な策と言いますの"
    },
    {
      "start": 712.16,
      "duration": 6.479,
      "text": "が株高の大きな要因だと。え、加えて"
    },
    {
      "start": 715.24,
      "duration": 7.2,
      "text": "ポピリズムがあることによって期待がどこ"
    },
    {
      "start": 718.639,
      "duration": 7.281,
      "text": "までも増幅してその増幅した期待という"
    },
    {
      "start": 722.44,
      "duration": 6.36,
      "text": "思惑が株価指数を大きく押し上げていると"
    },
    {
      "start": 725.92,
      "duration": 6.52,
      "text": "、ま、このような側面もあると思います。"
    },
    {
      "start": 728.8,
      "duration": 6.68,
      "text": "こういった風な流れの中で民主に交代世界"
    },
    {
      "start": 732.44,
      "duration": 7.32,
      "text": "分断進化資源武器利用応行長期インフレ"
    },
    {
      "start": 735.48,
      "duration": 8.28,
      "text": "継続通貨の不確実性増加株高の不安拡大と"
    },
    {
      "start": 739.76,
      "duration": 7.439,
      "text": "いった新しいタイプの非伝統的な有時が"
    },
    {
      "start": 743.76,
      "duration": 7.28,
      "text": "増幅していってこれが金価格を押し上げて"
    },
    {
      "start": 747.199,
      "duration": 8.241,
      "text": "いるんだとまこういった流れがあると考え"
    },
    {
      "start": 751.04,
      "duration": 5.12,
      "text": "ています。2010年頃以降の長期の流れ"
    },
    {
      "start": 755.44,
      "duration": 3.72,
      "text": "ですね。"
    },
    {
      "start": 756.16,
      "duration": 3.0,
      "text": "細かい上げ下げでは期の流れを作っている要素としてのイナス面とピュリズムが上げ"
    },
    {
      "start": 764.68,
      "duration": 4.24,
      "text": "られると思います。その経路をここで示し"
    },
    {
      "start": 767.079,
      "duration": 4.641,
      "text": "ています。"
    },
    {
      "start": 768.92,
      "duration": 7.2,
      "text": "ではもう1点なんですが、この情報の"
    },
    {
      "start": 771.72,
      "duration": 6.479,
      "text": "受け手情報の発信者の関係変化に関する"
    },
    {
      "start": 776.12,
      "duration": 6.959,
      "text": "詳細を述べていきますと、こちらの通り"
    },
    {
      "start": 778.199,
      "duration": 8.32,
      "text": "ですね、2000年頃以前と言いますのは"
    },
    {
      "start": 783.079,
      "duration": 6.681,
      "text": "情報の受けて情報の発信者の間で良質な"
    },
    {
      "start": 786.519,
      "duration": 6.68,
      "text": "情報をたくさんという点で思惑は一致して"
    },
    {
      "start": 789.76,
      "duration": 7.079,
      "text": "いました。ですが、SNSAIがあること"
    },
    {
      "start": 793.199,
      "duration": 6.88,
      "text": "によっておすめ機能があって、何度でも何"
    },
    {
      "start": 796.839,
      "duration": 5.761,
      "text": "度でもいくらでも見たいものを見ることが"
    },
    {
      "start": 800.079,
      "duration": 6.0,
      "text": "できる環境になってきました。次第にそれ"
    },
    {
      "start": 802.6,
      "duration": 6.52,
      "text": "は見たいものは見たいだけれども見たく"
    },
    {
      "start": 806.079,
      "duration": 6.721,
      "text": "ないものは見たくないに発展してきている"
    },
    {
      "start": 809.12,
      "duration": 7.32,
      "text": "があります。これによって情報の受けては"
    },
    {
      "start": 812.8,
      "duration": 7.32,
      "text": "連想しやすい簡易的期待に答えてくれる"
    },
    {
      "start": 816.44,
      "duration": 7.04,
      "text": "楽しい美しい情報をより見たくなっていっ"
    },
    {
      "start": 820.12,
      "duration": 6.92,
      "text": "たと言えます。こういった状況の中で情報"
    },
    {
      "start": 823.48,
      "duration": 6.2,
      "text": "の発信者は受け手が見たいものを見せて"
    },
    {
      "start": 827.04,
      "duration": 6.159,
      "text": "あげたいと考えになってきました。ですの"
    },
    {
      "start": 829.68,
      "duration": 7.12,
      "text": "で、過去の事例やサイクルを用いて簡単"
    },
    {
      "start": 833.199,
      "duration": 6.921,
      "text": "ですよと加えて複雑な説明を避けてYも"
    },
    {
      "start": 836.8,
      "duration": 6.88,
      "text": "する懸念を与えないエンターテイメント性"
    },
    {
      "start": 840.12,
      "duration": 6.24,
      "text": "を持たせる夢を語るとま、こういった情報"
    },
    {
      "start": 843.68,
      "duration": 6.959,
      "text": "をどんどんと発信していくようになりまし"
    },
    {
      "start": 846.36,
      "duration": 8.039,
      "text": "た。その結果世の中に出回っている少なく"
    },
    {
      "start": 850.639,
      "duration": 8.041,
      "text": "ない情報においては家庭や本質を軽視する"
    },
    {
      "start": 854.399,
      "duration": 8.041,
      "text": "もの、人気取り目的のもの、真実乱立と、"
    },
    {
      "start": 858.68,
      "duration": 7.04,
      "text": "ま、このような実態よりも思惑を優先する"
    },
    {
      "start": 862.44,
      "duration": 5.8,
      "text": "ような情報が拡段に増えていったという"
    },
    {
      "start": 865.72,
      "duration": 5.28,
      "text": "経緯があると思います。これがまさに"
    },
    {
      "start": 868.24,
      "duration": 5.8,
      "text": "ポピュリズムを増幅させていって、実態"
    },
    {
      "start": 871.0,
      "duration": 6.56,
      "text": "よりも思惑プラスの思惑は期待、マイナス"
    },
    {
      "start": 874.04,
      "duration": 5.76,
      "text": "の思惑は懸念。これらが優先される世界が"
    },
    {
      "start": 877.56,
      "duration": 6.719,
      "text": "出来上がっていったということですね。"
    },
    {
      "start": 879.8,
      "duration": 7.32,
      "text": "その結果が重視されやすい株価指数が影響"
    },
    {
      "start": 884.279,
      "duration": 5.881,
      "text": "を受けて上昇しているんだと。ま、こう"
    },
    {
      "start": 887.12,
      "duration": 6.079,
      "text": "いった流れを否定をすることは私はでき"
    },
    {
      "start": 890.16,
      "duration": 6.72,
      "text": "ないと考えています。"
    },
    {
      "start": 893.199,
      "duration": 8.801,
      "text": "このような2010年頃以降の大きな世界"
    },
    {
      "start": 896.88,
      "duration": 8.16,
      "text": "の潮流れが今後も私は継続すると考えてい"
    },
    {
      "start": 902.0,
      "duration": 7.48,
      "text": "ます。ということは世界全体としてのこの"
    },
    {
      "start": 905.04,
      "duration": 8.359,
      "text": "流れが存在すればですね、長期の株高や"
    },
    {
      "start": 909.48,
      "duration": 7.799,
      "text": "長期の金高はやはり継続する可能性がある"
    },
    {
      "start": 913.399,
      "duration": 8.721,
      "text": "と言えると思います。"
    },
    {
      "start": 917.279,
      "duration": 9.081,
      "text": "では最後なんですが関連する金関連ですね"
    },
    {
      "start": 922.12,
      "duration": 8.76,
      "text": "。商品をご紹介いたします。準金積み立て"
    },
    {
      "start": 926.36,
      "duration": 7.36,
      "text": "スポット購入投資信託長期の投資に馴染む"
    },
    {
      "start": 930.88,
      "duration": 6.36,
      "text": "商品がいくつもあります。"
    },
    {
      "start": 933.72,
      "duration": 6.64,
      "text": "国内のETF、ETN、海外ETF外国株"
    },
    {
      "start": 937.24,
      "duration": 6.519,
      "text": "、ま、こちらも一部長期の投資に馴染む"
    },
    {
      "start": 940.36,
      "duration": 7.0,
      "text": "ものがあります。あえて短期売買であれば"
    },
    {
      "start": 943.759,
      "duration": 6.241,
      "text": "国内海外の商品先物、商品CFDなどが"
    },
    {
      "start": 947.36,
      "duration": 5.36,
      "text": "馴染むと思います。用途に応じてご注目"
    },
    {
      "start": 950.0,
      "duration": 6.56,
      "text": "いただければ幸いです。"
    },
    {
      "start": 952.72,
      "duration": 3.84,
      "text": "では今回は"
    },
    {
      "start": 957.12,
      "duration": 7.839,
      "text": "金ゴールドを通して株価指数を見ると題し"
    },
    {
      "start": 962.16,
      "duration": 7.76,
      "text": "てお話させていただきました。また次回も"
    },
    {
      "start": 964.959,
      "duration": 4.961,
      "text": "どうぞよろしくお願いします。"
    }
  ]
}