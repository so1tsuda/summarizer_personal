    },
    {
      "start": 770.36,
      "duration": 5.36,
      "text": "And spending time with Chisato, the only"
    },
    {
      "start": 773.4,
      "duration": 5.48,
      "text": "best [music] friend to whom she truly"
    },
    {
      "start": 775.72,
      "duration": 3.16,
      "text": "opened her heart."
    },
    {
      "start": 782.28,
      "duration": 2.559,
      "text": "That was amazing."
    },
    {
      "start": 783.52,
      "duration": 3.24,
