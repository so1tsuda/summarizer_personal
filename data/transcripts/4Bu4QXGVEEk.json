      "start": 456.72,
      "duration": 5.319,
      "text": "冷静に見るとパランティアが下がったのは"
    },
    {
      "start": 459.319,
      "duration": 6.16,
      "text": "採用されたからじゃなくてイラン戦争と"
    },
    {
      "start": 462.039,
      "duration": 5.081,
      "text": "金利上昇が原因です。マイクロンは戦争の"
    },
    {
      "start": 465.479,
      "duration": 4.881,
      "text": "エスカレーションとGoogleメモリー"
    },
    {
      "start": 467.12,
      "duration": 5.919,
      "text": "技術がたまたま同じ週に重なった。採用と"
    },
    {
      "start": 470.36,
      "duration": 6.32,
      "text": "下落の因果関係は実はなさそうなんですよ"
    },
    {
      "start": 473.039,
      "duration": 6.401,
      "text": "ね。タイミングが最悪だっただけ。実は逆"
    },
    {
      "start": 476.68,
      "duration": 4.919,
      "text": "のパターンもあるんですよ。21年12月"
    },
    {
      "start": 479.44,
      "duration": 5.319,
      "text": "に採用されたMicクrosoftは直後"
    },
    {
      "start": 481.599,
      "duration": 6.241,
      "text": "に2022年の暴落に巻き込まれたんです"
    },
    {
      "start": 484.759,
      "duration": 5.601,
      "text": "けど、その後クラウドとAIで圧倒的な"
    },
    {
      "start": 487.84,
      "duration": 5.68,
      "text": "成長を解けてファングプラスの覚として今"
    },
    {
      "start": 490.36,
      "duration": 6.08,
      "text": "も残ってますよね。2022年12月に"
    },
    {
      "start": 493.52,
      "duration": 6.359,
      "text": "採用されたブロードコムもAI向け反動体"
    },
    {
      "start": 496.44,
      "duration": 6.479,
      "text": "の大本命として大成功。採用直後は苦しく"
    },
    {
      "start": 499.879,
      "duration": 5.801,
      "text": "ても長い目で見れば成長を続けた企業も"
    },
    {
      "start": 502.919,
      "duration": 5.84,
      "text": "あります。逆身伝説の正体はファング"
    },
    {
      "start": 505.68,
      "duration": 5.519,
      "text": "プラスが直近で最も勢いなる銘柄を"
    },
    {
      "start": 508.759,
      "duration": 5.28,
      "text": "スコアリングランクで採用する仕組みに"
    },
    {
      "start": 511.199,
      "duration": 6.08,
      "text": "あります。そこに外部環境の悪化が重なる"
    },
    {
      "start": 514.039,
      "duration": 6.041,
      "text": "と直線まで最も上がっていた銘柄が1番"
    },
    {
      "start": 517.279,
      "duration": 4.88,
      "text": "大きく下がる。構造の問題であって呪い"
    },
    {
      "start": 520.08,
      "duration": 5.04,
      "text": "じゃないんですよね。パランティアも"
    },
    {
      "start": 522.159,
      "duration": 6.041,
      "text": "マイクロンも業績は崩れていません。外部"
    },
    {
      "start": 525.12,
      "duration": 6.399,
      "text": "環境が落ち着けば本来の成長力が評価さ"
    },
    {
      "start": 528.2,
      "duration": 6.36,
      "text": "れる局面が来るはずなんですよね。では次"
    },
    {
      "start": 531.519,
      "duration": 5.601,
      "text": "の賞では金利上昇がファングプラスにどれ"
    },
    {
      "start": 534.56,
      "duration": 5.08,
      "text": "ほどの恐怖をもたらすのか、今と構造が似"
    },
    {
      "start": 537.12,
      "duration": 5.399,
      "text": "ている2020年を追体験していき"
    },
    {
      "start": 539.64,
      "duration": 6.199,
      "text": "ましょう。それでは本日の品き3つ目に"
    },
    {
      "start": 542.519,
      "duration": 6.401,
      "text": "参りましょう。あなたは49%限に耐え"
    },
    {
      "start": 545.839,
      "duration": 5.321,
      "text": "られるか?2022年リアルな再現です。"
    },
    {
      "start": 548.92,
      "duration": 4.599,
      "text": "あなたが今感じている不安、それは"
    },
    {
      "start": 551.16,
      "duration": 6.16,
      "text": "2020年に投資家たちが感じていた恐怖"
    },
    {
      "start": 553.519,
      "duration": 7.201,
      "text": "と実はよく似ています。20年2月ロシア"
    },
    {
      "start": 557.32,
      "duration": 7.28,
      "text": "がウクライナに進行。原油が急そして"
    },
    {
      "start": 560.72,
      "duration": 7.32,
      "text": "FRBがインフレのために政策金利を0%"
    },
    {
      "start": 564.6,
      "duration": 6.0,
      "text": "近から5.5%まで市場最速のペースで"
    },
    {
      "start": 568.04,
      "duration": 5.799,
      "text": "引き上げ始めたんですよね。戦争かける"
    },
    {
      "start": 570.6,
      "duration": 6.08,
      "text": "原油豊油かける利上げ。今回のイラン戦争"
    },
    {
      "start": 573.839,
      "duration": 5.801,
      "text": "かける原油100ドルかける利上げ観測と"
    },
    {
      "start": 576.68,
      "duration": 5.92,
      "text": "構造がとてもよく似ていますよね。では"
    },
    {
      "start": 579.64,
      "duration": 5.4,
      "text": "2020年のファングプラスが月ごにどう"
    },
    {
      "start": 582.6,
      "duration": 5.16,
      "text": "推移用したのか追体験して見ていき"
    },
    {
      "start": 585.04,
      "duration": 5.44,
      "text": "ましょう。なお、ここからの下落は川を"
    },
    {
      "start": 587.76,
      "duration": 6.319,
      "text": "考慮しないドルベースの指数の下落率でご"
    },
    {
      "start": 590.48,
      "duration": 6.359,
      "text": "紹介いたします。1月から3月FRBの"
    },
    {
      "start": 594.079,
      "duration": 6.361,
      "text": "利上げ開始。2月にロシアがウクライナに"
    },
    {
      "start": 596.839,
      "duration": 6.521,
      "text": "進行。原油が急ニュースは連日インフレ"
    },
    {
      "start": 600.44,
      "duration": 5.92,
      "text": "利上げ戦争の文字が並びました。"
    },
    {
      "start": 603.36,
      "duration": 6.039,
      "text": "NASダックが調整局面入りSNSに"
    },
    {
      "start": 606.36,
      "duration": 6.08,
      "text": "ハイテクバブル崩壊の声が広がり始めた。"
    },
    {
      "start": 609.399,
      "duration": 7.201,
      "text": "わずか3ヶ月で資産の15%が消えた。"
    },
    {
      "start": 612.44,
      "duration": 7.6,
      "text": "高値から-15%です。4月最悪の月、"
    },
    {
      "start": 616.6,
      "duration": 5.76,
      "text": "ファングプラスは月刊-19.3%"
    },
    {
      "start": 620.04,
      "duration": 5.16,
      "text": "たった1ヶ月で2割が吹き飛んだ"
    },
    {
      "start": 622.36,
      "duration": 6.12,
      "text": "Netflixの決算で会員数が10年"
    },
    {
      "start": 625.2,
      "duration": 7.24,
      "text": "ぶりに減少したと発表。株価は1日で-"
    },
    {
      "start": 628.48,
      "duration": 7.76,
      "text": "35%と大幅減少に見舞れます。さらに"
    },
    {
      "start": 632.44,
      "duration": 6.04,
      "text": "Amazonも決算後に-14%と急落。"
    },
    {
      "start": 636.24,
      "duration": 5.399,
      "text": "SNSはファングプラスは終わったが"
    },
    {
      "start": 638.48,
      "duration": 5.919,
      "text": "相言葉。証券講座を開くのが怖くなる体験"
    },
    {
      "start": 641.639,
      "duration": 6.681,
      "text": "をした人も多かったかと思います。そして"
    },
    {
      "start": 644.399,
      "duration": 6.601,
      "text": "5月から6月、FRBが0.75%の大幅"
    },
    {
      "start": 648.32,
      "duration": 6.12,
      "text": "上げを決定。景気を壊しててもインフレを"
    },
    {
      "start": 651.0,
      "duration": 7.48,
      "text": "潰すとパウエル議長。メタは初の売上減少"
    },
    {
      "start": 654.44,
      "duration": 7.04,
      "text": "を記録し、株価は最高値から-64%まで"
    },
    {
      "start": 658.48,
      "duration": 5.159,
      "text": "沈んだんですよね。半年で資産の4割近く"
    },
    {
      "start": 661.48,
      "duration": 4.479,
      "text": "が消えた。もうテクノロジーの時代は"
    },
    {
      "start": 663.639,
      "duration": 5.2,
      "text": "終わった。周りの投資家がどんどん売って"
    },
    {
      "start": 665.959,
      "duration": 6.041,
      "text": "いく。10月から11月ファングプラスは"
    },
    {
      "start": 668.839,
      "duration": 6.041,
      "text": "高値から-48.98%"
    },
    {
      "start": 672.0,
      "duration": 6.36,
      "text": "ほぼ反音です。あなたの資産がほぼ半分に"
    },
    {
      "start": 674.88,
      "duration": 6.72,
      "text": "なった。FRBはさらに0.75%の"
    },
    {
      "start": 678.36,
      "duration": 6.36,
      "text": "利上げを繰り返し、政策金利は4%に迫っ"
    },
    {
      "start": 681.6,
      "duration": 5.6,
      "text": "た。資産がほぼ半分。毎月のように下がり"
    },
    {
      "start": 684.72,
      "duration": 5.559,
      "text": "続ける。SNSを開けば終わったの。文字"
    },
    {
      "start": 687.2,
      "duration": 4.68,
      "text": "。証券構造を見るたびに胃がいたくなる。"
    },
    {
      "start": 690.279,
      "duration": 4.281,
      "text": "やっぱり売った方がいいんじゃないか。"
    },
    {
      "start": 691.88,
      "duration": 4.959,
      "text": "周りはどんどん売っていく。そんな"
    },
    {
      "start": 694.56,
      "duration": 4.92,
      "text": "2022年あなたがもしこの場にいたとし"
    },
    {
      "start": 696.839,
      "duration": 5.481,
      "text": "てこの10ヶ月間売らずに耐えられました"
    },
    {
      "start": 699.48,
      "duration": 5.44,
      "text": "か?これがファングプラスの現実です。"
    },
    {
      "start": 702.32,
      "duration": 5.319,
      "text": "数字で見るのと自分の資産がほぼ犯例に"
    },
    {
      "start": 704.92,
      "duration": 5.4,
      "text": "なっていくのを目の前で経験するのとは点"
    },
    {
      "start": 707.639,
      "duration": 6.64,
      "text": "とちょうど違いますよね。もちろんこれに"
    },
    {
      "start": 710.32,
      "duration": 7.16,
      "text": "は続きがあります。底根から169営業日"
    },
    {
      "start": 714.279,
      "duration": 7.081,
      "text": "約8ヶ月で全回復。そこからさらに上昇し"
    },
    {
      "start": 717.48,
      "duration": 8.0,
      "text": "て2024年末には底値の約2.5倍に"
    },
    {
      "start": 721.36,
      "duration": 7.32,
      "text": "あの時-48.98%で売っていたらその"
    },
    {
      "start": 725.48,
      "duration": 6.919,
      "text": "損失ではあり握り続けた人だけが資産が元"
    },
    {
      "start": 728.68,
      "duration": 6.44,
      "text": "に戻りさらに増えました。でもこの回復を"
    },
    {
      "start": 732.399,
      "duration": 5.24,
      "text": "教示できたのは恐怖の底で売らなかった人"
    },
    {
      "start": 735.12,
      "duration": 5.44,
      "text": "だけです。パニックで降りた人は回復の"
    },
    {
      "start": 737.639,
      "duration": 5.64,
      "text": "全てを取り逃したんですよね。そして今"
    },
    {
      "start": 740.56,
      "duration": 6.2,
      "text": "同じようなパターンになりつつあるイラン"
    },
    {
      "start": 743.279,
      "duration": 6.441,
      "text": "清掃かける利上げ観測。2020年と構造"
    },
    {
      "start": 746.76,
      "duration": 5.92,
      "text": "が似ていますよね。あの恐怖がもう1度"
    },
    {
      "start": 749.72,
      "duration": 5.28,
      "text": "来るかもしれない。今回も同じ展開になる"
    },
    {
      "start": 752.68,
      "duration": 5.0,
      "text": "保証はありません。でも歴史を知っている"
    },
    {
      "start": 755.0,
      "duration": 5.839,
      "text": "ことには意味があるんですよね。続きまし"
    },
    {
      "start": 757.68,
      "duration": 5.92,
      "text": "ては本日の品き4つ目に参りましょう。"
    },
    {
      "start": 760.839,
      "duration": 5.56,
      "text": "株価下落の今10社がやっていること知っ"
    },
    {
      "start": 763.6,
      "duration": 5.64,
      "text": "ていますか?2020年以降にファング"
    },
    {
      "start": 766.399,
      "duration": 5.961,
      "text": "プラスが回復できた理由、それは企業の"
    },
    {
      "start": 769.24,
      "duration": 6.719,
      "text": "稼ぐ力が衰えていなかったから金利という"
    },
    {
      "start": 772.36,
      "duration": 7.4,
      "text": "おしが外れて顕在だった企業の成長力が"
    },
    {
      "start": 775.959,
      "duration": 7.0,
      "text": "一気に株価に反映をされた。じゃあ今回は"
    },
    {
      "start": 779.76,
      "duration": 6.079,
      "text": "株価はマイナ22%下がってますよね。で"
    },
    {
      "start": 782.959,
      "duration": 5.601,
      "text": "も樹社は今この瞬間何をしてるのでしょう"
    },
    {
      "start": 785.839,
      "duration": 5.12,
      "text": "か?これを知ると見える景色が変わります"
    },
    {
      "start": 788.56,
      "duration": 4.839,
      "text": "。1社ずつ確認をしていきましょう。"
    },
    {
      "start": 790.959,
      "duration": 5.24,
      "text": "チャatトGPTを運営するOpenAI"
    },
    {
      "start": 793.399,
      "duration": 4.761,
      "text": "の最大収支者。皆さん、チャATGPTは"
    },
    {
      "start": 796.199,
      "duration": 3.921,
      "text": "使ったことありますよね。とんでもない"
    },
    {
      "start": 798.16,
      "duration": 4.88,
      "text": "ことになっています。週慣アクティブ"
    },
    {
      "start": 800.12,
      "duration": 6.24,
      "text": "ユーザーは9億人ですよ。地球の9人に"
    },
    {
      "start": 803.04,
      "duration": 6.359,
      "text": "1人が毎週使ってます。毎日10億円以上"
    },
    {
      "start": 806.36,
      "duration": 5.479,
      "text": "の質問に答えてるそうです。そして売上が"
    },
    {
      "start": 809.399,
      "duration": 6.44,
      "text": "2022年にはたった150億円だったの"
    },
    {
      "start": 811.839,
      "duration": 6.841,
      "text": "が2025年には1.3兆円。3年で87"
    },
    {
      "start": 815.839,
      "duration": 5.8,
      "text": "倍です。Amazonが売上1兆円に届く"
    },
    {
      "start": 818.68,
      "duration": 5.599,
      "text": "まで10年間かかったチャATGPTは3"
    },
    {
      "start": 821.639,
      "duration": 4.841,
      "text": "年でそれを達成しています。AIの普及"
    },
    {
      "start": 824.279,
      "duration": 5.68,
      "text": "速度はインターネットより早いんですよね"
    },
    {
      "start": 826.48,
      "duration": 5.12,
      "text": "。このチャATGPTを裏で支えてるのが"
    },
    {
      "start": 829.959,
      "duration": 5.0,
      "text": "MicrosクftのクラウドAlee"
    },
    {
      "start": 831.6,
      "duration": 6.159,
      "text": "です。世界中の人がチャATGPTを使え"
    },
    {
      "start": 834.959,
      "duration": 7.721,
      "text": "ば使うほどアジルの売上が伸びます。実際"
    },
    {
      "start": 837.759,
      "duration": 8.361,
      "text": "にアジルは売上がプラ26%。次にNVD"
    },
    {
      "start": 842.68,
      "duration": 7.0,
      "text": "売上プラ62%。データセンター売上は"
    },
    {
      "start": 846.12,
      "duration": 6.32,
      "text": "毎半期で過去最高を更新し続けています。"
    },
    {
      "start": 849.68,
      "duration": 4.159,
      "text": "AIチップは注文が殺当して供給が"
    },
    {
      "start": 852.44,
      "duration": 4.12,
      "text": "追いつかないほどです。"
    },
    {
      "start": 853.839,
      "duration": 6.401,
      "text": "そしてジェンソンファンCEOは2027"
    },
    {
      "start": 856.56,
      "duration": 6.32,
      "text": "までの売上予測を1兆約150兆円に"
    },
    {
      "start": 860.24,
      "duration": 5.8,
      "text": "引き上げています。株価が下がってるらで"
    },
    {
      "start": 862.88,
      "duration": 5.0,
      "text": "CEOが売上目標を倍に情報修正をして"
    },
    {
      "start": 866.04,
      "duration": 4.2,
      "text": "いるんです。さらに次世代"
    },
    {
      "start": 867.88,
      "duration": 5.04,
      "text": "プラットフォームベラルビン。こちらでは"
    },
    {
      "start": 870.24,
      "duration": 5.32,
      "text": "AIの水論コストが1/10になる。"
    },
    {
      "start": 872.92,
      "duration": 7.08,
      "text": "コストが下がれば使える企業が爆発的に"
    },
    {
      "start": 875.56,
      "duration": 6.719,
      "text": "増えます。次にメタ毎日35.8億人が"
    },
    {
      "start": 880.0,
      "duration": 4.56,
      "text": "メタのアプリを使っています。地球の人口"
    },
    {
      "start": 882.279,
      "duration": 4.081,
      "text": "の約半分です。Instagram、"
    },
    {
      "start": 884.56,
      "duration": 4.88,
      "text": "Facebook、WhatsApp。次"
    },
    {
      "start": 886.36,
      "duration": 6.68,
      "text": "にApple売上は過去最高を更新して"
    },
    {
      "start": 889.44,
      "duration": 5.68,
      "text": "プラ16%。世界で12億台以上の"
    },
    {
      "start": 893.04,
      "duration": 4.08,
      "text": "iPhoneが稼働中です。でも"
    },
    {
      "start": 895.12,
      "duration": 4.0,
      "text": "Appleの本当の強みは売って終わり"
    },
    {
      "start": 897.12,
      "duration": 4.12,
      "text": "じゃないところ。AppStoreや"
    },
    {
      "start": 899.12,
      "duration": 4.12,
      "text": "iCloud、AppleMusicなど"
    },
    {
      "start": 901.24,
      "duration": 5.32,
      "text": "1度iPhoneを買ったら毎月サービス"
    },
    {
      "start": 903.24,
      "duration": 6.279,
      "text": "にお金を払い続ける。このサービス収益が"
    },
    {
      "start": 906.56,
      "duration": 6.04,
      "text": "毎年積み上がるストック型ビジネスに進化"
    },
    {
      "start": 909.519,
      "duration": 6.361,
      "text": "をしています。次にAmazonAWSは"
    },
    {
      "start": 912.6,
      "duration": 5.159,
      "text": "世界のクラウドシェア第1位です。AWS"
    },
    {
      "start": 915.88,
      "duration": 5.12,
      "text": "ベッドロックというですね、サービスで"
    },
    {
      "start": 917.759,
      "duration": 6.32,
      "text": "自分でAIモデルを開発しなくてもAWS"
    },
    {
      "start": 921.0,
      "duration": 5.639,
      "text": "に接続するだけでAIが使えるようになっ"
    },
    {
      "start": 924.079,
      "duration": 5.401,
      "text": "てきています。次にGoogle検索"
    },
    {
      "start": 926.639,
      "duration": 5.521,
      "text": "シェアは9割以上変わりがない。今この"
    },
    {
      "start": 929.48,
      "duration": 5.56,
      "text": "瞬間も世界中の人がグっています。"
    },
    {
      "start": 932.16,
      "duration": 5.72,
      "text": "YouTubeは月刊25億人が視聴して"
    },
    {
      "start": 935.04,
      "duration": 5.44,
      "text": "います。さらにジムニーで次の時代も抑え"
    },
    {
      "start": 937.88,
      "duration": 6.319,
      "text": "に行ってますよね。次にNetflix"
    },
    {
      "start": 940.48,
      "duration": 6.96,
      "text": "会員数が3億人を突破。世界190カ国で"
    },
    {
      "start": 944.199,
      "duration": 6.08,
      "text": "展開。AIがあなたの視張リクを学習して"
    },
    {
      "start": 947.44,
      "duration": 5.48,
      "text": "次に見る作品を提案してくれます。この"
    },
    {
      "start": 950.279,
      "duration": 6.081,
      "text": "レコメンドの制度がすごくて解約率が脅異"
    },
    {
      "start": 952.92,
      "duration": 6.32,
      "text": "的に低いんですよね。にブロードコム"
    },
    {
      "start": 956.36,
      "duration": 5.919,
      "text": "NVD以外のAI反動体の本命。"
    },
    {
      "start": 959.24,
      "duration": 5.56,
      "text": "Googleやが自社専用のAIチップを"
    },
    {
      "start": 962.279,
      "duration": 5.881,
      "text": "開発する時設計パートナーになるのが"
    },
    {
      "start": 964.8,
      "duration": 6.24,
      "text": "ブロードコム。AI関連売上は全費3倍"
    },
    {
      "start": 968.16,
      "duration": 6.44,
      "text": "以上に爆発しています。次にパランティア"
    },
    {
      "start": 971.04,
      "duration": 5.84,
      "text": "元々CIAやアメリカ国防総省にAI"
    },
    {
      "start": 974.6,
      "duration": 5.2,
      "text": "データ分析を提供していたスパイ映画"
    },
    {
      "start": 976.88,
      "duration": 5.68,
      "text": "みたいな会社。それが今民間企業向けの"
    },
    {
      "start": 979.8,
      "duration": 6.399,
      "text": "AIプラットフォームAIPで爆発的に"
    },
    {
      "start": 982.56,
      "duration": 6.639,
      "text": "成長しています。最後にマイクAI向けの"
    },
    {
      "start": 986.199,
      "duration": 5.241,
      "text": "交代域メモリHBMで世界をリードしてい"
    },
    {
      "start": 989.199,
      "duration": 5.721,
      "text": "ます。NVDIAの実代プラットフォーム"
    },
    {
      "start": 991.44,
      "duration": 7.36,
      "text": "の心部を供給する会社。2026年分は"
    },
    {
      "start": 994.92,
      "duration": 7.68,
      "text": "なんとすでに完売。売上見通しは全費プラ"
    },
    {
      "start": 998.8,
      "duration": 6.32,
      "text": "100%超、EPSは前年の4倍以上に"
    },
    {
      "start": 1002.6,
      "duration": 4.56,
      "text": "拡大する見通し。Googleのメモリー"
    },
    {
      "start": 1005.12,
      "duration": 5.36,
      "text": "技術ショックで短期的には売られました"
    },
    {
      "start": 1007.16,
      "duration": 5.599,
      "text": "けども、足元の需要は全く衰えていない。"
    },
    {
      "start": 1010.48,
      "duration": 4.719,
      "text": "このようにファングプラスの数字だけ見て"
    },
    {
      "start": 1012.759,
      "duration": 5.481,
      "text": "いるとなかなか見えてこないのが企業の"
    },
    {
      "start": 1015.199,
      "duration": 6.401,
      "text": "成長なんですよね。今我々が成長している"
    },
    {
      "start": 1018.24,
      "duration": 6.839,
      "text": "。今我々が生活をしている。今まさにこの"
    },
    {
      "start": 1021.6,
      "duration": 5.88,
      "text": "時にも耐えず成長を続けてるんですよね。"
    },
    {
      "start": 1025.079,
      "duration": 5.12,
      "text": "それでは本日の失品き最後に参りましょう"
    },
    {
      "start": 1027.48,
      "duration": 6.439,
      "text": "。ファングプラスを長期保有するために"
    },
    {
      "start": 1030.199,
      "duration": 6.12,
      "text": "絶対に必要な2つの力です。最後に1番"
    },
    {
      "start": 1033.919,
      "duration": 5.681,
      "text": "大事なお話をします。ファングプラスを"
    },
    {
      "start": 1036.319,
      "duration": 6.041,
      "text": "長期で持ち続けるために絶対に必要な力が"
    },
    {
      "start": 1039.6,
      "duration": 6.16,
      "text": "2つあります。1つ目の力は10社を理解"
    },
    {
      "start": 1042.36,
      "duration": 6.0,
      "text": "しをアップデートし続けるそんな力です。"
    },
    {
      "start": 1045.76,
      "duration": 5.08,
      "text": "ファングプラスは10社。S&P500の"
    },
    {
      "start": 1048.36,
      "duration": 4.84,
      "text": "500社やオルカンの3000車と違って"
    },
    {
      "start": 1050.84,
      "duration": 5.32,
      "text": "全車を理解できますよね。これは武器です"
    },
    {
      "start": 1053.2,
      "duration": 5.56,
      "text": "よ。でも武器は使わなければ意味がない。"
    },
    {
      "start": 1056.16,
      "duration": 5.8,
      "text": "NDが何を売っているか知っていますか?"
    },
    {
      "start": 1058.76,
      "duration": 6.84,
      "text": "アジールがなんでプラ26%伸びているの"
    },
    {
      "start": 1061.96,
      "duration": 7.16,
      "text": "か説明できますか?メタのAI広告がなぜ"
    },
    {
      "start": 1065.6,
      "duration": 6.0,
      "text": "売上プラ24%に繋がっているか理解をさ"
    },
    {
      "start": 1069.12,
      "duration": 6.24,
      "text": "れてますか?これに答えられる人は-"
    },
    {
      "start": 1071.6,
      "duration": 6.36,
      "text": "22%を見ても企業の競争力は顕在だと"
    },
    {
      "start": 1075.36,
      "duration": 5.96,
      "text": "判断ができます。答えられない人はもう"
    },
    {
      "start": 1077.96,
      "duration": 6.839,
      "text": "ダめだとしか思えませんよね。同じ-"
    },
    {
      "start": 1081.32,
      "duration": 6.16,
      "text": "22%で結論が真逆になる。しかも10社"
    },
    {
      "start": 1084.799,
      "duration": 5.041,
      "text": "の顔ブレは定期的に変わります。だから"
    },
    {
      "start": 1087.48,
      "duration": 4.6,
      "text": "知識のアップデートが必要です。今の"
    },
    {
      "start": 1089.84,
      "duration": 5.68,
      "text": "ファングプラスを理解し続けること、それ"
    },
    {
      "start": 1092.08,
      "duration": 6.4,
      "text": "自体が投資迫力に直結してきます。もう1"
    },
    {
      "start": 1095.52,
      "duration": 5.48,
      "text": "つの力は自分のリスク強度を理解する力"
    },
    {
      "start": 1098.48,
      "duration": 5.04,
      "text": "です。突然ですが、あなたのポートフルの"
    },
    {
      "start": 1101.0,
      "duration": 6.039,
      "text": "中でファングプラスは何割を占めています"
    },
    {
      "start": 1103.52,
      "duration": 6.56,
      "text": "か?全力ファングプラスの人、相当な"
    },
    {
      "start": 1107.039,
      "duration": 6.201,
      "text": "リスク強度が求められます。-22%"
    },
    {
      "start": 1110.08,
      "duration": 6.079,
      "text": "どころか20不安ですよね。でも上がっ"
    },
    {
      "start": 1113.24,
      "duration": 5.76,
      "text": "てる時は誰でも投資を続けられます。本当"
    },
    {
      "start": 1116.159,
      "duration": 5.201,
      "text": "の握力が試されるのはまさに今のような時"
    },
    {
      "start": 1119.0,
      "duration": 4.799,
      "text": "です。なんとなくファングプラスを買った"
    },
    {
      "start": 1121.36,
      "duration": 5.4,
      "text": "人にとって今はかなりきつい時期だと思い"
    },
    {
      "start": 1123.799,
      "duration": 5.721,
      "text": "ます。でもこの動画を最後まで見てくれた"
    },
    {
      "start": 1126.76,
      "duration": 5.52,
      "text": "あなたはもうなんとなくじゃない。なぜ"
    },
    {
      "start": 1129.52,
      "duration": 5.96,
      "text": "下がってるのかを理解をした樹者が今何を"
    },
    {
      "start": 1132.28,
      "duration": 5.879,
      "text": "してるのかを知った。2020年の恐怖を"
    },
    {
      "start": 1135.48,
      "duration": 5.559,
      "text": "追体験して自分のリスク強度と向き合い"
    },
    {
      "start": 1138.159,
      "duration": 5.321,
      "text": "ましたよね。それだけで昨日までのあなた"
    },
    {
      "start": 1141.039,
      "duration": 5.441,
      "text": "とは違う投資家になっています。僕は売り"
    },
    {
      "start": 1143.48,
      "duration": 5.439,
      "text": "ません。10社の稼ぐからは私は衰えてい"
    },
    {
      "start": 1146.48,
      "duration": 4.679,
      "text": "ないと思います。AIの成長ストーリーも"
    },
    {
      "start": 1148.919,
      "duration": 4.081,
      "text": "変わっていないんですよね。本日も最後"
    },
    {
      "start": 1151.159,
      "duration": 4.961,
      "text": "までご視聴いただきありがとうございまし"
    },
    {
      "start": 1153.0,
      "duration": 4.919,
      "text": "た。本日の動画の裏話や動画の中では"
    },
    {
      "start": 1156.12,
      "duration": 4.28,
      "text": "ちょっと言いきれない本音をノートの"
    },
    {
      "start": 1157.919,
      "duration": 4.681,
      "text": "メンバーシップで発信を始めております。"
    },
    {
      "start": 1160.4,
      "duration": 4.159,
      "text": "台本を作りながら考えていたことや"
    },
    {
      "start": 1162.6,
      "duration": 4.76,
      "text": "ちょっと公開動画で言えないことも楽ヤ"
    },
    {
      "start": 1164.559,
      "duration": 5.081,
      "text": "トーク的に有力発信中です。気になる方は"
    },
    {
      "start": 1167.36,
      "duration": 4.52,
      "text": "概要欄かこちらのQRコードを読み込むと"
    },
    {
      "start": 1169.64,
      "duration": 4.399,
      "text": "ノートに登録できます。是非ご活用"
    },
    {
      "start": 1171.88,
      "duration": 4.0,
      "text": "ください。概要欄にLINEX、"
    },
    {
      "start": 1174.039,
      "duration": 5.481,
      "text": "Instタ、メルマガのURLがあります"
    },
    {
      "start": 1175.88,
      "duration": 6.4,
      "text": "。私自身が取り組んでいる資産形成や製造"
    },
    {
      "start": 1179.52,
      "duration": 5.48,
      "text": "の工夫は今後LINEで配信予定、ご興味"
    },
    {
      "start": 1182.28,
      "duration": 5.2,
      "text": "ある方はご登録ください。メルマガでは"
    },
    {
      "start": 1185.0,
      "duration": 5.84,
      "text": "日々の経済ニュースを分かりやすく解説し"
    },
    {
      "start": 1187.48,
      "duration": 6.04,
      "text": "ています。インスタやXではより短時間で"
    },
    {
      "start": 1190.84,
      "duration": 5.28,
      "text": "情報インプットができます。是非ご登録を"
    },
    {
      "start": 1193.52,
      "duration": 5.36,
      "text": "お願いします。"
    },
    {
      "start": 1196.12,
      "duration": 2.76,
      "text": "あ。"
    }
  ]
}