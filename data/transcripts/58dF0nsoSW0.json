    {
      "start": 374.96,
      "duration": 4.519,
      "text": "なかったなっていう風に思いました。ま、"
    },
    {
      "start": 377.12,
      "duration": 5.079,
      "text": "それもそのはずで香港における、ま、"
    },
    {
      "start": 379.479,
      "duration": 5.761,
      "text": "2025年の電気自動車の販売台数っての"
    },
    {
      "start": 382.199,
      "duration": 5.521,
      "text": "調べてみたんですけど、BYDが初めて"
    },
    {
      "start": 385.24,
      "duration": 6.48,
      "text": "テスラを抜いてトップに立ったということ"
    },
    {
      "start": 387.72,
      "duration": 7.08,
      "text": "ですね。25年通年でBYDの電気自動車"
    },
    {
      "start": 391.72,
      "duration": 6.199,
      "text": "売れた台数が9751"
    },
    {
      "start": 394.8,
      "duration": 6.0,
      "text": "台、テスラが9193"
    },
    {
      "start": 397.919,
      "duration": 4.56,
      "text": "台ということで、BYDが初めてテスロを"
    },
    {
      "start": 400.8,
      "duration": 4.72,
      "text": "上回ってトップに立ったっていうことです"
    },
    {
      "start": 402.479,
      "duration": 4.361,
      "text": "ね。あとこの香港で皆さん見たり乗った"
    },
    {
      "start": 405.52,
      "duration": 2.799,
      "text": "ことあるかもしんないですけど、香港の"
    },
    {
      "start": 406.84,
      "duration": 4.44,
      "text": "タクシーって赤いタクシーじゃないですか"
    },
    {
      "start": 408.319,
      "duration": 5.0,
      "text": "?赤いタクシーなんか最近ですね、香港の"
    },
    {
      "start": 411.28,
      "duration": 4.319,
      "text": "タクシーでもこれまで全部現金だったわけ"
    },
    {
      "start": 413.319,
      "duration": 5.121,
      "text": "ですけど、現金だけじゃなくて電子決済"
    },
    {
      "start": 415.599,
      "duration": 4.641,
      "text": "もう最低限使えるようにしておきなさい"
    },
    {
      "start": 418.44,
      "duration": 4.319,
      "text": "みたいな新しいルールができたりしてます"
    },
    {
      "start": 420.24,
      "duration": 4.519,
      "text": "けれども、香港で走ら例の赤いタクシーも"
    },
    {
      "start": 422.759,
      "duration": 4.72,
      "text": "長年日本のトヨタが独占してきたわけです"
    },
    {
      "start": 424.759,
      "duration": 4.641,
      "text": "けれども、最近ではBYD車も参入する"
    },
    {
      "start": 427.479,
      "duration": 4.801,
      "text": "ようになっているということで、ま、"
    },
    {
      "start": 429.4,
      "duration": 4.28,
      "text": "BYDの同行っていうのは1つ顕著な傾向"
    },
    {
      "start": 432.28,
      "duration": 4.24,
      "text": "としてあるんじゃないかなという風に思い"
    },
    {
      "start": 433.68,
      "duration": 6.56,
      "text": "ました。ま、香港経済社会におけるこの"
    },
    {
      "start": 436.52,
      "duration": 6.48,
      "text": "中国の影響力と存在感が特に2020年"
    },
    {
      "start": 440.24,
      "duration": 4.639,
      "text": "以降着実に高まっていると、ま、そういう"
    },
    {
      "start": 443.0,
      "duration": 4.24,
      "text": "現在値を示しているなということをですね"
    },
    {
      "start": 444.879,
      "duration": 4.6,
      "text": "、街中を歩きながら感じたという次第です"
    },
    {
      "start": 447.24,
      "duration": 5.0,
      "text": "。え、ここでですね、3個までに現地で"
    },
    {
      "start": 449.479,
      "duration": 4.801,
      "text": "撮ってきた写真が何枚かありますんで、"
    },
    {
      "start": 452.24,
      "duration": 4.519,
      "text": "それをちょっとですね、共有させて"
    },
    {
      "start": 454.28,
      "duration": 5.44,
      "text": "いただきたいんですけれども、こ、先ほど"
    },
    {
      "start": 456.759,
      "duration": 5.88,
      "text": "のこれBYDありますけれども、こちらが"
    },
    {
      "start": 459.72,
      "duration": 5.12,
      "text": "ワンチャイかな。香港のワンチャイにある"
    },
    {
      "start": 462.639,
      "duration": 5.201,
      "text": "BYDの、ま、ショップですけれども、ま"
    },
    {
      "start": 464.84,
      "duration": 5.68,
      "text": "、結構ですね、中心地にでっかいこの敷地"
    },
    {
      "start": 467.84,
      "duration": 5.0,
      "text": "を取って、この上にある電座っていうのも"
    },
    {
      "start": 470.52,
      "duration": 4.48,
      "text": "これ商用者、ま、割と大きめのワゴンです"
    },
    {
      "start": 472.84,
      "duration": 4.72,
      "text": "けれども、いくつかのこの種類、ま、"
    },
    {
      "start": 475.0,
      "duration": 5.879,
      "text": "BYD着実に影響力を増してるなっていう"
    },
    {
      "start": 477.56,
      "duration": 6.039,
      "text": "ことを感じましたし、こちら人民源、え、"
    },
    {
      "start": 480.879,
      "duration": 4.72,
      "text": "連民Bですね、人民源って書いてあること"
    },
    {
      "start": 483.599,
      "duration": 4.241,
      "text": "は分かると思うんですけれども、この報告"
    },
    {
      "start": 485.599,
      "duration": 4.04,
      "text": "で、これ香港のおそらくピークから撮った"
    },
    {
      "start": 487.84,
      "duration": 5.84,
      "text": "写真だと思うんですけれども、ま、この"
    },
    {
      "start": 489.639,
      "duration": 7.481,
      "text": "真ん中ら辺にですね、あなたに全面的に"
    },
    {
      "start": 493.68,
      "duration": 7.359,
      "text": "人民源サービスを提供しますよとか、"
    },
    {
      "start": 497.12,
      "duration": 6.72,
      "text": "あなたが人民源の最新教を把握することを"
    },
    {
      "start": 501.039,
      "duration": 6.16,
      "text": "お手伝いしますよとかですね。あなたの"
    },
    {
      "start": 503.84,
      "duration": 4.84,
      "text": "人民源を管理する金融会社ですよみたいな"
    },
    {
      "start": 507.199,
      "duration": 3.0,
      "text": "、ま、こういうことが書かれて"
    },
    {
      "start": 508.68,
      "duration": 4.159,
      "text": "るっていうことですけれども、やっぱり"
    },
    {
      "start": 510.199,
      "duration": 5.121,
      "text": "この人民源の影響力、ま、あの、香港では"
    },
    {
      "start": 512.839,
      "duration": 4.64,
      "text": "ね、日常的に香港ドルが使われてですね、"
    },
    {
      "start": 515.32,
      "duration": 4.44,
      "text": "香港ドルと米ドルはペックされてるわけ"
    },
    {
      "start": 517.479,
      "duration": 4.281,
      "text": "ですけれども、やっぱり人民源の影響力"
    },
    {
      "start": 519.76,
      "duration": 4.04,
      "text": "普及度というのも香港においで高まって"
    },
    {
      "start": 521.76,
      "duration": 4.44,
      "text": "くる。これ、ま、中国色の一環かなと思い"
    },
    {
      "start": 523.8,
      "duration": 4.039,
      "text": "ますし、最後の1枚ですけど、これも香港"
    },
    {
      "start": 526.2,
      "duration": 3.639,
      "text": "トレ取ったあるこのビルはどうでもいいん"
    },
    {
      "start": 527.839,
      "duration": 4.0,
      "text": "ですけど、このスローガンですね。中国"
    },
    {
      "start": 529.839,
      "duration": 5.361,
      "text": "広大集団っていうこれ、ま、国有企業です"
    },
    {
      "start": 531.839,
      "duration": 6.201,
      "text": "けれども、民族の偉大なる復興、香港の"
    },
    {
      "start": 535.2,
      "duration": 4.52,
      "text": "長期的な安定と反映みたいなことが書かれ"
    },
    {
      "start": 538.04,
      "duration": 5.28,
      "text": "てるわけですけれども、こういう形でです"
    },
    {
      "start": 539.72,
      "duration": 5.92,
      "text": "ね、この中国の企業がお金を出したり"
    },
    {
      "start": 543.32,
      "duration": 6.44,
      "text": "スポンサーになってですね、このやっぱり"
    },
    {
      "start": 545.64,
      "duration": 6.52,
      "text": "香港は中国の一部として中国の国際経済"
    },
    {
      "start": 549.76,
      "duration": 5.759,
      "text": "都市として発展していくんだよと。で、"
    },
    {
      "start": 552.16,
      "duration": 6.76,
      "text": "その過程で中国企業が、中国の通貨が、"
    },
    {
      "start": 555.519,
      "duration": 5.121,
      "text": "中国の車が影響力を持って香港経済を"
    },
    {
      "start": 558.92,
      "duration": 4.08,
      "text": "引っ張っていくよっていう、ま、こういう"
    },
    {
      "start": 560.64,
      "duration": 3.84,
      "text": "ですね、あの雰囲気をいろんなところで"
    },
    {
      "start": 563.0,
      "duration": 4.12,
      "text": "感じたということですね。ま、この"
    },
    {
      "start": 564.48,
      "duration": 5.12,
      "text": "スローガン、人民源、BYDということで"
    },
    {
      "start": 567.12,
      "duration": 7.8,
      "text": "、ま、数限られてる教縮レスルの3枚共有"
    },
    {
      "start": 569.6,
      "duration": 5.32,
      "text": "をさせていただきましたと。"
    },
    {
      "start": 577.32,
      "duration": 4.199,
      "text": "はい。こっからですね、パート2に行き"
    },
    {
      "start": 579.64,
      "duration": 4.84,
      "text": "たいという風に思うんですけれども、ま、"
    },
    {
      "start": 581.519,
      "duration": 5.041,
      "text": "香港経済と中国経済臨ジって、ま、この辺"
    },
    {
      "start": 584.48,
      "duration": 5.16,
      "text": "をですね、統計も引用しながら見ていき"
    },
    {
      "start": 586.56,
      "duration": 5.88,
      "text": "ましょうということですがはい。中国職が"
    },
    {
      "start": 589.64,
      "duration": 6.28,
      "text": "強まる香港でその経済状況がどうなってる"
    },
    {
      "start": 592.44,
      "duration": 6.12,
      "text": "のかということを2025年、ま、直近の"
    },
    {
      "start": 595.92,
      "duration": 4.919,
      "text": "主要経済統計と2024年を比較しながら"
    },
    {
      "start": 598.56,
      "duration": 4.48,
      "text": "整理したのでご覧いただきたいんです"
    },
    {
      "start": 600.839,
      "duration": 4.24,
      "text": "けれども、こちらを見るとですね、ま、上"
    },
    {
      "start": 603.04,
      "duration": 5.239,
      "text": "から、ま、GDPとかあの色々書いてある"
    },
    {
      "start": 605.079,
      "duration": 5.681,
      "text": "わけですが、ま、経済成長率、あとその下"
    },
    {
      "start": 608.279,
      "duration": 5.041,
      "text": "の固定資本形成っていうの、ま、設備投資"
    },
    {
      "start": 610.76,
      "duration": 5.079,
      "text": "を始めとする投資関係ですけれども、ま、"
    },
    {
      "start": 613.32,
      "duration": 4.28,
      "text": "あと、ま、民間における人消費、ま、大外"
    },
    {
      "start": 615.839,
      "duration": 5.401,
      "text": "輸出含めてですね、ま、こうやって見て"
    },
    {
      "start": 617.6,
      "duration": 6.479,
      "text": "みると、ま、2025年の数字が2024"
    },
    {
      "start": 621.24,
      "duration": 5.039,
      "text": "年をですね、掃除上回っているというとこ"
    },
    {
      "start": 624.079,
      "duration": 4.681,
      "text": "だという風に思います。それも結構顕著に"
    },
    {
      "start": 626.279,
      "duration": 4.8,
      "text": "上回ってる感じですよね。はい。物の輸出"
    },
    {
      "start": 628.76,
      "duration": 4.84,
      "text": "なんかもそうだし、この3つ目のその民間"
    },
    {
      "start": 631.079,
      "duration": 5.0,
      "text": "消費支出に関しても、ま、1昨年マイナス"
    },
    {
      "start": 633.6,
      "duration": 4.52,
      "text": "でしたけれども、1.6%とはいえプラス"
    },
    {
      "start": 636.079,
      "duration": 4.801,
      "text": "に展じたっていう、こういった状況が見て"
    },
    {
      "start": 638.12,
      "duration": 4.6,
      "text": "取れるというとこですね。ま、その背景"
    },
    {
      "start": 640.88,
      "duration": 4.8,
      "text": "っていうところで言うと、例えば、ま、"
    },
    {
      "start": 642.72,
      "duration": 5.679,
      "text": "中国のこのAI関連株への投資が"
    },
    {
      "start": 645.68,
      "duration": 4.36,
      "text": "盛り上がって、ま、香港反線株価指数って"
    },
    {
      "start": 648.399,
      "duration": 4.401,
      "text": "いうのはありますけれども、ま、2025"
    },
    {
      "start": 650.04,
      "duration": 4.919,
      "text": "年通年で約3割上昇したと、ま、こういっ"
    },
    {
      "start": 652.8,
      "duration": 3.719,
      "text": "たところもですね、この景気回復に一定"
    },
    {
      "start": 654.959,
      "duration": 4.641,
      "text": "程度起与したんじゃないかなっていう風に"
    },
    {
      "start": 656.519,
      "duration": 6.44,
      "text": "思うと。で、特出すべきはこの最後にある"
    },
    {
      "start": 659.6,
      "duration": 5.679,
      "text": "訪問客数。これはつまり香港を訪れる人、"
    },
    {
      "start": 662.959,
      "duration": 4.361,
      "text": "ま、外国人の、ま、もちろん外国人だけと"
    },
    {
      "start": 665.279,
      "duration": 4.481,
      "text": "はいらないですけれども、客数であると。"
    },
    {
      "start": 667.32,
      "duration": 5.4,
      "text": "ま、これを見るとですね、ま、2025年"
    },
    {
      "start": 669.76,
      "duration": 5.16,
      "text": "の方が2024年よりも増えて、ま、約"
    },
    {
      "start": 672.72,
      "duration": 5.679,
      "text": "5000万人が訪れてるってことですが、"
    },
    {
      "start": 674.92,
      "duration": 7.08,
      "text": "これちょっと皆さんですね、人口750万"
    },
    {
      "start": 678.399,
      "duration": 6.041,
      "text": "人の香港に5000万人近くが1年の間に"
    },
    {
      "start": 682.0,
      "duration": 5.2,
      "text": "訪れるっていうのはこれ私から見たら結構"
    },
    {
      "start": 684.44,
      "duration": 5.639,
      "text": "これとんでもない数字で、やっぱり香港が"
    },
    {
      "start": 687.2,
      "duration": 5.24,
      "text": "いかに外と繋がりながらこの経済社会が"
    },
    {
      "start": 690.079,
      "duration": 3.961,
      "text": "成り立ってるのかなっていうことを如実に"
    },
    {
      "start": 692.44,
      "duration": 5.76,
      "text": "感じさせるという風に思うんですけれども"
    },
    {
      "start": 694.04,
      "duration": 7.0,
      "text": "、参考までに日本は昨年2025年人口約"
    },
    {
      "start": 698.2,
      "duration": 6.079,
      "text": "1億2000万人の日本を訪れた外国人の"
    },
    {
      "start": 701.04,
      "duration": 6.44,
      "text": "数は初めて4000万人を突破し、過去"
    },
    {
      "start": 704.279,
      "duration": 6.481,
      "text": "最多の4270万人となったと。"
    },
    {
      "start": 707.48,
      "duration": 5.56,
      "text": "4270万人。それでも香港の数には及ば"
    },
    {
      "start": 710.76,
      "duration": 5.879,
      "text": "ないというのが、ま、現状としてあると。"
    },
    {
      "start": 713.04,
      "duration": 5.479,
      "text": "だからいかに香港を毎年毎日多くの人が"
    },
    {
      "start": 716.639,
      "duration": 3.921,
      "text": "訪れてるかっていうところが分かるんじゃ"
    },
    {
      "start": 718.519,
      "duration": 5.041,
      "text": "ないかなという風に思いますと。ま、"
    },
    {
      "start": 720.56,
      "duration": 5.44,
      "text": "そして香港経済社会における中国色を、ま"
    },
    {
      "start": 723.56,
      "duration": 6.399,
      "text": "、今日の1つのテーマですが、中国色を"
    },
    {
      "start": 726.0,
      "duration": 6.8,
      "text": "理解する上で鍵を握るのが訪問客数の中で"
    },
    {
      "start": 729.959,
      "duration": 5.961,
      "text": "占める中国の本土大陸から難化してきた人"
    },
    {
      "start": 732.8,
      "duration": 7.68,
      "text": "たちの割合。それを見ると昨年香港訪れた"
    },
    {
      "start": 735.92,
      "duration": 9.719,
      "text": "約4990万人のうち3783万"
    },
    {
      "start": 740.48,
      "duration": 7.039,
      "text": "人。3783万人。すなわち76%が中国"
    },
    {
      "start": 745.639,
      "duration": 5.2,
      "text": "本土から来たお客さんであるということ"
    },
    {
      "start": 747.519,
      "duration": 5.921,
      "text": "ですね。ま、この数字を見ても中国、本土"
    },
    {
      "start": 750.839,
      "duration": 5.481,
      "text": "と香港は、ま、当然陸続きで繋がってる"
    },
    {
      "start": 753.44,
      "duration": 5.0,
      "text": "わけです。新鮮とニューテリトリー、あと"
    },
    {
      "start": 756.32,
      "duration": 4.6,
      "text": "カウルンがね、陸続きで繋がってます"
    },
    {
      "start": 758.44,
      "duration": 6.8,
      "text": "けれども、ま、その中でですね、この観光"
    },
    {
      "start": 760.92,
      "duration": 8.159,
      "text": "とか勉強、修学とか修業、仕事、労働とか"
    },
    {
      "start": 765.24,
      "duration": 6.279,
      "text": "ですね、あらゆる分野で人、も、金情報の"
    },
    {
      "start": 769.079,
      "duration": 4.88,
      "text": "往来が、ま、非常に緊密、ま、これが中国"
    },
    {
      "start": 771.519,
      "duration": 4.481,
      "text": "、今度と本、ま、一刻、2制度と言って"
    },
    {
      "start": 773.959,
      "duration": 5.841,
      "text": "ますけれども、この関係性だと思いますと"
    },
    {
      "start": 776.0,
      "duration": 5.92,
      "text": "。ま、だからこれだけね、76%中国人が"
    },
    {
      "start": 779.8,
      "duration": 4.44,
      "text": "占めるというのは、ま、想像に硬くはない"
    },
    {
      "start": 781.92,
      "duration": 5.719,
      "text": "わけですけれども、ま、1つ言えることは"
    },
    {
      "start": 784.24,
      "duration": 6.159,
      "text": "香港の実態経済、そして株式市場を含めて"
    },
    {
      "start": 787.639,
      "duration": 6.32,
      "text": "やっぱりこれまで以上にですね、中国次第"
    },
    {
      "start": 790.399,
      "duration": 5.361,
      "text": "というか、この中国打み的な要素が高まっ"
    },
    {
      "start": 793.959,
      "duration": 4.12,
      "text": "ていくっていう、ま、この傾向というのは"
    },
    {
      "start": 795.76,
      "duration": 4.0,
      "text": "不逆的なんじゃないかなと。ま、この数制"
    },
    {
      "start": 798.079,
      "duration": 4.161,
      "text": "っていうのはもう変わらないんじゃないか"
    },
    {
      "start": 799.76,
      "duration": 5.56,
      "text": "なっていう風に私は考えてますと。ま、"
    },
    {
      "start": 802.24,
      "duration": 6.0,
      "text": "香港経済と中国経済のリンケージ、え、"
    },
    {
      "start": 805.32,
      "duration": 5.199,
      "text": "相互作用を示す実例の1つをもう1つ"
    },
    {
      "start": 808.24,
      "duration": 4.039,
      "text": "上げるとですね、近年懸念されている中国"
    },
    {
      "start": 810.519,
      "duration": 3.88,
      "text": "のデフレスパイラルの影響なんじゃないか"
    },
    {
      "start": 812.279,
      "duration": 4.481,
      "text": "なという風に見ていると。例えばです"
    },
    {
      "start": 814.399,
      "duration": 5.921,
      "text": "けれども、ま、デフレの影響が深刻化すれ"
    },
    {
      "start": 816.76,
      "duration": 6.72,
      "text": "ば中国本土からやってくる訪問者の懐具合"
    },
    {
      "start": 820.32,
      "duration": 4.6,
      "text": "にも影響して香港で落とすお金にも制限が"
    },
    {
      "start": 823.48,
      "duration": 4.4,
      "text": "かかるということだと思うんですね。"
    },
    {
      "start": 824.92,
      "duration": 5.56,
      "text": "つまり中国でデフレが進行すればするほど"
    },
    {
      "start": 827.88,
      "duration": 5.639,
      "text": "これだけ毎年もう3700万人ぐらいです"
    },
    {
      "start": 830.48,
      "duration": 4.64,
      "text": "かこれだけの人が香港訪れてるのにただ来"
    },
    {
      "start": 833.519,
      "duration": 3.401,
      "text": "ただけでお金を落とさないっていうですね"
    },
    {
      "start": 835.12,
      "duration": 4.36,
      "text": "。ま、こういう事態になりかねないと。だ"
    },
    {
      "start": 836.92,
      "duration": 5.599,
      "text": "から当然香港経済として先ほど申し上げた"
    },
    {
      "start": 839.48,
      "duration": 4.76,
      "text": "民間消費支出とかですね。ま、この消費内"
    },
    {
      "start": 842.519,
      "duration": 4.641,
      "text": "というところに当然影響は出てくるという"
    },
    {
      "start": 844.24,
      "duration": 6.76,
      "text": "ことはありますし、逆に中国本土のデフレ"
    },
    {
      "start": 847.16,
      "duration": 7.2,
      "text": "の影響を受けて香港と比べて中国が割安に"
    },
    {
      "start": 851.0,
      "duration": 6.12,
      "text": "なれば香港人は週末などに、ま、高速鉄道"
    },
    {
      "start": 854.36,
      "duration": 4.919,
      "text": "とか地下鉄に乗って、ま、隣接する新選と"
    },
    {
      "start": 857.12,
      "duration": 4.8,
      "text": "かに行ってですね、ま、そこでお金を使う"
    },
    {
      "start": 859.279,
      "duration": 5.56,
      "text": "ととなれば結果的に香港にお金が落ちなく"
    },
    {
      "start": 861.92,
      "duration": 5.919,
      "text": "なるということで、やっぱり中国の本土が"
    },
    {
      "start": 864.839,
      "duration": 4.721,
      "text": "中国経済がデフレになればなるほど、ま、"
    },
    {
      "start": 867.839,
      "duration": 4.24,
      "text": "香港経済にとっては不利にな"
    },
    {
      "start": 869.56,
      "duration": 4.0,
      "text": "るっていうこう結構明確な相関関係という"
    },
    {
      "start": 872.079,
      "duration": 3.361,
      "text": "のが見い出せるっていうところだという風"
    },
    {
      "start": 873.56,
      "duration": 4.24,
      "text": "に思います。ですから、ま、そういった"
    },
    {
      "start": 875.44,
      "duration": 4.68,
      "text": "ですね、香港経済と中国経済、特にこう"
    },
    {
      "start": 877.8,
      "duration": 5.36,
      "text": "デフレという観点から見るとこの相互作用"
    },
    {
      "start": 880.12,
      "duration": 5.399,
      "text": "が一種の悪循環を生み、香港経済にとって"
    },
    {
      "start": 883.16,
      "duration": 4.28,
      "text": "の景気下れリスクになっていくと、そう"
    },
    {
      "start": 885.519,
      "duration": 4.161,
      "text": "いう、ま、構造が見い出せるんじゃないか"
    },
    {
      "start": 887.44,
      "duration": 4.72,
      "text": "という風に思いますし、今回の、え、訪問"
    },
    {
      "start": 889.68,
      "duration": 4.88,
      "text": "でも一定程度そういった実態を感じたと"
    },
    {
      "start": 892.16,
      "duration": 6.4,
      "text": "いうことですね。ま、実際ですね、近年"
    },
    {
      "start": 894.56,
      "duration": 6.32,
      "text": "香港市民、香港住民が物価の安い割安の"
    },
    {
      "start": 898.56,
      "duration": 5.24,
      "text": "中国本土で買い物をする。これをですね、"
    },
    {
      "start": 900.88,
      "duration": 5.199,
      "text": "最近北上消費、つまり北に赴いて消費"
    },
    {
      "start": 903.8,
      "duration": 4.56,
      "text": "するって、この北上消費っていう言葉が"
    },
    {
      "start": 906.079,
      "duration": 5.081,
      "text": "流行ったんですけれども、ま、これが進行"
    },
    {
      "start": 908.36,
      "duration": 4.88,
      "text": "して香港における人消費が低明するという"
    },
    {
      "start": 911.16,
      "duration": 4.32,
      "text": "事態も実際に起きてきました。あの、"
    },
    {
      "start": 913.24,
      "duration": 4.64,
      "text": "先ほどの表に表されていたように民間消費"
    },
    {
      "start": 915.48,
      "duration": 5.56,
      "text": "の支出は2024年マイナス成長だったと"
    },
    {
      "start": 917.88,
      "duration": 5.639,
      "text": "。ま、2025年には1.6%増と前年費"
    },
    {
      "start": 921.04,
      "duration": 4.56,
      "text": "、ま、やや回復はしているものの今後どう"
    },
    {
      "start": 923.519,
      "duration": 3.76,
      "text": "なっていくのか、香港経済がどうなって"
    },
    {
      "start": 925.6,
      "duration": 4.28,
      "text": "いくのか、香港がどうなっていくのかって"
    },
    {
      "start": 927.279,
      "duration": 4.721,
      "text": "いうこのテーマがですね、ますます中国"
    },
    {
      "start": 929.88,
      "duration": 4.28,
      "text": "次第、中国がどうかっていうところに影響"
    },
    {
      "start": 932.0,
      "duration": 4.48,
      "text": "を受けるっていうま、この実態を今回も"
    },
    {
      "start": 934.16,
      "duration": 5.52,
      "text": "非常に感じたということでございます。"
    },
    {
      "start": 936.48,
      "duration": 3.2,
      "text": "はい。"
    },
    {
      "start": 941.759,
      "duration": 3.801,
      "text": "最後パート3。香港はどこへ向かうのかと"
    },
    {
      "start": 944.319,
      "duration": 2.921,
      "text": "いう話をしたいんですけども、ちょっと"
    },
    {
      "start": 945.56,
      "duration": 4.079,
      "text": "大きすぎる話かもしれないですけれども、"
    },
    {
      "start": 947.24,
      "duration": 5.76,
      "text": "最後この話をして閉めたいかなという風に"
    },
    {
      "start": 949.639,
      "duration": 6.2,
      "text": "思います。中国で、ま、以前ですね、この"
    },
    {
      "start": 953.0,
      "duration": 6.759,
      "text": "改革開放の、ま、中国で改革開放って"
    },
    {
      "start": 955.839,
      "duration": 6.321,
      "text": "1976年に盲沢投資が亡くなって文化大"
    },
    {
      "start": 959.759,
      "duration": 4.52,
      "text": "革命が終わってその後ですね、東翔兵士氏"
    },
    {
      "start": 962.16,
      "duration": 5.2,
      "text": "が政治の表部隊に復帰してですね、"
    },
    {
      "start": 964.279,
      "duration": 6.521,
      "text": "1970年代の後半から80年代の初島に"
    },
    {
      "start": 967.36,
      "duration": 5.719,
      "text": "かけてこの改革会放、ま、中国経済をです"
    },
    {
      "start": 970.8,
      "duration": 5.039,
      "text": "ね、改革して解放していくっていう、ま、"
    },
    {
      "start": 973.079,
      "duration": 6.24,
      "text": "この総設計士と呼ばれた東翔平さん、この"
    },
    {
      "start": 975.839,
      "duration": 5.961,
      "text": "東翔兵士が、ま、ダシピさんが香港の変換"
    },
    {
      "start": 979.319,
      "duration": 4.721,
      "text": "を巡って英国のイギリスのサッチャー首相"
    },
    {
      "start": 981.8,
      "duration": 5.719,
      "text": "と交渉を繰り広げたっていう経緯があって"
    },
    {
      "start": 984.04,
      "duration": 6.52,
      "text": "、その当初兵士はですね、50年不遍、"
    },
    {
      "start": 987.519,
      "duration": 5.201,
      "text": "50年は変わらないという方針を語ってい"
    },
    {
      "start": 990.56,
      "duration": 5.32,
      "text": "たと。これどういうことかと言うと、香港"
    },
    {
      "start": 992.72,
      "duration": 6.16,
      "text": "変換後の50年、すなわち2047年まで"
    },
    {
      "start": 995.88,
      "duration": 6.04,
      "text": "は香港は変わらなくていいよと。つまり"
    },
    {
      "start": 998.88,
      "duration": 5.439,
      "text": "社会主義を採用する中国本土とは異なり"
    },
    {
      "start": 1001.92,
      "duration": 4.08,
      "text": "資本主義制度を採用し続ける。ま、これ、"
    },
    {
      "start": 1004.319,
      "duration": 3.681,
      "text": "ま、まさに一国に制度っていうことです"
    },
    {
      "start": 1006.0,
      "duration": 4.8,
      "text": "けれども、それを要認するよという"
    },
    {
      "start": 1008.0,
      "duration": 5.72,
      "text": "スタンスを東翔兵士は当時から語っていた"
    },
    {
      "start": 1010.8,
      "duration": 4.959,
      "text": "ということですね。で、実際、ま、香港の"
    },
    {
      "start": 1013.72,
      "duration": 6.679,
      "text": "現状ってのを見てみると、ま、香港におけ"
    },
    {
      "start": 1015.759,
      "duration": 7.08,
      "text": "る資本市場の位置付けとか解放、税制、"
    },
    {
      "start": 1020.399,
      "duration": 4.081,
      "text": "言語、ま、関東語、英語、普通語、"
    },
    {
      "start": 1022.839,
      "duration": 3.801,
      "text": "マンダリングがダイナミックに共存してる"
    },
    {
      "start": 1024.48,
      "duration": 5.559,
      "text": "わけですけれども、あと労働市場における"
    },
    {
      "start": 1026.64,
      "duration": 6.6,
      "text": "多様性、国際性などですね、ま、中国本土"
    },
    {
      "start": 1030.039,
      "duration": 5.64,
      "text": "とは質的に次元が異なるということだと"
    },
    {
      "start": 1033.24,
      "duration": 4.64,
      "text": "いう風に思います。ドルと香港どルか"
    },
    {
      "start": 1035.679,
      "duration": 4.24,
      "text": "ペッグされているというのも香港経済を"
    },
    {
      "start": 1037.88,
      "duration": 4.159,
      "text": "巡る顕著な特徴なんじゃないかなという風"
    },
    {
      "start": 1039.919,
      "duration": 4.841,
      "text": "に思いますし、ま、これらの特徴というの"
    },
    {
      "start": 1042.039,
      "duration": 4.28,
      "text": "は政治的にこの自由なくき資本主義って"
    },
    {
      "start": 1044.76,
      "duration": 3.559,
      "text": "申し上げましたけども、そうなったからと"
    },
    {
      "start": 1046.319,
      "duration": 3.641,
      "text": "いっていきなりガラっと変わるってことは"
    },
    {
      "start": 1048.319,
      "duration": 4.72,
      "text": "私はないんじゃないかなという風には思っ"
    },
    {
      "start": 1049.96,
      "duration": 5.92,
      "text": "ていると。さらに香港では英国植民地時代"
    },
    {
      "start": 1053.039,
      "duration": 5.721,
      "text": "からの顧問ローつまり不通法が採用されて"
    },
    {
      "start": 1055.88,
      "duration": 5.28,
      "text": "いてこちらも中国今度とは異なるという"
    },
    {
      "start": 1058.76,
      "duration": 5.159,
      "text": "ことですね。このように、ま、香港では"
    },
    {
      "start": 1061.16,
      "duration": 6.24,
      "text": "ですね、金融センタービジネスとしての"
    },
    {
      "start": 1063.919,
      "duration": 5.801,
      "text": "機能を支えるこの制度的優意性が依前とし"
    },
    {
      "start": 1067.4,
      "duration": 4.84,
      "text": "て存続しているという風に思いますし、"
    },
    {
      "start": 1069.72,
      "duration": 4.64,
      "text": "これからも一定程度存続していくんだろう"
    },
    {
      "start": 1072.24,
      "duration": 4.64,
      "text": "なという風に私は見ていると、ま、日本の"
    },
    {
      "start": 1074.36,
      "duration": 5.52,
      "text": "企業や投資家としてもですね、この香港を"
    },
    {
      "start": 1076.88,
      "duration": 5.08,
      "text": "1つのビジネス拠点、投資の窓口に添える"
    },
    {
      "start": 1079.88,
      "duration": 3.919,
      "text": "同期背景になっているという風に見るべき"
    },
    {
      "start": 1081.96,
      "duration": 3.76,
      "text": "なんじゃないかなという風に思いますと。"
    },
    {
      "start": 1083.799,
      "duration": 5.041,
      "text": "あとやはりマーケットという観点から見れ"
    },
    {
      "start": 1085.72,
      "duration": 5.0,
      "text": "ば香港は中国、本土、特に上海とか新鮮"
    },
    {
      "start": 1088.84,
      "duration": 5.04,
      "text": "ですよね。経済都市ですけれども、そう"
    },
    {
      "start": 1090.72,
      "duration": 5.839,
      "text": "いった中国の大都市とかですね、あるいは"
    },
    {
      "start": 1093.88,
      "duration": 4.679,
      "text": "香港にとって1つの競争相手、競合相手で"
    },
    {
      "start": 1096.559,
      "duration": 3.6,
      "text": "あるシンガポール、そこはやっぱり中国と"
    },
    {
      "start": 1098.559,
      "duration": 4.321,
      "text": "の距離ということも含めてですね、"
    },
    {
      "start": 1100.159,
      "duration": 5.241,
      "text": "シンガポールとも異なるし、そして言語、"
    },
    {
      "start": 1102.88,
      "duration": 4.919,
      "text": "税制、多様性、地理的条件といった観点"
    },
    {
      "start": 1105.4,
      "duration": 5.92,
      "text": "から日本とも異なるということだと思い"
    },
    {
      "start": 1107.799,
      "duration": 6.36,
      "text": "ますね。ですから香港は北京上海新鮮とか"
    },
    {
      "start": 1111.32,
      "duration": 6.88,
      "text": "シンガポールとか東京とかソールとか太平"
    },
    {
      "start": 1114.159,
      "duration": 6.441,
      "text": "とかとも異なる独自の政党的な優意性条件"
    },
    {
      "start": 1118.2,
      "duration": 4.56,
      "text": "を有する国際経済都市なんだろうなって"
    },
    {
      "start": 1120.6,
      "duration": 3.92,
      "text": "いう、ま、この基本的な考えというのは今"
    },
    {
      "start": 1122.76,
      "duration": 4.279,
      "text": "も私は変わっていないっていうところが"
    },
    {
      "start": 1124.52,
      "duration": 5.399,
      "text": "ありますと。ま、当然ですね、2020年"
    },
    {
      "start": 1127.039,
      "duration": 5.721,
      "text": "先ほど申し上げたこの国感全法の施工と"
    },
    {
      "start": 1129.919,
      "duration": 5.64,
      "text": "いうのを境にですね、政治的にはニュー"
    },
    {
      "start": 1132.76,
      "duration": 5.159,
      "text": "ノーマル、ま、新たな状態に入ったという"
    },
    {
      "start": 1135.559,
      "duration": 4.961,
      "text": "ことはこれは間違いないとこの特にその"
    },
    {
      "start": 1137.919,
      "duration": 4.961,
      "text": "政治とかメディアとかあと教育とかこう"
    },
    {
      "start": 1140.52,
      "duration": 4.0,
      "text": "いった部分はどんどんこの北京と同じ"
    },
    {
      "start": 1142.88,
      "duration": 3.159,
      "text": "スタンダードになっていくんじゃないかな"
    },
    {
      "start": 1144.52,
      "duration": 3.56,
      "text": "という風に思います。ですから私もですね"
    },
    {
      "start": 1146.039,
      "duration": 5.241,
      "text": "、以前も本も出したことありますが、ま、"
    },
    {
      "start": 1148.08,
      "duration": 5.44,
      "text": "北京化する香港政治というところでそこは"
    },
    {
      "start": 1151.28,
      "duration": 5.36,
      "text": "不逆的なんじゃないかなという風に思う"
    },
    {
      "start": 1153.52,
      "duration": 6.159,
      "text": "ものの経済ビジネスという分野においては"
    },
    {
      "start": 1156.64,
      "duration": 7.08,
      "text": "ですね、依前としてこの制度的な優意性を"
    },
    {
      "start": 1159.679,
      "duration": 6.24,
      "text": "残しつつ中国色を強めながらも独自の道を"
    },
    {
      "start": 1163.72,
      "duration": 4.16,
      "text": "む体プレイヤーっていうのが香港なんじゃ"
    },
    {
      "start": 1165.919,
      "duration": 4.841,
      "text": "ないかなという風に私は思っていますし、"
    },
    {
      "start": 1167.88,
      "duration": 4.4,
      "text": "ま、そんな香港をどう見つめてどう生かし"
    },
    {
      "start": 1170.76,
      "duration": 3.52,
      "text": "ていくのか、ま、若干おかましいです"
    },
    {
      "start": 1172.28,
      "duration": 4.24,
      "text": "けれども、どう付き合っていくのかという"
    },
    {
      "start": 1174.28,
      "duration": 5.24,
      "text": "とこもですね、日本としても日本人として"
    },
    {
      "start": 1176.52,
      "duration": 5.12,
      "text": "もこれまで以上に真剣にこの香港との"
    },
    {
      "start": 1179.52,
      "duration": 5.12,
      "text": "付き合い方というところをですね、こう"
    },
    {
      "start": 1181.64,
      "duration": 4.279,
      "text": "自分たちの頭で考えて付き合って行動して"
    },
    {
      "start": 1184.64,
      "duration": 5.48,
      "text": "いくべきなんじゃないかなということを"
    },
    {
      "start": 1185.919,
      "duration": 7.161,
      "text": "ですね、今回の香港再を通じて改めて感じ"
    },
    {
      "start": 1190.12,
      "duration": 5.24,
      "text": "たという次第でございます。はい。今回は"
    },
    {
      "start": 1193.08,
      "duration": 4.32,
      "text": "、ま、香港に赴いてきたということで、ま"
    },
    {
      "start": 1195.36,
      "duration": 4.319,
      "text": "、出張報告ということも兼ねてですね、"
    },
    {
      "start": 1197.4,
      "duration": 5.6,
      "text": "現地での見文だったり実感っていうのを、"
    },
    {
      "start": 1199.679,
      "duration": 4.88,
      "text": "あの、香港の歴史とか経済状況とか制度と"
    },
    {
      "start": 1203.0,
      "duration": 3.799,
      "text": "かですね、そういったところもかなり"
    },
    {
      "start": 1204.559,
      "duration": 3.761,
      "text": "駆け足でしたけれども共有をさせて"
    },
    {
      "start": 1206.799,
      "duration": 4.24,
      "text": "いただきました。またこういう形でですね"
    },
    {
      "start": 1208.32,
      "duration": 4.16,
      "text": "、適々報告をしていきたいかなという風に"
    },
    {
      "start": 1211.039,
      "duration": 4.561,
      "text": "思います。私もいつもですね、やっぱり"
    },
    {
      "start": 1212.48,
      "duration": 5.52,
      "text": "こう真実は現場にしかないと。たら自分に"
    },
    {
      "start": 1215.6,
      "duration": 4.48,
      "text": "とってのその現場がどこにあるのか、ま、"
    },
    {
      "start": 1218.0,
      "duration": 3.76,
      "text": "それを考えることもですね、またすごく"
    },
    {
      "start": 1220.08,
      "duration": 4.079,
      "text": "大事なことだなという風に思いますので、"
    },
    {
      "start": 1221.76,
      "duration": 4.24,
      "text": "ま、私自身、ま、限られたケパシティでは"
    },
    {
      "start": 1224.159,
      "duration": 4.52,
      "text": "ありますけれども、可能な限りですね、"
    },
    {
      "start": 1226.0,
      "duration": 5.28,
      "text": "この自分なりの現場っていうのを追い求め"
    },
    {
      "start": 1228.679,
      "duration": 5.321,
      "text": "て行動していきたいかなという風に改めて"
    },
    {
      "start": 1231.28,
      "duration": 4.6,
      "text": "思っております。はい。楽天証券の投資"
    },
    {
      "start": 1234.0,
      "duration": 5.64,
      "text": "情報メディアトシルがお送りしております"
    },
    {
      "start": 1235.88,
      "duration": 6.24,
      "text": "。仮に私の先ほどの報告、え、少しは、え"
    },
    {
      "start": 1239.64,
      "duration": 4.0,
      "text": "、考えさせられたなと思われた方はですね"
    },
    {
      "start": 1242.12,
      "duration": 3.439,
      "text": "、是非チャンネル登録、そしていいね"
    },
    {
      "start": 1243.64,
      "duration": 3.68,
      "text": "いただけると大変さえでございます。"
    },
    {
      "start": 1245.559,
      "duration": 5.161,
      "text": "まとめにかかります。ご成聴ありがとう"
    },
    {
      "start": 1247.32,
      "duration": 3.4,
      "text": "ございました。"
    }
  ]
}