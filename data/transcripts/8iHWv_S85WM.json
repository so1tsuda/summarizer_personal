    {
      "start": 900.48,
      "duration": 6.32,
      "text": "引っ張った強かったセクター、こちらを見"
    },
    {
      "start": 903.279,
      "duration": 6.68,
      "text": "てみますと、え、32業種値上がりする"
    },
    {
      "start": 906.8,
      "duration": 6.56,
      "text": "展開になっています。その中で、え、"
