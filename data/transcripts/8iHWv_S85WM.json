    {
      "start": 525.56,
      "duration": 8.279,
      "text": "一方、今日、え、突出して動きが悪かった"
    },
    {
      "start": 529.16,
      "duration": 8.72,
      "text": "のはテスラですね。え、こちら5.4%の"
