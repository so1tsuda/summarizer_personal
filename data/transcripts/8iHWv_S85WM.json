    {
      "start": 961.04,
      "duration": 5.479,
      "text": "おりまして、ま、安全資産とされやすい"
    },
    {
      "start": 963.92,
      "duration": 5.279,
      "text": "ディフェンシブ銘柄として医薬品は入って"
    },
    {
      "start": 966.519,
      "duration": 5.521,
      "text": "くるかなと思うんですが、え、ま、リスク"
    },
    {
      "start": 969.199,
      "duration": 4.88,
      "text": "オンの流れというところで、え、セクター"
    },
    {
      "start": 972.04,
      "duration": 4.0,
      "text": "ローテーションが起こったのかなと思い"
