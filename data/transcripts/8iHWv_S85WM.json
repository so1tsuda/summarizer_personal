    {
      "start": 629.12,
      "duration": 6.24,
      "text": "くる可能性の方が高いのかなとは思います"
    },
    {
      "start": 631.48,
      "duration": 6.12,
      "text": "し、え、ま、Xの上場の話がどんどん進ん"
