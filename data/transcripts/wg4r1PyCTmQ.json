      "text": "病気が起こる可能性もなくはないということで飲むのがいいんですっていうのはね、飲んだら腸で吸収されるんですけど吸収される量が決まってるのでいくら"
    },
    {
      "start": 554.92,
      "duration": 3.0,
      "text": "Nたくさん飲んでもある程度しか吸収されない天滴だと直接入っちゃうんでね"
    },
    {
      "start": 560.64,
      "duration": 3.0,
      "text": "ていうようなこともあの今井先生おっしゃっててですね。"
    },
    {
      "start": 564.279,
      "duration": 3.0,
      "text": "そうですね。アンチエイジングのためと思ってもやりすぎは良くなくって"
    },
    {
      "start": 569.16,
      "duration": 3.0,
      "text": "そうですね。バランスって大事ですね。"
    },
    {
      "start": 572.839,
      "duration": 3.081,
      "text": "うん。うん。"
    },
    {
      "start": 573.8,
      "duration": 5.12,
      "text": "え、では続いての新常識お願いします。"
    },
    {
      "start": 575.92,
      "duration": 3.0,
      "text": "はい。オートファジーは生活習慣められる。"
    },
    {
      "start": 581.44,
      "duration": 2.88,
      "text": "おお。"
    },
    {
      "start": 582.839,
      "duration": 2.12,
      "text": "あ、そうなんですか。"
    },
    {
      "start": 584.32,
      "duration": 2.28,
      "text": "はい。"
    },
    {
      "start": 584.959,
      "duration": 4.641,
      "text": "生活習慣で"
    },
    {
      "start": 586.6,
      "duration": 3.0,
      "text": "ね。生活習慣っていうのは"
    },
    {
      "start": 589.92,
      "duration": 2.32,
      "text": "こう食べ物とかそういうことですか?"
    },
    {
      "start": 591.36,
      "duration": 3.88,
      "text": "あ、そうです。そうです。"
    },
    {
      "start": 592.24,
      "duration": 3.0,
      "text": "あの、さっきも言ったようにアーバンチャンもそうですけども、食べ物の中にそういうものがあるでもそれだけではないんですけど、ま、順番に申し上げますけども、アーバンチャ以外にもそのオートファジーを上げる成分を含んでいる食品っていうのが色々見つかっていてですね、納豆などに含まれるスペルミジンっていうものですね。"
    },
    {
      "start": 613.959,
      "duration": 3.0,
      "text": "これはあの大豆とかキノコとかチーズにも入ってるんですけど、納豆に非常にたくさん入ってるので有名なんですけど、あの魚のケとかに含まれるアさチン、それから、ま、有名なの赤ワインに入ってるレスベラトロール、もう普通のお茶屋に入ってる家も聞きます。そんな風にいろんな食品がありますね。はい。"
    },
    {
      "start": 635.36,
      "duration": 3.0,
      "text": "なんか決して珍しいものではなくてはい。"
    },
    {
      "start": 638.76,
      "duration": 3.0,
      "text": "でもやっぱりそのそれぞれに入ってる量っていうのはかなり少ない。"
    },
    {
      "start": 643.32,
      "duration": 3.0,
      "text": "そうですね。例えばね、ワインのレスベラトロールって聞くほど飲もうと思うと多分ある中になるじゃないとあのかなり飲まないといけないんですよ"
    },
    {
      "start": 654.6,
      "duration": 3.0,
      "text": "なので。うん。で、ここでもね、やっぱりだからうん。あんまり大量に同じものばっかりだから納豆がいいからって納豆しか食べないとかね、いうのはあまり良くないので、ま、"
    },
    {
      "start": 668.2,
      "duration": 3.639,
      "text": "うん。うん。"
    },
    {
      "start": 668.839,
      "duration": 3.0,
      "text": "おまけぐらいで考えた方がいいんですかね、この辺は。"
    },
    {
      "start": 672.16,
      "duration": 3.0,
      "text": "こういうものを取ってた方が多分ね。"
    },
    {
      "start": 675.44,
      "duration": 2.28,
      "text": "うん。"
    },
    {
      "start": 675.959,
      "duration": 4.761,
      "text": "うん。いいとは思います。うん。"
    },
    {
      "start": 677.72,
      "duration": 3.0,
      "text": "逆にこのオートファジーを低下させてしまう食べ物ってあったりするんですか?"
    },
    {
      "start": 682.2,
      "duration": 3.0,
      "text": "はい。ありますね。あの甲子脂肪色って言って"
    },
    {
      "start": 687.0,
      "duration": 3.0,
      "text": "あの脂っこいうあのまっこい食事を取り続けると脂肪感っていうあの病気ま肝臓にあるそのさっき言ったルビコンがあの増えちゃうんですね。"
    },
    {
      "start": 700.519,
      "duration": 3.0,
      "text": "脂肪食べる年取ってなくてもオートファジーが下がってであの肝臓の中の脂肪を分解できなくなってホグラみたいな肝臓になっちゃう。"
    },
    {
      "start": 711.839,
      "duration": 3.0,
      "text": "うん。だからっこい食事は避けた方が"
    },
    {
      "start": 715.519,
      "duration": 2.161,
      "text": "まいいですね。"
    },
    {
      "start": 716.839,
      "duration": 1.761,
      "text": "うん。"
    },
    {
      "start": 717.68,
      "duration": 1.8,
      "text": "あげ物ね。"
    },
    {
      "start": 718.6,
      "duration": 3.88,
      "text": "食べちゃうものが"
    },
    {
      "start": 719.48,
      "duration": 3.0,
      "text": "もう絶対食べちゃいけないってことはなくて私もラーメン好きなんで。"
    },
    {
      "start": 724.36,
      "duration": 3.0,
      "text": "ま、たまにこっそり食べますけど。あの"
    },
    {
      "start": 727.44,
      "duration": 1.48,
      "text": "こっそり行ってるんすね。"
    },
    {
      "start": 728.36,
      "duration": 3.56,
      "text": "はい。"
    },
    {
      "start": 728.92,
      "duration": 3.0,
      "text": "あの、でもストレスも音味下げるっていう論文。"
    },
    {
      "start": 733.639,
      "duration": 4.121,
      "text": "あ、へえ。"
    },
    {
      "start": 734.76,
      "duration": 3.0,
      "text": "ま、たまに食べてストレスをなくした方がいいかも"
    },
    {
      "start": 738.04,
      "duration": 2.12,
      "text": "しれないです。"
    },
    {
      "start": 738.68,
      "duration": 3.279,
      "text": "これもまたバランスですよね。"
    },
    {
      "start": 740.16,
      "duration": 4.799,
      "text": "バランスだと思います。"
    },
    {
      "start": 741.959,
      "duration": 3.0,
      "text": "なんか最近オートファジーを活性化させるための断食"
    },
    {
      "start": 747.68,
      "duration": 1.64,
      "text": "はい。はい。"
    },
    {
      "start": 748.04,
      "duration": 1.88,
      "text": "取り入れてる人"
    },
    {
      "start": 749.32,
      "duration": 3.0,
      "text": "聞きます"
    },
    {
      "start": 749.92,
      "duration": 5.4,
      "text": "ね。結構いますよね。"
    },
    {
      "start": 752.32,
      "duration": 3.0,
      "text": "時間ダイエットとかしてる人いるんですけど、あれはどうなんですか?"
    },
    {
      "start": 756.0,
      "duration": 3.0,
      "text": "そうですね。あのね、確かに絶するとオートファジが上がるのは分かってるんですけど、"
    },
    {
      "start": 760.88,
      "duration": 4.12,
      "text": "ただね、16"
    },
    {
      "start": 762.0,
      "duration": 3.0,
      "text": "時間断食しないとオートファジーが起こらないっていう風に思ってる方いらっしゃるんですけど、そんなそれはそんなことなくて、さっき全編で申し上げたようにそのオートファジーって毎日少しずつ起こってますからね。"
    },
    {
      "start": 777.44,
      "duration": 2.72,
      "text": "16"
    },
    {
      "start": 777.8,
      "duration": 3.96,
      "text": "時間断しなきゃダメていうことはない。"
    },
    {
      "start": 780.16,
      "duration": 2.16,
      "text": "いい、いいですし、"
    },
    {
      "start": 781.76,
      "duration": 3.56,
      "text": "16"
    },
    {
      "start": 782.32,
      "duration": 3.0,
      "text": "時間断したら、おがすごく上がるっていうあの証拠もないんですね。で、一方で例えば"
    },
    {
      "start": 788.839,
      "duration": 3.881,
      "text": "80%"
    },
    {
      "start": 789.72,
      "duration": 3.0,
      "text": "カロリー制限で動物実験では、ま、寿命が伸びてその時それがオートファジーによるっていうのは分かってるので、ま、腹"
    },
    {
      "start": 798.36,
      "duration": 1.32,
      "text": "8分目"
    },
    {
      "start": 799.32,
      "duration": 3.36,
      "text": "うん。"
    },
    {
      "start": 799.68,
      "duration": 3.0,
      "text": "でいいんじゃないかなって思いますね。ま、感触はあんまりしない方がいいですし、あと寝る前、え、に食べるのが良くない。"
    },
    {
      "start": 809.88,
      "duration": 5.12,
      "text": "じゃないかなとは思います。"
    },
    {
      "start": 812.0,
      "duration": 5.16,
      "text": "寝てる間にオートファジって上がる"
