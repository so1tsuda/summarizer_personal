    },
    {
      "start": 860.12,
      "duration": 5.159,
      "text": "待たされるかもしれない銘柄をNASダは"
    },
    {
      "start": 862.6,
      "duration": 5.359,
      "text": "先に取り込める可能性があります。ちなみ"
    },
    {
      "start": 865.279,
      "duration": 6.68,
      "text": "にこの3者の想定時価総額を合わせると"
    },
    {
      "start": 867.959,
      "duration": 6.601,
      "text": "3兆を超え約460兆円規模。これが"
    },
    {
      "start": 871.959,
      "duration": 4.88,
      "text": "NASダック客に投資してる人のある意味"
    },
    {
      "start": 874.56,
      "duration": 5.199,
      "text": "特権とも言えますよね。それでは本日の"
    },
    {
      "start": 876.839,
      "duration": 5.841,
      "text": "失明き5つ目に参りましょう。我々の投資"
    },
    {
      "start": 879.759,
      "duration": 6.361,
      "text": "にどう影響するのを理解すべき注意点とは"
    },
    {
      "start": 882.68,
      "duration": 6.0,
      "text": "。では具体的に我々の投資にどう影響する"
    },
    {
      "start": 886.12,
      "duration": 5.2,
      "text": "のか。NISAでNASダ100に投資し"
    },
    {
      "start": 888.68,
      "duration": 4.92,
      "text": "ている方何もしなくてOKです。連動する"
    },
    {
      "start": 891.32,
      "duration": 5.199,
      "text": "ファンドがルール変更後の銘柄入れ替を"
    },
    {
      "start": 893.6,
      "duration": 5.2,
      "text": "自動で反映してくれます。特定講座で"
    },
    {
      "start": 896.519,
      "duration": 5.281,
      "text": "レバナスに投資してる方も基本的には同じ"
    },
    {
      "start": 898.8,
      "duration": 5.2,
      "text": "です。ただしレバレッジ商品は銘柄入れ替"
    },
    {
      "start": 901.8,
      "duration": 4.64,
      "text": "のリバランスコストが若干増える可能性は"
    },
    {
      "start": 904.0,
      "duration": 4.399,
      "text": "あります。特定講座でゴールドと"
    },
    {
      "start": 906.44,
      "duration": 4.24,
      "text": "NASダda100に連動するゴルナスに"
    },
    {
      "start": 908.399,
      "duration": 4.841,
      "text": "投資してる方も自動で組み入れられますの"
    },
    {
      "start": 910.68,
      "duration": 4.64,
      "text": "で何もすることはありません。いずれにし"
    },
    {
      "start": 913.24,
      "duration": 4.8,
      "text": "てもちょっと想像してみてください。"
    },
    {
      "start": 915.32,
      "duration": 5.12,
      "text": "今年スペースXが来年にはOpenンAI"
    },
    {
      "start": 918.04,
      "duration": 5.56,
      "text": "やアンソロピックが入ってくるかもしれ"
    },
    {
      "start": 920.44,
      "duration": 5.079,
      "text": "ない。その全部をあなたは何もしなくても"
    },
    {
      "start": 923.6,
      "duration": 3.88,
      "text": "自動で手に入れていく。これが"
    },
    {
      "start": 925.519,
      "duration": 4.32,
      "text": "インデックス投資の本質であり、今回の"
    },
    {
      "start": 927.48,
      "duration": 5.64,
      "text": "ルール変更でそのスピードがさらに上がっ"
    },
    {
      "start": 929.839,
      "duration": 5.68,
      "text": "たとも言えますよね。過去30年間毎月"
    },
    {
      "start": 933.12,
      "duration": 5.279,
      "text": "3万円の積み立てで約1億7000万円に"
    },
    {
      "start": 935.519,
      "duration": 5.161,
      "text": "なった指数がさらに進化しようとしてる。"
    },
    {
      "start": 938.399,
      "duration": 5.68,
      "text": "自分が持ってる指数って思ってたよりも"
    },
    {
      "start": 940.68,
      "duration": 6.279,
      "text": "すごいかもと思える内容ですよね。最後に"
    },
    {
      "start": 944.079,
      "duration": 5.641,
      "text": "注意点です。まずはSpaceXのIPO"
    },
    {
      "start": 946.959,
      "duration": 5.041,
      "text": "自体がまだ正式に決まったわけでありませ"
    },
    {
      "start": 949.72,
      "duration": 4.72,
      "text": "ん。6月を目指してるという報道はあり"
    },
    {
      "start": 952.0,
      "duration": 4.079,
      "text": "ますが変更の可能性もあります。"
    },
    {
      "start": 954.44,
      "duration": 4.639,
      "text": "バリエーションのリスクもあります。"
    },
    {
      "start": 956.079,
      "duration": 5.041,
      "text": "スペースXの想定時価総素総額は2兆と"
    },
    {
      "start": 959.079,
      "duration": 4.841,
      "text": "報じられておりますけども、売上の100"
    },
    {
      "start": 961.12,
      "duration": 5.8,
      "text": "倍を超える水準、ピッチブックにもマスク"
    },
    {
      "start": 963.92,
      "duration": 6.0,
      "text": "氏特有の株価の触れ幅を許容できる投資家"
    },
    {
      "start": 966.92,
      "duration": 5.719,
      "text": "向けと書かれています。オープンAIや"
    },
    {
      "start": 969.92,
      "duration": 5.839,
      "text": "アンソロピックも年間100億ドル以上の"
    },
    {
      "start": 972.639,
      "duration": 5.88,
      "text": "赤字を抱いながらの上場になります。AI"
    },
    {
      "start": 975.759,
      "duration": 5.52,
      "text": "の成長の本格はこれからですけれども短期"
    },
    {
      "start": 978.519,
      "duration": 5.361,
      "text": "的な下落はありえますよね。ただルール"
    },
    {
      "start": 981.279,
      "duration": 5.441,
      "text": "変更自体は確定をしています。NASDA"
    },
    {
      "start": 983.88,
      "duration": 5.28,
      "text": "公式のメソドロジーとして5月1日に発行"
    },
    {
      "start": 986.72,
      "duration": 4.679,
      "text": "します。そしてNASダック100は過去"
    },
    {
      "start": 989.16,
      "duration": 4.44,
      "text": "もテスレア、マイクロンやパランティアを"
    },
    {
      "start": 991.399,
      "duration": 5.521,
      "text": "取り込んで投資家にリターンをもたらして"
    },
    {
      "start": 993.6,
      "duration": 6.08,
      "text": "きた。今回の流変更はその力をさらに加速"
    },
    {
      "start": 996.92,
      "duration": 5.56,
      "text": "させるものです。このように自分の保有し"
    },
    {
      "start": 999.68,
      "duration": 5.719,
      "text": "てる銘柄の進化を理解することは長期投資"
    },
    {
      "start": 1002.48,
      "duration": 4.919,
      "text": "の投資握力と爆上げしてくれるものです。"
    },
    {
      "start": 1005.399,
      "duration": 3.92,
      "text": "今後も本チャンネルではアップデートをし"
    },
    {
      "start": 1007.399,
      "duration": 4.92,
      "text": "ていきますので、チャンネル登録をしてお"
    },
    {
      "start": 1009.319,
      "duration": 5.601,
      "text": "待ちください。それでは本日のお品き最後"
    },
    {
      "start": 1012.319,
      "duration": 4.88,
      "text": "に参りましょう。まとめです。1つ目、"
    },
    {
      "start": 1014.92,
      "duration": 4.52,
      "text": "NASDA100のルールが5月1日から"
    },
    {
      "start": 1017.199,
      "duration": 5.041,
      "text": "変わります。ファストエントリー制度が"
    },
    {
      "start": 1019.44,
      "duration": 6.599,
      "text": "新設をされて自価総額トップ40に入る"
    },
    {
      "start": 1022.24,
      "duration": 6.4,
      "text": "企業は最短15取引でNASダに採用され"
    },
    {
      "start": 1026.039,
      "duration": 5.92,
      "text": "ます。不動株キャップの安全装置もあり"
    },
    {
      "start": 1028.64,
      "duration": 6.679,
      "text": "ます。2つ目、NASダは過去も入れ替え"
    },
    {
      "start": 1031.959,
      "duration": 6.72,
      "text": "で強くなってきた。黒件なし柔軟な基準で"
    },
    {
      "start": 1035.319,
      "duration": 7.281,
      "text": "毎年約1割を入れ替える。過去18年間で"
    },
    {
      "start": 1038.679,
      "duration": 7.081,
      "text": "S&Pに勝率78%。累積リターンは約"
    },
    {
      "start": 1042.6,
      "duration": 6.36,
      "text": "2.4倍の差。新陳代謝が言動力なんです"
    },
    {
      "start": 1045.76,
      "duration": 6.48,
      "text": "よね。そして3つ目はSpaceXや"
    },
    {
      "start": 1048.96,
      "duration": 5.68,
      "text": "OpenAI、アンソロピックメガIPが"
    },
    {
      "start": 1052.24,
      "duration": 5.48,
      "text": "来る可能性がある。あなたのNASダック"
    },
    {
      "start": 1054.64,
      "duration": 5.919,
      "text": "役がこれらの成長を自動で取り込んでいく"
    },
    {
      "start": 1057.72,
      "duration": 5.24,
      "text": "。NASダック役に通している方にとって"
    },
    {
      "start": 1060.559,
      "duration": 5.041,
      "text": "今回のニュースは自分が選んだ指数は"
    },
    {
      "start": 1062.96,
      "duration": 5.24,
      "text": "ちゃんと進化し続けていると投資悪力を"
    },
    {
      "start": 1065.6,
      "duration": 6.16,
      "text": "高めるのに十分な内容だったかと思います"
    },
    {
      "start": 1068.2,
      "duration": 6.24,
      "text": "。皆さんは夏田役の進化どう思ますか?"
    },
    {
      "start": 1071.76,
      "duration": 4.64,
      "text": "是非コメント欄で教えてください。本日も"
    },
    {
      "start": 1074.44,
      "duration": 4.96,
      "text": "最後までご視聴いただきましてありがとう"
    },
    {
      "start": 1076.4,
      "duration": 5.44,
      "text": "ございました。本日の動画の裏話や動画の"
    },
    {
      "start": 1079.4,
      "duration": 5.0,
      "text": "中でちょっと言いきれない本音をノートの"
    },
    {
      "start": 1081.84,
      "duration": 4.839,
      "text": "メンバーシップで発信を始めております。"
    },
    {
      "start": 1084.4,
      "duration": 4.44,
      "text": "台本を作りながら考えたことやちょっと"
    },
    {
      "start": 1086.679,
      "duration": 5.441,
      "text": "公開動画では言えないことも楽やトーク的"
    },
    {
      "start": 1088.84,
      "duration": 5.199,
      "text": "に有力発信中です。気になる方は概要欄か"
    },
    {
      "start": 1092.12,
      "duration": 4.52,
      "text": "こちらのQRコードを読み込むとノート"
    },
    {
      "start": 1094.039,
      "duration": 5.281,
      "text": "登録できますので是非ご活用ください。"
    },
    {
      "start": 1096.64,
      "duration": 5.08,
      "text": "概要欄にLINEXインスタメルマガの"
    },
    {
      "start": 1099.32,
      "duration": 5.599,
      "text": "URLがあります。私自身が取り組んで"
    },
    {
      "start": 1101.72,
      "duration": 5.8,
      "text": "いる資産形成や製造との工夫は今後"
    },
    {
      "start": 1104.919,
      "duration": 5.24,
      "text": "LINEで配信予定ご興味ある方はご登録"
    },
    {
      "start": 1107.52,
      "duration": 5.44,
      "text": "ください。メルマでは日々の経済ニュース"
    },
    {
      "start": 1110.159,
      "duration": 5.721,
      "text": "を分かりやすく解説しています。インスタ"
    },
    {
      "start": 1112.96,
      "duration": 6.447,
      "text": "やXではより短時間で情報インプットが"
    },
    {
      "start": 1115.88,
      "duration": 5.547,
      "text": "できます。是非ご登録をお願いします。"
    },
    {
      "start": 1119.407,
      "duration": 2.02,
      "text": "[音楽][ベル]"
    }
  ]
}