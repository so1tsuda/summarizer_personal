    {
      "start": 451.4,
      "duration": 6.32,
      "text": "でかい企業だけが使えるVIP入件なん"
    },
    {
      "start": 454.599,
      "duration": 7.04,
      "text": "ですよね。具体的な流れはこうです。上場"
