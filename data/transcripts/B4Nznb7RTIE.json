    {
      "start": 457.72,
      "duration": 6.52,
      "text": "して7取引目に評価をされます。上位40"
    },
    {
      "start": 461.639,
      "duration": 5.801,
      "text": "位以内なら10取引目にアナウンスされ"
    },
    {
      "start": 464.24,
      "duration": 5.679,
      "text": "ます。そして15取引目に正式対応。"
    },
    {
      "start": 467.44,
      "duration": 5.52,
      "text": "こんな流れなんですよね。新ルールの2つ"
    },
    {
      "start": 469.919,
      "duration": 5.96,
      "text": "目不動株キャップです。もう1つ重要な"
