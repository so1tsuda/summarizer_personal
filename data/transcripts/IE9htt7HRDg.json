    {
      "start": 1151.039,
      "duration": 3.401,
      "text": "に先に入れるんじゃなくて頭で考えた上で"
    },
    {
      "start": 1153.76,
      "duration": 1.24,
      "text": "AIを使う。"
    },
    {
      "start": 1154.44,
      "duration": 3.56,
      "text": "そうなんです。"
    },
    {
      "start": 1155.0,
      "duration": 3.0,
      "text": "自分はこの問題についてこういう風に思うっていうことを自分なりに整理してから"
    },
    {
      "start": 1159.44,
      "duration": 3.32,
      "text": "AI"
    },
    {
      "start": 1159.76,
      "duration": 3.0,
      "text": "に入れていくとでそうするとあの違うかったらあれっていう風にこう思ったりとかあの立ち止まることができますよね。で、そういう風なやり方というのが"
    },
    {
      "start": 1169.2,
      "duration": 5.08,
      "text": "1つあり得るのかなというところです。"
    },
    {
      "start": 1171.28,
      "duration": 3.0,
      "text": "なるほど。あの私懸念してのはどっちかてこう企業の文化風みたいなのがま、従業員から"
    },
    {
      "start": 1177.32,
      "duration": 3.239,
      "text": "AI"
    },
    {
      "start": 1177.559,
      "duration": 3.0,
      "text": "でこう壁打ちして色々やってくとですね、本来上司に相談するようなことっていうのが"
    },
    {
      "start": 1181.559,
      "duration": 3.961,
      "text": "はい。AIに相談するような形で最後"
    },
    {
      "start": 1184.0,
      "duration": 4.679,
      "text": "アウトプットが出てくっていう、ま、"
    },
    {
      "start": 1185.52,
      "duration": 4.96,
      "text": "そんな形に、え、働き方時代が変わってき"
    },
    {
      "start": 1188.679,
      "duration": 4.521,
      "text": "てるっていうのはもうこれ実態あるかなと"
    },
    {
      "start": 1190.48,
      "duration": 5.8,
      "text": "いう風に思っていて、ま、そうすると"
    },
    {
      "start": 1193.2,
      "duration": 5.56,
      "text": "いわゆる長く働いてもらうとか、その会社"
    },
    {
      "start": 1196.28,
      "duration": 4.6,
      "text": "のことを理解して色々立ち振る舞うみたい"
    },
    {
      "start": 1198.76,
      "duration": 4.72,
      "text": "なところ、そういうところがどんどん"
    },
    {
      "start": 1200.88,
      "duration": 6.12,
      "text": "どんどんこう知恵として、え、人間にかけ"
    },
    {
      "start": 1203.48,
      "duration": 5.96,
      "text": "てきちゃうことが、ま、起こってるように"
    },
    {
      "start": 1207.0,
      "duration": 4.84,
      "text": "今私個人としてはこう見受けられています"
    },
    {
      "start": 1209.44,
      "duration": 4.32,
      "text": "。なるほど。で、元々こう"
    },
    {
      "start": 1211.84,
      "duration": 4.6,
      "text": "コミュニケーションを人とって、ま、上司"
    },
    {
      "start": 1213.76,
      "duration": 6.039,
      "text": "でもチーム名文取って、そこで何かを達成"
    },
    {
      "start": 1216.44,
      "duration": 5.2,
      "text": "して初めてこう一体感が出て次のステップ"
    },
    {
      "start": 1219.799,
      "duration": 4.921,
      "text": "に進んでいくようなこうウェルビーング"
    },
    {
      "start": 1221.64,
      "duration": 5.72,
      "text": "みたいな体験っていうのをなかなかこう"
    },
    {
      "start": 1224.72,
      "duration": 5.16,
      "text": "AIがあ、少しずつ奪っていっちゃうって"
    },
    {
      "start": 1227.36,
      "duration": 5.0,
      "text": "いうところは少し懸念をしてる部分で、ま"
    },
    {
      "start": 1229.88,
      "duration": 5.2,
      "text": "、そういう働き方になると当然メンタル"
    },
    {
      "start": 1232.36,
      "duration": 5.0,
      "text": "ケアも含めてですね、追加で考えていく"
    },
    {
      "start": 1235.08,
      "duration": 2.88,
      "text": "必要が出てくるかなというところを思って"
    },
    {
      "start": 1237.36,
      "duration": 3.6,
      "text": "ますね。"
    },
    {
      "start": 1237.96,
      "duration": 3.0,
      "text": "こう横の繋がりみたいなところをどういう風に増やしていくのかって大事なのかなと思うんですけど、いかがですか?"
    },
    {
      "start": 1243.28,
      "duration": 4.24,
      "text": "非常に大事ですね。あの、上司部下関係"
    },
    {
      "start": 1245.84,
      "duration": 4.839,
      "text": "ですとさっきのようにやっぱりどう思わ"
    },
    {
      "start": 1247.52,
      "duration": 5.639,
      "text": "れるのかという風な観点が強くあのこう"
    },
    {
      "start": 1250.679,
      "duration": 5.88,
      "text": "効いてきてしまうので、そうではない人間"
    },
    {
      "start": 1253.159,
      "duration": 5.64,
      "text": "関係を社内の中にいかにあの張り巡らせて"
    },
    {
      "start": 1256.559,
      "duration": 5.321,
      "text": "いくことができるのか、つまりいろんな"
    },
    {
      "start": 1258.799,
      "duration": 5.561,
      "text": "相談相手をいろんな場所にあの持っておく"
    },
    {
      "start": 1261.88,
      "duration": 5.44,
      "text": "ことができるのかということが重要になり"
    },
    {
      "start": 1264.36,
      "duration": 5.36,
      "text": "ますし、組織としてもそれをなんか従業員"
    },
    {
      "start": 1267.32,
      "duration": 4.76,
      "text": "だけに任せておくわけではなくて、例えば"
    },
    {
      "start": 1269.72,
      "duration": 4.28,
      "text": "いろんな人と関係性が作れるような機会を"
    },
    {
      "start": 1272.08,
      "duration": 4.52,
      "text": "作ったりとかそういった支援が"
    },
    {
      "start": 1274.0,
      "duration": 4.039,
      "text": "必要になってくるんじゃないのかなと考えてます。"
    },
    {
      "start": 1276.6,
      "duration": 3.52,
      "text": "これあえて聞きたいんですけど、じゃあ"
    },
    {
      "start": 1278.039,
      "duration": 4.721,
      "text": "それどうやって強くするのか、これ制度と"
    },
    {
      "start": 1280.12,
      "duration": 4.919,
      "text": "かで整えていくっていうイメージでいいん"
    },
    {
      "start": 1282.76,
      "duration": 5.64,
      "text": "ですか?え、これいろんな考え方あると"
    },
    {
      "start": 1285.039,
      "duration": 6.0,
      "text": "思うんですが、先ほどあのAIに任せる"
    },
    {
      "start": 1288.4,
      "duration": 5.68,
      "text": "領域か、それともAIと一緒にやる領域か"
    },
    {
      "start": 1291.039,
      "duration": 4.921,
      "text": "、それから人間だけが人間が取り組む領域"
    },
    {
      "start": 1294.08,
      "duration": 4.079,
      "text": "かというのを分けていくことが重要ですと"
    },
    {
      "start": 1295.96,
      "duration": 5.719,
      "text": "いうお話をさせていただいたんですが、実"
    },
    {
      "start": 1298.159,
      "duration": 5.801,
      "text": "はその人間だけが行う領域において、あの"
    },
    {
      "start": 1301.679,
      "duration": 3.721,
      "text": "、その行い方が重要っていう風にも言われ"
    },
    {
      "start": 1303.96,
      "duration": 4.44,
      "text": "ていて、はい。"
    },
    {
      "start": 1305.4,
      "duration": 3.0,
      "text": "つまり、えっと、個人で独力で仕事を進めるのではなくて、チームで集団で話し合いながら仕事を進めていくのが人間に残された領域においてパフォーマンスが高く発揮できる方法なんだという風なあのことが指摘されているんですよね。"
    },
    {
      "start": 1321.52,
      "duration": 3.0,
      "text": "そうすると先ほいた質問にしての答えというのはんな人と仕事を共にできるようなあの機会というのを会社側が提供していく"
    },
    {
      "start": 1332.48,
      "duration": 3.0,
      "text": "固定化された人間関係だけではなくていいんな人と働けるような機会というのを提供していくということが"
    },
    {
      "start": 1339.4,
      "duration": 2.48,
      "text": "1"
    },
    {
      "start": 1339.559,
      "duration": 5.321,
      "text": "つ私作にはなってくるのかなと思います。"
    },
    {
      "start": 1341.88,
      "duration": 3.0,
      "text": "ああ、分かりました。ま、改めて、え、小木さんたちがやられている、ま、その事業の展望と含めてどういうところを目指してるのかということをお願いします。"
    },
    {
      "start": 1349.96,
      "duration": 5.839,
      "text": "はい。あの、我々はこう、AIとか新しい"
    },
    {
      "start": 1353.0,
      "duration": 5.76,
      "text": "技術が入ってきた時にこう働き方が変わっ"
    },
    {
      "start": 1355.799,
      "duration": 5.521,
      "text": "てそこにおける組織設計と付随して"
    },
    {
      "start": 1358.76,
      "duration": 4.399,
      "text": "いわゆるケアのいろんなケアの方法が"
    },
    {
      "start": 1361.32,
      "duration": 3.64,
      "text": "変わっていく中で、ま、今回はメンタル"
    },
    {
      "start": 1363.159,
      "duration": 4.681,
      "text": "ですけども、そういったものをですね、"
    },
    {
      "start": 1364.96,
      "duration": 4.92,
      "text": "しっかりと従業員様の方の状態をキャッチ"
    },
    {
      "start": 1367.84,
      "duration": 4.76,
      "text": "して、え、データをもにしっかりとケアし"
    },
    {
      "start": 1369.88,
      "duration": 5.2,
      "text": "ていくということが、ま、我々の役名で"
    },
    {
      "start": 1372.6,
      "duration": 4.76,
      "text": "あり、かつ生産性高くですね、健康で働き"
    },
    {
      "start": 1375.08,
      "duration": 4.44,
      "text": "続けていただけるような状態を我々の"
    },
    {
      "start": 1377.36,
      "duration": 2.439,
      "text": "サービスで作っていくっていうことを提供"
    },
    {
      "start": 1379.52,
      "duration": 3.279,
      "text": "して"
    },
    {
      "start": 1379.799,
      "duration": 3.0,
      "text": "っていうのが、あ、今後の我々の展開という形になっています。"
    },
    {
      "start": 1383.48,
      "duration": 4.079,
      "text": "うん。なるほど。"
    },
    {
      "start": 1384.559,
      "duration": 3.0,
      "text": "あの、あくまでもですね、やっぱりこう従業員の方、あ、やっぱなかなかこう偏見の目とかですね、相談しづらいみたいなところは絶対にどこまで行っても出てくると思ってます。"
    },
    {
      "start": 1395.24,
      "duration": 3.439,
      "text": "うん。"
    },
    {
      "start": 1395.679,
      "duration": 3.0,
      "text": "なので、え、きっちりとそこら辺の匿名性を担保してですね、かつそういったサービスを最後こう運用にどうやって載せてくかで、いわゆる窓口を用意しました。"
    },
    {
      "start": 1404.88,
      "duration": 3.0,
      "text": "使ってくださいっていうのをメールとかイントラで、え、やっぱお伝えしたものなかなか当然限界があると、あのなので、え、"
    },
    {
      "start": 1411.76,
      "duration": 3.32,
      "text": "LINE"
    },
    {
      "start": 1412.08,
      "duration": 3.0,
      "text": "ケアの中にですね、え、マネージャーにいわゆる持たせる武器としてこういったサドパーティーの商品っていうのをきちんと持たせて、"
    },
    {
      "start": 1418.679,
      "duration": 3.0,
      "text": "で、え、何かあったらもういわゆるこう負の部分はもう"
    },
    {
      "start": 1422.36,
      "duration": 3.0,
      "text": "そういうものを使って、え、解消しなさいと。で、もうマネージャープラスの部分ですね。"
    },
    {
      "start": 1427.08,
      "duration": 3.52,
      "text": "いわゆる従業"
    },
    {
      "start": 1427.6,
      "duration": 3.0,
      "text": "員の能力を持ち上げていくっていうところに、え、人事の方々と共にこう集中していくみたいな形の運用設計までできると悪いってそのサードパーティーを使い倒すってのがしっかりとできて効果も出てくるのかなと。"
    },
    {
      "start": 1440.919,
      "duration": 3.561,
      "text": "やっぱり1"
    },
    {
      "start": 1441.48,
      "duration": 3.0,
      "text": "番最初に現れてくるのはそうじゃない会社には人が集まらないということですよね。みんな行きたくないですよね。"
    },
    {
      "start": 1449.039,
      "duration": 2.361,
      "text": "なるほど。行きたくないです。"
    },
    {
      "start": 1450.279,
      "duration": 4.121,
      "text": "行きたくないですよね。"
    },
    {
      "start": 1451.4,
      "duration": 3.0,
      "text": "しかもあの売手市場が続いてますしかつ人手不足がこう続いていっているという中であの人員を確保できなくなってくる、"
    },
    {
      "start": 1460.84,
      "duration": 3.0,
      "text": "え、ましては事者にあった人材をきちんと確保できなくなってくるということになるとこれはあの組織運営上非常に苦しいあの状況にあのなってくることは間違いありませんのであのその意味で組織目線で見ても持続可能性という風なあの観点からやはりメンタルヘルスに関する対策え"
    },
    {
      "start": 1480.88,
      "duration": 3.0,
      "text": "AI、外部、そして車内の人材という理想をこうまく使っていきながらきちんとあの張り巡らせていくという風なことが重要ではないかなと思います。"
    },
    {
      "start": 1491.279,
      "duration": 3.0,
      "text": "なるほど。色々とこうサービス変えてく中でヘルプというのはこの先どういう進化を考えてるんですか?"
    },
    {
      "start": 1496.76,
      "duration": 3.0,
      "text": "あの、まだまだこれから色々発展をさせていくんですけども、メンタルという側面で言うと、ある一定例えばですけど補数が極端にある一定から下がってきてるっていうこの時系列"
    },
    {
      "start": 1508.08,
      "duration": 2.319,
      "text": "1"
    },
    {
      "start": 1508.24,
      "duration": 5.159,
      "text": "日の歩く距離ということですか?はい。はい。はい。"
    },
    {
      "start": 1510.399,
      "duration": 3.0,
      "text": "を見ることによっていわゆるメンタル的にちょっとまずいんじゃないかっていうのを事前に予測とかあ地みたいなところを我々としては強めていきながらフォローできればな"
    },
    {
      "start": 1522.399,
      "duration": 3.0,
      "text": "確かにこう外に出て日の光を浴びるとかなんか単純なことですけど人と話すみたいなところが多分減ってるんだろうなっていうのも想像つきますもんね。なるほど。そうですか。わかりました。ありがとうございます。あのま、何より第"
    },
    {
      "start": 1533.559,
      "duration": 2.681,
      "text": "3の居場所ができることで救われる方が"
    },
    {
      "start": 1536.08,
      "duration": 3.079,
      "text": "1"
    },
    {
      "start": 1536.24,
      "duration": 5.919,
      "text": "人でも多くね、増えればいいなという風に私は思いました。"
    },
    {
      "start": 1539.159,
      "duration": 3.0,
      "text": "え、ご成長していただいた皆さん、そしてビジネスリサーチラボの伊達伊達さん、ヘルスケアテクノロジーズの河野之さんにお話をお伺いしました。お二方ありがとうございました。"
    },
    {
      "start": 1548.52,
      "duration": 4.0,
      "text": "ありがとうございました。おお"
    },
    {
      "start": 1571.279,
      "duration": 2.041,
      "text": "。"
    }
  ]
}