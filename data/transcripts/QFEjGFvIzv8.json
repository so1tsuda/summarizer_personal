      "start": 352.479,
      "duration": 4.681,
      "text": "ですね、どちらの方が覚えてるかと言わ"
    },
    {
      "start": 354.479,
      "duration": 5.44,
      "text": "れると紙の本のが内容を覚えてる感覚が"
    },
    {
      "start": 357.16,
      "duration": 5.319,
      "text": "強いんで私は感覚的に紙を優先して読んで"
    },
    {
      "start": 359.919,
      "duration": 4.4,
      "text": "いましたがやっぱり農格的にも証明されて"
    },
    {
      "start": 362.479,
      "duration": 4.641,
      "text": "いたんですよね。是非ね、あなたもまずは"
    },
    {
      "start": 364.319,
      "duration": 5.761,
      "text": "この本ポチってみてください。2つ目。"
    },
    {
      "start": 367.12,
      "duration": 5.68,
      "text": "読書がもたらす農科学的メリットという話"
    },
    {
      "start": 370.08,
      "duration": 4.88,
      "text": "。実は読書ってただ知識が増えるだけじゃ"
    },
    {
      "start": 372.8,
      "duration": 4.04,
      "text": "ないんです。これ農科学的に見るとやば"
    },
    {
      "start": 374.96,
      "duration": 5.359,
      "text": "すぎる3つのメリットがありまして、それ"
    },
    {
      "start": 376.84,
      "duration": 6.04,
      "text": "が究極の急速、最強のノトレ、一生物の"
    },
    {
      "start": 380.319,
      "duration": 4.761,
      "text": "資産。順番にお伝えしますので鼻の穴を"
    },
    {
      "start": 382.88,
      "duration": 4.2,
      "text": "かっぽじって耳を餃子にして聞いていって"
    },
    {
      "start": 385.08,
      "duration": 4.6,
      "text": "くださいね。読書のメリット。まず1つ目"
    },
    {
      "start": 387.08,
      "duration": 4.959,
      "text": "が究極の休速。これあなたも経験あると"
    },
    {
      "start": 389.68,
      "duration": 5.239,
      "text": "思うんですが、過去の後悔とか未来の不安"
    },
    {
      "start": 392.039,
      "duration": 5.121,
      "text": "を頭でぐるぐる考えちゃう。これ半数思考"
    },
    {
      "start": 394.919,
      "duration": 4.921,
      "text": "と言うんですが、実はこれ脳のデフォルト"
    },
    {
      "start": 397.16,
      "duration": 4.52,
      "text": "モードネットワっていう回路が働きすぎて"
    },
    {
      "start": 399.84,
      "duration": 4.96,
      "text": "疲弊してしまっている状態なんですよ。で"
    },
    {
      "start": 401.68,
      "duration": 5.12,
      "text": "も本の世界にグっと集中すると脳は運転"
    },
    {
      "start": 404.8,
      "duration": 4.119,
      "text": "モードを切り替えてくれてこのデフォルト"
    },
    {
      "start": 406.8,
      "duration": 4.08,
      "text": "モードネットワークの暴走をピタッと止め"
    },
    {
      "start": 408.919,
      "duration": 4.601,
      "text": "てくれるんです。実際にイギリスの"
    },
    {
      "start": 410.88,
      "duration": 4.999,
      "text": "サセックス大学の研究で別に卑猥な大学"
    },
    {
      "start": 413.52,
      "duration": 5.16,
      "text": "じゃないですからね。その大学でわずか6"
    },
    {
      "start": 415.879,
      "duration": 5.641,
      "text": "分間本を読むだけでストレスレベルが最大"
    },
    {
      "start": 418.68,
      "duration": 4.84,
      "text": "68%も下がったっていうとんでもない"
    },
    {
      "start": 421.52,
      "duration": 4.2,
      "text": "データもあるくらいなんです。これ音楽を"
    },
    {
      "start": 423.52,
      "duration": 3.959,
      "text": "聞いたり散歩したりするよりも高い"
    },
    {
      "start": 425.72,
      "duration": 4.44,
      "text": "リラックス効果になってるんです。だから"
    },
    {
      "start": 427.479,
      "duration": 5.481,
      "text": "ですね、ああ、疲れたから本読めないよ"
    },
    {
      "start": 430.16,
      "duration": 5.68,
      "text": "じゃなくて本当は疲れているからこそ本を"
    },
    {
      "start": 432.96,
      "duration": 5.48,
      "text": "読んで脳を休ませるのが大正解なんです。"
    },
    {
      "start": 435.84,
      "duration": 5.0,
      "text": "読書のメリット2つ目が最強のノトレ。"
    },
    {
      "start": 438.44,
      "duration": 4.96,
      "text": "読書ってただ知識が増えるだけじゃなくて"
    },
    {
      "start": 440.84,
      "duration": 5.479,
      "text": "根本的に頭を良くしてくれるんです。本を"
    },
    {
      "start": 443.4,
      "duration": 5.919,
      "text": "読んでる時脳の中では文字を見る視野、"
    },
    {
      "start": 446.319,
      "duration": 5.481,
      "text": "意味を理解する言語や想像する前頭前夜"
    },
    {
      "start": 449.319,
      "duration": 5.241,
      "text": "などいろんな部分が同時に振る稼働してい"
    },
    {
      "start": 451.8,
      "duration": 4.92,
      "text": "て神経細胞同士の繋がりがどんどん強く"
    },
    {
      "start": 454.56,
      "duration": 4.72,
      "text": "なって思考力が上がっていくんです。"
    },
    {
      "start": 456.72,
      "duration": 4.68,
      "text": "しかもですよ。実は我々日本人って日本語"
    },
    {
      "start": 459.28,
      "duration": 3.72,
      "text": "が読めるってだけで世界的に見て"
    },
    {
      "start": 461.4,
      "duration": 3.84,
      "text": "めちゃくちゃ得してるって知ってましたか"
    },
    {
      "start": 463.0,
      "duration": 4.0,
      "text": "?というのも漢じって書けなくても不思議"
    },
    {
      "start": 465.24,
      "duration": 4.28,
      "text": "と読むことは普通にできちゃいますよね。"
    },
    {
      "start": 467.0,
      "duration": 5.36,
      "text": "これなんでかと言うと漢字は目で見て直接"
    },
    {
      "start": 469.52,
      "duration": 5.239,
      "text": "意味を理解する表異文字だから脳が形を"
    },
    {
      "start": 472.36,
      "duration": 4.88,
      "text": "パッと捉えるだけで音に変換する手間を"
    },
    {
      "start": 474.759,
      "duration": 4.84,
      "text": "すっ飛ばして意味にアクセスできる特別な"
    },
    {
      "start": 477.24,
      "duration": 4.959,
      "text": "ルートを使ってるんです。一方でひがや"
    },
    {
      "start": 479.599,
      "duration": 5.0,
      "text": "カタカナは文字を一度音に変換してから"
    },
    {
      "start": 482.199,
      "duration": 5.521,
      "text": "意味を理解する表音文字、つまり日本語"
    },
    {
      "start": 484.599,
      "duration": 6.401,
      "text": "ってこの意味を直接捉える感じと音に変換"
    },
    {
      "start": 487.72,
      "duration": 5.72,
      "text": "するひがという脳の全く違う回路を同時に"
    },
    {
      "start": 491.0,
      "duration": 4.68,
      "text": "スパッと切り替えながら処理する二刀流の"
    },
    {
      "start": 493.44,
      "duration": 3.92,
      "text": "言語なんですよ。だからね、よく海外の人"
    },
    {
      "start": 495.68,
      "duration": 3.76,
      "text": "が日本語って難しいって言いますけど、"
    },
    {
      "start": 497.36,
      "duration": 3.92,
      "text": "その通りなんですよね。他の方はこれやっ"
    },
    {
      "start": 499.44,
      "duration": 4.52,
      "text": "てないんですもん。もうね、脳学的に見る"
    },
    {
      "start": 501.28,
      "duration": 4.479,
      "text": "とこれまるで右投げと左投げを事在に"
    },
    {
      "start": 503.96,
      "duration": 3.44,
      "text": "使い分けるピッチャーくらいに"
    },
    {
      "start": 505.759,
      "duration": 3.641,
      "text": "めちゃくちゃ高度な処理をしているそう"
    },
    {
      "start": 507.4,
      "duration": 4.359,
      "text": "です。さあ、何が言いたいかと言うと、"
    },
    {
      "start": 509.4,
      "duration": 5.199,
      "text": "日本語の本を読むだけで普通に文字を読む"
    },
    {
      "start": 511.759,
      "duration": 5.441,
      "text": "よりも勝手に脳の広い範囲がフル稼働して"
    },
    {
      "start": 514.599,
      "duration": 5.281,
      "text": "、他の言語を話す人よりもはるかに効率"
    },
    {
      "start": 517.2,
      "duration": 4.92,
      "text": "よくがっつり脳が鍛えられるということな"
    },
    {
      "start": 519.88,
      "duration": 4.519,
      "text": "んですよ。せっかくこんなハイスペックな"
    },
    {
      "start": 522.12,
      "duration": 4.24,
      "text": "脳の使い方ができるのに本を読まない"
    },
    {
      "start": 524.399,
      "duration": 4.041,
      "text": "なんてマジでもったいないです。どれ"
    },
    {
      "start": 526.36,
      "duration": 4.84,
      "text": "くらいもったいないかと言うと、冷蔵庫の"
    },
    {
      "start": 528.44,
      "duration": 4.56,
      "text": "奥に忘れていた賞味期限が切れた高級"
    },
    {
      "start": 531.2,
      "duration": 5.0,
      "text": "プリンぐらいもったいないです。そして"
    },
    {
      "start": 533.0,
      "duration": 5.36,
      "text": "読書のメリットが一生物の資産になる。"
    },
    {
      "start": 536.2,
      "duration": 4.4,
      "text": "アメリカにシスターメアリっていう女性が"
    },
    {
      "start": 538.36,
      "duration": 4.52,
      "text": "いたんですが、この方すごいのが101歳"
    },
    {
      "start": 540.6,
      "duration": 5.239,
      "text": "で亡くなるまで周りがビビるくらい図頭脳"
    },
    {
      "start": 542.88,
      "duration": 5.48,
      "text": "の面積で記憶も抜群だったんですね。でも"
    },
    {
      "start": 545.839,
      "duration": 5.56,
      "text": "亡くなった後に彼女の脳を調べてみたら"
    },
    {
      "start": 548.36,
      "duration": 5.039,
      "text": "衝撃なんとアルツハイマー病特有の深刻な"
    },
    {
      "start": 551.399,
      "duration": 4.12,
      "text": "ダメージが脳にびっしりあったんです。"
    },
    {
      "start": 553.399,
      "duration": 4.56,
      "text": "普通なら重度の認知症になっていても"
    },
    {
      "start": 555.519,
      "duration": 5.601,
      "text": "おかしくない状態なのになんで元気だった"
    },
    {
      "start": 557.959,
      "duration": 5.56,
      "text": "のか。実は彼女若い頃から読書と作分が"
    },
    {
      "start": 561.12,
      "duration": 4.52,
      "text": "大好きでずっと知的な活動を続けていたん"
    },
    {
      "start": 563.519,
      "duration": 4.721,
      "text": "ですよ。そのおかげで脳にダメージを受け"
    },
    {
      "start": 565.64,
      "duration": 5.199,
      "text": "てもそれをカバーできるくらい認知予備力"
    },
    {
      "start": 568.24,
      "duration": 4.839,
      "text": "っていう強力なネットワークが脳内に貯金"
    },
    {
      "start": 570.839,
      "duration": 4.401,
      "text": "されていて、認知症の発症を防いでいった"
    },
    {
      "start": 573.079,
      "duration": 4.32,
      "text": "と言われているんです。読書するだけで"
    },
    {
      "start": 575.24,
      "duration": 4.52,
      "text": "日々のストレスを消し去ってくれて一生"
    },
    {
      "start": 577.399,
      "duration": 5.641,
      "text": "使える最強のを作ってくれるなんてもう"
    },
    {
      "start": 579.76,
      "duration": 6.16,
      "text": "読まない理由がないですよね。最後3つ目"
    },
    {
      "start": 583.04,
      "duration": 5.0,
      "text": "。読書習慣を身につける実践法という話"
    },
    {
      "start": 585.92,
      "duration": 4.159,
      "text": "です。紙の本を読んだ方がいいことはもう"
    },
    {
      "start": 588.04,
      "duration": 4.68,
      "text": "分かった。耳にタコができとる。じゃあ"
    },
    {
      "start": 590.079,
      "duration": 4.88,
      "text": "具体的にどうやって読めば頭が良くなるの"
    },
    {
      "start": 592.72,
      "duration": 4.679,
      "text": "?そもそも忙しくて続かない。買ったけど"
    },
    {
      "start": 594.959,
      "duration": 4.761,
      "text": "読んでない本が積み上がっていてこのツ読"
    },
    {
      "start": 597.399,
      "duration": 5.161,
      "text": "したらええねんって人いますよね。大丈夫"
    },
    {
      "start": 599.72,
      "duration": 6.2,
      "text": "です。明日からすぐに実践できる脳科学的"
    },
    {
      "start": 602.56,
      "duration": 5.88,
      "text": "に正しい読書のコツを読む前読書中読んだ"
    },
    {
      "start": 605.92,
      "duration": 4.32,
      "text": "後の3リステップでバカ分かりやすくお"
    },
    {
      "start": 608.44,
      "duration": 4.2,
      "text": "伝えしていきます。これを知ってるだけで"
    },
    {
      "start": 610.24,
      "duration": 5.32,
      "text": "読書のコスパが劇的に変わりますからお"
    },
    {
      "start": 612.64,
      "duration": 5.24,
      "text": "楽しみに。ステップ1読む前の準備と脳の"
    },
    {
      "start": 615.56,
      "duration": 5.08,
      "text": "セットアップ。読書を習慣にするには"
    },
    {
      "start": 617.88,
      "duration": 5.88,
      "text": "気合いを入れて毎日1時間読むぞと高い"
    },
    {
      "start": 620.64,
      "duration": 6.72,
      "text": "目標を立てるのは絶対にNG。コツは寝る"
    },
    {
      "start": 623.76,
      "duration": 6.079,
      "text": "前に1ページだけとか通勤電車で3分だけ"
    },
    {
      "start": 627.36,
      "duration": 5.159,
      "text": "と超小さい目標にしてください。これを"
    },
    {
      "start": 629.839,
      "duration": 5.041,
      "text": "クリアするだけで脳にドーパミンが出て書"
    },
    {
      "start": 632.519,
      "duration": 4.601,
      "text": "って楽しいと勝手に学習してくれるんです"
    },
    {
      "start": 634.88,
      "duration": 5.16,
      "text": "よ。もちろん気が散らないようにスマホは"
    },
    {
      "start": 637.12,
      "duration": 5.279,
      "text": "別の部屋に隠すのが鉄速。そして本を開く"
    },
    {
      "start": 640.04,
      "duration": 4.56,
      "text": "前に必ずやって欲しいことがあってそれは"
    },
    {
      "start": 642.399,
      "duration": 4.761,
      "text": "クエスチョンを立てること。自分はこの本"
    },
    {
      "start": 644.6,
      "duration": 6.239,
      "text": "から何を学びたいのかと問を設定するだけ"
    },
    {
      "start": 647.16,
      "duration": 6.04,
      "text": "で脳の前頭前が活性化し脳内に答えを探す"
    },
    {
      "start": 650.839,
      "duration": 4.56,
      "text": "レーダーが貼られます。すると必要な情報"
    },
    {
      "start": 653.2,
      "duration": 4.52,
      "text": "が自然と目に飛び込んでくるようになり"
    },
    {
      "start": 655.399,
      "duration": 5.88,
      "text": "読書効率が上がっていくんです。ステップ"
    },
    {
      "start": 657.72,
      "duration": 5.919,
      "text": "2読書中の3つの読書法。ただ漠然と文字"
    },
    {
      "start": 661.279,
      "duration": 4.601,
      "text": "を追うのはもったいない。目的に合わせて"
    },
    {
      "start": 663.639,
      "duration": 5.081,
      "text": "脳の使う領域を切り替えるのがポイント"
    },
    {
      "start": 665.88,
      "duration": 4.759,
      "text": "です。1つ目が解読。全部の文字を読むん"
    },
    {
      "start": 668.72,
      "duration": 4.76,
      "text": "じゃなくて目次やみ出しだけをスキャンし"
    },
    {
      "start": 670.639,
      "duration": 5.76,
      "text": "て全体像を掴む方法です。脳のワーキング"
    },
    {
      "start": 673.48,
      "duration": 4.919,
      "text": "メモリーを節約しながら短い時間で効率"
    },
    {
      "start": 676.399,
      "duration": 4.721,
      "text": "よく情報を処理することができます。"
    },
    {
      "start": 678.399,
      "duration": 5.0,
      "text": "ちなみに私は本の解説をする時、まず目次"
    },
    {
      "start": 681.12,
      "duration": 4.839,
      "text": "を見てここら辺がいいなと目星をつけて"
    },
    {
      "start": 683.399,
      "duration": 5.321,
      "text": "読むようにしています。2つ目が性。"
    },
    {
      "start": 685.959,
      "duration": 4.761,
      "text": "じっくり時間をかけて業を読む方法。これ"
    },
    {
      "start": 688.72,
      "duration": 5.32,
      "text": "をやってみるとですね、言語だけじゃなく"
    },
    {
      "start": 690.72,
      "duration": 6.359,
      "text": "て水論を司さどる前頭前夜までがフル回転"
    },
    {
      "start": 694.04,
      "duration": 5.76,
      "text": "し、知識が脳の奥深くに刻み込まれるん"
    },
    {
      "start": 697.079,
      "duration": 5.401,
      "text": "ですよ。そして3つ目、著者が最強の記憶"
    },
    {
      "start": 699.8,
      "duration": 4.96,
      "text": "術として激押ししているのがなんと音読"
    },
    {
      "start": 702.48,
      "duration": 4.72,
      "text": "です。いや、小学生じゃないんだからって"
    },
    {
      "start": 704.76,
      "duration": 4.8,
      "text": "思うかもしれませんが、侮る中、恋に出し"
    },
    {
      "start": 707.2,
      "duration": 5.439,
      "text": "て読むとすごい効果あるんですよ。まずは"
    },
    {
      "start": 709.56,
      "duration": 6.12,
      "text": "目で見る資格、口を動かす運動感覚、自分"
    },
    {
      "start": 712.639,
      "duration": 5.64,
      "text": "の声を聞く聴覚という3つの感覚が同時に"
    },
    {
      "start": 715.68,
      "duration": 6.04,
      "text": "振る稼働しますよね。すると脳の後輩が"
    },
    {
      "start": 718.279,
      "duration": 5.56,
      "text": "爆発的に活性化して記憶への定着率が半端"
    },
    {
      "start": 721.72,
      "duration": 5.32,
      "text": "じゃないんです。あともう1つ読書中の"
    },
    {
      "start": 723.839,
      "duration": 5.081,
      "text": "裏技。心の中でなるほど面白いと自分に"
    },
    {
      "start": 727.04,
      "duration": 3.52,
      "text": "ポジティブな言葉を投げかけてみて"
    },
    {
      "start": 728.92,
      "duration": 3.88,
      "text": "ください。これをセルフトークと呼ぶん"
    },
    {
      "start": 730.56,
      "duration": 4.32,
      "text": "ですが、これだけで脳にドーパミンが出て"
    },
    {
      "start": 732.8,
      "duration": 4.36,
      "text": "理解力もモチベーションも上がっていくん"
    },
    {
      "start": 734.88,
      "duration": 4.36,
      "text": "ですよ。逆につまらないと思うとストレス"
    },
    {
      "start": 737.16,
      "duration": 4.4,
      "text": "ホルモンが出て脳がフリーズしちゃうので"
    },
    {
      "start": 739.24,
      "duration": 4.719,
      "text": "要注意。そしてステップ3読んだ後の"
    },
    {
      "start": 741.56,
      "duration": 4.8,
      "text": "アウトプット。実は読みっぱなしが1番"
    },
    {
      "start": 743.959,
      "duration": 5.201,
      "text": "記憶に残りません。読んだ内容や感想を"
    },
    {
      "start": 746.36,
      "duration": 4.56,
      "text": "メモに書いたりSNSや読書メーターなど"
    },
    {
      "start": 749.16,
      "duration": 4.4,
      "text": "アプリに書き出してみてください。これを"
    },
    {
      "start": 750.92,
      "duration": 5.359,
      "text": "ノー科学では早期練習と呼ぶんですが、"
    },
    {
      "start": 753.56,
      "duration": 5.44,
      "text": "自分の言葉で必死に思い出そうとする行為"
    },
    {
      "start": 756.279,
      "duration": 5.401,
      "text": "そのものがただの短期記憶を一生使える"
    },
    {
      "start": 759.0,
      "duration": 5.24,
      "text": "生きた知識へ進化させる唯一の方法なん"
    },
    {
      "start": 761.68,
      "duration": 4.719,
      "text": "です。スマホを遠ざけて問いを立てて目的"
    },
    {
      "start": 764.24,
      "duration": 4.279,
      "text": "に合わせて読み方を変え最後は"
    },
    {
      "start": 766.399,
      "duration": 4.841,
      "text": "アウトプットする。たったこれだけでただ"
    },
    {
      "start": 768.519,
      "duration": 5.041,
      "text": "文字を追うだけの読書から脳を最大限に"
    },
    {
      "start": 771.24,
      "duration": 5.08,
      "text": "活用する読書へと一気に変わるんです。"
    },
    {
      "start": 773.56,
      "duration": 5.079,
      "text": "正直私も7年間読んだ本をYouTube"
    },
    {
      "start": 776.32,
      "duration": 4.24,
      "text": "で解説してきましたから本当にね他の人"
    },
    {
      "start": 778.639,
      "duration": 4.56,
      "text": "よりアウトプット続けてるんですよ。でも"
    },
    {
      "start": 780.56,
      "duration": 4.639,
      "text": "そのおかげで本の内容の記憶力マジで"
    },
    {
      "start": 783.199,
      "duration": 3.921,
      "text": "上がったと思います。アウトプットはね、"
    },
    {
      "start": 785.199,
      "duration": 4.681,
      "text": "絶対にやった方がいい。今日から是非騙さ"
    },
    {
      "start": 787.12,
      "duration": 5.36,
      "text": "れたと思って紙の本の1ページから始めて"
    },
    {
      "start": 789.88,
      "duration": 5.519,
      "text": "みてください。いやあ、今回の話ですよね"
    },
    {
      "start": 792.48,
      "duration": 6.0,
      "text": "。この本には他にも記憶の定着率がバグる"
    },
    {
      "start": 795.399,
      "duration": 5.961,
      "text": "読書メーターなどのアプリ活用術や絶対に"
    },
    {
      "start": 798.48,
      "duration": 4.96,
      "text": "外れを引かない脳価科学的な本の選び方。"
    },
    {
      "start": 801.36,
      "duration": 4.32,
      "text": "あとみんなが読んでるベストセラーは"
    },
    {
      "start": 803.44,
      "duration": 4.8,
      "text": "あえて読むなというちょっと意外な読書の"
    },
    {
      "start": 805.68,
      "duration": 4.64,
      "text": "裏技など明日から読書に使えるやばい"
    },
    {
      "start": 808.24,
      "duration": 4.2,
      "text": "ノーフがまだまだたくさん書かれていまし"
    },
    {
      "start": 810.32,
      "duration": 4.68,
      "text": "た。これからの時代本をちゃんと読んで"
    },
    {
      "start": 812.44,
      "duration": 4.44,
      "text": "いる人が結果を出し成果を出す時代だと"
    },
    {
      "start": 815.0,
      "duration": 3.959,
      "text": "本気で思っています。だってみんなスマホ"
    },
    {
      "start": 816.88,
      "duration": 4.36,
      "text": "でポチポチ活字を読んでるんです。そんな"
    },
    {
      "start": 818.959,
      "duration": 4.601,
      "text": "中、昔からいいと言われていた本を"
    },
    {
      "start": 821.24,
      "duration": 4.32,
      "text": "コツコツ読んだらそれは絶対ライバに勝て"
    },
    {
      "start": 823.56,
      "duration": 4.56,
      "text": "ますから、今からやりましょう。それが3"
    },
    {
      "start": 825.56,
      "duration": 4.56,
      "text": "年後、5年後のあなたを絶対助けてくれる"
    },
    {
      "start": 828.12,
      "duration": 4.04,
      "text": "知識になりますから。さあ、この本さらに"
    },
    {
      "start": 830.12,
      "duration": 4.639,
      "text": "気になるという方は説明欄のリンクから"
    },
    {
      "start": 832.16,
      "duration": 4.96,
      "text": "是非ね、ポチってみてください。私はです"
    },
    {
      "start": 834.759,
      "duration": 5.0,
      "text": "ね、仕事のために本をめっちゃ読み出した"
    },
    {
      "start": 837.12,
      "duration": 4.719,
      "text": "のが26歳くらいの時でした。それまでは"
    },
    {
      "start": 839.759,
      "duration": 4.44,
      "text": "小説とかは結構読んでいたんですが、"
    },
    {
      "start": 841.839,
      "duration": 4.321,
      "text": "256歳ぐらいからはビジネス書めっちゃ"
    },
    {
      "start": 844.199,
      "duration": 3.88,
      "text": "読んでいましたね。で、本を読むのが大事"
    },
    {
      "start": 846.16,
      "duration": 4.119,
      "text": "なのは正直みんな分かってるじゃないです"
    },
    {
      "start": 848.079,
      "duration": 4.44,
      "text": "か。でもたくさん読んでいても1m目にも"
    },
    {
      "start": 850.279,
      "duration": 4.48,
      "text": "人生変わってない人結構いるんですよ。"
    },
    {
      "start": 852.519,
      "duration": 4.44,
      "text": "これもう個人的に理由分かってるんですが"
    },
    {
      "start": 854.759,
      "duration": 4.561,
      "text": "読んだのにそれをやらない人、要は"
    },
    {
      "start": 856.959,
      "duration": 4.24,
      "text": "アウトプットしない人これが1番もったい"
    },
    {
      "start": 859.32,
      "duration": 4.68,
      "text": "ないんですよ。私ですね、サラリーマンの"
    },
    {
      "start": 861.199,
      "duration": 4.721,
      "text": "時1冊読んだらその本の中の内容を1つ"
    },
    {
      "start": 864.0,
      "duration": 4.16,
      "text": "だけ仕事で実践してみよう。これを"
    },
    {
      "start": 865.92,
      "duration": 4.68,
      "text": "サラリーマン時代から5年間以上やってい"
    },
    {
      "start": 868.16,
      "duration": 5.16,
      "text": "たんですよ。その結果売上も上がったし"
    },
    {
      "start": 870.6,
      "duration": 4.88,
      "text": "利益率も上がった。効率性も上げて赤字の"
    },
    {
      "start": 873.32,
      "duration": 3.959,
      "text": "会社を黒字にすることできたんですよね。"
    },
    {
      "start": 875.48,
      "duration": 3.96,
      "text": "ま、ちっちゃい会社だったんで、当時売上"
    },
    {
      "start": 877.279,
      "duration": 5.36,
      "text": "3億円くらいだったのを4年間で10億"
    },
    {
      "start": 879.44,
      "duration": 5.199,
      "text": "近くまで上げて利益率も10%以上改善し"
    },
    {
      "start": 882.639,
      "duration": 3.801,
      "text": "ました。ぶっちゃけね、やったことは本に"
    },
    {
      "start": 884.639,
      "duration": 4.0,
      "text": "書いてあったことをやってみただけです。"
    },
    {
      "start": 886.44,
      "duration": 4.079,
      "text": "営業の本だったら営業の仕方を変えるとか"
    },
    {
      "start": 888.639,
      "duration": 4.081,
      "text": "、マネジメントの本だったらマネジメント"
    },
    {
      "start": 890.519,
      "duration": 4.201,
      "text": "の仕方を変える。経費削減の本だったら"
    },
    {
      "start": 892.72,
      "duration": 4.559,
      "text": "削減の仕方を導入してみる。こういった"
    },
    {
      "start": 894.72,
      "duration": 5.0,
      "text": "こと1つだけやっていったら本当に成果出"
    },
    {
      "start": 897.279,
      "duration": 4.56,
      "text": "たんですよ。私もね、本で人生が変わった"
    },
    {
      "start": 899.72,
      "duration": 4.239,
      "text": "からこそこの1つだけやってみるおすすめ"
    },
    {
      "start": 901.839,
      "duration": 4.521,
      "text": "なんで是非ね、やってみてください。正直"
    },
    {
      "start": 903.959,
      "duration": 4.041,
      "text": "ですね、本だけじゃなくてこういった学作"
    },
    {
      "start": 906.36,
      "duration": 3.919,
      "text": "みたいな動画もそうだと思っていて、"
    },
    {
      "start": 908.0,
      "duration": 4.48,
      "text": "やっぱりアウトプットが大事で実践しない"
    },
    {
      "start": 910.279,
      "duration": 4.601,
      "text": "と何も変わらないんですよ。だからこそ"
    },
    {
      "start": 912.48,
      "duration": 4.52,
      "text": "これいい方法だなと思ったことはメモをし"
    },
    {
      "start": 914.88,
      "duration": 4.36,
      "text": "て必ずやるようにしてみてください。やっ"
    },
    {
      "start": 917.0,
      "duration": 4.519,
      "text": "てみてもしね、効果がなかったらあ、自分"
    },
    {
      "start": 919.24,
      "duration": 4.599,
      "text": "には合わない方法だったんだなで終われば"
    },
    {
      "start": 921.519,
      "duration": 4.32,
      "text": "大きな損はないですし、やってみて失敗し"
    },
    {
      "start": 923.839,
      "duration": 4.521,
      "text": "た経験はその後どっかで生きてくるんです"
    },
    {
      "start": 925.839,
      "duration": 5.081,
      "text": "よ。これですね、私も荒らフになって、今"
    },
    {
      "start": 928.36,
      "duration": 5.08,
      "text": "までたくさん失敗してきた経験が今になっ"
    },
    {
      "start": 930.92,
      "duration": 5.56,
      "text": "て生きてきてるなって本当にね、実感して"
    },
    {
      "start": 933.44,
      "duration": 6.319,
      "text": "います。最後に精神界で有名な斎藤もさん"
    },
    {
      "start": 936.48,
      "duration": 6.08,
      "text": "の名言を紹介します。人生に失敗がないと"
    },
    {
      "start": 939.759,
      "duration": 4.801,
      "text": "人生を失敗する。これ深くないですか?ま"
    },
    {
      "start": 942.56,
      "duration": 4.959,
      "text": "、今私が言ったようなことと似てる意味だ"
    },
    {
      "start": 944.56,
      "duration": 5.04,
      "text": "と思いますが、失敗がない人生のが失敗し"
    },
    {
      "start": 947.519,
      "duration": 4.521,
      "text": "やすくなっちゃうんですよ。何でも興味を"
    },
    {
      "start": 949.6,
      "duration": 4.32,
      "text": "持った本読んで1つ実践してみる。是非ね"
    },
    {
      "start": 952.04,
      "duration": 3.68,
      "text": "、今日からやってみてください。客式"
    },
    {
      "start": 953.92,
      "duration": 3.68,
      "text": "サロンはYouTuberさんのための"
    },
    {
      "start": 955.72,
      "duration": 4.4,
      "text": "オンラインサロンを運営しています。"
    },
    {
      "start": 957.6,
      "duration": 5.0,
      "text": "おかげ様で運営3年以上、メンバー300"
    },
    {
      "start": 960.12,
      "duration": 5.12,
      "text": "名以上。その他にも登録者5万人以上の"
    },
    {
      "start": 962.6,
      "duration": 5.12,
      "text": "運営者は150名以上参加しています。"
    },
    {
      "start": 965.24,
      "duration": 4.36,
      "text": "YouTubeは本当に難しくて難易度は"
    },
    {
      "start": 967.72,
      "duration": 3.88,
      "text": "どんどん上がっています。でも実は"
    },
    {
      "start": 969.6,
      "duration": 4.28,
      "text": "YouTubeには明確なコツがあるん"
    },
    {
      "start": 971.6,
      "duration": 4.52,
      "text": "です。それに気づけないで運営していたら"
    },
    {
      "start": 973.88,
      "duration": 4.04,
      "text": "1年経っても登録者1000人達成でき"
    },
    {
      "start": 976.12,
      "duration": 3.6,
      "text": "ないことがリアルに起こってしまうんです"
    },
    {
      "start": 977.92,
      "duration": 3.68,
      "text": "よね。そこでこのサロンでは"
    },
    {
      "start": 979.72,
      "duration": 4.239,
      "text": "YouTubeのノンハウをみんなで学ぶ"
    },
    {
      "start": 981.6,
      "duration": 4.4,
      "text": "ためにこういったコツの得典を用意してい"
    },
    {
      "start": 983.959,
      "duration": 4.481,
      "text": "ます。私からの直接アドバイスも"
    },
    {
      "start": 986.0,
      "duration": 4.68,
      "text": "もちろんOKですし、今このサロンに参加"
    },
    {
      "start": 988.44,
      "duration": 5.04,
      "text": "した人限定で伸び悩んでるチャンネルを"
    },
    {
      "start": 990.68,
      "duration": 5.68,
      "text": "劇的に改善する裏技7000。これを無料"
    },
    {
      "start": 993.48,
      "duration": 5.919,
      "text": "でプレゼント中です。実際2ヶ月で収益化"
    },
    {
      "start": 996.36,
      "duration": 5.719,
      "text": "達成できた人、3ヶ月で月20万円稼げた"
    },
    {
      "start": 999.399,
      "duration": 4.601,
      "text": "人、さらにその上の金額を稼いでいる人も"
    },
    {
      "start": 1002.079,
      "duration": 4.32,
      "text": "たくさん生まれています。本当にね、"
    },
    {
      "start": 1004.0,
      "duration": 4.12,
      "text": "すごいメンバーが揃ってるんですよ。ただ"
    },
    {
      "start": 1006.399,
      "duration": 4.161,
      "text": "YouTubeは簡単ではありません。"
    },
    {
      "start": 1008.12,
      "duration": 4.199,
      "text": "本気でやらないと成果は絶対出ませんので"
    },
    {
      "start": 1010.56,
      "duration": 4.32,
      "text": "、これからね、本気でYouTube"
    },
    {
      "start": 1012.319,
      "duration": 4.361,
      "text": "頑張りたい。副業で稼いでみたいという方"
    },
    {
      "start": 1014.88,
      "duration": 3.399,
      "text": "のみお待ちしております。一緒に"
    },
    {
      "start": 1016.68,
      "duration": 5.959,
      "text": "YouTube頑張ってみませんか?"
    },
    {
      "start": 1018.279,
      "duration": 4.36,
      "text": "さよなら。さよなら。さよなら。"
    }
  ]
}