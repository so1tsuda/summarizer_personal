      "start": 517.719,
      "duration": 3.641,
      "text": "どういう流れで喋ろうかっていうのもやっ"
    },
    {
      "start": 520.24,
      "duration": 3.52,
      "text": "たことないからわかんないわけじゃない"
    },
    {
      "start": 521.36,
      "duration": 5.24,
      "text": "ですか。だからもうこっちも練習やと"
    },
    {
      "start": 523.76,
      "duration": 4.92,
      "text": "うまくできんと頑張るけどもうまくできる"
    },
    {
      "start": 526.6,
      "duration": 4.0,
      "text": "かどうか分かへんとてなったらギャラ"
    },
    {
      "start": 528.68,
      "duration": 2.76,
      "text": "低かった方がハードル低いじゃないですか"
    },
    {
      "start": 530.6,
      "duration": 3.84,
      "text": "。"
    },
    {
      "start": 531.44,
      "duration": 3.0,
      "text": "で、これギャラ高くもら、自分で言ってもらい続すぎちゃうとこう高い人と一緒のレベルで測られちゃうんで。で、そしたらこっちペなのに、あ、なんか全然大したことないなって思われても嫌だからまず安くてもこっちの練習場所としてまず受ける。で、しかも引退っていうのがあるんで。"
    },
    {
      "start": 548.079,
      "duration": 1.521,
      "text": "うん。"
    },
    {
      "start": 548.8,
      "duration": 3.8,
      "text": "やめてすぐ1"
    },
    {
      "start": 549.6,
      "duration": 3.0,
      "text": "年目の人っていうのはやっぱ新鮮じゃないですか?ことに。で、初めてのに来るから。だから、ま、コンビニで言うと新商品みたいなもんなんですよ。"
    },
    {
      "start": 558.079,
      "duration": 3.961,
      "text": "おお。新商品。"
    },
    {
      "start": 559.68,
      "duration": 5.24,
      "text": "ま、どんな感じかわからへんけど、新商品"
    },
    {
      "start": 562.04,
      "duration": 5.56,
      "text": "だから買ってみようかって思うのが新情"
    },
    {
      "start": 564.92,
      "duration": 5.12,
      "text": "じゃないですか。だからそれで引退事需要"
    },
    {
      "start": 567.6,
      "duration": 4.28,
      "text": "は新商品なんで選ばれやすいんですよね。"
    },
    {
      "start": 570.04,
      "duration": 4.12,
      "text": "どんなもんなのかな。だから要は試され"
    },
    {
      "start": 571.88,
      "duration": 5.639,
      "text": "てるっていうところもあるわけですよ。で"
    },
    {
      "start": 574.16,
      "duration": 6.119,
      "text": "、そこで美味しかったり良かったら、あ、"
    },
    {
      "start": 577.519,
      "duration": 6.681,
      "text": "もっちにもう1回しようとなったりとか、"
    },
    {
      "start": 580.279,
      "duration": 5.721,
      "text": "それが後々定番商品になってロングセラー"
    },
    {
      "start": 584.2,
      "duration": 4.04,
      "text": "になる可能性もあるわけじゃないですか。"
    },
    {
      "start": 586.0,
      "duration": 4.399,
      "text": "だからその1年目っていう新商品の"
    },
    {
      "start": 588.24,
      "duration": 4.96,
      "text": "フレッシュなみんなから手に取りやすい"
    },
    {
      "start": 590.399,
      "duration": 5.321,
      "text": "時代にいろんなことしてもダメだし、値段"
    },
    {
      "start": 593.2,
      "duration": 5.84,
      "text": "交渉してもダメだし、便利屋になった"
    },
    {
      "start": 595.72,
      "duration": 4.84,
      "text": "ぐらいで何でも受けますよと何でもやり"
    },
    {
      "start": 599.04,
      "duration": 3.359,
      "text": "ますよ。で、いろんなところ行って"
    },
    {
      "start": 600.56,
      "duration": 4.48,
      "text": "いろんな人とコミュニケーション取って"
    },
    {
      "start": 602.399,
      "duration": 5.44,
      "text": "こう種巻きやと1年目は新商品種巻きや"
    },
    {
      "start": 605.04,
      "duration": 5.799,
      "text": "とこでどんだけ足り巻くかによってのやつ"
    },
    {
      "start": 607.839,
      "duration": 5.481,
      "text": "が2年目以降変わるかもしれへんと思って"
    },
    {
      "start": 610.839,
      "duration": 4.041,
      "text": "1年目結構忙しいと思ってたんですよ。"
    },
    {
      "start": 613.32,
      "duration": 3.36,
      "text": "いや、1年目だ。まあでもこんなも最初"
    },
    {
      "start": 614.88,
      "duration": 5.8,
      "text": "だけやからな。やっぱ1年目やからと思っ"
    },
    {
      "start": 616.68,
      "duration": 6.599,
      "text": "たら、あの、1年目が1番暇でした。"
    },
    {
      "start": 620.68,
      "duration": 4.92,
      "text": "そっからどんどん芽いていって、で、そっ"
    },
    {
      "start": 623.279,
      "duration": 7.081,
      "text": "からやっぱ3年ぐらいはやっぱいいねっす"
    },
    {
      "start": 625.6,
      "duration": 7.04,
      "text": "ね。途中で聞かれるんすよ。佐崎さん、"
    },
    {
      "start": 630.36,
      "duration": 5.56,
      "text": "これあの予算いくらぐらいかかりますか?"
    },
    {
      "start": 632.64,
      "duration": 5.16,
      "text": "みたいな。出演量とか公園料とかあの"
    },
    {
      "start": 635.92,
      "duration": 3.28,
      "text": "いくらぐらい"
    },
    {
      "start": 637.8,
      "duration": 4.52,
      "text": "教えてもらっていいですか?みたいな来る"
    },
    {
      "start": 639.2,
      "duration": 5.24,
      "text": "じゃないですか。1番難しいすよね。"
    },
    {
      "start": 642.32,
      "duration": 4.92,
      "text": "みんな皆さん言えます。あなたの値段"
    },
    {
      "start": 644.44,
      "duration": 5.36,
      "text": "いくらですかって言われるんです。俺"
    },
    {
      "start": 647.24,
      "duration": 5.56,
      "text": "いくらなんやろと思って。で、しかも相場"
    },
    {
      "start": 649.8,
      "duration": 5.12,
      "text": "がわかんないわけですよね。隣のや"
    },
    {
      "start": 652.8,
      "duration": 4.68,
      "text": "キャベツいくらにしてんやろとかちょっと"
    },
    {
      "start": 654.92,
      "duration": 6.24,
      "text": "2円安くしとこうかとかね。ていうのは他"
    },
    {
      "start": 657.48,
      "duration": 5.28,
      "text": "が見えてたら分かるすけどそん他の人に"
    },
    {
      "start": 661.16,
      "duration": 3.919,
      "text": "聞けないじゃないですか。なんとかさん"
    },
    {
      "start": 662.76,
      "duration": 5.319,
      "text": "公演っていくらなんですかみたいな。"
    },
    {
      "start": 665.079,
      "duration": 3.0,
      "text": "か、だから周りもわかんないんで。で、その中でやらなきゃいけないってなった時に、ま、低く設定してもダめだし、"
    },
    {
      "start": 672.399,
      "duration": 3.0,
      "text": "高く設定しすぎてもダメだし、でもいくらがスタンダードかわかんないんで、"
    },
    {
      "start": 676.24,
      "duration": 3.159,
      "text": "1"
    },
    {
      "start": 676.399,
      "duration": 3.0,
      "text": "番最初、ま、今でもそうすけどやってたのが予算もあると思うんで、無理も言ってもあれなんで、あの、いただけるだけのマックスくださいって言ってました。"
    },
    {
      "start": 687.36,
      "duration": 3.0,
      "text": "質問を質問で返すっていう。"
    },
    {
      "start": 691.959,
      "duration": 6.521,
      "text": "そうすると相手のマックスであろう金額が"
    },
    {
      "start": 696.16,
      "duration": 4.679,
      "text": "出てくるんで、ま、それで最初は受けてた"
    },
    {
      "start": 698.48,
      "duration": 4.799,
      "text": "んですよ、ずっと。で、それで3年間"
    },
    {
      "start": 700.839,
      "duration": 5.68,
      "text": "ぐらいやってると相場感分かってくるわけ"
    },
    {
      "start": 703.279,
      "duration": 8.201,
      "text": "ですよ。大体の僕の値段感が分かってくる"
    },
    {
      "start": 706.519,
      "duration": 8.0,
      "text": "ことによってまず1時段階の自分の値段"
    },
    {
      "start": 711.48,
      "duration": 5.72,
      "text": "設定をその3年ぐらい2、3年やった中で"
    },
    {
      "start": 714.519,
      "duration": 7.041,
      "text": "相場感見て決めますよね。僕はもう基本的"
    },
    {
      "start": 717.2,
      "duration": 8.84,
      "text": "にはテレビラジオとかその映像コンテンツ"
    },
    {
      "start": 721.56,
      "duration": 7.839,
      "text": "のものっていうのは僕の宣伝としか捉えて"
    },
    {
      "start": 726.04,
      "duration": 6.68,
      "text": "ないんで佐崎ってこういう解説しますよ。"
    },
    {
      "start": 729.399,
      "duration": 5.641,
      "text": "佐崎いますよここにっていう宣伝として"
    },
    {
      "start": 732.72,
      "duration": 7.08,
      "text": "そこで稼ごうとかもう思ってないですね。"
    },
    {
      "start": 735.04,
      "duration": 7.4,
      "text": "正直公園とか野球教室とかっていうその"
    },
    {
      "start": 739.8,
      "duration": 6.56,
      "text": "どこでやってもテレビとか時間違ったりと"
    },
    {
      "start": 742.44,
      "duration": 5.44,
      "text": "かね、その媒体によっては予算も規模も違"
    },
    {
      "start": 746.36,
      "duration": 6.08,
      "text": "うっていうのはいっぱいあるわけじゃない"
    },
    {
      "start": 747.88,
      "duration": 6.84,
      "text": "ですか。でも公園とか野球教室とかって"
    },
    {
      "start": 752.44,
      "duration": 5.28,
      "text": "いうのはやること一緒なんで。"
    },
    {
      "start": 754.72,
      "duration": 3.0,
      "text": "ってなるとそこはもうどんどん自分の中でのさの値段っていうのをしっかり伝えてその中でそちらはそういうものをしっかり"
    },
    {
      "start": 765.6,
      "duration": 3.4,
      "text": "うん。"
    },
    {
      "start": 766.0,
      "duration": 3.639,
      "text": "ビジネスとしてもらうっていうこっちは宣伝として"
    },
    {
      "start": 769.0,
      "duration": 3.639,
      "text": "うん。"
    },
    {
      "start": 769.639,
      "duration": 3.0,
      "text": "ね、薄りた倍で多くのものを宣伝活動する。こっちはしっかり身を持った美人をするっていうのをその仕事とか媒体によって使い分けてるって感じですね。"
    },
    {
      "start": 779.04,
      "duration": 7.0,
      "text": "でも僕の中では1年目から今12年目なん"
    },
    {
      "start": 782.279,
      "duration": 5.881,
      "text": "ですけど、絶対自分自身の中で守ってる鉄"
    },
    {
      "start": 786.04,
      "duration": 4.84,
      "text": "があるんですよ。"
    },
    {
      "start": 788.16,
      "duration": 5.6,
      "text": "早いものがちっすよ。どんなに高くても、"
    },
    {
      "start": 790.88,
      "duration": 6.319,
      "text": "どんなに安くても早く言ってきた人の仕事"
    },
    {
      "start": 793.76,
      "duration": 6.92,
      "text": "が僕の中では1番なんですよ。金額とか"
    },
    {
      "start": 797.199,
      "duration": 6.32,
      "text": "仕事のでかさで断って入れ替えるとかしな"
    },
    {
      "start": 800.68,
      "duration": 5.32,
      "text": "いっす。いや、僕はそこまで汚く行きたく"
    },
    {
      "start": 803.519,
      "duration": 5.76,
      "text": "ないんですよ。で、誰かに迷惑かかるじゃ"
    },
    {
      "start": 806.0,
      "duration": 6.12,
      "text": "ないですか。だ、この人に迷惑かかるわけ"
    },
    {
      "start": 809.279,
      "duration": 4.161,
      "text": "じゃないですか。で、そんな、ま、表現が"
    },
    {
      "start": 812.12,
      "duration": 3.12,
      "text": "正しいかどうかわかんないですけど、僕は"
    },
    {
      "start": 813.44,
      "duration": 4.8,
      "text": "そんな意地汚く行きたくないんですよ。お"
    },
    {
      "start": 815.24,
      "duration": 5.159,
      "text": "金は大好きですよ。間違いなく。お金は"
    },
    {
      "start": 818.24,
      "duration": 4.599,
      "text": "大好きだし、お金が全てだと思ってます"
    },
    {
      "start": 820.399,
      "duration": 5.481,
      "text": "けど、そこまで人を裏切ってまで行きたく"
    },
    {
      "start": 822.839,
      "duration": 6.521,
      "text": "ないんですよ。今もう12年目ですけど、"
    },
    {
      "start": 825.88,
      "duration": 7.399,
      "text": "1回も崩したことないですし、だから結果"
    },
    {
      "start": 829.36,
      "duration": 6.2,
      "text": "的にすけど、あの、さ忙しいってなるわけ"
    },
    {
      "start": 833.279,
      "duration": 4.521,
      "text": "ですよ。早いんすよ。どんどん来てくれる"
    },
    {
      "start": 835.56,
      "duration": 4.32,
      "text": "んですよ。佐々もう早く言っとかなきゃ"
    },
    {
      "start": 837.8,
      "duration": 5.76,
      "text": "空いてないから佐々さんにやってもらおう"
    },
    {
      "start": 839.88,
      "duration": 6.639,
      "text": "としたらもう1年前とか半年前とかから"
    },
    {
      "start": 843.56,
      "duration": 5.48,
      "text": "どんどん入ってくるんで結果的にそう"
    },
    {
      "start": 846.519,
      "duration": 5.641,
      "text": "ちゃんと僕の中ですよちゃんとやってる"
    },
    {
      "start": 849.04,
      "duration": 7.88,
      "text": "からこそのいい音恵が受けられてるん"
    },
    {
      "start": 852.16,
      "duration": 4.76,
      "text": "ちゃうかって僕は思ってます。はい。"
    },
    {
      "start": 860.56,
      "duration": 5.92,
      "text": "ま、日本人ってこう文化的にすよ。いい"
    },
    {
      "start": 863.56,
      "duration": 6.639,
      "text": "悪い別として、このお金の話はいじ汚いと"
    },
    {
      "start": 866.48,
      "duration": 7.32,
      "text": "かね、なんか自慢済んだとかね、金に"
    },
    {
      "start": 870.199,
      "duration": 8.841,
      "text": "細かいとかなんかお金の話は下品だって"
    },
    {
      "start": 873.8,
      "duration": 9.959,
      "text": "いう文化じゃないですか。でもお金をの話"
    },
    {
      "start": 879.04,
      "duration": 7.12,
      "text": "するとお金が入ってきます。お金の話し"
    },
    {
      "start": 883.759,
      "duration": 5.2,
      "text": "たい人はいるんですよ、世の中に。こんな"
    },
    {
      "start": 886.16,
      "duration": 6.119,
      "text": "に勝ったよとか、投資でこんなに儲けたよ"
    },
    {
      "start": 888.959,
      "duration": 6.081,
      "text": "とか。いいあるんだよとかね。こう本当は"
    },
    {
      "start": 892.279,
      "duration": 4.761,
      "text": "言いたいんですけど、なんか言うとなんか"
    },
    {
      "start": 895.04,
      "duration": 5.2,
      "text": "こう"
    },
    {
      "start": 897.04,
      "duration": 7.2,
      "text": "騙そうとしてきてんちゃうかとか俺を"
    },
    {
      "start": 900.24,
      "duration": 6.2,
      "text": "もしくはそれでなんか紹介したマージンで"
    },
    {
      "start": 904.24,
      "duration": 5.0,
      "text": "稼ごうとしてんちゃうかとかっていう"
    },
    {
      "start": 906.44,
      "duration": 3.92,
      "text": "なんかちょっとマイナスイメージが多い"
    },
    {
      "start": 909.24,
      "duration": 3.76,
      "text": "じゃないですか。したい人はいっぱいいる"
    },
    {
      "start": 910.36,
      "duration": 5.279,
      "text": "のに。だからするのもしにくいすよね。"
    },
    {
      "start": 913.0,
      "duration": 4.839,
      "text": "相手がそのお金に対してね、こうフリーな"
    },
    {
      "start": 915.639,
      "duration": 4.081,
      "text": "のかクローズなのかっていうのも分から"
    },
    {
      "start": 917.839,
      "duration": 2.8,
      "text": "ないしだしないっていう判断になってくる"
    },
    {
      "start": 919.72,
      "duration": 3.919,
      "text": "わけじゃないですか。"
    },
    {
      "start": 920.639,
      "duration": 3.0,
      "text": "それがね、お金のチャンスを減らしてるわけですよ。自分からお金の話するわけじゃないですか。そしたら、あ、この人お金の話大好きなんやってなるわけですよ。お金の話しやすいなってなるわけですよ。で、そうしたらそういうこういうの良かったよとかこういうのいいのあるよっていうのが入ってくるんですよ。情報が。"
    },
    {
      "start": 940.199,
      "duration": 7.56,
      "text": "お金の選択肢が広まることによって自分の"
    },
    {
      "start": 943.36,
      "duration": 6.52,
      "text": "資産形成とか投資先とかいろんなものが"
    },
    {
      "start": 947.759,
      "duration": 4.32,
      "text": "知れてくるっていうのは"
    },
    {
      "start": 949.88,
      "duration": 6.04,
      "text": "自分にとってプラスになるんで、ま、した"
    },
    {
      "start": 952.079,
      "duration": 6.56,
      "text": "方が話やすいですよっていうないよりあっ"
    },
    {
      "start": 955.92,
      "duration": 4.919,
      "text": "た方が絶対いいんで。普通の一般の人でも"
    },
    {
      "start": 958.639,
      "duration": 4.88,
      "text": "お金の話とか情報入ってきやすいし僕ら"
    },
    {
      "start": 960.839,
      "duration": 5.36,
      "text": "みたいな感じだとそれが仕事になって投資"
    },
    {
      "start": 963.519,
      "duration": 4.481,
      "text": "の番組とか投資の企画とかに呼ばれること"
    },
    {
      "start": 966.199,
      "duration": 5.361,
      "text": "によってそれがビジネスにな"
    },
    {
      "start": 968.0,
      "duration": 3.56,
      "text": "るっていうところが大きいですよね。"
    },
    {
      "start": 975.519,
      "duration": 6.041,
      "text": "持ちは持ち合いなんでプロに聞くっていう"
    },
    {
      "start": 978.16,
      "duration": 6.0,
      "text": "常にもう優秀な人に1番聞けっていうのが"
    },
    {
      "start": 981.56,
      "duration": 7.279,
      "text": "もう僕のMODなんでもうその投資にして"
    },
    {
      "start": 984.16,
      "duration": 7.96,
      "text": "ももう僕のその銀行ね投資信託の会社の"
    },
    {
      "start": 988.839,
      "duration": 5.68,
      "text": "担当の人の意見をしっかり聞いて最終的に"
    },
    {
      "start": 992.12,
      "duration": 4.839,
      "text": "は僕が判断してますけどはい。それはうち"
    },
    {
      "start": 994.519,
      "duration": 5.161,
      "text": "の父親も言ってたんですよ。うちの父親が"
    },
    {
      "start": 996.959,
      "duration": 5.24,
      "text": "大工なんですよ。うん。で、大工だから家"
    },
    {
      "start": 999.68,
      "duration": 4.519,
      "text": "立てるじゃないですか。あの、お客さん、"
    },
    {
      "start": 1002.199,
      "duration": 3.521,
      "text": "いや、は素人じゃないですか。ああ、して"
    },
    {
      "start": 1004.199,
      "duration": 4.281,
      "text": "くれ、こうしてくれ。結構言ってくるっす"
    },
    {
      "start": 1005.72,
      "duration": 4.799,
      "text": "よね。でも構造上できないものもあるわけ"
    },
    {
      "start": 1008.48,
      "duration": 4.68,
      "text": "ですよ。ま、無理なんだ言ってくるけど、"
    },
    {
      "start": 1010.519,
      "duration": 4.521,
      "text": "僕が家立てる時に、あの、持ちは持ち合い"
    },
    {
      "start": 1013.16,
      "duration": 3.919,
      "text": "やからプロの言うことは聞いとけよって"
    },
    {
      "start": 1015.04,
      "duration": 3.64,
      "text": "言われました。素人は好きかって言うけど"
    },
    {
      "start": 1017.079,
      "duration": 4.081,
      "text": "、そんなもんできんものはできひんねんぞ"
    },
    {
      "start": 1018.68,
      "duration": 4.8,
      "text": "と。で、あと困るだけやからなって言われ"
    },
    {
      "start": 1021.16,
      "duration": 5.399,
      "text": "てるんで、やっぱりね、プロはプロに聞い"
    },
    {
      "start": 1023.48,
      "duration": 5.319,
      "text": "た方がいいんですよ。物事をの上達は2つ"
    },
    {
      "start": 1026.559,
      "duration": 5.24,
      "text": "しかないんですよ。方法論は。"
    },
    {
      "start": 1028.799,
      "duration": 6.0,
      "text": "自分で調べて、自分で考えて、自分で行動"
    },
    {
      "start": 1031.799,
      "duration": 5.4,
      "text": "して、自分で能力上げるか、もう1つは誰"
    },
    {
      "start": 1034.799,
      "duration": 4.321,
      "text": "かに聞く、教えてもらう。これ2個しか"
    },
    {
      "start": 1037.199,
      "duration": 4.801,
      "text": "ないわけですよ。大さんに言うと。で、僕"
    },
    {
      "start": 1039.12,
      "duration": 5.839,
      "text": "はもうめんどくさいじゃないですか。"
    },
    {
      "start": 1042.0,
      "duration": 4.839,
      "text": "そんな労力当たるか外れるかわかんないの"
    },
    {
      "start": 1044.959,
      "duration": 2.24,
      "text": "に、そんな労力あんまり考えたくないん"
    },
    {
      "start": 1046.839,
      "duration": 3.36,
      "text": "ですよ。"
    },
    {
      "start": 1047.199,
      "duration": 3.0,
      "text": "やっぱいい人になら常にもう優秀な人に"
    },
    {
      "start": 1052.4,
      "duration": 4.92,
      "text": "1番聞けっていうのがもう僕のMODな"
    },
    {
      "start": 1054.32,
      "duration": 3.0,
      "text": "んで知識もないのにあの自分でネットバンキングで自分で投資して知識ありゃいいすよ。手数料もいらないし知識もないのにそれで行くんすよね。もう長半爆地みたいなもんすよね。当たるも発当たらぬも発景みたいな。もうそんなん僕逆にできないすよ。しかもすよ。相談無料なんすよ、これが。"
    },
    {
      "start": 1077.52,
      "duration": 3.0,
      "text": "だって弁護士とか金かかるじゃないですか。相談"
    },
    {
      "start": 1081.0,
      "duration": 3.0,
      "text": "投資の担当の人相談無料っすよ。"
    },
    {
      "start": 1084.039,
      "duration": 2.241,
      "text": "言って聞けばいいだけで僕は投資でも"
    },
    {
      "start": 1086.039,
      "duration": 3.241,
      "text": "1"
    },
    {
      "start": 1086.28,
      "duration": 3.0,
      "text": "でも増えればいいと思ってるんで別に手数料払っても有益な情報もらえてだその手数量が相談量やと思えばで最後選ぶのは自分なんで全部が全部言われたままやる必要ないんで現役中は無駄な買い物とかしないですよ。欲しいものは買いますよ。もちろん。"
    },
    {
      "start": 1108.64,
      "duration": 3.0,
      "text": "でもなんか設税するために経費使おうとかもう"
    },
    {
      "start": 1113.72,
      "duration": 4.72,
      "text": "1mmもないですね。"
    },
    {
      "start": 1115.44,
      "duration": 3.0,
      "text": "会社員ってなってくると経費って会社のお金じゃないですか。"
    },
    {
      "start": 1120.559,
      "duration": 2.441,
      "text": "だ自分の懐ないですよね。"
    },
    {
      "start": 1122.159,
      "duration": 3.841,
      "text": "うん。"
    },
    {
      "start": 1123.0,
      "duration": 3.0,
      "text": "いや、じゃあ飲み食いした。いや、接、ゴルフやなんとかや。これ全部経費で賄えるからはい。領収書持って経に回します。はい。これはい、会社で払っといてくださいね。"
    },
    {
      "start": 1133.12,
      "duration": 3.0,
      "text": "と僕ら個人需要主とか経営者とかの人の"
    },
    {
      "start": 1137.84,
      "duration": 5.199,
      "text": "経費の考え方って"
    },
    {
      "start": 1140.039,
      "duration": 3.0,
      "text": "それ使ってもいいけど認められなるかもしんないですけど初詮自分のお金なくなってるだけですからね。で、万が一ずれ仕事しなくなってももうじゃあ法人として僕みたいに個人事務所してたらそっから給料もらいながらっていうのも永遠できるわけじゃないですか。仕事として。"
    },
    {
      "start": 1159.039,
      "duration": 4.201,
      "text": "でもここのお金がなくなったらもう"
    },
    {
      "start": 1161.72,
      "duration": 4.24,
      "text": "ショートするわけじゃないですか。で、"
    },
    {
      "start": 1163.24,
      "duration": 6.52,
      "text": "そんな無駄なものを使ってなくなすくらい"
    },
    {
      "start": 1165.96,
      "duration": 6.199,
      "text": "だったら税金払った方がお金溜まるんで。"
    },
    {
      "start": 1169.76,
      "duration": 4.56,
      "text": "だから必要なね、本当に接対でしなきゃ"
    },
    {
      "start": 1172.159,
      "duration": 5.0,
      "text": "いけないものはした方がいいですけど、"
    },
    {
      "start": 1174.32,
      "duration": 6.04,
      "text": "設税のためにやるのは僕は悪やと思うん"
    },
    {
      "start": 1177.159,
      "duration": 5.161,
      "text": "ですよ。資産は余らして死ぬことが最高な"
    },
    {
      "start": 1180.36,
      "duration": 5.64,
      "text": "んで。"
    },
    {
      "start": 1182.32,
      "duration": 6.839,
      "text": "余力を持って死なないといけないんで。だ"
    },
    {
      "start": 1186.0,
      "duration": 4.76,
      "text": "から引退後の資産形成と同じようにいつ"
    },
    {
      "start": 1189.159,
      "duration": 4.161,
      "text": "死ぬかわかんないわけじゃないですか。"
    },
    {
      "start": 1190.76,
      "duration": 6.32,
      "text": "死ぬ時期が分かってんだったら僕もすよ。"
    },
    {
      "start": 1193.32,
      "duration": 6.56,
      "text": "あなたは何歳の何月何日何時に死にますっ"
    },
    {
      "start": 1197.08,
      "duration": 7.28,
      "text": "て言われるんだったらもうそこまでに向け"
    },
    {
      "start": 1199.88,
      "duration": 7.4,
      "text": "て全部使い切りますよ、正直。でも知ら"
    },
    {
      "start": 1204.36,
      "duration": 6.88,
      "text": "ないわけじゃないですか。ってなった時に"
    },
    {
      "start": 1207.28,
      "duration": 7.6,
      "text": "やっぱりある一定の資産を常に持っとか"
    },
    {
      "start": 1211.24,
      "duration": 7.0,
      "text": "ないと何かあった時の保険が持っといた方"
    },
    {
      "start": 1214.88,
      "duration": 6.84,
      "text": "が僕は心に言い取りもできるし楽だと思う"
    },
    {
      "start": 1218.24,
      "duration": 5.72,
      "text": "から。で、それがじゃあ500万余って"
    },
    {
      "start": 1221.72,
      "duration": 4.88,
      "text": "死にました。2000万余って死にました"
    },
    {
      "start": 1223.96,
      "duration": 5.8,
      "text": "。1億円余って死にました。でも死ぬまで"
    },
    {
      "start": 1226.6,
      "duration": 5.36,
      "text": "の間瞬華週冬で季節の美味しい食事も"
    },
    {
      "start": 1229.76,
      "duration": 4.88,
      "text": "食べれてます。そんな毎回じゃないかも"
    },
    {
      "start": 1231.96,
      "duration": 5.16,
      "text": "しんないけど、旅行が趣味で年に1回好き"
    },
    {
      "start": 1234.64,
      "duration": 5.279,
      "text": "なところに旅行に行けてます。お正活とか"
    },
    {
      "start": 1237.12,
      "duration": 5.28,
      "text": "誕生日とか記念日に子供や孫にプレゼント"
    },
    {
      "start": 1239.919,
      "duration": 5.041,
      "text": "あげれてますね。そんな贅沢もしてない"
    },
    {
      "start": 1242.4,
      "duration": 5.08,
      "text": "けども自分の生活の中で自分がやりたい"
    },
    {
      "start": 1244.96,
      "duration": 7.88,
      "text": "ようなことは何かの制限があることなく"
    },
    {
      "start": 1247.48,
      "duration": 7.52,
      "text": "できてますの中で死ぬ時に数百万数千万お"
    },
    {
      "start": 1252.84,
      "duration": 5.48,
      "text": "金余ってました。いや、最高じゃないです"
    },
    {
      "start": 1255.0,
      "duration": 5.36,
      "text": "か。だから僕はその"
    },
    {
      "start": 1258.32,
      "duration": 5.04,
      "text": "余らして全てですよ。"
    },
    {
      "start": 1260.36,
      "duration": 3.0,
      "text": "全ては余らして終わるのが最高なわけですよ。終わってバターはダメなわけですよ。それ使い切ったがいいかもしんないですけど、ま、それは何かの弊害を起きるんで。"
    },
    {
      "start": 1270.6,
      "duration": 3.319,
      "text": "うん。"
    },
    {
      "start": 1270.919,
      "duration": 3.0,
      "text": "はい。答えを知りたがる人種になってると思うんですよ。自分で考えるっていうことを放棄してです。何かしらの理由で誰もやってない。でも誰でもできる。ハードルも低い取りかかりも安い。"
    },
    {
      "start": 1284.36,
      "duration": 6.28,
      "text": "BGSチャンスや。0を1にするのが大事"
    },
    {
      "start": 1286.799,
      "duration": 5.841,
      "text": "なんで、0は0なんで本音を死にたいって"
    },
    {
      "start": 1290.64,
      "duration": 5.039,
      "text": "いうフェーズに時代が変わってきたんです"
    },
    {
      "start": 1292.64,
      "duration": 6.88,
      "text": "よ。目指すべきものはヒーローじゃなくて"
    },
    {
      "start": 1295.679,
      "duration": 3.841,
      "text": "ヒールなんですよ。"
    }
  ]
}