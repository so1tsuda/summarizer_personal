    {
      "start": 517.56,
      "duration": 5.68,
      "text": "はい。え、ポジティブなリスクファクター"
    },
    {
      "start": 520.039,
      "duration": 6.681,
      "text": "としましては、え、イランの紛争が早期に"
    },
    {
      "start": 523.24,
      "duration": 7.159,
      "text": "集結すること、え、そして、え、アメリカ"
    },
    {
      "start": 526.72,
      "duration": 6.36,
      "text": "のAIの過剰投資懸念やまたサーズの支の"
    },
    {
      "start": 530.399,
      "duration": 5.481,
      "text": "懸念というのが交代していくことなどを"
    },
    {
      "start": 533.08,
      "duration": 5.999,
      "text": "上げております。一方でネガティブな"
    },
    {
      "start": 535.88,
      "duration": 6.24,
      "text": "リスクファクターとしましては、え、紛争"
    },
    {
      "start": 539.079,
      "duration": 6.241,
      "text": "の長期化というところですね、3ヶ月以上"
    },
    {
      "start": 542.12,
      "duration": 6.159,
      "text": "長引いて世界経済がスタグフレーション、"
    },
    {
      "start": 545.32,
      "duration": 5.759,
      "text": "悪いインフレに陥るリスクが高まる。こう"
    },
    {
      "start": 548.279,
      "duration": 6.0,
      "text": "いったところを上げております。では最後"
    },
    {
      "start": 551.079,
      "duration": 5.481,
      "text": "に日本とアメリカのセクター戦略です。"
    },
    {
      "start": 554.279,
      "duration": 5.401,
      "text": "まずアメリカからお願いいたします。はい"
    },
    {
      "start": 556.56,
      "duration": 5.64,
      "text": "。え、アメリカ株につきまして、え、"
    },
    {
      "start": 559.68,
      "duration": 6.04,
      "text": "セクターの見通しを変更した点につきまし"
    },
    {
      "start": 562.2,
      "duration": 6.36,
      "text": "てはエネルギーを、え、まず弱きから中立"
    },
    {
      "start": 565.72,
      "duration": 5.72,
      "text": "に上げております。え、エネルギーは原油"
    },
    {
      "start": 568.56,
      "duration": 5.839,
      "text": "価格の上昇が、え、アメリカのシェール"
    },
    {
      "start": 571.44,
      "duration": 5.76,
      "text": "企業の売上を下載するとの見立てから"
    },
    {
      "start": 574.399,
      "duration": 5.641,
      "text": "引き上げております。そして素材につき"
    },
    {
      "start": 577.2,
      "duration": 6.12,
      "text": "ましては、こちらは強気から中立に"
    },
    {
      "start": 580.04,
      "duration": 6.919,
      "text": "引き下げております。え、原油価格の上昇"
    },
    {
      "start": 583.32,
      "duration": 6.88,
      "text": "に伴う現在コストの増加というのが原価を"
    },
    {
      "start": 586.959,
      "duration": 6.841,
      "text": "押し上げて、え、業績の重荷になると見て"
    },
    {
      "start": 590.2,
      "duration": 6.879,
      "text": "おります。で、また生活品につきましては"
    },
    {
      "start": 593.8,
      "duration": 6.36,
      "text": "、え、こちらは中立から気に引き下げて"
    },
    {
      "start": 597.079,
      "duration": 5.88,
      "text": "おります。え、ガソリン価格の高等などを"
    },
    {
      "start": 600.16,
      "duration": 6.08,
      "text": "受けて消費マインドが悪化した場合、業績"
    },
    {
      "start": 602.959,
      "duration": 6.281,
      "text": "の重荷になる可能性を見ております。日本"
    },
    {
      "start": 606.24,
      "duration": 7.08,
      "text": "株はどうでしょうか?はい。え、日本株に"
    },
    {
      "start": 609.24,
      "duration": 7.0,
      "text": "つきましては、まず輸送機につきまして、"
    },
    {
      "start": 613.32,
      "duration": 5.36,
      "text": "え、短期的にはガソリン価格の、え、急闘"
    },
    {
      "start": 616.24,
      "duration": 5.48,
      "text": "などの悪影居などを考慮しまして、え、"
    },
    {
      "start": 618.68,
      "duration": 6.8,
      "text": "強気から中立に引き下げております。"
    },
    {
      "start": 621.72,
      "duration": 6.6,
      "text": "そして保険ですが、え、戦争に伴う保険金"
    },
    {
      "start": 625.48,
      "duration": 6.599,
      "text": "の支払いが増える懸念などから、え、強気"
    },
    {
      "start": 628.32,
      "duration": 6.759,
      "text": "から中立に引き下げております。一方で、"
    },
    {
      "start": 632.079,
      "duration": 6.041,
      "text": "え、大手勝者などを含むおろし売りですね"
    },
    {
      "start": 635.079,
      "duration": 5.641,
      "text": "。こちらは、え、世界各地で、え、中東に"
    },
    {
      "start": 638.12,
      "duration": 5.0,
      "text": "依存しない資源開発。こういったところの"
    },
    {
      "start": 640.72,
      "duration": 5.76,
      "text": "金融が高まる可能性があると見ており、"
    },
    {
      "start": 643.12,
      "duration": 7.68,
      "text": "中立から強気に引き上げております。宮崎"
    },
    {
      "start": 646.48,
      "duration": 4.32,
      "text": "さん、どうもありがとうございました。"
    },
    {
      "start": 651.76,
      "duration": 4.96,
      "text": "みずほマンスリー株式でした。ご覧"
    },
    {
      "start": 654.48,
      "duration": 5.039,
      "text": "いただいたみホマンスリーいかがでしたか"
    },
    {
      "start": 656.72,
      "duration": 8.119,
      "text": "?画面下から評価をお知らせください。"
    },
    {
      "start": 659.519,
      "duration": 5.32,
      "text": "またチャンネル登録もお待ちしています。"
    },
    {
      "start": 665.04,
      "duration": 3.16,
      "text": "うん。"
    },
