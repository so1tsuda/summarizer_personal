      "start": 488.96,
      "duration": 7.639,
      "text": "その材料も別だしプロセも別なので一緒に"
    },
    {
      "start": 492.4,
      "duration": 7.4,
      "text": "はできないんですが、ただあの密天が得意"
    },
    {
      "start": 496.599,
      "duration": 6.401,
      "text": "としてるIGBTとローブのSICという"
    },
    {
      "start": 499.8,
      "duration": 5.2,
      "text": "のは事業領域が非常に似ているんですね。"
    },
    {
      "start": 503.0,
      "duration": 4.68,
      "text": "で、あの、例えばインフィニオンなんかは"
    },
    {
      "start": 505.0,
      "duration": 5.039,
      "text": "両方ともこれ強いんですけれども、お客"
    },
    {
      "start": 507.68,
      "duration": 6.08,
      "text": "さんに同じようなそのモジュールに"
    },
    {
      "start": 510.039,
      "duration": 5.44,
      "text": "組み立ててこっちの方が、ま、買い方同じ"
    },
    {
      "start": 513.76,
      "duration": 3.199,
      "text": "です。ただこちらにはこういう特徴があり"
    },
    {
      "start": 515.479,
      "duration": 4.12,
      "text": "ます。さあ、どちらにしますかという、"
    },
    {
      "start": 516.959,
      "duration": 6.921,
      "text": "そのお客さんにその選択肢を与えるような"
    },
    {
      "start": 519.599,
      "duration": 6.961,
      "text": "、ま、言ってみればあのぶつかり合うと"
    },
    {
      "start": 523.88,
      "duration": 5.36,
      "text": "よりはそのどちらでも使えますよという"
    },
    {
      "start": 526.56,
      "duration": 5.959,
      "text": "その幅広い提案ができるという意味で考え"
    },
    {
      "start": 529.24,
      "duration": 5.68,
      "text": "ていくとあの同じ会社の中にいれば"
    },
    {
      "start": 532.519,
      "duration": 5.721,
      "text": "ぶつかり合うことはないということで反射"
    },
    {
      "start": 534.92,
      "duration": 5.8,
      "text": "連合できた時のそのロームと三菱視点の"
    },
    {
      "start": 538.24,
      "duration": 4.92,
      "text": "連携プレーというのも、ま、"
    },
    {
      "start": 540.72,
      "duration": 5.44,
      "text": "インフィニオンと同様の期待ができるなと"
    },
    {
      "start": 543.16,
      "duration": 7.0,
      "text": "いう意味では、ま、非常にこれ事業ベース"
    },
    {
      "start": 546.16,
      "duration": 7.6,
      "text": "での効率化とかお客さんへの選択肢の提供"
    },
    {
      "start": 550.16,
      "duration": 7.119,
      "text": "ということで非常に期待ができるので製造"
    },
    {
      "start": 553.76,
      "duration": 6.4,
      "text": "面でのプラス面はシリコン同士でそれから"
    },
    {
      "start": 557.279,
      "duration": 6.041,
      "text": "ま、あの、ま、お客さんからの使い方だと"
    },
    {
      "start": 560.16,
      "duration": 6.32,
      "text": "か選択肢という意味で言うと、ま、その"
    },
    {
      "start": 563.32,
      "duration": 7.0,
      "text": "SICとIGBTの組み合わせというのは"
    },
    {
      "start": 566.48,
      "duration": 6.68,
      "text": "非常に意味があるんでしょうか。うん。ま"
    },
    {
      "start": 570.32,
      "duration": 4.959,
      "text": "、今後このロムの競争力の核みたいな"
    },
    {
      "start": 573.16,
      "duration": 5.96,
      "text": "ところも問われていくのかなと思うのです"
    },
    {
      "start": 575.279,
      "duration": 6.161,
      "text": "が、もちろん今あのEV市場のどもやはり"
    },
    {
      "start": 579.12,
      "duration": 6.32,
      "text": "言われていますので、今までのその"
    },
    {
      "start": 581.44,
      "duration": 6.92,
      "text": "シリコンSICの強さというのがどれほど"
    },
    {
      "start": 585.44,
      "duration": 4.72,
      "text": "にこう効いてくるのかというのも分から"
    },
    {
      "start": 588.36,
      "duration": 4.8,
      "text": "ないなというところはあるんですが、ここ"
    },
    {
      "start": 590.16,
      "duration": 6.64,
      "text": "の大山さんの見立て、そしてその第5世代"
    },
    {
      "start": 593.16,
      "duration": 6.28,
      "text": "のSICモスFETというものが、ま、出"
    },
    {
      "start": 596.8,
      "duration": 3.12,
      "text": "てきたことによる、ま、競争力の向上、"
    },
    {
      "start": 599.44,
      "duration": 1.92,
      "text": "ここら辺"
    },
    {
      "start": 599.92,
      "duration": 2.4,
      "text": "はどのように見てらっしゃいますか?"
    },
    {
      "start": 601.36,
      "duration": 3.96,
      "text": "まずです。あのEV"
    },
    {
      "start": 602.32,
      "duration": 3.0,
      "text": "市場というのは確かにあの今までもその補助金がないとなかなか育たないよと盛り上がらないよということでで例えばそのドイツが補助金打ち切りましたら中国が打ち切りましたらそうするとちょっとあの需要が低明します。"
    },
    {
      "start": 614.839,
      "duration": 5.44,
      "text": "ま、中国でまた新しい補助金のあの仕組み"
    },
    {
      "start": 618.0,
      "duration": 4.68,
      "text": "を今立ち上げたりもしてるようなんです"
    },
    {
      "start": 620.279,
      "duration": 6.601,
      "text": "けれども、そういう意味で言うとそのまだ"
    },
    {
      "start": 622.68,
      "duration": 7.68,
      "text": "あの通常のガソリニンエンジン車と十分ま"
    },
    {
      "start": 626.88,
      "duration": 6.04,
      "text": "対抗できるような市場になっていない状態"
    },
    {
      "start": 630.36,
      "duration": 6.76,
      "text": "だと思いますね。あの、時間の問題だと"
    },
    {
      "start": 632.92,
      "duration": 6.52,
      "text": "思うんですが、ただあの3月以降の原油"
    },
    {
      "start": 637.12,
      "duration": 4.04,
      "text": "価格が高騰してることもあって、またEV"
    },
    {
      "start": 639.44,
      "duration": 5.04,
      "text": "が戻ってくるんじゃないかと見方もあって"
    },
    {
      "start": 641.16,
      "duration": 6.239,
      "text": "、ま、これもあの中長期で見るべき話なの"
    },
    {
      "start": 644.48,
      "duration": 6.039,
      "text": "で、ちょっとまだ3月以降の数字は見てみ"
    },
    {
      "start": 647.399,
      "duration": 5.801,
      "text": "ないと分かりませんけれども、EVという"
    },
    {
      "start": 650.519,
      "duration": 5.281,
      "text": "のはこれからさっきもやっぱり、ま、"
    },
    {
      "start": 653.2,
      "duration": 5.079,
      "text": "立ち上がにと思ったより時間がかかっては"
    },
    {
      "start": 655.8,
      "duration": 5.36,
      "text": "いるんですけれども、ま、十分長い目で"
    },
    {
      "start": 658.279,
      "duration": 5.921,
      "text": "期待ができる市場だという見方はしてい"
    },
    {
      "start": 661.16,
      "duration": 6.6,
      "text": "ます。で、それからあのSICも今8割型"
    },
    {
      "start": 664.2,
      "duration": 5.879,
      "text": "EV向けがその需要が偏ってしまっている"
    },
    {
      "start": 667.76,
      "duration": 4.68,
      "text": "んでこういう影響を受けているんですが、"
    },
    {
      "start": 670.079,
      "duration": 5.241,
      "text": "ま、産業引き出るとかね、あのあるいは"
    },
    {
      "start": 672.44,
      "duration": 5.199,
      "text": "そのエネルギー関係のそのパワコンなんか"
    },
    {
      "start": 675.32,
      "duration": 5.4,
      "text": "にもあの非常に幅広く今使われようとして"
    },
    {
      "start": 677.639,
      "duration": 5.0,
      "text": "いるところなのでこっから先の需要には"
    },
    {
      "start": 680.72,
      "duration": 4.28,
      "text": "非常に期待したいなと。で、また今"
    },
    {
      "start": 682.639,
      "duration": 4.121,
      "text": "ちょっとご指摘のあったモセフィとSIC"
    },
    {
      "start": 685.0,
      "duration": 4.36,
      "text": "の組み合わせというのはモジュール面で"
    },
    {
      "start": 686.76,
      "duration": 4.8,
      "text": "組み合わせる商品っていうのは、ま、"
    },
    {
      "start": 689.36,
      "duration": 4.479,
      "text": "まさにあのローマが投資版に目をつけたの"
    },
    {
      "start": 691.56,
      "duration": 4.32,
      "text": "はこの組み合わせによって新しい提案が"
    },
    {
      "start": 693.839,
      "duration": 5.161,
      "text": "できるようになるぞということで、で、"
    },
    {
      "start": 695.88,
      "duration": 5.199,
      "text": "ここら辺は今までロームにはそれができ"
    },
    {
      "start": 699.0,
      "duration": 3.76,
      "text": "なかったのが投資場と組むことによって"
    },
    {
      "start": 701.079,
      "duration": 5.121,
      "text": "スムーズにできるようになるぞという期待"
    },
    {
      "start": 702.76,
      "duration": 5.72,
      "text": "もあるので、この辺も実はあのずっと"
    },
    {
      "start": 706.2,
      "duration": 4.6,
      "text": "ドイツ、ドイツのインフィニオンにの工人"
    },
    {
      "start": 708.48,
      "duration": 2.96,
      "text": "を生してきたところでもあるので、ま、"
    },
    {
      "start": 710.8,
      "duration": 3.64,
      "text": "こういうところ"
    },
    {
      "start": 711.44,
      "duration": 3.0,
      "text": "は、ま、両者が組み合わさることによって強みを発揮してもらいたいなと思ってます。"
    },
    {
      "start": 716.76,
      "duration": 3.0,
      "text": "では最後にですね、今日本勢が本当に向き合うべき相手は誰なのかというところも含めてですね、何かメッセージがあればお願いいたします。"
    },
    {
      "start": 724.959,
      "duration": 4.841,
      "text": "ま、今まで日本のパワー反動、ま、パワー"
    },
    {
      "start": 727.079,
      "duration": 5.32,
      "text": "に限らないんですが、その、ま、合体さ"
    },
    {
      "start": 729.8,
      "duration": 5.24,
      "text": "せようとするとどちらかというと、その、"
    },
    {
      "start": 732.399,
      "duration": 5.481,
      "text": "ま、一緒になって世界で戦える会社になり"
    },
    {
      "start": 735.04,
      "duration": 4.68,
      "text": "ましょうというよりは、お互いが組み合っ"
    },
    {
      "start": 737.88,
      "duration": 4.44,
      "text": "た時にどっちが上手を取るかというその"
    },
    {
      "start": 739.72,
      "duration": 5.0,
      "text": "組み手争いが目立ってくるという残念な"
    },
    {
      "start": 742.32,
      "duration": 4.68,
      "text": "ことが非常に多かったんですね。ま、あの"
    },
    {
      "start": 744.72,
      "duration": 5.08,
      "text": "、今までエルピーラとかルネサスとかが"
    },
    {
      "start": 747.0,
      "duration": 5.279,
      "text": "できた時には割とスムーズにできたんです"
    },
    {
      "start": 749.8,
      "duration": 6.479,
      "text": "が、これはあの、もう1つちょっとあの、"
    },
    {
      "start": 752.279,
      "duration": 7.281,
      "text": "非常に言葉選ばずに申し上げると、親会社"
    },
    {
      "start": 756.279,
      "duration": 6.36,
      "text": "が反動体事業をディラム事業を切り離し"
    },
    {
      "start": 759.56,
      "duration": 6.0,
      "text": "たくて、ま、外へ出てきたとちょっとあの"
    },
    {
      "start": 762.639,
      "duration": 6.32,
      "text": "、どっちかというとネガティブな同期が"
    },
    {
      "start": 765.56,
      "duration": 6.44,
      "text": "含まれているので、で、ま、あの、連結"
    },
    {
      "start": 768.959,
      "duration": 5.56,
      "text": "から切り離された側にそういう組み手争い"
    },
    {
      "start": 772.0,
      "duration": 5.72,
      "text": "というのがこういう時には発生していない"
    },
    {
      "start": 774.519,
      "duration": 7.361,
      "text": "んですが、今回のようにパワー反動体は"
    },
    {
      "start": 777.72,
      "duration": 7.919,
      "text": "日本勢がまだ強くて世界と戦えるぞとなっ"
    },
    {
      "start": 781.88,
      "duration": 5.48,
      "text": "た時に新会社のじゃあ誰が主験を握るのか"
    },
    {
      "start": 785.639,
      "duration": 4.721,
      "text": "という組点争いってのはどうしても"
    },
    {
      "start": 787.36,
      "duration": 5.159,
      "text": "やっぱり避けられないというところあり"
    },
    {
      "start": 790.36,
      "duration": 4.52,
      "text": "ますね。で、そういうことしてる場合じゃ"
    },
    {
      "start": 792.519,
      "duration": 6.68,
      "text": "ないんだというのは外野私なんかから言う"
    },
    {
      "start": 794.88,
      "duration": 6.12,
      "text": "の申し上げるのは簡単なんですが、本当は"
    },
    {
      "start": 799.199,
      "duration": 3.921,
      "text": "ドイツのインフィニオの背中を追っかけて"
    },
    {
      "start": 801.0,
      "duration": 4.199,
      "text": "もらいたい、あるいは中国人がこれから"
    },
    {
      "start": 803.12,
      "duration": 5.079,
      "text": "立ち上がってくるところをきちんと牽制し"
    },
    {
      "start": 805.199,
      "duration": 6.64,
      "text": "てもらいたいという、そういう思いで世界"
    },
    {
      "start": 808.199,
      "duration": 5.561,
      "text": "との戦う事故をってもらいたいという目を"
    },
    {
      "start": 811.839,
      "duration": 4.321,
      "text": "そっちに向けていただきたいと思い、ま、"
    },
    {
      "start": 813.76,
      "duration": 4.48,
      "text": "本音として非常にです。ま、今後も多分"
    },
    {
      "start": 816.16,
      "duration": 4.039,
      "text": "東島の件含めてアップデートあると思い"
    },
    {
      "start": 818.24,
      "duration": 2.64,
      "text": "ますので、引き続き山さんどうぞよろしく"
    },
    {
      "start": 820.199,
      "duration": 3.681,
      "text": "お願いいたします。"
    },
    {
      "start": 820.88,
      "duration": 3.0,
      "text": "ありがとうございました。"
    },
    {
      "start": 824.76,
      "duration": 3.0,
      "text": "ピボットアプリで動画を視聴するとマイルが溜まり、豪華特定に応募できます。定番の"
    },
    {
      "start": 830.519,
      "duration": 3.801,
      "text": "Amazonギフト券図書、さらには毎月"
    },
    {
      "start": 833.8,
      "duration": 3.2,
      "text": "MC"
    },
    {
      "start": 834.32,
      "duration": 3.12,
      "text": "厳選のプレゼントもご用意しております。"
    },
    {
      "start": 837.0,
      "duration": 3.44,
      "text": "YouTube"
    },
    {
      "start": 837.44,
      "duration": 3.0,
      "text": "視聴だけでは得られない特典をボットアプリでお楽しみください。"
    },
    {
      "start": 854.959,
      "duration": 3.0,
      "text": "お"
    }
  ]
}