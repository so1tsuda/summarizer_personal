    {
      "start": 794.12,
      "duration": 6.399,
      "text": "てみましょうということなんですけど、"
    },
    {
      "start": 796.399,
      "duration": 8.761,
      "text": "東目は最後が続いていて、2026年3月"
    },
    {
      "start": 800.519,
      "duration": 8.361,
      "text": "期も最後撃を更新した模様です。JR東海"
    },
    {
      "start": 805.16,
      "duration": 7.0,
      "text": "もリニア中央新幹線の問題を除東海道新"
    },
    {
      "start": 808.88,
      "duration": 6.28,
      "text": "幹線は非常に好調で成長性があり、"
    },
    {
      "start": 812.16,
      "duration": 6.64,
      "text": "2025年3月期に続いて2026年3月"
    },
    {
      "start": 815.16,
      "duration": 5.64,
      "text": "期も、え、最高を更新した模様です。で、"
    },
    {
      "start": 818.8,
      "duration": 5.279,
      "text": "ちょっと飛ばして安田走行なんですけど、"
    },
    {
      "start": 820.8,
      "duration": 7.159,
      "text": "2020年3月期以来、え、最高を更新し"
    },
    {
      "start": 824.079,
      "duration": 7.801,
      "text": "てないんですけど、2026年3月期には"
    },
    {
      "start": 827.959,
      "duration": 7.721,
      "text": "最高を更新したという風に予想しています"
    },
    {
      "start": 831.88,
      "duration": 6.16,
      "text": "。ホールディングスはちょっと最高遠い"
    },
    {
      "start": 835.68,
      "duration": 4.88,
      "text": "てるんですけれども、そんなに成長性が"
    },
    {
      "start": 838.04,
      "duration": 5.799,
      "text": "高いとは思っていませんけれども、中長期"
    },
    {
      "start": 840.56,
      "duration": 6.76,
      "text": "的に緩やかに業績は拡大するだろうという"
    },
    {
      "start": 843.839,
      "duration": 6.321,
      "text": "風に思っています。日本優先は2023年"
    },
    {
      "start": 847.32,
      "duration": 5.12,
      "text": "3月期以来、え、最高からまたドンと落ち"
    },
    {
      "start": 850.16,
      "duration": 4.32,
      "text": "てる。利益が落ちてるところで、今後とも"
    },
    {
      "start": 852.44,
      "duration": 4.8,
      "text": "利益は大きく荒れるとは思うんですけども"
    },
    {
      "start": 854.48,
      "duration": 5.64,
      "text": "、利益のトレンドとしては、え、伸びて"
