    {
      "start": 761.24,
      "duration": 6.24,
      "text": "言っていいと思います。REがちょっと物"
    },
    {
      "start": 764.68,
      "duration": 6.76,
      "text": "足りないですね。10%以上はあるといい"
    },
    {
      "start": 767.48,
      "duration": 7.28,
      "text": "んですけれども、ま、どこも10%"
    },
    {
      "start": 771.44,
      "duration": 7.56,
      "text": "に達していないというところです。ま、"
    },
    {
      "start": 774.76,
      "duration": 7.6,
      "text": "それでも東目JR東海日本優先は7%近"
    },
    {
      "start": 779.0,
      "duration": 6.6,
      "text": "から9%あって、そんなに問題ないという"
    },
    {
      "start": 782.36,
      "duration": 5.839,
      "text": "風に思います。王子はちょっと低いですね"
