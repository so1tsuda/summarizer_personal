    {
      "start": 710.44,
      "duration": 7.24,
      "text": "ます。じゃあこういった会社の財務内容、"
    },
    {
      "start": 714.839,
      "duration": 5.281,
      "text": "ROE成長性ってどうなんでしょうかと"
    },
    {
      "start": 717.68,
      "duration": 5.76,
      "text": "いうことで、ちょっと簡単に、え、指標で"
    },
    {
      "start": 720.12,
      "duration": 5.92,
      "text": "チェックしますね。ROE、え、これは"
    },
    {
      "start": 723.44,
      "duration": 4.16,
      "text": "今期の予想ROEですから、これいつも"
    },
    {
      "start": 726.04,
      "duration": 4.12,
      "text": "この数字になるというわけじゃないです。"
    },
    {
      "start": 727.6,
      "duration": 6.0,
      "text": "今たまたまこういう、え、水準だという"
    },
    {
      "start": 730.16,
      "duration": 5.479,
      "text": "ことです。自己資本比率だけで財務内容を"
    },
    {
      "start": 733.6,
      "duration": 4.72,
      "text": "判断するのはちょっと危険ですけど、ま、"
    },
    {
      "start": 735.639,
      "duration": 6.0,
      "text": "自己資本比率も、ま、見てみましょうと。"
    },
    {
      "start": 738.32,
      "duration": 6.48,
      "text": "で、準利益最後更新し続けてるんですか?"
    },
    {
      "start": 741.639,
      "duration": 5.121,
      "text": "過去最後を上げた決算機を出しています。"
    },
    {
      "start": 744.8,
      "duration": 4.44,
      "text": "で、まず自己使用比率見ていただきたいん"
    },
    {
      "start": 746.76,
      "duration": 4.84,
      "text": "ですけど、これどれも40%超えてて、"
    },
    {
      "start": 749.24,
      "duration": 5.52,
      "text": "財務内容は良行と言っていいと思います。"
