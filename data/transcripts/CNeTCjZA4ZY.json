      "start": 609.32,
      "duration": 7.84,
      "text": "たEV、つまりKEVが販売されています"
    },
    {
      "start": 612.64,
      "duration": 7.16,
      "text": "。具体的にはHONDAのN1や日産の桜"
    },
    {
      "start": 617.16,
      "duration": 6.0,
      "text": "などがあるんですけども日本メーカーにも"
    },
    {
      "start": 619.8,
      "duration": 6.0,
      "text": "チャンスがあるのか伊東中双権の深尾"
    },
    {
      "start": 623.16,
      "duration": 5.919,
      "text": "三史郎エクゼクティブフェローに話を聞き"
    },
    {
      "start": 625.8,
      "duration": 3.279,
      "text": "ました。"
    },
    {
      "start": 632.36,
      "duration": 6.159,
      "text": "プラスに働く可能性はあるという風に考え"
    },
    {
      "start": 635.16,
      "duration": 7.359,
      "text": "てます。で、それはですね、あの、奥の"
    },
    {
      "start": 638.519,
      "duration": 7.921,
      "text": "あの日本の自動車メーカーは、え、やはり"
    },
    {
      "start": 642.519,
      "duration": 8.401,
      "text": "あの方者を含む、えっと、大衆者で、ま、"
    },
    {
      "start": 646.44,
      "duration": 8.04,
      "text": "世界を上げてきたという、ま、歴史もあっ"
    },
    {
      "start": 650.92,
      "duration": 6.64,
      "text": "てですね、え、アメリカですとか中国と"
    },
    {
      "start": 654.48,
      "duration": 7.68,
      "text": "いったいわゆるDセグメントで中型車が"
    },
    {
      "start": 657.56,
      "duration": 6.88,
      "text": "主体の市場よりも、あの、え、Bセグメン"
    },
    {
      "start": 662.16,
      "duration": 5.479,
      "text": "トって言われるですね、サブコンパクト化"
    },
    {
      "start": 664.44,
      "duration": 6.24,
      "text": "を中心にやはり世界を大きく上げてきたと"
    },
    {
      "start": 667.639,
      "duration": 6.64,
      "text": "いう、え、過去の経験がありますので、"
    },
    {
      "start": 670.68,
      "duration": 7.0,
      "text": "日本社にとっては有利になりるという風な"
    },
    {
      "start": 674.279,
      "duration": 6.881,
      "text": "あの見方をしてます。アメリカと中国って"
    },
    {
      "start": 677.68,
      "duration": 8.12,
      "text": "いうのは、えっと、車の、え、を走らせる"
    },
    {
      "start": 681.16,
      "duration": 7.679,
      "text": "、え、走行か、えとは環境とかが要するに"
    },
    {
      "start": 685.8,
      "duration": 5.32,
      "text": "かなり長い距離高速で走ったりとかするっ"
    },
    {
      "start": 688.839,
      "duration": 4.481,
      "text": "ていうとこにおいてはアメリカと中国って"
    },
    {
      "start": 691.12,
      "duration": 4.159,
      "text": "いうのは、えっと、道の構造も含めて非常"
    },
    {
      "start": 693.32,
      "duration": 4.44,
      "text": "に似てるんですけど、先ほどお伝えした"
    },
    {
      "start": 695.279,
      "duration": 5.441,
      "text": "ように、え、ヨーロッパっていうの都市"
    },
    {
      "start": 697.76,
      "duration": 6.48,
      "text": "国家の集まりですので、え、日本と"
    },
    {
      "start": 700.72,
      "duration": 7.559,
      "text": "ヨーロッパはどちらかというと地下、え、"
    },
    {
      "start": 704.24,
      "duration": 7.839,
      "text": "道幅、狭道幅でも山道でもっていう特に"
    },
    {
      "start": 708.279,
      "duration": 6.24,
      "text": "スイスとかフランスの街の中とかイタリア"
    },
    {
      "start": 712.079,
      "duration": 6.401,
      "text": "の街の中っていうのは大きな車って実は"
    },
    {
      "start": 714.519,
      "duration": 3.961,
      "text": "走ってないんですね。あんまり"
    },
    {
      "start": 721.44,
      "duration": 4.04,
      "text": "全ての日本の自動メーカーにとっては"
    },
    {
      "start": 723.72,
      "duration": 4.48,
      "text": "プラスかというとそうではないんですけど"
    },
    {
      "start": 725.48,
      "duration": 5.0,
      "text": "もヨーロッパに向上を持っている日本の"
    },
    {
      "start": 728.2,
      "duration": 5.12,
      "text": "自動車ブランドにとって追い風となると"
    },
    {
      "start": 730.48,
      "duration": 5.12,
      "text": "いうのが正確な表現になりますね。"
    },
    {
      "start": 733.32,
      "duration": 7.04,
      "text": "ヨーロッパにとってリスクとして考え"
    },
    {
      "start": 735.6,
      "duration": 7.32,
      "text": "られるのは中国税が、え、小型EVでも"
    },
    {
      "start": 740.36,
      "duration": 4.96,
      "text": "中国へ作ってそれでヨーロッパに輸出"
    },
    {
      "start": 742.92,
      "duration": 4.4,
      "text": "するって流れが強くなってしまうと"
    },
    {
      "start": 745.32,
      "duration": 4.36,
      "text": "ヨーロッパにおいてはやっぱり雇用が奪わ"
    },
    {
      "start": 747.32,
      "duration": 5.24,
      "text": "れるというリスクがありますのでいきなり"
    },
    {
      "start": 749.68,
      "duration": 6.719,
      "text": "で生産するというのは条件として上げられ"
    },
    {
      "start": 752.56,
      "duration": 6.56,
      "text": "ますね。の観点で言うと、えっと、鈴木が"
    },
    {
      "start": 756.399,
      "duration": 5.56,
      "text": "ハンガリーの工場ありますので、え、この"
    },
    {
      "start": 759.12,
      "duration": 6.2,
      "text": "工場を使うですとか、えっと、実は昨年"
    },
    {
      "start": 761.959,
      "duration": 5.88,
      "text": "あの、え、ミヘモーター賞の、えっと、"
    },
    {
      "start": 765.32,
      "duration": 5.959,
      "text": "改正直前に、えっと、トヨタがチェコに"
    },
    {
      "start": 767.839,
      "duration": 7.401,
      "text": "おける、え、小型者制度向上において、え"
    },
    {
      "start": 771.279,
      "duration": 6.721,
      "text": "、EVと、大地の生産を、え、開始する"
    },
    {
      "start": 775.24,
      "duration": 4.959,
      "text": "計画ですね。2008、2028年なん"
    },
    {
      "start": 778.0,
      "duration": 5.079,
      "text": "ですけども、え、こういったものを発表し"
    },
    {
      "start": 780.199,
      "duration": 6.121,
      "text": "ていると日産はあの1番大きいヨーロッパ"
    },
    {
      "start": 783.079,
      "duration": 5.681,
      "text": "の工場はですね、あの英国にある、え、"
    },
    {
      "start": 786.32,
      "duration": 4.24,
      "text": "サンダーランド工場です。ただご存知の"
    },
    {
      "start": 788.76,
      "duration": 4.0,
      "text": "通りはブレグジットっていうものがあり"
    },
    {
      "start": 790.56,
      "duration": 5.079,
      "text": "ますので、後期のヨーロッパというところ"
    },
    {
      "start": 792.76,
      "duration": 6.079,
      "text": "で、え、今イギリスで作ってるというよう"
    },
    {
      "start": 795.639,
      "duration": 6.081,
      "text": "な形ですので、え、直接的にこのイパー"
    },
    {
      "start": 798.839,
      "duration": 6.521,
      "text": "セグメントというところの創設によって、"
    },
    {
      "start": 801.72,
      "duration": 6.479,
      "text": "え、即座に、ええ、日産においてですね、"
    },
    {
      "start": 805.36,
      "duration": 5.68,
      "text": "この波に乗れるように状況という点におい"
    },
    {
      "start": 808.199,
      "duration": 5.2,
      "text": "ては、あの、まだあの超えるべきハード"
    },
    {
      "start": 811.04,
      "duration": 5.599,
      "text": "ルっていうのはあるわけですけども、今"
    },
    {
      "start": 813.399,
      "duration": 5.281,
      "text": "すでにもうあのリーフを作ってる工場でも"
    },
    {
      "start": 816.639,
      "duration": 5.361,
      "text": "ありますし、ま、イギリにおいてはかなり"
    },
    {
      "start": 818.68,
      "duration": 5.56,
      "text": "大きな雇用を抱えた英国最大の工場にも"
    },
    {
      "start": 822.0,
      "duration": 4.88,
      "text": "なってるんですけども、そこも含めてです"
    },
    {
      "start": 824.24,
      "duration": 4.8,
      "text": "けども、えっと、ヨーロッパに工場を持っ"
    },
    {
      "start": 826.88,
      "duration": 5.759,
      "text": "ている日本の自動車メーカーにとっては"
    },
    {
      "start": 829.04,
      "duration": 6.88,
      "text": "追かれ追い風となりる。本棚はもう欧州に"
    },
    {
      "start": 832.639,
      "duration": 5.44,
      "text": "生産向上ないんです。昔イギリスにあり"
    },
    {
      "start": 835.92,
      "duration": 5.12,
      "text": "ましたし、トルコにあったんですけども"
    },
    {
      "start": 838.079,
      "duration": 6.721,
      "text": "ないんですね。なので、えっと、これ"
    },
    {
      "start": 841.04,
      "duration": 7.719,
      "text": "ホンダが生き内で、え、EAを作ってって"
    },
    {
      "start": 844.8,
      "duration": 7.68,
      "text": "いう議論は実はできないですね。向上がれ"
    },
    {
      "start": 848.759,
      "duration": 6.08,
      "text": "ば日本からKV社を輸出する可能性はある"
    },
    {
      "start": 852.48,
      "duration": 5.64,
      "text": "のでしょうか?"
    },
    {
      "start": 854.839,
      "duration": 5.56,
      "text": "えっと0ではないんですけども、えっと車"
    },
    {
      "start": 858.12,
      "duration": 5.839,
      "text": "っていうのはやはり車が小さければ小さい"
    },
    {
      "start": 860.399,
      "duration": 6.12,
      "text": "ほどリハ薄いですので輸っていうところの"
    },
    {
      "start": 863.959,
      "duration": 5.841,
      "text": "コストを考えてしまうと、えっと、やらな"
    },
    {
      "start": 866.519,
      "duration": 6.0,
      "text": "いっていうとこですね。うん。で、先ほど"
    },
    {
      "start": 869.8,
      "duration": 5.24,
      "text": "おっしゃられたその日産の桜とか、えっと"
    },
    {
      "start": 872.519,
      "duration": 5.601,
      "text": "、え、N1ホondaのN1て、これ軽"
    },
    {
      "start": 875.04,
      "duration": 7.44,
      "text": "自動車ですね。平常車って基本的に日本で"
    },
    {
      "start": 878.12,
      "duration": 4.36,
      "text": "作って日本で売るものですね。"
    },
    {
      "start": 884.759,
      "duration": 6.121,
      "text": "日本が例えば強みを持っているその安全性"
    },
    {
      "start": 887.24,
      "duration": 7.12,
      "text": "の高い、え、要するに耐久性の高い経者を"
    },
    {
      "start": 890.88,
      "duration": 6.879,
      "text": "作るっていう形での企画作りとかルール"
    },
    {
      "start": 894.36,
      "duration": 5.8,
      "text": "メイキングに、え、日本としてはあの経験"
    },
    {
      "start": 897.759,
      "duration": 4.921,
      "text": "があるので、で、それをヨーロッパと一緒"
    },
    {
      "start": 900.16,
      "duration": 5.32,
      "text": "に作っていくっていうような、ま、いわば"
    },
    {
      "start": 902.68,
      "duration": 7.279,
      "text": "ルールメイキングにおいてそういうその、"
    },
    {
      "start": 905.48,
      "duration": 8.52,
      "text": "え、市場が求めるような、え、耐久性で"
    },
    {
      "start": 909.959,
      "duration": 7.12,
      "text": "安全で安心な、え、コンパクト化そのうち"
    },
    {
      "start": 914.0,
      "duration": 5.279,
      "text": "の1そして経者っていうものの企画を"
    },
    {
      "start": 917.079,
      "duration": 5.401,
      "text": "ヨーロッパと一緒にこれから作っていくっ"
    },
    {
      "start": 919.279,
      "duration": 5.641,
      "text": "ていう風になるのはあの1番美しい形では"
    },
    {
      "start": 922.48,
      "duration": 6.24,
      "text": "ありますね。"
    },
    {
      "start": 924.92,
      "duration": 6.919,
      "text": "少し話がそれですけども、ちょうどEUで"
    },
    {
      "start": 928.72,
      "duration": 6.08,
      "text": "新制度の話が出たタイミングでアメリカの"
    },
    {
      "start": 931.839,
      "duration": 6.641,
      "text": "トランプ大統領が日本を訪れた時に見た"
    },
    {
      "start": 934.8,
      "duration": 7.64,
      "text": "小型自動車をとても小さくて可いらしい車"
    },
    {
      "start": 938.48,
      "duration": 7.159,
      "text": "と表して自身のSNSでアメリカで超小型"
    },
    {
      "start": 942.44,
      "duration": 6.639,
      "text": "者の製造を承認すると投稿。関連する部署"
    },
    {
      "start": 945.639,
      "duration": 7.601,
      "text": "に規制の緩和を支持しました。ヨーロッパ"
    },
    {
      "start": 949.079,
      "duration": 6.721,
      "text": "は国が多くEU加盟国が国連などで結束し"
    },
    {
      "start": 953.24,
      "duration": 4.719,
      "text": "て意見を伝えることでルール作りをリード"
    },
    {
      "start": 955.8,
      "duration": 5.2,
      "text": "していくということがあり、ルールメイク"
    },
    {
      "start": 957.959,
      "duration": 6.281,
      "text": "の中心地とも言われていて、EU本部が"
    },
    {
      "start": 961.0,
      "duration": 5.88,
      "text": "あるブルッセルが影響を持つことから"
    },
    {
      "start": 964.24,
      "duration": 6.68,
      "text": "ブルッセル効果という言葉もあるほどです"
    },
    {
      "start": 966.88,
      "duration": 7.36,
      "text": "。今回のEUの企画に日本の軽自動車の"
    },
    {
      "start": 970.92,
      "duration": 5.479,
      "text": "企画がどこまで参考にされるのか引き続き"
    },
    {
      "start": 974.24,
      "duration": 5.959,
      "text": "注目をしていきたいと思います。以上、"
    },
    {
      "start": 976.399,
      "duration": 3.8,
      "text": "ロンドン試局からお伝えしました。"
    }
  ]
}