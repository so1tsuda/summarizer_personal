    {
      "start": 496.4,
      "duration": 5.4,
      "text": "うん言われてみればすご"
    },
    {
      "start": 499.12,
      "duration": 3.6,
      "text": "じゃこんなんで同の前にちゃんと治療してほしいですからね"
    },
