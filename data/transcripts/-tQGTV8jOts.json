    },
    {
      "start": 483.8,
      "duration": 3.2,
      "text": "確かに"
    },
    {
      "start": 484.24,
      "duration": 5.76,
      "text": "お前の思うを聞くやつをやってくれそうなんか"
    },
    {
      "start": 487.0,
      "duration": 3.0,
      "text": "思うそれはさてを聞くやそうやってくれって弱はちょっと予約してくださいって聞かなかったら意味ないですしね"
