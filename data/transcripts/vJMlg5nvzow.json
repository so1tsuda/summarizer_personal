    },
    {
      "start": 164.159,
      "duration": 6.401,
      "text": "可能性を排除できます。今夜にとっては逆"
    },
    {
      "start": 167.76,
      "duration": 5.36,
      "text": "となり値下がりした場合よりも高く買う"
    },
    {
      "start": 170.56,
      "duration": 6.08,
      "text": "ことにはなりますが、値上がりしても商売"
    },
    {
      "start": 173.12,
      "duration": 5.32,
      "text": "が破綻することはありません。要は双方に"
    },
    {
      "start": 176.64,
      "duration": 3.44,
      "text": "とってリスクを減らす仕組みだということ"
    },
    {
      "start": 178.44,
      "duration": 3.719,
      "text": "です。"
    },
    {
      "start": 180.08,
      "duration": 6.32,
      "text": "価格変動などのリスクを減らすことを"
    },
    {
      "start": 182.159,
      "duration": 6.121,
      "text": "ヘッジと表現します。つまり先物取引は"
    },
    {
      "start": 186.4,
      "duration": 4.04,
      "text": "将来の価格がどうなるか分からないという"
    },
    {
      "start": 188.28,
      "duration": 4.599,
      "text": "不安を解消するために生まれた仕組みだと"
    },
    {
      "start": 190.44,
      "duration": 5.76,
      "text": "言えます。"
    },
    {
      "start": 192.879,
      "duration": 5.881,
      "text": "ここで少し歴史の話をすると実は日本は"
    },
    {
      "start": 196.2,
      "duration": 4.399,
      "text": "世界に先けて先物取引を導入していました"
    },
    {
      "start": 198.76,
      "duration": 5.479,
      "text": "。"
    },
    {
      "start": 200.599,
      "duration": 7.241,
      "text": "江戸時代の大阪にあった同島米会社は"
    },
    {
      "start": 204.239,
      "duration": 7.441,
      "text": "1730年にできた政府公認の先物取引所"
    },
    {
      "start": 207.84,
      "duration": 6.119,
      "text": "として知られています。当時米の価格は"
    },
    {
      "start": 211.68,
      "duration": 6.32,
      "text": "天候などによって激しく変動していたため"
    },
    {
      "start": 213.959,
      "duration": 6.521,
      "text": "、先に価格を決めておく先物取引の導入は"
    },
    {
      "start": 218.0,
      "duration": 5.4,
      "text": "商人にとっては秋内の安定につがりました"
    },
    {
      "start": 220.48,
      "duration": 5.8,
      "text": "し、米価を安定させたい幕府にとっても"
    },
    {
      "start": 223.4,
      "duration": 5.6,
      "text": "都合のいいものでした。"
    },
    {
      "start": 226.28,
      "duration": 7.319,
      "text": "現代では先物取引の対象は脳物だけに"
    },
    {
      "start": 229.0,
      "duration": 8.12,
      "text": "とまらず、原油、金、通貨、株価指数など"
    },
    {
      "start": 233.599,
      "duration": 6.161,
      "text": "非常に幅広い商品に広がっています。基本"
    },
    {
      "start": 237.12,
      "duration": 5.64,
      "text": "的に価格が変動するものには先物取引が"
    },
    {
      "start": 239.76,
      "duration": 6.479,
      "text": "あると考えてもらっていいと思います。"
    },
    {
      "start": 242.76,
      "duration": 8.0,
      "text": "このように先物取引は数百年の歴史を持つ"
    },
    {
      "start": 246.239,
      "duration": 7.121,
      "text": "非常に実践的な仕組みだということです。"
    },
    {
      "start": 250.76,
      "duration": 5.08,
      "text": "ここまでで先物取引の基本的な考え方を"
    },
    {
      "start": 253.36,
      "duration": 4.439,
      "text": "説明していきましたが、ここからはもう"
    },
    {
      "start": 255.84,
      "duration": 3.519,
      "text": "少し具体的な仕組みに踏み込んでいきます"
    },
    {
      "start": 257.799,
      "duration": 4.441,
      "text": "。"
    },
    {
      "start": 259.359,
      "duration": 4.801,
      "text": "先物取引の重要な特徴を3つに絞って見て"
    },
    {
      "start": 262.24,
      "duration": 4.88,
      "text": "いきます。"
    },
    {
      "start": 264.16,
      "duration": 7.44,
      "text": "まず1つ目の特徴は期限があるということ"
    },
    {
      "start": 267.12,
      "duration": 6.799,
      "text": "です。先物取引にはいつまでに売買するか"
    },
    {
      "start": 271.6,
      "duration": 6.64,
      "text": "という期限が決まっていて、この期限の"
    },
    {
      "start": 273.919,
      "duration": 8.321,
      "text": "ことを現月と呼びます。例えば4月切りで"
    },
    {
      "start": 278.24,
      "duration": 7.799,
      "text": "あれば4月が期限、6月切りであれば6月"
    },
    {
      "start": 282.24,
      "duration": 7.239,
      "text": "が期限ということになります。このため"
    },
    {
      "start": 286.039,
      "duration": 6.72,
      "text": "例えば原油先物価格と言っても実は1つで"
    },
    {
      "start": 289.479,
      "duration": 6.801,
      "text": "はなく、現時点から見て来月受け渡しの"
    },
    {
      "start": 292.759,
      "duration": 6.081,
      "text": "契約と半年先に受け渡しの契約では値段が"
    },
    {
      "start": 296.28,
      "duration": 5.32,
      "text": "異なっています。"
    },
    {
      "start": 298.84,
      "duration": 7.04,
      "text": "2つ目の特徴は証拠金で取引するという点"
    },
    {
      "start": 301.6,
      "duration": 7.439,
      "text": "です。先物取引では必ずしも取引する金額"
    },
    {
      "start": 305.88,
      "duration": 6.64,
      "text": "の全額を用意する必要はなく、奨額の担保"
    },
    {
      "start": 309.039,
      "duration": 6.961,
      "text": "金、つまり証拠金を入れておくだけでそれ"
    },
    {
      "start": 312.52,
      "duration": 6.48,
      "text": "を上回る大きな金額の取引ができます。"
    },
    {
      "start": 316.0,
      "duration": 5.44,
      "text": "例えば100万円分の原油の取引を"
    },
    {
      "start": 319.0,
      "duration": 5.919,
      "text": "20万円程度の証拠金で行えるみたいな"
    },
    {
      "start": 321.44,
      "duration": 6.599,
      "text": "イメージです。証拠金の何倍まで扱えるか"
    },
    {
      "start": 324.919,
      "duration": 5.72,
      "text": "は商品によって異なります。このように"
    },
    {
      "start": 328.039,
      "duration": 6.081,
      "text": "少ない資金で大きな取引ができることを"
    },
    {
      "start": 330.639,
      "duration": 7.481,
      "text": "レバリッジがかかるなどと言います。"
    },
    {
      "start": 334.12,
      "duration": 6.24,
      "text": "証拠金取引は次で説明する決済と合わせて"
    },
    {
      "start": 338.12,
      "duration": 5.6,
      "text": "取引を円滑にするのに大いに役立ってい"
    },
    {
      "start": 340.36,
      "duration": 5.839,
      "text": "ますが、単に大きいお金を動かして大きな"
    },
    {
      "start": 343.72,
      "duration": 5.16,
      "text": "利益を狙うという本来の趣旨とは異なる"
    },
    {
      "start": 346.199,
      "duration": 6.56,
      "text": "使われ方もされています。この辺りも後に"
    },
    {
      "start": 348.88,
      "duration": 5.8,
      "text": "触れていきます。3つ目の特徴は実際に"
    },
    {
      "start": 352.759,
      "duration": 5.0,
      "text": "品物を受け取らなくてもいいという点です"
    },
    {
      "start": 354.68,
      "duration": 7.0,
      "text": "。これはなかなか直感的に理解しにくいん"
    },
    {
      "start": 357.759,
      "duration": 6.241,
      "text": "ですが、先物取引では期限が来る前にその"
    },
    {
      "start": 361.68,
      "duration": 7.4,
      "text": "先物取引の権利を売買することもできます"
    },
    {
      "start": 364.0,
      "duration": 7.639,
      "text": "。例えば2月の段階で4月に米100票を"
    },
    {
      "start": 369.08,
      "duration": 6.119,
      "text": "受け取る権利を300万円で買った場合で"
    },
    {
      "start": 371.639,
      "duration": 6.161,
      "text": "、この4月切りが3月になったら"
    },
    {
      "start": 375.199,
      "duration": 5.56,
      "text": "330万円で売り返されるようになってい"
    },
    {
      "start": 377.8,
      "duration": 6.519,
      "text": "た時、元々持っていた権利を売って生産"
    },
    {
      "start": 380.759,
      "duration": 6.56,
      "text": "することができます。この時300万円が"
    },
    {
      "start": 384.319,
      "duration": 5.401,
      "text": "330万円になったので30万円の利益が"
    },
    {
      "start": 387.319,
      "duration": 5.041,
      "text": "出ることになります。"
    },
    {
      "start": 389.72,
      "duration": 5.72,
      "text": "反対に3月になって相場が落ちて"
    },
    {
      "start": 392.36,
      "duration": 5.959,
      "text": "270万円になっていた場合でこれ以上"
    },
    {
      "start": 395.44,
      "duration": 6.199,
      "text": "価格が落ちるのを嫌って生産すると-"
    },
    {
      "start": 398.319,
      "duration": 6.241,
      "text": "30万円になります。このように売買の"
    },
    {
      "start": 401.639,
      "duration": 6.921,
      "text": "差額の部分についてのみ金銭の従事を行う"
    },
    {
      "start": 404.56,
      "duration": 6.96,
      "text": "決済方法を作金決済と言います。差額のみ"
    },
    {
      "start": 408.56,
      "duration": 5.72,
      "text": "が動く仕組みのため、取引全体の金額から"
    },
    {
      "start": 411.52,
      "duration": 6.48,
      "text": "すると実際に動く金額はかなり少なく済み"
    },
    {
      "start": 414.28,
      "duration": 6.96,
      "text": "、これが証拠金取引を可能にしています。"
    },
    {
      "start": 418.0,
      "duration": 5.84,
      "text": "先ほどの-30万円の場合は証拠金"
    },
    {
      "start": 421.24,
      "duration": 4.48,
      "text": "50万円が20万円に減額されることに"
    },
    {
      "start": 423.84,
      "duration": 4.56,
      "text": "なります。"
    },
    {
      "start": 425.72,
      "duration": 5.72,
      "text": "先物取引の多くは期限が来たら自動的に"
    },
    {
      "start": 428.4,
      "duration": 6.28,
      "text": "反対売買が行われ、先金決済となるものが"
    },
    {
      "start": 431.44,
      "duration": 5.56,
      "text": "多くなっているため、実際には最初に説明"
    },
    {
      "start": 434.68,
      "duration": 5.359,
      "text": "したような商品の受け渡しがある取引は"
    },
    {
      "start": 437.0,
      "duration": 5.08,
      "text": "ごく一部にとまっています。"
    },
    {
      "start": 440.039,
      "duration": 4.801,
      "text": "先物取引の全体を見るといろんなことを"
    },
    {
      "start": 442.08,
      "duration": 5.32,
      "text": "やっているように見えて実態としては参加"
    },
    {
      "start": 444.84,
      "duration": 4.919,
      "text": "者の証拠金の金額が最後に動いただけで"
    },
    {
      "start": 447.4,
      "duration": 5.6,
      "text": "あり、かなり仮想的な取引に近くなって"
    },
    {
      "start": 449.759,
      "duration": 5.88,
      "text": "いることが分かります。"
    },
    {
      "start": 453.0,
      "duration": 5.44,
      "text": "仮想的なお金の取引ではあるものの、参加"
    },
    {
      "start": 455.639,
      "duration": 4.601,
      "text": "者が先物取引を使って将来の価格変動"
    },
    {
      "start": 458.44,
      "duration": 5.24,
      "text": "リスクを抑えることができるという点には"
    },
    {
      "start": 460.24,
      "duration": 6.88,
      "text": "変わりがありません。日本の同島取引場が"
    },
    {
      "start": 463.68,
      "duration": 6.799,
      "text": "扱っている米国指数先物取引ではやはり"
    },
    {
      "start": 467.12,
      "duration": 6.56,
      "text": "実際の米の受け渡しは行っておらず全国の"
    },
    {
      "start": 470.479,
      "duration": 6.041,
      "text": "平均価を予想する質同島米平均を対象と"
    },
    {
      "start": 473.68,
      "duration": 6.04,
      "text": "する先物取引となっていて全てはお金で"
    },
    {
      "start": 476.52,
      "duration": 5.84,
      "text": "決済が行われますがこれを利用すれば"
    },
    {
      "start": 479.72,
      "duration": 5.4,
      "text": "思わしくない方向に価格が変動した時に"
    },
    {
      "start": 482.36,
      "duration": 5.16,
      "text": "先物取引では利益が出ていることによって"
    },
    {
      "start": 485.12,
      "duration": 5.039,
      "text": "売上や必要な資金を補填することができる"
    },
    {
      "start": 487.52,
      "duration": 4.959,
      "text": "というわけです。"
    },
    {
      "start": 490.159,
      "duration": 5.76,
      "text": "こうした特徴があるため、先物市場には"
    },
    {
      "start": 492.479,
      "duration": 6.201,
      "text": "大きく分けて2種類の参加者がいます。1"
    },
    {
      "start": 495.919,
      "duration": 6.081,
      "text": "つはヘッーと呼ばれる人たちで、実際に"
    },
    {
      "start": 498.68,
      "duration": 5.76,
      "text": "原油を使う航空会社や石油会社など価格"
    },
    {
      "start": 502.0,
      "duration": 4.24,
      "text": "変動のリスクを避けたい、ヘッしたい事業"
    },
    {
      "start": 504.44,
      "duration": 4.319,
      "text": "者です。"
    },
    {
      "start": 506.24,
      "duration": 5.6,
      "text": "これは先ほど農家との例であげたような"
    },
    {
      "start": 508.759,
      "duration": 5.2,
      "text": "使い方で、経営の安定のために先物取引を"
    },
    {
      "start": 511.84,
      "duration": 5.28,
      "text": "利用します。"
    },
    {
      "start": 513.959,
      "duration": 6.161,
      "text": "もう1つはいわゆる当期化で、実際の商品"
    },
    {
      "start": 517.12,
      "duration": 4.799,
      "text": "自体とは無関係に価格の値動きそのもので"
    },
    {
      "start": 520.12,
      "duration": 3.96,
      "text": "利益を得ようとする投資ファンドや"
    },
    {
      "start": 521.919,
      "duration": 4.641,
      "text": "トレーダーです。"
    },
    {
      "start": 524.08,
      "duration": 4.84,
      "text": "そう聞くとなんだか金儲け目当ての悪い人"
    },
    {
      "start": 526.56,
      "duration": 5.52,
      "text": "たちのように思いますが、このような参加"
    },
    {
      "start": 528.92,
      "duration": 6.2,
      "text": "者がたくさんいることで市場に十分な取引"
    },
    {
      "start": 532.08,
      "duration": 5.84,
      "text": "、流動性が生まれ、実際に必要としている"
    },
    {
      "start": 535.12,
      "duration": 5.88,
      "text": "人たちが先物取引を利用しやすくなり、"
    },
    {
      "start": 537.92,
      "duration": 5.2,
      "text": "また多くの参加者の予想が反映された合理"
    },
    {
      "start": 541.0,
      "duration": 4.24,
      "text": "的な価格が形成されやすいと考えられてい"
    },
    {
      "start": 543.12,
      "duration": 5.279,
      "text": "ます。"
    },
    {
      "start": 545.24,
      "duration": 5.96,
      "text": "また先物取引は先物市場に参加しない人に"
    },
    {
      "start": 548.399,
      "duration": 6.241,
      "text": "とっても役に立つものです。"
    },
    {
      "start": 551.2,
      "duration": 6.72,
      "text": "先物取引価格は社会全体にとって将来価格"
    },
    {
      "start": 554.64,
      "duration": 7.08,
      "text": "の参考値になるという側面があります。"
    },
    {
      "start": 557.92,
      "duration": 7.08,
      "text": "例えばある人がビジネス上扱う商材が価格"
    },
    {
      "start": 561.72,
      "duration": 5.92,
      "text": "変動リスクの比較的高い商品である場合、"
    },
    {
      "start": 565.0,
      "duration": 5.64,
      "text": "半年や1年といった先の期間に引き渡しが"
    },
    {
      "start": 567.64,
      "duration": 5.36,
      "text": "行われるような契約を結ぶ時に金額を一体"
    },
    {
      "start": 570.64,
      "duration": 5.36,
      "text": "いくらにするのかというところで何の指標"
    },
    {
      "start": 573.0,
      "duration": 5.839,
      "text": "もなければ困ってしまいます。なるべく"
    },
    {
      "start": 576.0,
      "duration": 4.64,
      "text": "安く設定したい買手となるべく高く設定し"
    },
    {
      "start": 578.839,
      "duration": 4.44,
      "text": "たい売り手で落としどを見つけることが"
    },
    {
      "start": 580.64,
      "duration": 6.0,
      "text": "困難になり合意を形成することが難しく"
    },
    {
      "start": 583.279,
      "duration": 6.281,
      "text": "なってきます。これが市場によって形成さ"
    },
    {
      "start": 586.64,
      "duration": 5.96,
      "text": "れた将来のそのものの価格が明らかにされ"
    },
    {
      "start": 589.56,
      "duration": 7.959,
      "text": "ていれば両者が納得する形で契約を結ぶ"
    },
    {
      "start": 592.6,
      "duration": 8.2,
      "text": "ことができ非を回避することができます。"
    },
    {
      "start": 597.519,
      "duration": 5.921,
      "text": "もちろん先物価格と実際の現物価格は必ず"
    },
    {
      "start": 600.8,
      "duration": 4.92,
      "text": "しも一致するわけではありませんが、小"
    },
    {
      "start": 603.44,
      "duration": 4.24,
      "text": "取引を円滑にするという絶大な効力がある"
    },
    {
      "start": 605.72,
      "duration": 4.48,
      "text": "わけです。"
    },
    {
      "start": 607.68,
      "duration": 5.32,
      "text": "このような有要用性は価格発見機能と呼ば"
    },
    {
      "start": 610.2,
      "duration": 5.199,
      "text": "れていて、市場の存在意義の1つと考え"
    },
    {
      "start": 613.0,
      "duration": 4.36,
      "text": "られています。"
    },
    {
      "start": 615.399,
      "duration": 5.281,
      "text": "一般の人にはおよそ関係がないように"
    },
    {
      "start": 617.36,
      "duration": 7.76,
      "text": "思える先物取引も実は現代の社会経済を"
    },
    {
      "start": 620.68,
      "duration": 6.839,
      "text": "支える重要な基盤になっているわけです。"
    },
    {
      "start": 625.12,
      "duration": 5.32,
      "text": "ここまで先物取引の基本を説明していき"
    },
    {
      "start": 627.519,
      "duration": 6.521,
      "text": "ましたが、ここからはこの知識を前提にし"
    },
    {
      "start": 630.44,
      "duration": 6.399,
      "text": "て今回のイラン危機と原油先物の動きを"
    },
    {
      "start": 634.04,
      "duration": 6.0,
      "text": "読み解いていきたいと思います。"
    },
    {
      "start": 636.839,
      "duration": 5.841,
      "text": "改めて攻撃以降の流れを完結に整理すると"
    },
    {
      "start": 640.04,
      "duration": 5.039,
      "text": "2月28日に戦闘が始まって以来、"
    },
    {
      "start": 642.68,
      "duration": 5.08,
      "text": "ホルムズ海峡の封鎖や周辺国のエネルギー"
    },
    {
      "start": 645.079,
      "duration": 6.481,
      "text": "関連施設などへの攻撃によってエネルギー"
    },
    {
      "start": 647.76,
      "duration": 5.96,
      "text": "市場に甚大な影響が出ています。単に原油"
    },
    {
      "start": 651.56,
      "duration": 5.04,
      "text": "やLNGのタンカーが海峡を通れないと"
    },
    {
      "start": 653.72,
      "duration": 5.72,
      "text": "いうだけでなく、巨大なLNG施設や"
    },
    {
      "start": 656.6,
      "duration": 5.72,
      "text": "声優所が一時閉鎖に追い込まれるなど"
    },
    {
      "start": 659.44,
      "duration": 5.959,
      "text": "エネルギー供給面への打撃は深刻であり、"
    },
    {
      "start": 662.32,
      "duration": 5.519,
      "text": "ドバ原油先物価格などは年の2倍以上に"
    },
    {
      "start": 665.399,
      "duration": 4.321,
      "text": "価格が跳ね上がるなど大変な事態となって"
    },
    {
      "start": 667.839,
      "duration": 4.44,
      "text": "います。"
    },
    {
      "start": 669.72,
      "duration": 4.96,
      "text": "ではなぜ先物価格がこれほど激しく動いた"
    },
    {
      "start": 672.279,
      "duration": 6.36,
      "text": "のか、主に3つのポイントが考えられます"
    },
    {
      "start": 674.68,
      "duration": 6.32,
      "text": "。まず1つ目はシンプルに供給が減りそう"
    },
    {
      "start": 678.639,
      "duration": 5.481,
      "text": "という予測です。"
    },
    {
      "start": 681.0,
      "duration": 6.079,
      "text": "ホルムズ海峡が事実上封鎖され、また石油"
    },
    {
      "start": 684.12,
      "duration": 6.24,
      "text": "施設などが稼働を止めたことで中東からの"
    },
    {
      "start": 687.079,
      "duration": 6.961,
      "text": "原油供給が滞る可能性が高まり原油不足を"
    },
    {
      "start": 690.36,
      "duration": 7.279,
      "text": "見越した会が殺頭しました。先ほど説明し"
    },
    {
      "start": 694.04,
      "duration": 6.799,
      "text": "た通り先物取引は将来の価格を今のうちに"
    },
    {
      "start": 697.639,
      "duration": 6.121,
      "text": "決める取引なので先々の供給が減ると予測"
    },
    {
      "start": 700.839,
      "duration": 4.961,
      "text": "されれば当然先物価格は上がることになり"
    },
    {
      "start": 703.76,
      "duration": 4.319,
      "text": "ます。"
    },
    {
      "start": 705.8,
      "duration": 4.479,
      "text": "石油などを仕入れて売る会社にとっては"
    },
    {
      "start": 708.079,
      "duration": 5.2,
      "text": "先々に調達できなくなることが1番怖いの"
    },
    {
      "start": 710.279,
      "duration": 6.641,
      "text": "でこれを買う権利は取り合い状態となり"
    },
    {
      "start": 713.279,
      "duration": 6.161,
      "text": "高値で取引されることになります。"
    },
    {
      "start": 716.92,
      "duration": 5.96,
      "text": "2つ目は不確実性が価格を押し上げると"
    },
    {
      "start": 719.44,
      "duration": 6.839,
      "text": "いう要因です。すでに確定している供給の"
    },
    {
      "start": 722.88,
      "duration": 5.84,
      "text": "途に加えて戦下が拡大するかもしれない。"
    },
    {
      "start": 726.279,
      "duration": 5.521,
      "text": "ホルムズ海峡の高校が安定するのか分から"
    },
    {
      "start": 728.72,
      "duration": 5.88,
      "text": "ない。原油や天然ガス施設がもっと大きな"
    },
    {
      "start": 731.8,
      "duration": 6.12,
      "text": "被害に合うかもしれない。残した先行きの"
    },
    {
      "start": 734.6,
      "duration": 7.239,
      "text": "見えなさ、変動リスクの高さは先々の予想"
    },
    {
      "start": 737.92,
      "duration": 6.12,
      "text": "価格に上乗せ圧力をかけます。要はどう"
    },
    {
      "start": 741.839,
      "duration": 4.761,
      "text": "なるか分からない分、最終的な取り分が"
    },
    {
      "start": 744.04,
      "duration": 5.0,
      "text": "大きくなければ割に合わないと市場参加者"
    },
    {
      "start": 746.6,
      "duration": 5.44,
      "text": "が判断するということであり、将来の価格"
    },
    {
      "start": 749.04,
      "duration": 5.28,
      "text": "は高くなっていきます。分からないこと"
    },
    {
      "start": 752.04,
      "duration": 4.52,
      "text": "自体が価格を押し上げる力を持っていると"
    },
    {
      "start": 754.32,
      "duration": 5.72,
      "text": "いうことです。"
    },
    {
      "start": 756.56,
      "duration": 7.079,
      "text": "そして3つ目は当期化の動きです。先に"
    },
    {
      "start": 760.04,
      "duration": 6.599,
      "text": "触れた通り先物市場には実際に取引を必要"
    },
    {
      "start": 763.639,
      "duration": 6.081,
      "text": "とする人以外に取引の差額による利益を"
    },
    {
      "start": 766.639,
      "duration": 5.601,
      "text": "追求する登期化が多数参加していますが、"
    },
    {
      "start": 769.72,
      "duration": 5.559,
      "text": "原油価格が上がり始めるとまだもっと"
    },
    {
      "start": 772.24,
      "duration": 6.599,
      "text": "上がるはずという思惑で買が買連鎖が起き"
    },
    {
      "start": 775.279,
      "duration": 6.481,
      "text": "ます。反対に危機が収束するかもという"
    },
    {
      "start": 778.839,
      "duration": 5.44,
      "text": "空気になれば売りが先行して一気に価格が"
    },
    {
      "start": 781.76,
      "duration": 4.439,
      "text": "落ちる場面を作ります。"
    },
    {
      "start": 784.279,
      "duration": 4.401,
      "text": "これは実際にどれくらい足りなくなるかと"
    },
    {
      "start": 786.199,
      "duration": 6.2,
      "text": "か、予想されるシナリオの幅がどの程度か"
    },
    {
      "start": 788.68,
      "duration": 7.32,
      "text": "といった基礎的な情報を超えて勢いや恐怖"
    },
    {
      "start": 792.399,
      "duration": 5.841,
      "text": "、心理的な転換といった計り知れない力を"
    },
    {
      "start": 796.0,
      "duration": 6.12,
      "text": "増幅させる言動力になっていると考えられ"
    },
    {
      "start": 798.24,
      "duration": 6.52,
      "text": "ます。特に今回のコルムズ海峡の風鎖は"
    },
    {
      "start": 802.12,
      "duration": 5.719,
      "text": "かなり以前から懸念されていたもので、"
    },
    {
      "start": 804.76,
      "duration": 5.879,
      "text": "事前の資産として完全風鎖となれば原油1"
    },
    {
      "start": 807.839,
      "duration": 4.961,
      "text": "バレル150ドルといった具体的な水準"
    },
    {
      "start": 810.639,
      "duration": 3.76,
      "text": "まで提示されていたため、ネガティブな"
    },
    {
      "start": 812.8,
      "duration": 4.8,
      "text": "ニュース、ポジティブなニュースどちらに"
    },
    {
      "start": 814.399,
      "duration": 5.961,
      "text": "もかなり敏感に反応しています。結果とし"
    },
    {
      "start": 817.6,
      "duration": 5.88,
      "text": "て1日に10%を超えるような乱行が発生"
    },
    {
      "start": 820.36,
      "duration": 6.12,
      "text": "していると言えます。"
    },
    {
      "start": 823.48,
      "duration": 5.64,
      "text": "ここで先ほど説明した現月の話を実例で見"
    },
    {
      "start": 826.48,
      "duration": 4.599,
      "text": "てみると市場の同向がよりはっきりと見え"
    },
    {
      "start": 829.12,
      "duration": 5.079,
      "text": "てきます。"
    },
    {
      "start": 831.079,
      "duration": 7.481,
      "text": "2026年3月26日の時点では直近の"
    },
    {
      "start": 834.199,
      "duration": 7.521,
      "text": "限月ほど価格が高く半年先、1年先と先の"
    },
    {
      "start": 838.56,
      "duration": 7.0,
      "text": "減月になるほど価格が安くなっています。"
    },
    {
      "start": 841.72,
      "duration": 6.6,
      "text": "この手前が高く先が安い状態を専門用語で"
    },
    {
      "start": 845.56,
      "duration": 5.04,
      "text": "バックデーションと呼びますが、これは"
    },
    {
      "start": 848.32,
      "duration": 5.319,
      "text": "当面供給懸念があり、原油の取り合いが"
    },
    {
      "start": 850.6,
      "duration": 6.0,
      "text": "発生する。でも半年後には紛争が落ち着い"
    },
    {
      "start": 853.639,
      "duration": 5.76,
      "text": "て供給も回復するだろうという市場参加者"
    },
    {
      "start": 856.6,
      "duration": 5.359,
      "text": "全体の見立てが現月ごとの価格差として"
    },
    {
      "start": 859.399,
      "duration": 5.601,
      "text": "現れているということです。"
    },
    {
      "start": 861.959,
      "duration": 5.521,
      "text": "実際EIA米国エネルギー情報局の見通し"
    },
    {
      "start": 865.0,
      "duration": 6.32,
      "text": "でも大体同じような予測がなされています"
    },
    {
      "start": 867.48,
      "duration": 6.599,
      "text": "。ちなみに逆のパターンもあり先の減月"
    },
    {
      "start": 871.32,
      "duration": 5.519,
      "text": "ほど価格が高い状態であればこれは混タ語"
    },
    {
      "start": 874.079,
      "duration": 6.0,
      "text": "と呼ばれ市場がこの先もっと悪くなると見"
    },
    {
      "start": 876.839,
      "duration": 6.281,
      "text": "ていることを示します。このように現との"
    },
    {
      "start": 880.079,
      "duration": 4.68,
      "text": "価格差を見ることで市場参加者が将来を"
    },
    {
      "start": 883.12,
      "duration": 4.32,
      "text": "どう見ているのかを読み取ることができる"
    },
    {
      "start": 884.759,
      "duration": 6.161,
      "text": "わけです。"
    },
    {
      "start": 887.44,
      "duration": 5.839,
      "text": "ただしこれは今現在から考えた将来の価格"
    },
    {
      "start": 890.92,
      "duration": 5.96,
      "text": "に過ぎないため必ずそうなるということで"
    },
    {
      "start": 893.279,
      "duration": 6.24,
      "text": "はありません。半年から1年で平常に戻る"
    },
    {
      "start": 896.88,
      "duration": 5.879,
      "text": "という観測は少し楽観的すぎるという味方"
    },
    {
      "start": 899.519,
      "duration": 6.161,
      "text": "がある一方で現在はかなり先行きの不透明"
    },
    {
      "start": 902.759,
      "duration": 6.0,
      "text": "感が強く必要以上にリスクが折り込まれて"
    },
    {
      "start": 905.68,
      "duration": 5.36,
      "text": "いるという意見もあります。今後情勢が"
    },
    {
      "start": 908.759,
      "duration": 4.721,
      "text": "どう動いていくのか。これはトランプ"
    },
    {
      "start": 911.04,
      "duration": 4.28,
      "text": "大統領やイランの政権幹部ですらまだ"
    },
    {
      "start": 913.48,
      "duration": 4.88,
      "text": "分かっていないことであり、どうしようも"
    },
    {
      "start": 915.32,
      "duration": 5.92,
      "text": "ないことですが、何万人もの実務化や当期"
    },
    {
      "start": 918.36,
      "duration": 5.64,
      "text": "化の思惑が生み出す1つの答えとして先物"
    },
    {
      "start": 921.24,
      "duration": 4.839,
      "text": "価格があり、世界経済としてはやはりこれ"
    },
    {
      "start": 924.0,
      "duration": 5.079,
      "text": "を重要な指標として捉えていると言えます"
    },
    {
      "start": 926.079,
      "duration": 3.0,
      "text": "。"
    },
    {
      "start": 930.6,
      "duration": 6.239,
      "text": "それでは今回のまとめです。先物取引とは"
    },
    {
      "start": 934.36,
      "duration": 4.839,
      "text": "将来の価格をあらかじめ決める取引で、"
    },
    {
      "start": 936.839,
      "duration": 5.68,
      "text": "元々は価格変動のリスクを避けるために"
    },
    {
      "start": 939.199,
      "duration": 6.361,
      "text": "生まれた仕組みですが、証拠金取引や金"
    },
    {
      "start": 942.519,
      "duration": 5.201,
      "text": "決済といった特徴があるため様々な思惑を"
    },
    {
      "start": 945.56,
      "duration": 6.079,
      "text": "持った参加者がいてこれが成立しています"
    },
    {
      "start": 947.72,
      "duration": 6.919,
      "text": "。現在のイラン危機では目先の供給不安を"
    },
    {
      "start": 951.639,
      "duration": 6.0,
      "text": "起点として不確実性の高まりと登期筋の"
    },
    {
      "start": 954.639,
      "duration": 6.481,
      "text": "動きが重なって原油先物価格が激しく動い"
    },
    {
      "start": 957.639,
      "duration": 5.801,
      "text": "ていますが現月ごとの価格差を見ると市場"
    },
    {
      "start": 961.12,
      "duration": 5.399,
      "text": "参加者が将来をどう見ているかがある程度"
    },
    {
      "start": 963.44,
      "duration": 4.639,
      "text": "読み取れるということでした。"
    },
    {
      "start": 966.519,
      "duration": 3.32,
      "text": "それでは今回も最後まで見てくれて"
    },
    {
      "start": 968.079,
      "duration": 5.041,
      "text": "ありがとうございました。またお会いし"
    },
    {
      "start": 969.839,
      "duration": 3.281,
      "text": "ましょう。"
    }
  ]
}