    {
      "start": 393.28,
      "duration": 3.88,
      "text": "そうすると俺の方を見て考えるんじゃない"
    },
    {
      "start": 395.56,
      "duration": 3.96,
      "text": "。もっとお客さんのこと考えろって言われ"
    },
    {
      "start": 397.16,
      "duration": 5.599,
      "text": "てずっとずれが起きてきちゃうんですね。"
    },
    {
      "start": 399.52,
      "duration": 6.119,
      "text": "これあくまでも一例です。あくまでも一例"
    },
    {
      "start": 402.759,
      "duration": 6.44,
      "text": "なんですけども、ここには実は本質がある"
    },
    {
      "start": 405.639,
      "duration": 6.56,
      "text": "んですね。当時の視店長何してたか?実は"
    },
    {
      "start": 409.199,
      "duration": 5.961,
      "text": "指示じゃなくて感想を伝えてたんですね。"
    },
    {
      "start": 412.199,
      "duration": 6.56,
      "text": "これ優しい方だとめちゃめちゃ起きるん"
    },
    {
      "start": 415.16,
      "duration": 6.64,
      "text": "です。できればもう訪問頻度を上げられる"
    },
    {
      "start": 418.759,
      "duration": 6.681,
      "text": "なら上げてみるといいかもしれないね。"
    },
    {
      "start": 421.8,
      "duration": 6.399,
      "text": "これ実はですね、指示じゃなくて感想なん"
    },
    {
      "start": 425.44,
      "duration": 5.08,
      "text": "ですよね。できれば手が開いてたらやれば"
    },
    {
      "start": 428.199,
      "duration": 4.961,
      "text": "いいのかな。これはやらなきゃいけない"
    },
    {
      "start": 430.52,
      "duration": 6.079,
      "text": "ことなのかな。現場分からないんです。"
    },
    {
      "start": 433.16,
      "duration": 6.28,
      "text": "あくまでも人によってはこれを感想と捉え"
    },
    {
      "start": 436.599,
      "duration": 5.201,
      "text": "てあ、四店長はそういう考えなんですね。"
    },
    {
      "start": 439.44,
      "duration": 4.759,
      "text": "ま、僕は違うやり方でもやりますよねって"
    },
    {
      "start": 441.8,
      "duration": 5.04,
      "text": "人によって解釈が異なってきちゃったん"
    },
    {
      "start": 444.199,
      "duration": 4.881,
      "text": "ですね。で、これもめちゃめちゃ皆さん"
    },
    {
      "start": 446.84,
      "duration": 4.96,
      "text": "当たり前のことだって思いますよね。でも"
    },
    {
      "start": 449.08,
      "duration": 5.76,
      "text": "これやるのめっちゃ難しくないですか?"
    },
    {
      "start": 451.8,
      "duration": 4.92,
      "text": "なんかやれって言ったらトが立ちそうだし"
    },
    {
      "start": 454.84,
      "duration": 4.4,
      "text": "なんか嫌われるんじゃないかって怖いん"
    },
    {
      "start": 456.72,
      "duration": 5.159,
      "text": "ですね。でも部下目線から考えると実は"
    },
    {
      "start": 459.24,
      "duration": 6.56,
      "text": "そういうことはないんですね。この曖昧な"
    },
    {
      "start": 461.879,
      "duration": 6.801,
      "text": "言葉を使っちゃうということは実は優しい"
    },
    {
      "start": 465.8,
      "duration": 5.04,
      "text": "ようで上司の逃げになっちゃうことがある"
    },
    {
      "start": 468.68,
      "duration": 4.44,
      "text": "んです。なぜかと言うとさっきみたいに"
    },
    {
      "start": 470.84,
      "duration": 5.359,
      "text": "伝えたつもりなのに現場動いてないじゃ"
    },
    {
      "start": 473.12,
      "duration": 5.68,
      "text": "んって言って会議やって詰めちゃうって"
    },
    {
      "start": 476.199,
      "duration": 4.601,
      "text": "よく現場で起きるんですね。なので皆さん"
    },
    {
      "start": 478.8,
      "duration": 4.04,
      "text": "にはですね、例えばこういう風に変えて"
    },
    {
      "start": 480.8,
      "duration": 4.079,
      "text": "欲しい。できれば訪問頻度を上げられる"
    },
    {
      "start": 482.84,
      "duration": 4.96,
      "text": "ならあげてみるといいかもしれないとか"
    },
    {
      "start": 484.879,
      "duration": 5.921,
      "text": "営業活動で手が開けば、ま、計画の見直し"
    },
    {
      "start": 487.8,
      "duration": 5.72,
      "text": "を随時していけるといいね。ちょっと"
    },
    {
      "start": 490.8,
      "duration": 4.839,
      "text": "柔らかく言うんだけど、これはこれでいい"
    },
    {
      "start": 493.52,
      "duration": 5.2,
      "text": "んです。訪問頻度を週3回にあげて"
    },
    {
      "start": 495.639,
      "duration": 6.84,
      "text": "ください。毎月1回計画見直しの時間を"
    },
    {
      "start": 498.72,
      "duration": 6.28,
      "text": "30分作ってね。これ誰が見てもずれない"
    },
    {
      "start": 502.479,
      "duration": 6.16,
      "text": "んですね。つまり誰が聞いてもずれのない"
    },
    {
      "start": 505.0,
      "duration": 5.759,
      "text": "言葉にするというのは私は前作の書籍にも"
    },
    {
      "start": 508.639,
      "duration": 4.96,
      "text": "何回も書いたんですけどこれ仕事ができる"
    },
    {
      "start": 510.759,
      "duration": 5.881,
      "text": "人の大前提になるんですね。で、これを"
    },
    {
      "start": 513.599,
      "duration": 5.68,
      "text": "言葉にして恐れずに伝えるということなん"
    },
    {
      "start": 516.64,
      "duration": 6.16,
      "text": "ですね。なんで皆さんが今一度部下の方に"
    },
    {
      "start": 519.279,
      "duration": 6.0,
      "text": "何か指示を出してる時本当に誰が見ても"
    },
    {
      "start": 522.8,
      "duration": 5.32,
      "text": "ずれない指示になっているかどうかそして"
    },
    {
      "start": 525.279,
      "duration": 5.321,
      "text": "あなたの感想とかね、できればとか"
    },
    {
      "start": 528.12,
      "duration": 4.92,
      "text": "ちょっと遠極的な表現になってないかこれ"
    },
    {
      "start": 530.6,
      "duration": 5.679,
      "text": "を今一度見直して欲しいという風に思って"
    },
    {
      "start": 533.04,
      "duration": 3.239,
      "text": "います。"
    },
    {
      "start": 538.92,
      "duration": 4.919,
      "text": "で、2つ目はなるべく早くを今日から"
    },
    {
      "start": 541.519,
      "duration": 6.44,
      "text": "捨てる。はい。これも仕事ができるの大"
    },
    {
      "start": 543.839,
      "duration": 6.041,
      "text": "前提ですね。上司の人ほどこの早くこう"
    },
    {
      "start": 547.959,
      "duration": 3.961,
      "text": "いう言葉使わない方がいいです。あの、"
    },
    {
      "start": 549.88,
      "duration": 4.56,
      "text": "よくあるのがこのもっと綺麗にっていう風"
    },
    {
      "start": 551.92,
      "duration": 5.4,
      "text": "な言葉ありますね。はい。上司の糸は"
    },
    {
      "start": 554.44,
      "duration": 5.44,
      "text": "例えば資料を見てもっと綺麗にシンプルに"
    },
    {
      "start": 557.32,
      "duration": 5.0,
      "text": "削ぎ落として欲しいパターンと部下の解釈"
    },
    {
      "start": 559.88,
      "duration": 6.24,
      "text": "あ、じゃあもっとパステルカラーで華やか"
    },
    {
      "start": 562.32,
      "duration": 6.32,
      "text": "にちょっと資料を彩ろう。これずれてるん"
    },
    {
      "start": 566.12,
      "duration": 5.48,
      "text": "ですよね。もう一方でなるべく早くって"
    },
    {
      "start": 568.64,
      "duration": 6.16,
      "text": "先ほどの話も今日の15時までだよなと"
    },
    {
      "start": 571.6,
      "duration": 5.88,
      "text": "思いながら部下の解釈は、ま、今週の金曜"
    },
    {
      "start": 574.8,
      "duration": 5.08,
      "text": "18時までかな。で、これ何をお伝えする"
    },
    {
      "start": 577.48,
      "duration": 4.96,
      "text": "かというと綺麗とか早い。ま、こういう"
    },
    {
      "start": 579.88,
      "duration": 5.399,
      "text": "形用とか使ったりですね、先ほどのなるべ"
    },
    {
      "start": 582.44,
      "duration": 5.6,
      "text": "くっていう復習を使うとまず他人と一致"
    },
    {
      "start": 585.279,
      "duration": 5.081,
      "text": "することは絶対にないんですね。で、これ"
    },
    {
      "start": 588.04,
      "duration": 5.64,
      "text": "は前作の書籍にもしっかり書いてあるん"
    },
    {
      "start": 590.36,
      "duration": 5.64,
      "text": "ですけど、この言葉上司ほど気をつけて"
    },
    {
      "start": 593.68,
      "duration": 5.92,
      "text": "言わないと影響範囲めちゃめちゃ大きく"
    },
    {
      "start": 596.0,
      "duration": 7.32,
      "text": "なります。今までは1対1だったものが1"
    },
    {
      "start": 599.6,
      "duration": 5.84,
      "text": "対3、1対5になるんですね。人の解釈は"
    },
    {
      "start": 603.32,
      "duration": 4.92,
      "text": "5通りになっちゃいます。10通りになっ"
    },
    {
      "start": 605.44,
      "duration": 6.76,
      "text": "てしまうわけなんです。なので改めて皆"
    },
    {
      "start": 608.24,
      "duration": 6.32,
      "text": "さんこの左側のNG例ですね。ここに該当"
    },
    {
      "start": 612.2,
      "duration": 4.36,
      "text": "していないかこの動画ご覧いただいた方、"
    },
    {
      "start": 614.56,
      "duration": 4.279,
      "text": "あれ俺大丈夫かなって思って欲しいんです"
    },
    {
      "start": 616.56,
      "duration": 5.8,
      "text": "ね。なるべく早くお願いします。丁寧に"
    },
    {
      "start": 618.839,
      "duration": 6.521,
      "text": "いい感じに図とかですね。これ使いやすい"
    },
    {
      "start": 622.36,
      "duration": 6.599,
      "text": "んです日本語って。でも本来であれば数字"
    },
    {
      "start": 625.36,
      "duration": 7.08,
      "text": "とか固有名刺を使って明日の14時までと"
    },
    {
      "start": 628.959,
      "duration": 7.44,
      "text": "かメモを取りながら聞いてくれ。A41枚"
    },
    {
      "start": 632.44,
      "duration": 6.36,
      "text": "で毎朝10時と夕方17時。これ実は言葉"
    },
    {
      "start": 636.399,
      "duration": 4.761,
      "text": "に変えることができるんです。なんでこの"
    },
    {
      "start": 638.8,
      "duration": 4.68,
      "text": "慶用士とか復習を捨てることは上司として"
    },
    {
      "start": 641.16,
      "duration": 4.6,
      "text": "の責任なんだっていうことを思って欲しい"
    },
    {
      "start": 643.48,
      "duration": 5.08,
      "text": "んです。さあ、皆さん今ここまで聞いて"
    },
    {
      "start": 645.76,
      "duration": 5.04,
      "text": "どうだったでしょうか?めんどくさって"
    },
    {
      "start": 648.56,
      "duration": 4.44,
      "text": "思いますよね。そうなんです。それぐらい"
    },
    {
      "start": 650.8,
      "duration": 4.24,
      "text": "コミュニケーションって気をつけないと"
    },
    {
      "start": 653.0,
      "duration": 5.839,
      "text": "ずれが生まれるんですね。このめんどくさ"
    },
    {
      "start": 655.04,
      "duration": 6.28,
      "text": "さを上司として受け入れて1個1個緻密に"
    },
    {
      "start": 658.839,
      "duration": 7.281,
      "text": "やるだけで実はずれが起きなくなるんだっ"
    },
    {
      "start": 661.32,
      "duration": 4.8,
      "text": "てことを頭の中に入れておいてください。"
    },
    {
      "start": 668.88,
      "duration": 4.639,
      "text": "3つ目ちょっとやっていきたいと思います"
    },
    {
      "start": 670.32,
      "duration": 6.319,
      "text": "。叱るのではなく違いを伝えるという"
    },
    {
      "start": 673.519,
      "duration": 6.12,
      "text": "テーマですね。私も体育会計のコンサルに"
    },
    {
      "start": 676.639,
      "duration": 5.64,
      "text": "いたので、ま、土合も浴びせられたわけな"
    },
    {
      "start": 679.639,
      "duration": 4.721,
      "text": "んですね。だけど私の受け手としては自分"
    },
    {
      "start": 682.279,
      "duration": 3.881,
      "text": "がコンサルしてもっと能力上げなきゃいけ"
    },
    {
      "start": 684.36,
      "duration": 3.84,
      "text": "ないという、ま、着替いがありましたから"
    },
    {
      "start": 686.16,
      "duration": 4.4,
      "text": "なんとかついていけた。でも今の時代は"
    },
    {
      "start": 688.2,
      "duration": 4.48,
      "text": "違います。ハラスメントもあれば人によっ"
    },
    {
      "start": 690.56,
      "duration": 3.959,
      "text": "てモチベーションも違うわけです。大事な"
    },
    {
      "start": 692.68,
      "duration": 4.24,
      "text": "のはこのフィードバックは違いを伝え"
    },
    {
      "start": 694.519,
      "duration": 5.401,
      "text": "るってことなんですね。よくあるのが何回"
    },
    {
      "start": 696.92,
      "duration": 5.64,
      "text": "同じミスしてんだよ。いい加減覚えろ。"
    },
    {
      "start": 699.92,
      "duration": 4.88,
      "text": "お前もお次はないぞ。うん。みたいな"
    },
    {
      "start": 702.56,
      "duration": 5.04,
      "text": "ことって僕結構言われたことはあるんです"
    },
    {
      "start": 704.8,
      "duration": 7.36,
      "text": "ね。で、これ目的は何かと言うと、実は"
    },
    {
      "start": 707.6,
      "duration": 8.44,
      "text": "上司側が本人をへこませること、反省さ"
    },
    {
      "start": 712.16,
      "duration": 6.239,
      "text": "せること、そして裏の目的としては自分の"
    },
    {
      "start": 716.04,
      "duration": 5.16,
      "text": "生場のないストレスを発散させたいんです"
    },
    {
      "start": 718.399,
      "duration": 5.401,
      "text": "ね。で、こういう風にしてしまうと結果的"
    },
    {
      "start": 721.2,
      "duration": 4.639,
      "text": "に何がしたいの?あくまでも部下に改善し"
    },
    {
      "start": 723.8,
      "duration": 5.96,
      "text": "て欲しいんですね。でも改善して欲しい"
    },
    {
      "start": 725.839,
      "duration": 6.12,
      "text": "内容が自分が相手をへこませてどんだけ"
    },
    {
      "start": 729.76,
      "duration": 4.72,
      "text": "大変なことが分かったかって反省しろ。"
    },
    {
      "start": 731.959,
      "duration": 5.361,
      "text": "いやいや、反省した先に行動が改善し"
    },
    {
      "start": 734.48,
      "duration": 6.64,
      "text": "なきゃいけないんです。その時に皆さんが"
    },
    {
      "start": 737.32,
      "duration": 5.84,
      "text": "どんなタイミングでも常に相手に注意をし"
    },
    {
      "start": 741.12,
      "duration": 4.0,
      "text": "、フィードバックを促せるようにするには"
    },
    {
      "start": 743.16,
      "duration": 4.6,
      "text": "この違いを伝えることがすごい大事なん"
    },
    {
      "start": 745.12,
      "duration": 5.519,
      "text": "ですね。提出期限原種が会社のルールだね"
    },
    {
      "start": 747.76,
      "duration": 5.96,
      "text": "。提出期限が守れてないですね。これが"
    },
    {
      "start": 750.639,
      "duration": 5.241,
      "text": "違い。これだけなんです。だからネクスト"
    },
    {
      "start": 753.72,
      "duration": 4.88,
      "text": "アクションとしてなぜこれが守れないのか"
    },
    {
      "start": 755.88,
      "duration": 4.8,
      "text": "原因と対策を一緒に考えましょう。行動を"
    },
    {
      "start": 758.6,
      "duration": 4.96,
      "text": "変えるための次のアクションを伝え"
    },
    {
      "start": 760.68,
      "duration": 4.44,
      "text": "るってことが大事なんです。え、それでも"
    },
    {
      "start": 763.56,
      "duration": 4.0,
      "text": "治らない人どうしたらいいのって。これ"
    },
    {
      "start": 765.12,
      "duration": 4.68,
      "text": "よく来るんですね。言い続けるんです。"
    },
    {
      "start": 767.56,
      "duration": 4.88,
      "text": "この言い続けるだけでいいんですね。"
    },
    {
      "start": 769.8,
      "duration": 5.719,
      "text": "あなたの基準はこれ。会社の基準はこれ。"
    },
    {
      "start": 772.44,
      "duration": 5.36,
      "text": "お客様と会ったら笑顔で立って餌釈する。"
    },
    {
      "start": 775.519,
      "duration": 4.721,
      "text": "これが会社のルールだよ。今の自分できて"
    },
    {
      "start": 777.8,
      "duration": 4.8,
      "text": "ないね。だから守ってね。これだけなん"
    },
    {
      "start": 780.24,
      "duration": 4.159,
      "text": "です。これを淡々と伝え"
    },
    {
      "start": 782.6,
      "duration": 4.72,
      "text": "るっていうことなんですね。なので常に"
    },
    {
      "start": 784.399,
      "duration": 5.161,
      "text": "ゴールと現状、このギャップの違いがあっ"
    },
    {
      "start": 787.32,
      "duration": 4.0,
      "text": "て次のアクションを決めるということなん"
    },
    {
      "start": 789.56,
      "duration": 4.279,
      "text": "です。で、この次のアクションができて"
    },
    {
      "start": 791.32,
      "duration": 5.12,
      "text": "なかった時に次のアクションをすると決め"
    },
    {
      "start": 793.839,
      "duration": 5.0,
      "text": "た。今はできていない。この原因は何?"
    },
    {
      "start": 796.44,
      "duration": 5.24,
      "text": "これをずっと繰り返し続けるっていうこと"
    },
    {
      "start": 798.839,
      "duration": 5.201,
      "text": "なんですね。あくまでも人の行動が変わる"
    },
    {
      "start": 801.68,
      "duration": 5.8,
      "text": "のは自分でしか変わることができません。"
    },
    {
      "start": 804.04,
      "duration": 5.919,
      "text": "なので上司としてはそうか違いだけを伝え"
    },
    {
      "start": 807.48,
      "duration": 4.919,
      "text": "続ければいいんだ。このマインドになると"
    },
    {
      "start": 809.959,
      "duration": 5.761,
      "text": "一気に相手に指摘しやすくなるんですね。"
    },
    {
      "start": 812.399,
      "duration": 5.361,
      "text": "だから何としてもその人の行動を俺の力で"
    },
    {
      "start": 815.72,
      "duration": 6.119,
      "text": "変えてやろうっていう風に思うとですね、"
    },
    {
      "start": 817.76,
      "duration": 6.24,
      "text": "なぜ難しいのかこれ実は後半で皆さんにお"
    },
    {
      "start": 821.839,
      "duration": 6.881,
      "text": "伝えしたいと思いますんで、この後半の"
    },
    {
      "start": 824.0,
      "duration": 4.72,
      "text": "動画もご覧いただければと思います。"
    },
    {
      "start": 831.68,
      "duration": 5.48,
      "text": "指摘する時にやってはいけない比較、これ"
    },
    {
      "start": 834.839,
      "duration": 5.8,
      "text": "是非覚えておいて欲しいんですね。上司と"
    },
    {
      "start": 837.16,
      "duration": 6.119,
      "text": "してお前できてないぞとそん時によく比較"
    },
    {
      "start": 840.639,
      "duration": 5.44,
      "text": "を使うことになります。A君はさ、でき"
    },
    {
      "start": 843.279,
      "duration": 4.841,
      "text": "てるよ。うん。お前の同僚のA君、佐藤君"
    },
    {
      "start": 846.079,
      "duration": 4.361,
      "text": "はこんなにできてんのに、なんでお前は"
    },
    {
      "start": 848.12,
      "duration": 5.56,
      "text": "できないんだ?これよく聞きません。誰か"
    },
    {
      "start": 850.44,
      "duration": 5.16,
      "text": "と比較するケース。もう1個です。後輩と"
    },
    {
      "start": 853.68,
      "duration": 4.599,
      "text": "の比較をするケースもあるんですね。お前"
    },
    {
      "start": 855.6,
      "duration": 4.88,
      "text": "もう3年目か入社。もうさあ、今の新卒は"
    },
    {
      "start": 858.279,
      "duration": 5.281,
      "text": "な、A君はな、もう2ヶ月でこんなこと"
    },
    {
      "start": 860.48,
      "duration": 7.44,
      "text": "できんだぞ。それに比べてお前はどうだっ"
    },
    {
      "start": 863.56,
      "duration": 7.959,
      "text": "ていう新卒との比較。1番まずいのが上司"
    },
    {
      "start": 867.92,
      "duration": 6.4,
      "text": "の過去と自分との比較なんですね。例えば"
    },
    {
      "start": 871.519,
      "duration": 5.961,
      "text": "俺が新層の時はなこうだったぞ。夜遅く"
    },
    {
      "start": 874.32,
      "duration": 6.079,
      "text": "まで仕事して寝ずに会社行ってお客さん"
    },
    {
      "start": 877.48,
      "duration": 6.08,
      "text": "ために働くのが当たり前だったんだぞって"
    },
    {
      "start": 880.399,
      "duration": 5.641,
      "text": "いう風に誰かと何かを比較することによっ"
    },
    {
      "start": 883.56,
      "duration": 4.56,
      "text": "て相手に伝えたいメッセージを伝えるって"
    },
    {
      "start": 886.04,
      "duration": 3.76,
      "text": "人た非常に多いんですね。この比較はまず"
    },
    {
      "start": 888.12,
      "duration": 4.04,
      "text": "やめた方がいいです。なぜかと言うとこれ"
    },
    {
      "start": 889.8,
      "duration": 4.64,
      "text": "上司の保針なんですね。自分がストレート"
    },
    {
      "start": 892.16,
      "duration": 5.08,
      "text": "に物事を言えないのであいつはここまで"
    },
    {
      "start": 894.44,
      "duration": 5.68,
      "text": "できてるぞ。お前できてないけどねって"
    },
    {
      "start": 897.24,
      "duration": 6.48,
      "text": "言いたい。で、もっと言うと俺の時はこう"
    },
    {
      "start": 900.12,
      "duration": 6.279,
      "text": "だったんだけどね、今は甘いと思うよ。"
    },
    {
      "start": 903.72,
      "duration": 4.84,
      "text": "こういう風に誰かと何かの比較をすること"
    },
    {
      "start": 906.399,
      "duration": 4.401,
      "text": "によってストレートに物事を伝えなくなる"
    },
    {
      "start": 908.56,
      "duration": 4.24,
      "text": "んですね。でも受け手としては言われた"
    },
    {
      "start": 910.8,
      "duration": 4.719,
      "text": "からって言ったってだから何?って話です"
    },
    {
      "start": 912.8,
      "duration": 5.039,
      "text": "し、例えば新卒の後輩と比較する。これ"
    },
    {
      "start": 915.519,
      "duration": 5.961,
      "text": "めちゃめちゃへこみますよね。3年間仕事"
    },
    {
      "start": 917.839,
      "duration": 5.56,
      "text": "してるのに、え、自分よりも3歳年が下の"
    },
    {
      "start": 921.48,
      "duration": 4.56,
      "text": "社員と比べて自分できてない。どうしよう"
    },
    {
      "start": 923.399,
      "duration": 4.721,
      "text": "。これもさっきと一緒です。行動を変え"
    },
    {
      "start": 926.04,
      "duration": 3.76,
      "text": "させるんじゃなくて、相手をへこませ"
    },
    {
      "start": 928.12,
      "duration": 4.48,
      "text": "るっていう風に目的が変わってっちゃうん"
    },
    {
      "start": 929.8,
      "duration": 4.88,
      "text": "ですね。なので比較で伝えてはいけない"
    },
    {
      "start": 932.6,
      "duration": 4.64,
      "text": "です。これはあくまでも自分を守ろうと"
    },
    {
      "start": 934.68,
      "duration": 5.36,
      "text": "する保針になってるので、これは是非注意"
    },
    {
      "start": 937.24,
      "duration": 4.64,
      "text": "をしてください。はい。で、前編度ですね"
    },
    {
      "start": 940.04,
      "duration": 4.32,
      "text": "、3つの当たり前ちょっと皆さんにお話を"
    },
    {
      "start": 941.88,
      "duration": 5.319,
      "text": "してきました。まず指示は感想ではなく"
    },
    {
      "start": 944.36,
      "duration": 5.399,
      "text": "命令にしてくださいねと。そして経用士、"
    },
    {
      "start": 947.199,
      "duration": 5.841,
      "text": "福祉。これは前作からもすごい大事です。"
    },
    {
      "start": 949.759,
      "duration": 6.361,
      "text": "全て具体的な数字固有名刺で語っていか"
    },
    {
      "start": 953.04,
      "duration": 5.599,
      "text": "ないと上司はマネジメントする人数多い"
    },
    {
      "start": 956.12,
      "duration": 4.639,
      "text": "ですからね。その分だけずれていきます。"
    },
    {
      "start": 958.639,
      "duration": 4.601,
      "text": "これ注意しましょう。そして叱るのでは"
    },
    {
      "start": 960.759,
      "duration": 4.801,
      "text": "なく違いをちゃんと伝えていきましょうと"
    },
    {
      "start": 963.24,
      "duration": 5.36,
      "text": "いうことです。叱るのにはエネルギーが"
    },
    {
      "start": 965.56,
      "duration": 7.44,
      "text": "めちゃめちゃいります。だから常に基準と"
    },
    {
      "start": 968.6,
      "duration": 7.64,
      "text": "今の部下の行動の現状、この違いを淡々と"
    },
    {
      "start": 973.0,
      "duration": 5.24,
      "text": "伝えて次の行動は何かを決めるだけです。"
    },
    {
      "start": 976.24,
      "duration": 4.68,
      "text": "これをやり続ければいいんだってなると"
    },
    {
      "start": 978.24,
      "duration": 4.64,
      "text": "自分が相手に指摘するこの精神的なコスト"
    },
    {
      "start": 980.92,
      "duration": 4.12,
      "text": "めちゃめちゃ下がりますよね。私が言っ"
    },
    {
      "start": 982.88,
      "duration": 4.12,
      "text": "てるのはこの等身台で皆さんが上司を"
    },
    {
      "start": 985.04,
      "duration": 5.12,
      "text": "いかにできるか。これを論点に上げてます"
    },
    {
      "start": 987.0,
      "duration": 5.48,
      "text": "ので是非後半はですね、モチベーションの"
    },
    {
      "start": 990.16,
      "duration": 5.479,
      "text": "話が出てきますので是非この後半動画も"
    },
    {
      "start": 992.48,
      "duration": 5.44,
      "text": "ご覧いただければと思います。"
    },
    {
      "start": 995.639,
      "duration": 5.161,
      "text": "モチベーションを上げるな下げないことが"
    },
    {
      "start": 997.92,
      "duration": 5.159,
      "text": "重要。そもそも測れないし、上がったとし"
    },
    {
      "start": 1000.8,
      "duration": 4.64,
      "text": "てもプライベートで落ちちゃうし、自分が"
    },
    {
      "start": 1003.079,
      "duration": 4.401,
      "text": "よかれと思ってやればやるほど場合によっ"
    },
    {
      "start": 1005.44,
      "duration": 4.12,
      "text": "ては逆効果見えないものを皆さん"
    },
    {
      "start": 1007.48,
      "duration": 4.279,
      "text": "コントロールしてはいけない。本当に強い"
    },
    {
      "start": 1009.56,
      "duration": 4.079,
      "text": "チームっていうのは仕事への指摘っていう"
    },
    {
      "start": 1011.759,
      "duration": 3.721,
      "text": "のはもう人格攻撃じゃないんだって全員が"
    },
    {
      "start": 1013.639,
      "duration": 5.041,
      "text": "分かってるってことです。仕事の人として"
    },
    {
      "start": 1015.48,
      "duration": 5.799,
      "text": "は尊敬していて相手がこれをやったら改善"
    },
    {
      "start": 1018.68,
      "duration": 6.959,
      "text": "ができるから自信を持って指摘できる関係"
    },
    {
      "start": 1021.279,
      "duration": 4.36,
      "text": "性が大事なんです。"
    }
  ]
}