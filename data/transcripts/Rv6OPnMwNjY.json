    {
      "start": 696.8,
      "duration": 3.0,
      "text": "年の革命以降ずっと続いてたので、イランとしては制裁をな何とか解除してもらいたい。"
    },
    {
      "start": 701.92,
      "duration": 4.96,
      "text": "で、ま、その代わり核開発はやめますと、"
    },
    {
      "start": 704.76,
      "duration": 4.519,
      "text": "え、いうことで、え、ま、そういった合意"
    },
    {
      "start": 706.88,
      "duration": 4.36,
      "text": "アメリカと結んで、で、オバマとしては"
    },
    {
      "start": 709.279,
      "duration": 4.12,
      "text": "これで良かったんです。とてもいい合意が"
    },
    {
      "start": 711.24,
      "duration": 4.8,
      "text": "できたと彼は思っていて、イランという国"
