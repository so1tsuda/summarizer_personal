    {
      "start": 1111.76,
      "duration": 3.0,
      "text": "ユダヤ人あるはシオニストの必要条件ではないんだとかなんとかって言って自分はイスラエルの大の大ファンなんだっていう"
    },
    {
      "start": 1119.32,
      "duration": 3.0,
      "text": "ことはもう本当ずっと言っててなので新イスラエル路線っていうのはトランプ政権から継承してずっと変わらず"
    },
    {
      "start": 1126.159,
      "duration": 3.0,
      "text": "だったんですけれどまがまた立中浮かなくなったのが"
    },
    {
      "start": 1129.799,
      "duration": 3.36,
      "text": "2023年の10月なのか"
    },
