      "start": 362.4,
      "duration": 4.079,
      "text": "変わりました。それに従っておいて本当に"
    },
    {
      "start": 364.44,
      "duration": 4.44,
      "text": "良かったなと思います。おかげ様でですね"
    },
    {
      "start": 366.479,
      "duration": 5.241,
      "text": "、3月はちゃんと黒字出しました。まね、"
    },
    {
      "start": 368.88,
      "duration": 5.12,
      "text": "1月2月は微妙に赤字でしたけど、話を"
    },
    {
      "start": 371.72,
      "duration": 4.56,
      "text": "戻してですからあなたも明日からAIに"
    },
    {
      "start": 374.0,
      "duration": 5.16,
      "text": "何かを聞く時1つだけやってみてください"
    },
    {
      "start": 376.28,
      "duration": 5.199,
      "text": "。AIの回答が出てきたらそのまま使わず"
    },
    {
      "start": 379.16,
      "duration": 4.439,
      "text": "自分しか知らない情報って何かな?で、3"
    },
    {
      "start": 381.479,
      "duration": 4.321,
      "text": "秒だけ考えてみる。予算でもいいし、人数"
    },
    {
      "start": 383.599,
      "duration": 4.401,
      "text": "でもいい。お客さんから直接聞いた声何で"
    },
    {
      "start": 385.8,
      "duration": 4.6,
      "text": "もいいんです。それを1でもいいから追加"
    },
    {
      "start": 388.0,
      "duration": 5.12,
      "text": "してもう1回聞き直す。これだけであなた"
    },
    {
      "start": 390.4,
      "duration": 5.32,
      "text": "のアウトプットは別物になっていきます。"
    },
    {
      "start": 393.12,
      "duration": 5.4,
      "text": "2つ目、AIに足りないものという話。1"
    },
    {
      "start": 395.72,
      "duration": 4.759,
      "text": "つ目で現場の情報をぶつければ120点の"
    },
    {
      "start": 398.52,
      "duration": 4.76,
      "text": "提案が作れるって話をしましたけど、じゃ"
    },
    {
      "start": 400.479,
      "duration": 4.961,
      "text": "、120点の提案を作ったら相手は動いて"
    },
    {
      "start": 403.28,
      "duration": 4.0,
      "text": "くれるのか実はですね、これそうでもない"
    },
    {
      "start": 405.44,
      "duration": 4.159,
      "text": "んです。あなたもこんな経験ありませんか"
    },
    {
      "start": 407.28,
      "duration": 5.16,
      "text": "ね?データも揃えた、ロジックも完璧、"
    },
    {
      "start": 409.599,
      "duration": 5.0,
      "text": "AIも使って隙のない資料を作ったなのに"
    },
    {
      "start": 412.44,
      "duration": 4.199,
      "text": "上司に出したらうん、ま、言ってることは"
    },
    {
      "start": 414.599,
      "duration": 3.801,
      "text": "分かるんだけどね。で、終わってしまう。"
    },
    {
      "start": 416.639,
      "duration": 3.4,
      "text": "いやいや、分かるんだったら通せをバカ"
    },
    {
      "start": 418.4,
      "duration": 3.28,
      "text": "野ろうって思いますよね。これですね、"
    },
    {
      "start": 420.039,
      "duration": 3.84,
      "text": "このにめちゃくちゃ刺さることが書いて"
    },
    {
      "start": 421.68,
      "duration": 4.799,
      "text": "あって、正論だけじゃ人って動かないん"
    },
    {
      "start": 423.879,
      "duration": 5.481,
      "text": "ですよ。人を動かすには3つの要素が必要"
    },
    {
      "start": 426.479,
      "duration": 5.481,
      "text": "で、論理、ロゴス、感情、パトス、信頼、"
    },
    {
      "start": 429.36,
      "duration": 5.08,
      "text": "エトス、この3つが揃って始めて相手は"
    },
    {
      "start": 431.96,
      "duration": 4.12,
      "text": "動いてくれるんです。AIって論理を作る"
    },
    {
      "start": 434.44,
      "duration": 4.479,
      "text": "のはめちゃくちゃ得意なんですよね。"
    },
    {
      "start": 436.08,
      "duration": 5.36,
      "text": "データを集めて分析して筋の通った提案を"
    },
    {
      "start": 438.919,
      "duration": 4.921,
      "text": "出す。でも感情と信頼はどうかと言うと、"
    },
    {
      "start": 441.44,
      "duration": 4.479,
      "text": "ここが抜けてしまっているから正論なのに"
    },
    {
      "start": 443.84,
      "duration": 4.16,
      "text": "通りにくいんですよ。え、じゃあ感情と"
    },
    {
      "start": 445.919,
      "duration": 3.84,
      "text": "信頼まで自分で考えなきゃいけないのって"
    },
    {
      "start": 448.0,
      "duration": 3.56,
      "text": "思いますよね。いや、正直それ"
    },
    {
      "start": 449.759,
      "duration": 3.84,
      "text": "めちゃくちゃ難しいですよね。でもですね"
    },
    {
      "start": 451.56,
      "duration": 3.96,
      "text": "、ここがこの本のすごいところなんです"
    },
    {
      "start": 453.599,
      "duration": 3.641,
      "text": "けど、ベルトライアングルっていう"
    },
    {
      "start": 455.52,
      "duration": 4.799,
      "text": "プロンプトのテンプレートがあって、これ"
    },
    {
      "start": 457.24,
      "duration": 6.0,
      "text": "を自分の状況に埋めるだけでAIが論理、"
    },
    {
      "start": 460.319,
      "duration": 4.961,
      "text": "感情、信頼の3つを分析して提案まで一気"
    },
    {
      "start": 463.24,
      "duration": 4.84,
      "text": "に作ってくれるんですよ。例えばあなたが"
    },
    {
      "start": 465.28,
      "duration": 4.759,
      "text": "上司に新しいシステムの導入を提案する"
    },
    {
      "start": 468.08,
      "duration": 5.16,
      "text": "ケースでやってみます。普通にやったら"
    },
    {
      "start": 470.039,
      "duration": 5.521,
      "text": "このシステムを入れれば業務効率が30%"
    },
    {
      "start": 473.24,
      "duration": 4.399,
      "text": "上がります。コストは半年で回収できます"
    },
    {
      "start": 475.56,
      "duration": 4.4,
      "text": "みたいな提案になりますよね。正しいけど"
    },
    {
      "start": 477.639,
      "duration": 4.4,
      "text": "これだと論理しかありません。ここでペル"
    },
    {
      "start": 479.96,
      "duration": 4.4,
      "text": "トライアングルを使います。AIにあなた"
    },
    {
      "start": 482.039,
      "duration": 5.321,
      "text": "は説得コミュニケーションの専門家です。"
    },
    {
      "start": 484.36,
      "duration": 5.519,
      "text": "論理、感情、信頼の三要素で相手を分析し"
    },
    {
      "start": 487.36,
      "duration": 4.72,
      "text": "て心を動かす提案を作ってください。手"
    },
    {
      "start": 489.879,
      "duration": 4.521,
      "text": "指持した上でテンプレートにこう埋め込ん"
    },
    {
      "start": 492.08,
      "duration": 5.32,
      "text": "でいきます。提案の概要、新システムの"
    },
    {
      "start": 494.4,
      "duration": 5.799,
      "text": "導入、相手の属性、IT投資に慎重な部長"
    },
    {
      "start": 497.4,
      "duration": 5.72,
      "text": "、相手の関心ごと、コスト削減と現場の"
    },
    {
      "start": 500.199,
      "duration": 5.44,
      "text": "安定、相手の不安。前回のシステム導入で"
    },
    {
      "start": 503.12,
      "duration": 4.96,
      "text": "現場が混乱した経験がある。共通体験。"
    },
    {
      "start": 505.639,
      "duration": 4.68,
      "text": "前回の混乱を一緒に乗り越えた。こうやっ"
    },
    {
      "start": 508.08,
      "duration": 4.639,
      "text": "て投げると例えばこんな感じで帰ってくる"
    },
    {
      "start": 510.319,
      "duration": 4.52,
      "text": "んです。まずAIがこの部長を分析して"
    },
    {
      "start": 512.719,
      "duration": 5.12,
      "text": "くれて、この人は論理的にはメリットを"
    },
    {
      "start": 514.839,
      "duration": 5.08,
      "text": "理解できる。でも感情面で前回の失敗が"
    },
    {
      "start": 517.839,
      "duration": 4.08,
      "text": "トラウマになっていて、そこが最大の"
    },
    {
      "start": 519.919,
      "duration": 4.161,
      "text": "ブロックになってるみたいな感じで書てき"
    },
    {
      "start": 521.919,
      "duration": 4.121,
      "text": "ます。要はどこが刺さってどこが"
    },
    {
      "start": 524.08,
      "duration": 4.439,
      "text": "引っかかってるかを整理してくれるんです"
    },
    {
      "start": 526.04,
      "duration": 5.16,
      "text": "。次にじゃあその引っかかりをどう解消"
    },
    {
      "start": 528.519,
      "duration": 5.201,
      "text": "するのか。前回の経験を共有した仲間とし"
    },
    {
      "start": 531.2,
      "duration": 5.759,
      "text": "ての立場を生かして相手の不安に先に"
    },
    {
      "start": 533.72,
      "duration": 5.359,
      "text": "触れるべき前車導入ではなく小さく始める"
    },
    {
      "start": 536.959,
      "duration": 4.841,
      "text": "提案にすることでリスクへの恐怖を"
    },
    {
      "start": 539.079,
      "duration": 4.88,
      "text": "柔らげるみたいに具体的な攻め方まで出し"
    },
    {
      "start": 541.8,
      "duration": 4.64,
      "text": "てくれるんですよ。で、最終的には例えば"
    },
    {
      "start": 543.959,
      "duration": 4.88,
      "text": "こんな提案が出てきます。前回の導入で"
    },
    {
      "start": 546.44,
      "duration": 4.839,
      "text": "現場が混乱したことは私も覚えています。"
    },
    {
      "start": 548.839,
      "duration": 4.281,
      "text": "一緒に乗り越えたからこそ同じ思いはして"
    },
    {
      "start": 551.279,
      "duration": 4.601,
      "text": "いただきたくないんです。だから今回は"
    },
    {
      "start": 553.12,
      "duration": 5.44,
      "text": "まずは1つの部署で小さく試して問題が"
    },
    {
      "start": 555.88,
      "duration": 5.76,
      "text": "ないことを確認してから全車に広げる形に"
    },
    {
      "start": 558.56,
      "duration": 5.24,
      "text": "しました。どうですかね?業務効率30%"
    },
    {
      "start": 561.64,
      "duration": 5.08,
      "text": "アップしますだけの提案と比べたらなんか"
    },
    {
      "start": 563.8,
      "duration": 5.92,
      "text": "全然違いますよね。論理は同じなのに相手"
    },
    {
      "start": 566.72,
      "duration": 4.88,
      "text": "の不安に触れて信頼関係を生かして感情で"
    },
    {
      "start": 569.72,
      "duration": 4.359,
      "text": "包み込んでいるんです。これをテンプレに"
    },
    {
      "start": 571.6,
      "duration": 4.64,
      "text": "埋めるだけでAIが一気にやってくれるん"
    },
    {
      "start": 574.079,
      "duration": 4.44,
      "text": "ですよ。これ今回はかなりコンパクトに"
    },
    {
      "start": 576.24,
      "duration": 4.44,
      "text": "紹介したんですが、実際には各ステップを"
    },
    {
      "start": 578.519,
      "duration": 4.161,
      "text": "個別にやれるプロンプトもこの本に載って"
    },
    {
      "start": 580.68,
      "duration": 4.159,
      "text": "いて、もっと深掘りができちゃいます。"
    },
    {
      "start": 582.68,
      "duration": 5.12,
      "text": "マジで役に立つので、是非ね、そこは読ん"
    },
    {
      "start": 584.839,
      "duration": 5.68,
      "text": "でみてください。3つ目、AI時代の自分"
    },
    {
      "start": 587.8,
      "duration": 5.52,
      "text": "の現在値という話です。ここまでですね、"
    },
    {
      "start": 590.519,
      "duration": 5.76,
      "text": "情報の入れ方で提案の質を上げる方法、"
    },
    {
      "start": 593.32,
      "duration": 4.84,
      "text": "そして感情と信頼で相手を動かす方法を"
    },
    {
      "start": 596.279,
      "duration": 3.761,
      "text": "話してきましたけど、ぶっちゃけですね、"
    },
    {
      "start": 598.16,
      "duration": 4.28,
      "text": "これ知ってるだけじゃ意味がないんですよ"
    },
    {
      "start": 600.04,
      "duration": 3.84,
      "text": "。あなたが動いてるかどうかが全てなん"
    },
    {
      "start": 602.44,
      "duration": 3.6,
      "text": "です。ってね、ちょっと聞きたいんです"
    },
    {
      "start": 603.88,
      "duration": 5.56,
      "text": "けど、あなたは普段AIどう使ってますか"
    },
    {
      "start": 606.04,
      "duration": 5.84,
      "text": "ね?たまに調べ物する時に使うとか文章の"
    },
    {
      "start": 609.44,
      "duration": 4.32,
      "text": "叩き台を作ってるくらいの人正直ね、結構"
    },
    {
      "start": 611.88,
      "duration": 4.56,
      "text": "多いんですよ。便利なのは分かってる。で"
    },
    {
      "start": 613.76,
      "duration": 4.88,
      "text": "もなんだかんだ検索で止まっている。実は"
    },
    {
      "start": 616.44,
      "duration": 5.28,
      "text": "ですね、この本に面白い話が書いてあって"
    },
    {
      "start": 618.64,
      "duration": 5.68,
      "text": "、新しい技術って普及する時に5つの段階"
    },
    {
      "start": 621.72,
      "duration": 5.4,
      "text": "を減るんです。最初に飛びつく確信者。次"
    },
    {
      "start": 624.32,
      "duration": 5.639,
      "text": "に1早く取り入れる初期採用者。その後に"
    },
    {
      "start": 627.12,
      "duration": 5.04,
      "text": "前期多数派、後期多数派。最後に遅延車。"
    },
    {
      "start": 629.959,
      "duration": 4.641,
      "text": "で、ここからが大事なんですけど初期採用"
    },
    {
      "start": 632.16,
      "duration": 4.56,
      "text": "車と前期多数派の間に超えるのが"
    },
    {
      "start": 634.6,
      "duration": 3.88,
      "text": "めちゃくちゃ難しい深い溝がいつもあるん"
    },
    {
      "start": 636.72,
      "duration": 4.6,
      "text": "です。これをキャズムって呼ぶんですけど"
    },
    {
      "start": 638.48,
      "duration": 5.32,
      "text": "、要はこの溝を超えられるかどうかでAI"
    },
    {
      "start": 641.32,
      "duration": 4.92,
      "text": "時代のキャリアの明暗が分れてくるんです"
    },
    {
      "start": 643.8,
      "duration": 4.92,
      "text": "。超えられない人ってどんな人かと言うと"
    },
    {
      "start": 646.24,
      "duration": 4.92,
      "text": "時間がないとか使い方が分からない。別に"
    },
    {
      "start": 648.72,
      "duration": 4.28,
      "text": "今のやり方で困ってないという人でもこれ"
    },
    {
      "start": 651.16,
      "duration": 4.28,
      "text": "ですね、スキルの問題じゃないんです。"
    },
    {
      "start": 653.0,
      "duration": 4.88,
      "text": "心理的な壁があるんですよ。やり方が"
    },
    {
      "start": 655.44,
      "duration": 4.44,
      "text": "分からないんじゃなくて変化が怖い。今の"
    },
    {
      "start": 657.88,
      "duration": 4.32,
      "text": "ままでいいやってどうしても思っちゃう。"
    },
    {
      "start": 659.88,
      "duration": 4.399,
      "text": "これがキャズムの正体なんです。じゃそこ"
    },
    {
      "start": 662.2,
      "duration": 4.92,
      "text": "をどうやって超えるのか。ここでもこの本"
    },
    {
      "start": 664.279,
      "duration": 4.881,
      "text": "のテンプレが使えてAIにあなたは技術"
    },
    {
      "start": 667.12,
      "duration": 5.04,
      "text": "分析とデジタルトランスフォーメーション"
    },
    {
      "start": 669.16,
      "duration": 5.76,
      "text": "の専門家です。AIに使われる人からAI"
    },
    {
      "start": 672.16,
      "duration": 5.359,
      "text": "を使いこなす人への変革を設計して"
    },
    {
      "start": 674.92,
      "duration": 5.12,
      "text": "ください。て指示した上で自分のAI活用"
    },
    {
      "start": 677.519,
      "duration": 5.521,
      "text": "の現状と変化への態度を埋めていくんです"
    },
    {
      "start": 680.04,
      "duration": 5.64,
      "text": "よ。例えばAI活用の現状使っているAI"
    },
    {
      "start": 683.04,
      "duration": 6.56,
      "text": "ツールズルチャットGPT使用頻度週に数"
    },
    {
      "start": 685.68,
      "duration": 6.32,
      "text": "回主な用途検索変の態度AIへの本音便利"
    },
    {
      "start": 689.6,
      "duration": 4.799,
      "text": "だけど使いこなせてる気がしない。周囲の"
    },
    {
      "start": 692.0,
      "duration": 4.8,
      "text": "状況同僚はまだほとんど使っていない。"
    },
    {
      "start": 694.399,
      "duration": 4.801,
      "text": "最大の消壁何に使えばいいのか分からない"
    },
    {
      "start": 696.8,
      "duration": 5.039,
      "text": "。これにプラスして5段階のステージ診断"
    },
    {
      "start": 699.2,
      "duration": 5.439,
      "text": "をしてキャズムを超える戦略を立てて30"
    },
    {
      "start": 701.839,
      "duration": 4.921,
      "text": "日間の行動計画を作ってください。こう"
    },
    {
      "start": 704.639,
      "duration": 4.241,
      "text": "やって指示するとどうなるかこんな感じで"
    },
    {
      "start": 706.76,
      "duration": 4.84,
      "text": "帰ってくるんです。まずあなたは今初期"
    },
    {
      "start": 708.88,
      "duration": 5.44,
      "text": "作業者と前期多数派の境い目にいます。て"
    },
    {
      "start": 711.6,
      "duration": 5.239,
      "text": "診断が出ます。次にあなたの最大の壁は"
    },
    {
      "start": 714.32,
      "duration": 5.36,
      "text": "用途が見えないこと。まずは毎日の業務の"
    },
    {
      "start": 716.839,
      "duration": 5.44,
      "text": "中で1つだけAIに任せるタスクを決めて"
    },
    {
      "start": 719.68,
      "duration": 5.12,
      "text": "みてくださいみたいな具体的な突破策が出"
    },
    {
      "start": 722.279,
      "duration": 5.761,
      "text": "てくるんです。しかも1周目はとか2周目"
    },
    {
      "start": 724.8,
      "duration": 5.039,
      "text": "はと30日間の行動計画まで作ってくれる"
    },
    {
      "start": 728.04,
      "duration": 4.4,
      "text": "んですよ。いや、これ画期的じゃないです"
    },
    {
      "start": 729.839,
      "duration": 4.721,
      "text": "か?自分がどこにいて何をすればいいのか"
    },
    {
      "start": 732.44,
      "duration": 4.519,
      "text": "AIが全部設計してくれるんです。ちなみ"
    },
    {
      "start": 734.56,
      "duration": 4.56,
      "text": "に私はやってみたら初期採用者でした。1"
    },
    {
      "start": 736.959,
      "duration": 4.361,
      "text": "つ目と2つ目で紹介したテンプレもそうな"
    },
    {
      "start": 739.12,
      "duration": 4.2,
      "text": "んですけど、各ステップを個別にやれる"
    },
    {
      "start": 741.32,
      "duration": 4.079,
      "text": "プロンプともこの本にはしっかりと載って"
    },
    {
      "start": 743.32,
      "duration": 4.0,
      "text": "います。マジでね、全部使える内容だと"
    },
    {
      "start": 745.399,
      "duration": 4.161,
      "text": "読んでいて思ったので是非ね、手に取って"
    },
    {
      "start": 747.32,
      "duration": 4.28,
      "text": "みてください。結局ですね、AIの使い方"
    },
    {
      "start": 749.56,
      "duration": 4.56,
      "text": "を知ってる人と知らない人の差じゃないん"
    },
    {
      "start": 751.6,
      "duration": 4.76,
      "text": "です。知った上で動いたか動かなかったか"
    },
    {
      "start": 754.12,
      "duration": 5.12,
      "text": "の差なんです。このキャズムを超えるのに"
    },
    {
      "start": 756.36,
      "duration": 4.8,
      "text": "必要なのはすごいスキルでも特別な才能で"
    },
    {
      "start": 759.24,
      "duration": 4.36,
      "text": "もありません。まず一歩動いてみ"
    },
    {
      "start": 761.16,
      "duration": 4.88,
      "text": "るっていうたったそれだけの覚悟。やるか"
    },
    {
      "start": 763.6,
      "duration": 4.919,
      "text": "やらないかはあなた次第。今回紹介した"
    },
    {
      "start": 766.04,
      "duration": 5.0,
      "text": "以外にもこの本にはAIのアウトプットを"
    },
    {
      "start": 768.519,
      "duration": 4.961,
      "text": "最大化する独自のメソッドが30個、"
    },
    {
      "start": 771.04,
      "duration": 4.919,
      "text": "さらに90個のプロンプトレも書かれてい"
    },
    {
      "start": 773.48,
      "duration": 4.84,
      "text": "ます。手元に1冊だけあってもこれなんて"
    },
    {
      "start": 775.959,
      "duration": 4.721,
      "text": "AIに聞けばいいんだろうて悩み解決する"
    },
    {
      "start": 778.32,
      "duration": 5.04,
      "text": "こと間違いなし。説明欄にリンク貼ります"
    },
    {
      "start": 780.68,
      "duration": 5.0,
      "text": "ので是非ねポチってみてください。いや、"
    },
    {
      "start": 783.36,
      "duration": 5.0,
      "text": "AIの流れどんどん進んできましたよね。"
    },
    {
      "start": 785.68,
      "duration": 4.719,
      "text": "今ですね、新橋のGSバっていう私がやっ"
    },
    {
      "start": 788.36,
      "duration": 4.12,
      "text": "てるお店にもいろんなビジネスマン来るん"
    },
    {
      "start": 790.399,
      "duration": 4.081,
      "text": "ですが、AI事業やってますっていう経営"
    },
    {
      "start": 792.48,
      "duration": 3.719,
      "text": "者の方が来ることめっちゃ増えています。"
    },
    {
      "start": 794.48,
      "duration": 3.68,
      "text": "そしてね、正直ね、みんなね、"
    },
    {
      "start": 796.199,
      "duration": 4.961,
      "text": "めちゃくちゃ稼いでそうな感じするんです"
    },
    {
      "start": 798.16,
      "duration": 5.52,
      "text": "よね。本当にですね、私副業でもAI関連"
    },
    {
      "start": 801.16,
      "duration": 4.0,
      "text": "が個人的に今1番お勧めしています。私"
    },
    {
      "start": 803.68,
      "duration": 2.88,
      "text": "YouTuberですけど、正直"
    },
    {
      "start": 805.16,
      "duration": 3.919,
      "text": "YouTubeってやっぱ簡単ではないの"
    },
    {
      "start": 806.56,
      "duration": 4.36,
      "text": "で、今ならAIの方がチャンスがあると"
    },
    {
      "start": 809.079,
      "duration": 4.681,
      "text": "本気で思っています。で、私もそうなん"
    },
    {
      "start": 810.92,
      "duration": 5.32,
      "text": "ですが、AI学ぼうとするとすぐに新しい"
    },
    {
      "start": 813.76,
      "duration": 4.639,
      "text": "ツル出てきて結局どれがええねんってなり"
    },
    {
      "start": 816.24,
      "duration": 4.159,
      "text": "ますよね。あれ本当に困る。でですね、"
    },
    {
      "start": 818.399,
      "duration": 4.321,
      "text": "この前私が運営しているYouTuber"
    },
    {
      "start": 820.399,
      "duration": 4.88,
      "text": "のオンラインサロンの中でAIに詳しい人"
    },
    {
      "start": 822.72,
      "duration": 4.919,
      "text": "が話してくれて、その時にそれぞれ今どれ"
    },
    {
      "start": 825.279,
      "duration": 5.24,
      "text": "が1番なのか聞いてみたんです。4月7日"
    },
    {
      "start": 827.639,
      "duration": 6.081,
      "text": "現在だとまず文章作成はクロードオパス"
    },
    {
      "start": 830.519,
      "duration": 5.601,
      "text": "4.6。これが今1番優秀な文章を出して"
    },
    {
      "start": 833.72,
      "duration": 4.799,
      "text": "くれるそうです。次にサムネイルなど画像"
    },
    {
      "start": 836.12,
      "duration": 4.279,
      "text": "生成。これはなノバナナ2Pro。これね"
    },
    {
      "start": 838.519,
      "duration": 3.641,
      "text": "、本当すごいんですよ。私このチャンネル"
    },
    {
      "start": 840.399,
      "duration": 3.721,
      "text": "以外にも複数YouTubeチャンネル"
    },
    {
      "start": 842.16,
      "duration": 3.44,
      "text": "やっていて、そこのディレクターの人と"
    },
    {
      "start": 844.12,
      "duration": 3.92,
      "text": "毎週ミーティングしてるんです。で、その"
    },
    {
      "start": 845.6,
      "duration": 4.32,
      "text": "時にこのナノバナ使ってるディレクターは"
    },
    {
      "start": 848.04,
      "duration": 4.08,
      "text": "ミーティング中にですよ。こんな感じです"
    },
    {
      "start": 849.92,
      "duration": 4.08,
      "text": "かって画像共有してきますからね。もう早"
    },
    {
      "start": 852.12,
      "duration": 3.48,
      "text": "すぎて笑います。しかもクオリティ"
    },
    {
      "start": 854.0,
      "duration": 4.199,
      "text": "めちゃくちゃ高いの出してくるんですよ。"
    },
    {
      "start": 855.6,
      "duration": 4.4,
      "text": "そして音楽は素直。これはね、本当面白い"
    },
    {
      "start": 858.199,
      "duration": 3.32,
      "text": "ですよ。うちもね、YouTubeで曲の"
    },
    {
      "start": 860.0,
      "duration": 4.16,
      "text": "配信するチャンネルやってるんですが、"
    },
    {
      "start": 861.519,
      "duration": 5.041,
      "text": "このツール使っていてマジで名曲出してき"
    },
    {
      "start": 864.16,
      "duration": 4.84,
      "text": "ますから。それぞれね、有料とか無料とか"
    },
    {
      "start": 866.56,
      "duration": 4.24,
      "text": "違いはあるんで、自分の予算で使える範囲"
    },
    {
      "start": 869.0,
      "duration": 3.92,
      "text": "のものでいいんで、まず触ってみて"
    },
    {
      "start": 870.8,
      "duration": 4.52,
      "text": "ください。本当にね、まず大事なのは実際"
    },
    {
      "start": 872.92,
      "duration": 4.839,
      "text": "に自分で触ってみること。これがAI"
    },
    {
      "start": 875.32,
      "duration": 5.0,
      "text": "スキル手に入れる第1歩ですから本当に"
    },
    {
      "start": 877.759,
      "duration": 5.361,
      "text": "これからの時代市場価値が高い人間になる"
    },
    {
      "start": 880.32,
      "duration": 5.28,
      "text": "ためにもAIに代替される人間ではなく"
    },
    {
      "start": 883.12,
      "duration": 4.399,
      "text": "AIを使いこなせる人間。これにみんなで"
    },
    {
      "start": 885.6,
      "duration": 3.84,
      "text": "なっていきましょうね。学式サノは"
    },
    {
      "start": 887.519,
      "duration": 4.44,
      "text": "LINEをしています。LINE限定得典"
    },
    {
      "start": 889.44,
      "duration": 5.68,
      "text": "を無料で2つ用意。1つ目、LINE限定"
    },
    {
      "start": 891.959,
      "duration": 5.361,
      "text": "動画。タイトルは絶望の国で生き抜く力。"
    },
    {
      "start": 895.12,
      "duration": 4.12,
      "text": "絶望の国というのはもちろんこの日本の"
    },
    {
      "start": 897.32,
      "duration": 4.4,
      "text": "ことです。普段からね、このチャンネルを"
    },
    {
      "start": 899.24,
      "duration": 4.959,
      "text": "見てくださっている勉強熱心なあなたなら"
    },
    {
      "start": 901.72,
      "duration": 4.52,
      "text": "今の日本やばくね。自分はどう行動したら"
    },
    {
      "start": 904.199,
      "duration": 4.401,
      "text": "いいんだろうということはすでに考えてる"
    },
    {
      "start": 906.24,
      "duration": 5.039,
      "text": "と思います。本当に素晴らしい。その日本"
    },
    {
      "start": 908.6,
      "duration": 5.239,
      "text": "で今後生き抜くためには一体どんな力が"
    },
    {
      "start": 911.279,
      "duration": 4.761,
      "text": "必要なのか。私の目線で語った動画を無料"
    },
    {
      "start": 913.839,
      "duration": 4.961,
      "text": "でプレゼントしています。普段はね、書籍"
    },
    {
      "start": 916.04,
      "duration": 4.799,
      "text": "解説なので、本の内容ばかりで私自身の"
    },
    {
      "start": 918.8,
      "duration": 5.159,
      "text": "意見はあまり言わないんですが、この動画"
    },
    {
      "start": 920.839,
      "duration": 5.68,
      "text": "は違くて、私の頭の中にあることをセラに"
    },
    {
      "start": 923.959,
      "duration": 5.641,
      "text": "喋っています。2つ目、ビジネス書診断。"
    },
    {
      "start": 926.519,
      "duration": 5.76,
      "text": "私が今までに解説した約400冊の本の中"
    },
    {
      "start": 929.6,
      "duration": 5.0,
      "text": "から今のあなたにぴたりの1冊を選び出し"
    },
    {
      "start": 932.279,
      "duration": 4.68,
      "text": "ます。スタートボタンを押して質問に答え"
    },
    {
      "start": 934.6,
      "duration": 5.12,
      "text": "ていくと診断結果が届くんですが、これ"
    },
    {
      "start": 936.959,
      "duration": 4.88,
      "text": "やってみるとすごく楽しいです。説明欄の"
    },
    {
      "start": 939.72,
      "duration": 4.479,
      "text": "URLをタップして友達追加して"
    },
    {
      "start": 941.839,
      "duration": 4.56,
      "text": "いただければすぐにこの2つの得典が無料"
    },
    {
      "start": 944.199,
      "duration": 4.361,
      "text": "で見れちゃいます。是非ね、私お友達"
    },
    {
      "start": 946.399,
      "duration": 7.521,
      "text": "少ないので友達になってください。おなし"
    },
    {
      "start": 948.56,
      "duration": 5.36,
      "text": "。さよなら。さよなら。さよなら。"
    }
  ]
}