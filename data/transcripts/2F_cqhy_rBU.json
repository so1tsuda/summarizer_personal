    {
      "start": 486.639,
      "duration": 3.56,
      "text": "あ、ありますか?これ"
    },
    {
      "start": 487.4,
      "duration": 5.799,
      "text": "あります。あります。あの、朝起きて"
    },
    {
      "start": 490.199,
      "duration": 3.0,
      "text": "今日仕事する気ないなと思った時にスマホ開いてベッドで"
