      "start": 520.2,
      "duration": 3.199,
      "text": "2"
    },
    {
      "start": 520.399,
      "duration": 3.0,
      "text": "つあるんですけど根本的な対策としてはい"
    },
    {
      "start": 524.279,
      "duration": 3.0,
      "text": "スマホ依存とかってその依存とか中毒になりやすいものって力が出るからあの依存しちゃうとかじゃないんですね。現実の何かしらのストレスが柔らぐから依存しちゃうっていう気"
    },
    {
      "start": 538.16,
      "duration": 5.96,
      "text": "らしいんですよ。なので、そのいや、なん"
    },
    {
      "start": 541.399,
      "duration": 5.161,
      "text": "か本当はやめたいんだけども、お酒飲ん"
    },
    {
      "start": 544.12,
      "duration": 4.36,
      "text": "じゃうとか、スマホ見ちゃうとか、本当は"
    },
    {
      "start": 546.56,
      "duration": 5.36,
      "text": "やめたいんだけども、そっちに行っちゃ"
