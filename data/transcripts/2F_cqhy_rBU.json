    {
      "start": 592.8,
      "duration": 6.76,
      "text": "とどうしてもあの人間ってこう新規探索性"
    },
    {
      "start": 596.12,
      "duration": 8.08,
      "text": "って言ってこう通知を気になっちゃったり"
