    {
      "start": 511.319,
      "duration": 4.16,
      "text": "あるんですよ。"
    },
    {
      "start": 512.479,
      "duration": 3.0,
      "text": "あの辺りってどう向き合えばいいですかね?"
    },
    {
      "start": 515.959,
      "duration": 3.0,
      "text": "あの根本的な対策とえっと対象療法とあの"
