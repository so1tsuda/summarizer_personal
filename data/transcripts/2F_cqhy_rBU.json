    {
      "start": 599.56,
      "duration": 6.48,
      "text": "とかXとかでも新しい情報ないかなとか"
    },
    {
      "start": 604.2,
      "duration": 5.199,
      "text": "リプついてないかなとか気になっちゃうと"
    },
    {
      "start": 606.04,
      "duration": 6.359,
      "text": "思うんですけれども情報量をめちゃめちゃ"
    },
    {
      "start": 609.399,
      "duration": 4.721,
      "text": "少なくするといいっていうのがあって"
    },
    {
      "start": 612.399,
      "duration": 4.081,
      "text": "例えばあのiPhoneもAndroid"
    },
    {
      "start": 614.12,
      "duration": 3.959,
      "text": "も多分できたと思うんですけど基本"
    },
    {
      "start": 616.48,
      "duration": 3.44,
      "text": "カラーじゃないですかうん"
    },
    {
      "start": 618.079,
      "duration": 3.921,
      "text": "あの情報量を落とすのに"
    },
    {
      "start": 619.92,
      "duration": 2.76,
      "text": "白黒にする設定があるんですよ。"
    },
    {
      "start": 622.0,
      "duration": 2.519,
      "text": "はい。"
    },
    {
      "start": 622.68,
      "duration": 2.279,
      "text": "それはすごく効果的です。"
    },
    {
      "start": 624.519,
      "duration": 2.161,
      "text": "ああ。"
    },
    {
      "start": 624.959,
      "duration": 2.081,
      "text": "そうするとつまらなくなる。"
    },
    {
      "start": 626.68,
      "duration": 3.36,
      "text": "はい。はい。"
    },
    {
      "start": 627.04,
      "duration": 3.0,
      "text": "ですよね。で、つまらなくなるとあのこう日常に戻れたりとかするので"
    },
    {
      "start": 631.8,
      "duration": 3.599,
      "text": "へえ。"
    },
    {
      "start": 632.399,
      "duration": 3.0,
      "text": "情報量を減らすっていうのが対処両方ですがおすすめです。"
    },
    {
      "start": 635.56,
      "duration": 3.0,
      "text": "リアルな生活の情報量を"
