      "text": "1"
    },
    {
      "start": 497.28,
      "duration": 3.0,
      "text": "時間見ちゃうとかめちゃくちゃ何それみたいな矛盾したことやってます。"
    },
    {
      "start": 502.44,
      "duration": 3.0,
      "text": "いや、私も動画見始めたらとかあの"
