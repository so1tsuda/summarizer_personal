    {
      "start": 362.96,
      "duration": 5.16,
      "text": "ていくんですよ。伝鉄会社はその町の価値"
    },
    {
      "start": 365.52,
      "duration": 5.16,
      "text": "を長期に渡って育てる同期があるんです。"
    },
    {
      "start": 368.12,
      "duration": 5.0,
      "text": "だから伝鉄会社が開発計画を持っている"
    },
    {
      "start": 370.68,
      "duration": 5.2,
      "text": "エリアは価値が維持されやすいと言われて"
    },
    {
      "start": 373.12,
      "duration": 5.32,
      "text": "いるんですよ。例えば今注目なのが渋谷"
    },
    {
      "start": 375.88,
      "duration": 5.0,
      "text": "周辺。渋谷は勝って若者の町という"
    },
    {
      "start": 378.44,
      "duration": 4.56,
      "text": "イメージでしたが、今は再開発によって"
    },
    {
      "start": 380.88,
      "duration": 5.159,
      "text": "全く別の町に生まれ変わりつつあるんです"
    },
    {
      "start": 383.0,
      "duration": 6.16,
      "text": "。伝鉄各者が沿線の価値を上げるために再"
    },
    {
      "start": 386.039,
      "duration": 5.761,
      "text": "開発を進めていて、構想ビルや商業施設が"
    },
    {
      "start": 389.16,
      "duration": 5.24,
      "text": "次々と生まれています。悪く言えば公倍力"
    },
    {
      "start": 391.8,
      "duration": 4.92,
      "text": "の低い層ばかりが集まる町だったのが今や"
    },
    {
      "start": 394.4,
      "duration": 4.239,
      "text": "大人が楽しめる町へと進化しつつある。"
    },
    {
      "start": 396.72,
      "duration": 4.919,
      "text": "これはエリアの価値を上げるだけじゃなく"
    },
    {
      "start": 398.639,
      "duration": 5.761,
      "text": "てすにある地域を再開発するのでリスクが"
    },
    {
      "start": 401.639,
      "duration": 5.721,
      "text": "低く成果も出やすいんです。あとは新宿"
    },
    {
      "start": 404.4,
      "duration": 5.6,
      "text": "近辺小田急と京葉がターミナルとして君臨"
    },
    {
      "start": 407.36,
      "duration": 5.119,
      "text": "し最高勢力でインバウンド需要も取り込み"
    },
    {
      "start": 410.0,
      "duration": 5.199,
      "text": "ながら大きく価値が高まっています。東京"
    },
    {
      "start": 412.479,
      "duration": 5.16,
      "text": "都心やその周辺という立地だけで十分魅力"
    },
    {
      "start": 415.199,
      "duration": 5.041,
      "text": "的ですが再開発が予定されているのであれ"
    },
    {
      "start": 417.639,
      "duration": 5.081,
      "text": "ばそれは明らかな価値筋になると著者は"
    },
    {
      "start": 420.24,
      "duration": 4.72,
      "text": "明言しています。不動産投資では価値が"
    },
    {
      "start": 422.72,
      "duration": 4.919,
      "text": "下がらないエリアを選ぶことが何よりも"
    },
    {
      "start": 424.96,
      "duration": 5.519,
      "text": "重要。そのエリアを見分ける鍵が鉄道会社"
    },
    {
      "start": 427.639,
      "duration": 4.761,
      "text": "が長期にわって資本を投じ町としての価値"
    },
    {
      "start": 430.479,
      "duration": 4.081,
      "text": "を高めようとしているエリアなんですよね"
    },
    {
      "start": 432.4,
      "duration": 4.84,
      "text": "。ま、正直そういったエリアリアって"
    },
    {
      "start": 434.56,
      "duration": 4.759,
      "text": "1部屋で2億とか3億以上するんで一般人"
    },
    {
      "start": 437.24,
      "duration": 4.679,
      "text": "じゃ買えないし難しい点もあるんですよね"
    },
    {
      "start": 439.319,
      "duration": 4.681,
      "text": "。でもそういった参入壁があるからこそ"
    },
    {
      "start": 441.919,
      "duration": 4.0,
      "text": "プレミアムをついて価格が値上がりし"
    },
    {
      "start": 444.0,
      "duration": 4.199,
      "text": "やすいという構造になってるんですよね。"
    },
    {
      "start": 445.919,
      "duration": 4.441,
      "text": "だから富の格差が進んでいくんだと私は"
    },
    {
      "start": 448.199,
      "duration": 4.68,
      "text": "個人的には思っています。そこでですね、"
    },
    {
      "start": 450.36,
      "duration": 5.32,
      "text": "これから私たちがやるべきこと、それが"
    },
    {
      "start": 452.879,
      "duration": 5.6,
      "text": "考え方の変化。それを次の話でお話して"
    },
    {
      "start": 455.68,
      "duration": 5.359,
      "text": "いきます。3つ目、ステージ思考という話"
    },
    {
      "start": 458.479,
      "duration": 4.44,
      "text": "。あなたは今お金持ちになるために何を"
    },
    {
      "start": 461.039,
      "duration": 3.921,
      "text": "やってみますかね?宝くじ買ってますと"
    },
    {
      "start": 462.919,
      "duration": 4.28,
      "text": "いう人絶対にやめてください。あれは期待"
    },
    {
      "start": 464.96,
      "duration": 4.6,
      "text": "値が低いただのギャンブルです。中にはね"
    },
    {
      "start": 467.199,
      "duration": 4.161,
      "text": "、NISや不動産、暗号師さんなんかを"
    },
    {
      "start": 469.56,
      "duration": 3.72,
      "text": "自分なりにやってる人もいるかと思います"
    },
    {
      "start": 471.36,
      "duration": 4.239,
      "text": "。でもちょっとここで立ち止まってみて"
    },
    {
      "start": 473.28,
      "duration": 4.52,
      "text": "欲しいんですが、本当にそれ今の自分に"
    },
    {
      "start": 475.599,
      "duration": 4.641,
      "text": "あった方法ですかね?世の中にはこれを"
    },
    {
      "start": 477.8,
      "duration": 4.079,
      "text": "やれば儲かるって情報がSNSとか"
    },
    {
      "start": 480.24,
      "duration": 4.12,
      "text": "YouTubeとかにもう溢れてるじゃ"
    },
    {
      "start": 481.879,
      "duration": 4.241,
      "text": "ないですか。でもそれ全部正しいとは正直"
    },
    {
      "start": 484.36,
      "duration": 3.88,
      "text": "限らないんです。というのも不裕"
    },
    {
      "start": 486.12,
      "duration": 4.4,
      "text": "に成り上がった人たって一気にそこへ"
    },
    {
      "start": 488.24,
      "duration": 4.639,
      "text": "たどり着いたわけじゃなくて段階を踏んで"
    },
    {
      "start": 490.52,
      "duration": 4.56,
      "text": "その段階にあった方法を取ってきたからな"
    },
    {
      "start": 492.879,
      "duration": 4.28,
      "text": "んです。著者はこれをステージ思考と呼ん"
    },
    {
      "start": 495.08,
      "duration": 4.2,
      "text": "でいるんですが、要は自分が今どの"
    },
    {
      "start": 497.159,
      "duration": 4.241,
      "text": "ステージにいるかを知らずに動くから"
    },
    {
      "start": 499.28,
      "duration": 4.8,
      "text": "うまくいかない。ステージに合わない投資"
    },
    {
      "start": 501.4,
      "duration": 5.079,
      "text": "や事業に手を出して失敗する。これが資産"
    },
    {
      "start": 504.08,
      "duration": 4.72,
      "text": "が増えない本当の理由になっていると明記"
    },
    {
      "start": 506.479,
      "duration": 4.68,
      "text": "してるんですよね。このステージは全部で"
    },
    {
      "start": 508.8,
      "duration": 3.919,
      "text": "5つあるんですが、全部紹介すると1時間"
    },
    {
      "start": 511.159,
      "duration": 4.281,
      "text": "くらいになっちゃうので、ここでは1番"
    },
    {
      "start": 512.719,
      "duration": 5.721,
      "text": "大事なステージ1と2に絞って紹介して"
    },
    {
      "start": 515.44,
      "duration": 4.88,
      "text": "いきます。ステージ1種線1000万円を"
    },
    {
      "start": 518.44,
      "duration": 3.8,
      "text": "し抜きで作るフェーズ。え、いきなり"
    },
    {
      "start": 520.32,
      "duration": 3.719,
      "text": "1000万円ってなりますよね。でもね、"
    },
    {
      "start": 522.24,
      "duration": 4.36,
      "text": "ちょっとだけ聞いてください。資本主義の"
    },
    {
      "start": 524.039,
      "duration": 4.441,
      "text": "世界では金銭がない人は病で食われて"
    },
    {
      "start": 526.6,
      "duration": 4.4,
      "text": "終わりなんですよ。元出手がなければ"
    },
    {
      "start": 528.48,
      "duration": 5.2,
      "text": "どんな投資もビジネスも始まりません。新"
    },
    {
      "start": 531.0,
      "duration": 4.88,
      "text": "N差もS&P500も入れるお金がなけれ"
    },
    {
      "start": 533.68,
      "duration": 4.08,
      "text": "ばただの絵に書いた持ちなんですよね。"
    },
    {
      "start": 535.88,
      "duration": 4.04,
      "text": "じゃ、どうやって1000万円作るのか"
    },
    {
      "start": 537.76,
      "duration": 5.44,
      "text": "著者がここで1番大事だと言ってるのが"
    },
    {
      "start": 539.92,
      "duration": 6.96,
      "text": "入金力を最大化することです。具体的には"
    },
    {
      "start": 543.2,
      "duration": 5.96,
      "text": "節約、副業本業の強化、この3つまず節約"
    },
    {
      "start": 546.88,
      "duration": 4.079,
      "text": "。ここで1番大事なのは余ったら貯金じゃ"
    },
    {
      "start": 549.16,
      "duration": 3.48,
      "text": "ダ目てことです。これやりがちなんです"
    },
    {
      "start": 550.959,
      "duration": 4.761,
      "text": "けど、そんなんやったら余らないんですよ"
    },
    {
      "start": 552.64,
      "duration": 5.72,
      "text": "、絶対。だから先に貯金分を別口座に確保"
    },
    {
      "start": 555.72,
      "duration": 5.4,
      "text": "して残りで生活するというスイッチが必要"
    },
    {
      "start": 558.36,
      "duration": 5.479,
      "text": "。小林さん自身年2回のボーナスを全額"
    },
    {
      "start": 561.12,
      "duration": 4.719,
      "text": "貯金に回し続けて3年で600万円貯めた"
    },
    {
      "start": 563.839,
      "duration": 4.601,
      "text": "そうなんですよね。あとですね、固定費の"
    },
    {
      "start": 565.839,
      "duration": 4.68,
      "text": "削減も大事で、例えば携帯を格安SIMに"
    },
    {
      "start": 568.44,
      "duration": 4.04,
      "text": "変えるだけで月5000円削れたりします"
    },
    {
      "start": 570.519,
      "duration": 4.0,
      "text": "から、そういったできることからどんどん"
    },
    {
      "start": 572.48,
      "duration": 4.32,
      "text": "やっていくのが大事です。入ってるけど"
    },
    {
      "start": 574.519,
      "duration": 4.361,
      "text": "使ってないサブスクならそれも今すぐに"
    },
    {
      "start": 576.8,
      "duration": 4.279,
      "text": "解約しましょう。それが仮に月2000円"
    },
    {
      "start": 578.88,
      "duration": 4.72,
      "text": "。年間1万4000円なら10年で"
    },
    {
      "start": 581.079,
      "duration": 5.2,
      "text": "14万円も手元に残るお金が変わってくる"
    },
    {
      "start": 583.6,
      "duration": 4.919,
      "text": "んです。そう考えると1円単位で細かい"
    },
    {
      "start": 586.279,
      "duration": 4.12,
      "text": "部分も馬鹿にできないですからね。自販機"
    },
    {
      "start": 588.519,
      "duration": 4.481,
      "text": "でジュース買うとか絶対にやっちゃだめ"
    },
    {
      "start": 590.399,
      "duration": 5.081,
      "text": "です。ツ頭にお茶入れましょう。次に副業"
    },
    {
      "start": 593.0,
      "duration": 4.56,
      "text": "。今はSNSやプラットフォームを使えば"
    },
    {
      "start": 595.48,
      "duration": 5.16,
      "text": "どんなスキルでも売れる時代ですよね。"
    },
    {
      "start": 597.56,
      "duration": 5.68,
      "text": "副業でも月10万円稼げていれば年間"
    },
    {
      "start": 600.64,
      "duration": 4.72,
      "text": "120万円の際になります。実際小林さん"
    },
    {
      "start": 603.24,
      "duration": 4.279,
      "text": "が最初に始めたのは当初趣味だった"
    },
    {
      "start": 605.36,
      "duration": 4.4,
      "text": "ラジコンの修理から始めたそうなんですよ"
    },
    {
      "start": 607.519,
      "duration": 4.841,
      "text": "ね。面白い趣味ですよね。だからこそです"
    },
    {
      "start": 609.76,
      "duration": 4.44,
      "text": "ね、あなたも自分の趣味がお金に変わら"
    },
    {
      "start": 612.36,
      "duration": 4.52,
      "text": "ないかなってまずは考えてみて欲しいん"
    },
    {
      "start": 614.2,
      "duration": 4.879,
      "text": "です。案外あなたの当たり前のスキルが誰"
    },
    {
      "start": 616.88,
      "duration": 4.32,
      "text": "かにとってはお金を払ってでも知りたい"
    },
    {
      "start": 619.079,
      "duration": 4.2,
      "text": "スキルだったり使いたいサービスだったり"
    },
    {
      "start": 621.2,
      "duration": 4.24,
      "text": "するんです。私もですね、本をたくさん"
    },
    {
      "start": 623.279,
      "duration": 4.441,
      "text": "読んでいた。そして文章にまとめるのが"
    },
    {
      "start": 625.44,
      "duration": 4.8,
      "text": "得意だった。この2つからこの学式サロン"
    },
    {
      "start": 627.72,
      "duration": 4.559,
      "text": "を副業で始めて、今それでおまんま食べて"
    },
    {
      "start": 630.24,
      "duration": 4.0,
      "text": "いるんです。もうね、見てくれている学式"
    },
    {
      "start": 632.279,
      "duration": 4.0,
      "text": "サロンのファン、通称ガッキーの皆さんに"
    },
    {
      "start": 634.24,
      "duration": 4.92,
      "text": "は感謝しかありません。そして最後3つ目"
    },
    {
      "start": 636.279,
      "duration": 5.601,
      "text": "、本業も手を抜かない。副業の成果を本業"
    },
    {
      "start": 639.16,
      "duration": 5.44,
      "text": "に連動させて小心給与アップにつげていく"
    },
    {
      "start": 641.88,
      "duration": 5.24,
      "text": "んです。会社を上手に活用しながら副業も"
    },
    {
      "start": 644.6,
      "duration": 4.88,
      "text": "回す。これが1番お金を貯めやすい戦略な"
    },
    {
      "start": 647.12,
      "duration": 4.68,
      "text": "んですよね。まずは目標としてどんな方法"
    },
    {
      "start": 649.48,
      "duration": 4.599,
      "text": "であっても月10万円貯めるというのを"
    },
    {
      "start": 651.8,
      "duration": 4.2,
      "text": "設定してみてください。難しく考えなくて"
    },
    {
      "start": 654.079,
      "duration": 4.601,
      "text": "OKです。まずは1年これだけやってみ"
    },
    {
      "start": 656.0,
      "duration": 4.88,
      "text": "ましょう。毎年120万円でも10年続け"
    },
    {
      "start": 658.68,
      "duration": 4.399,
      "text": "たら1200万円になりますから。で、"
    },
    {
      "start": 660.88,
      "duration": 4.04,
      "text": "ここまでがステージ1。コツコツ線を"
    },
    {
      "start": 663.079,
      "duration": 3.56,
      "text": "積み上げていくとやがてステージ2の"
    },
    {
      "start": 664.92,
      "duration": 4.76,
      "text": "フェーズが見えてきますよね。ステージ2"
    },
    {
      "start": 666.639,
      "duration": 5.2,
      "text": "は資産5000万円でお金を働かせる段階"
    },
    {
      "start": 669.68,
      "duration": 4.24,
      "text": "です。このステージで著者が言ってるのは"
    },
    {
      "start": 671.839,
      "duration": 4.481,
      "text": "今NISで積み立てをやってる人はその"
    },
    {
      "start": 673.92,
      "duration": 4.56,
      "text": "まま続けてOKということ。ただ資産が"
    },
    {
      "start": 676.32,
      "duration": 4.92,
      "text": "膨らんできたら次の選択肢も見えてきます"
    },
    {
      "start": 678.48,
      "duration": 5.2,
      "text": "。例えば高配当株。これは簡単に言うと"
    },
    {
      "start": 681.24,
      "duration": 5.12,
      "text": "持っているだけで定期的に配当金が入って"
    },
    {
      "start": 683.68,
      "duration": 4.24,
      "text": "くる株のことです。4から5%程度の"
    },
    {
      "start": 686.36,
      "duration": 3.8,
      "text": "利回りが取れるものもあって、"
    },
    {
      "start": 687.92,
      "duration": 4.68,
      "text": "5000万円をここに置いとくだけで年間"
    },
    {
      "start": 690.16,
      "duration": 5.08,
      "text": "200万から250万円が入ってくる計算"
    },
    {
      "start": 692.6,
      "duration": 5.0,
      "text": "になります。毎月言い直すと約17万から"
    },
    {
      "start": 695.24,
      "duration": 4.76,
      "text": "20万円。働かなくてもお金が入ってくる"
    },
    {
      "start": 697.6,
      "duration": 4.56,
      "text": "状態ですよね。サラリーマンとして毎月"
    },
    {
      "start": 700.0,
      "duration": 4.639,
      "text": "頑張って稼いでいるお金とほぼ同じくらい"
    },
    {
      "start": 702.16,
      "duration": 4.64,
      "text": "の金額が何もしなくても入ってくる。これ"
    },
    {
      "start": 704.639,
      "duration": 4.401,
      "text": "がお金を働かせるということなんです。"
    },
    {
      "start": 706.8,
      "duration": 5.0,
      "text": "もちろん投資なのでリスクは当然あります"
    },
    {
      "start": 709.04,
      "duration": 4.88,
      "text": "。でも姉線が育ってきた時に初めてこう"
    },
    {
      "start": 711.8,
      "duration": 4.76,
      "text": "いう選択肢が現実的になってくるんですよ"
    },
    {
      "start": 713.92,
      "duration": 4.479,
      "text": "ね。逆に言えば種線がない状態でここだけ"
    },
    {
      "start": 716.56,
      "duration": 4.399,
      "text": "真似しようとしても意味はありません。だ"
    },
    {
      "start": 718.399,
      "duration": 5.321,
      "text": "からこそステージ1で種線を作ることが"
    },
    {
      "start": 720.959,
      "duration": 5.361,
      "text": "全ての出発点なんでなるだけ早く貯めた方"
    },
    {
      "start": 723.72,
      "duration": 5.0,
      "text": "が先行車有利を取れるんですよね。そして"
    },
    {
      "start": 726.32,
      "duration": 4.6,
      "text": "ステージ3からは資産が1億円を超えて"
    },
    {
      "start": 728.72,
      "duration": 4.32,
      "text": "資産拡大のフェーズの話になってくるので"
    },
    {
      "start": 730.92,
      "duration": 4.479,
      "text": "そこまでね気になるという方は是非ねこの"
    },
    {
      "start": 733.04,
      "duration": 5.56,
      "text": "本読んでみてください。今回紹介した以外"
    },
    {
      "start": 735.399,
      "duration": 5.481,
      "text": "にもこのは不裕層だけが無意識に実践して"
    },
    {
      "start": 738.6,
      "duration": 4.28,
      "text": "いる思考の習慣などをあなたが不裕層に"
    },
    {
      "start": 740.88,
      "duration": 3.88,
      "text": "なるための情報がたくさん書かれています"
    },
    {
      "start": 742.88,
      "duration": 4.759,
      "text": "。説明欄にリンクも貼ってありますので"
    },
    {
      "start": 744.76,
      "duration": 5.48,
      "text": "是非ねってみてください。この前ですね、"
    },
    {
      "start": 747.639,
      "duration": 4.64,
      "text": "私千葉のカ浦に人生で初めて行ったんです"
    },
    {
      "start": 750.24,
      "duration": 4.56,
      "text": "よ。東京からちょっと遠いんですが"
    },
    {
      "start": 752.279,
      "duration": 5.281,
      "text": "めちゃくちゃ良かったです。まず海が結構"
    },
    {
      "start": 754.8,
      "duration": 5.08,
      "text": "綺麗。正直ですね。内ちの木さらずあたり"
    },
    {
      "start": 757.56,
      "duration": 4.8,
      "text": "だとまだね、海がちょっと汚いんですが、"
    },
    {
      "start": 759.88,
      "duration": 4.959,
      "text": "外棒はやっぱめっちゃ綺麗でなんか9歳。"
    },
    {
      "start": 762.36,
      "duration": 4.839,
      "text": "最近誕生日迎えて9歳になった娘がいるん"
    },
    {
      "start": 764.839,
      "duration": 4.761,
      "text": "ですが、毎日ですね、パパ海行こうって"
    },
    {
      "start": 767.199,
      "duration": 4.521,
      "text": "言ってずっと海岸で遊んでるんですよ。今"
    },
    {
      "start": 769.6,
      "duration": 5.2,
      "text": "までそんなことなかったのになんかそれが"
    },
    {
      "start": 771.72,
      "duration": 5.119,
      "text": "私も嬉しくて娘にも自分が好きな場所とか"
    },
    {
      "start": 774.8,
      "duration": 4.92,
      "text": "好きなものがだんだん確立されてきたんだ"
    },
    {
      "start": 776.839,
      "duration": 4.68,
      "text": "なって成長を感じました。あとね星これも"
    },
    {
      "start": 779.72,
      "duration": 4.559,
      "text": "ね、めちゃくちゃ綺麗でした。星はですね"
    },
    {
      "start": 781.519,
      "duration": 4.88,
      "text": "、5歳の息子が大興奮でもう上を見ながら"
    },
    {
      "start": 784.279,
      "duration": 4.841,
      "text": "ずっと歩くから転びそうになって超危険"
    },
    {
      "start": 786.399,
      "duration": 4.601,
      "text": "でした。いや、関東にも自然を感じられる"
    },
    {
      "start": 789.12,
      "duration": 4.279,
      "text": "素晴らしいところあるんですね。そこで"
    },
    {
      "start": 791.0,
      "duration": 5.279,
      "text": "ですね、あなたにお聞きしたいのが関東で"
    },
    {
      "start": 793.399,
      "duration": 4.961,
      "text": "海が綺麗、星が綺麗、川が綺麗なおすすめ"
    },
    {
      "start": 796.279,
      "duration": 3.721,
      "text": "な場所どっかありますかね?是非ね、今度"
    },
    {
      "start": 798.36,
      "duration": 3.64,
      "text": "行ってみたいと思うので、あなたが言った"
    },
    {
      "start": 800.0,
      "duration": 4.12,
      "text": "ことあるおすすめの場所是非ね、コメント"
    },
    {
      "start": 802.0,
      "duration": 4.639,
      "text": "欄で教えて欲しいです。なんかね、今回お"
    },
    {
      "start": 804.12,
      "duration": 4.8,
      "text": "金を貯めようという動画で旅行のおまけ話"
    },
    {
      "start": 806.639,
      "duration": 3.921,
      "text": "ですみませんでした。学式サノは"
    },
    {
      "start": 808.92,
      "duration": 4.159,
      "text": "YouTuberさんのためのオンライン"
    },
    {
      "start": 810.56,
      "duration": 4.88,
      "text": "サロンを運営しています。おかげ様で運営"
    },
    {
      "start": 813.079,
      "duration": 5.281,
      "text": "3年以上、メンバー300名以上、その他"
    },
    {
      "start": 815.44,
      "duration": 4.88,
      "text": "にも登録者5万人以上の運営者は150名"
    },
    {
      "start": 818.36,
      "duration": 4.4,
      "text": "以上参加しています。YouTubeは"
    },
    {
      "start": 820.32,
      "duration": 4.84,
      "text": "本当に難しくて難易度はどんどん上がって"
    },
    {
      "start": 822.76,
      "duration": 4.639,
      "text": "います。でも実はYouTubeには明確"
    },
    {
      "start": 825.16,
      "duration": 4.479,
      "text": "なコツがあるんです。それに気づけないで"
    },
    {
      "start": 827.399,
      "duration": 4.201,
      "text": "運営していたら1年経っても登録者"
    },
    {
      "start": 829.639,
      "duration": 3.76,
      "text": "1000人達成できないことがリアルに"
    },
    {
      "start": 831.6,
      "duration": 3.599,
      "text": "起こってしまうんですよね。そこでこの"
    },
    {
      "start": 833.399,
      "duration": 4.44,
      "text": "サロンではYouTubeのノンハウを"
    },
    {
      "start": 835.199,
      "duration": 4.721,
      "text": "みんなで学ぶためにこういったコツの特典"
    },
    {
      "start": 837.839,
      "duration": 4.401,
      "text": "を用意しています。私からの直接"
    },
    {
      "start": 839.92,
      "duration": 4.52,
      "text": "アドバイスももちろんOKですし、今この"
    },
    {
      "start": 842.24,
      "duration": 5.039,
      "text": "サロンに参加した人限定で伸び悩んでいる"
    },
    {
      "start": 844.44,
      "duration": 5.399,
      "text": "チャンネルを劇的に改善する裏技7戦。"
    },
    {
      "start": 847.279,
      "duration": 5.48,
      "text": "これを無料でプレゼント中です。実際2"
    },
    {
      "start": 849.839,
      "duration": 5.841,
      "text": "ヶ月で収益化達成できた人、3ヶ月で月"
    },
    {
      "start": 852.759,
      "duration": 5.0,
      "text": "20万円稼げた人、さらにその上の金額を"
    },
    {
      "start": 855.68,
      "duration": 4.159,
      "text": "稼いでいる人もたくさん生まれています。"
    },
    {
      "start": 857.759,
      "duration": 4.161,
      "text": "本当にね、すごいメンバーが揃ってるん"
    },
    {
      "start": 859.839,
      "duration": 4.56,
      "text": "ですよ。ただYouTubeは簡単では"
    },
    {
      "start": 861.92,
      "duration": 4.279,
      "text": "ありません。本気でやらないと成果は絶対"
    },
    {
      "start": 864.399,
      "duration": 3.921,
      "text": "出ませんので、これからね、本気で"
    },
    {
      "start": 866.199,
      "duration": 4.44,
      "text": "YouTube頑張りたい、副業で稼いで"
    },
    {
      "start": 868.32,
      "duration": 3.959,
      "text": "みたいという方のみお待ちしております。"
    },
    {
      "start": 870.639,
      "duration": 6.44,
      "text": "一緒にYouTube頑張ってみませんか"
    },
    {
      "start": 872.279,
      "duration": 4.8,
      "text": "?さよなら。さよなら。さよなら。"
    }
  ]
}