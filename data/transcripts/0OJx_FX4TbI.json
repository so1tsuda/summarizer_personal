      "start": 366.039,
      "duration": 5.0,
      "text": "でいて思いました。日常の小さな変化を"
    },
    {
      "start": 368.24,
      "duration": 5.04,
      "text": "感じられる人のが絶対幸せなマジになると"
    },
    {
      "start": 371.039,
      "duration": 4.841,
      "text": "本気で思っています。さ、話を戻してその"
    },
    {
      "start": 373.28,
      "duration": 4.759,
      "text": "小さな季節な変化を完璧にキャッチし、"
    },
    {
      "start": 375.88,
      "duration": 4.92,
      "text": "自然のリズムに寄り添って暮らしているの"
    },
    {
      "start": 378.039,
      "duration": 5.44,
      "text": "がそう猫なんです。毎日あれもこれもし"
    },
    {
      "start": 380.8,
      "duration": 6.08,
      "text": "なきゃと無理して環境に逆らんのではなく"
    },
    {
      "start": 383.479,
      "duration": 6.12,
      "text": "猫をお手本にして72のさやかな変化に身"
    },
    {
      "start": 386.88,
      "duration": 5.08,
      "text": "を委ねた生活をしてみる。これこそが現代"
    },
    {
      "start": 389.599,
      "duration": 4.961,
      "text": "のストレスを手放し無理なく快適に生きる"
    },
    {
      "start": 391.96,
      "duration": 4.48,
      "text": "ためのある意味現代の最強の知恵なのかも"
    },
    {
      "start": 394.56,
      "duration": 3.96,
      "text": "しれません。じゃあ、もっと具体的にどう"
    },
    {
      "start": 396.44,
      "duration": 3.84,
      "text": "やって日々の生活に取り入れていけばいい"
    },
    {
      "start": 398.52,
      "duration": 3.679,
      "text": "のか、その具体的なアクションについては"
    },
    {
      "start": 400.28,
      "duration": 5.319,
      "text": "次で解説していきますので、是非見ていっ"
    },
    {
      "start": 402.199,
      "duration": 6.041,
      "text": "てください。12つ目、心と体を整える"
    },
    {
      "start": 405.599,
      "duration": 4.88,
      "text": "季節のサインの取り入れ方という話です。"
    },
    {
      "start": 408.24,
      "duration": 5.04,
      "text": "猫みたいに生きた方がいいのは分かった。"
    },
    {
      "start": 410.479,
      "duration": 5.241,
      "text": "でもじゃあ明日から具体的に何をすれば私"
    },
    {
      "start": 413.28,
      "duration": 5.96,
      "text": "は幸せになれるんじゃという質問に結論"
    },
    {
      "start": 415.72,
      "duration": 6.28,
      "text": "からお答えします。ズバり12や72個の"
    },
    {
      "start": 419.24,
      "duration": 5.399,
      "text": "暦みに合わせてその時期ごとの旬のものを"
    },
    {
      "start": 422.0,
      "duration": 5.8,
      "text": "食べたり行事を楽しんだりすること。実は"
    },
    {
      "start": 424.639,
      "duration": 5.321,
      "text": "これがあなたの体を内側から整える最強の"
    },
    {
      "start": 427.8,
      "duration": 4.959,
      "text": "メソッドなんです。例えばこれから来る春"
    },
    {
      "start": 429.96,
      "duration": 5.16,
      "text": "、4月って新年度が始まって職場や学校"
    },
    {
      "start": 432.759,
      "duration": 5.0,
      "text": "など環境がガラっと変わる時期ですよね。"
    },
    {
      "start": 435.12,
      "duration": 4.72,
      "text": "新しい人間関係や慣れない業務で知らず"
    },
    {
      "start": 437.759,
      "duration": 4.44,
      "text": "知らずのうちにめちゃくちゃストレスや"
    },
    {
      "start": 439.84,
      "duration": 5.32,
      "text": "疲れが溜まりやすいんですよ。そんな4月"
    },
    {
      "start": 442.199,
      "duration": 6.201,
      "text": "4日から18日頃にあたるのが生命という"
    },
    {
      "start": 445.16,
      "duration": 5.8,
      "text": "12席です。物が清らかに明るくなるこの"
    },
    {
      "start": 448.4,
      "duration": 5.56,
      "text": "時期ですが、72校ではこの期間の終わり"
    },
    {
      "start": 450.96,
      "duration": 5.519,
      "text": "に虹初めて現るという5日間がやってき"
    },
    {
      "start": 453.96,
      "duration": 4.88,
      "text": "ます。これは雨上がりに虹が姿を見せ"
    },
    {
      "start": 456.479,
      "duration": 5.28,
      "text": "始める時期という意味です。新生活の"
    },
    {
      "start": 458.84,
      "duration": 5.799,
      "text": "ストレスで心に通り雨が降った時こそ"
    },
    {
      "start": 461.759,
      "duration": 5.56,
      "text": "あえて立ち止まって空の虹を探すような心"
    },
    {
      "start": 464.639,
      "duration": 5.081,
      "text": "の余を持つようにしてみてください。また"
    },
    {
      "start": 467.319,
      "duration": 4.32,
      "text": "旬を迎えるたのこを食べてみたり春"
    },
    {
      "start": 469.72,
      "duration": 4.439,
      "text": "キャベツを食べてみる。春のい吹きを"
    },
    {
      "start": 471.639,
      "duration": 5.041,
      "text": "感じるたのこご飯なんて確別に美味しい"
    },
    {
      "start": 474.159,
      "duration": 5.16,
      "text": "ですよね。またお花見をして家族とか仲間"
    },
    {
      "start": 476.68,
      "duration": 5.239,
      "text": "とお弁当を食べる風習も実は両園を"
    },
    {
      "start": 479.319,
      "duration": 4.481,
      "text": "引き寄せるための最高の玄関になるんで"
    },
    {
      "start": 481.919,
      "duration": 4.881,
      "text": "じゃんじゃんお花見やりましょう。さらに"
    },
    {
      "start": 483.8,
      "duration": 6.799,
      "text": "4月19日から5月4日頃の虚空という"
    },
    {
      "start": 486.8,
      "duration": 6.92,
      "text": "12席は闇みて苗いずるという霜が収まっ"
    },
    {
      "start": 490.599,
      "duration": 6.401,
      "text": "て苗が出揃う72個があります。準備が"
    },
    {
      "start": 493.72,
      "duration": 5.879,
      "text": "実行へと移る季節。ここでは初パワー"
    },
    {
      "start": 497.0,
      "duration": 4.96,
      "text": "フードであるニンニクが旬を迎えます。新"
    },
    {
      "start": 499.599,
      "duration": 4.521,
      "text": "年度のスタートダッシュで疲れた体にこの"
    },
    {
      "start": 501.96,
      "duration": 4.28,
      "text": "初ガツオとニンニクの組み合わせがあなた"
    },
    {
      "start": 504.12,
      "duration": 4.32,
      "text": "にとっての最強のエネルギーチャージに"
    },
    {
      "start": 506.24,
      "duration": 4.76,
      "text": "なること間違いなしです。なんかこうやっ"
    },
    {
      "start": 508.44,
      "duration": 4.839,
      "text": "て季節に合わせて旬のものを食べるって"
    },
    {
      "start": 511.0,
      "duration": 5.719,
      "text": "丁寧な暮らししてる感じがしてとてもね、"
    },
    {
      "start": 513.279,
      "duration": 6.68,
      "text": "憧れますよね。そして夏6月21日から7"
    },
    {
      "start": 516.719,
      "duration": 5.56,
      "text": "月6日頃の1年で昼が1番長い下しの時期"
    },
    {
      "start": 519.959,
      "duration": 5.681,
      "text": "には是非近所の神社に行ってみてください"
    },
    {
      "start": 522.279,
      "duration": 5.201,
      "text": "。6月の終わり頃神社に大きな草の輪かが"
    },
    {
      "start": 525.64,
      "duration": 4.08,
      "text": "ドーンと飾られているのを見たことあり"
    },
    {
      "start": 527.48,
      "duration": 4.6,
      "text": "ませんかね?あれをしと呼ぶんですが、"
    },
    {
      "start": 529.72,
      "duration": 5.32,
      "text": "そこをくぐるだけでこの半年間のストレス"
    },
    {
      "start": 532.08,
      "duration": 6.08,
      "text": "やモヤモヤを全部落として心身をリセット"
    },
    {
      "start": 535.04,
      "duration": 5.359,
      "text": "できる名の大払いという最強のメンタル"
    },
    {
      "start": 538.16,
      "duration": 4.64,
      "text": "ケアイベントになるんです。本人はさらに"
    },
    {
      "start": 540.399,
      "duration": 5.921,
      "text": "効果を爆上げする裏技も書かれていて、"
    },
    {
      "start": 542.8,
      "duration": 6.64,
      "text": "くぐる時に心の中でみ月の名の払いをする"
    },
    {
      "start": 546.32,
      "duration": 5.959,
      "text": "人は千歳の命の部というなりという昔の"
    },
    {
      "start": 549.44,
      "duration": 4.8,
      "text": "言葉を唱えるとさらにご利役が強まるそう"
    },
    {
      "start": 552.279,
      "duration": 4.281,
      "text": "です。ちょっとね長くて覚えらんねえよっ"
    },
    {
      "start": 554.24,
      "duration": 4.8,
      "text": "て人はこれで半年間のモヤモヤをリセット"
    },
    {
      "start": 556.56,
      "duration": 4.719,
      "text": "してまた明日から前向こうと気持ちを"
    },
    {
      "start": 559.04,
      "duration": 4.239,
      "text": "切り替えてくぐるだけでも十分効果はある"
    },
    {
      "start": 561.279,
      "duration": 4.961,
      "text": "んで是非ねやってみてください。この時期"
    },
    {
      "start": 563.279,
      "duration": 5.56,
      "text": "の72個はハゲcolという期間があり、"
    },
    {
      "start": 566.24,
      "duration": 4.839,
      "text": "田上など大きな作業を終えて自然のリズム"
    },
    {
      "start": 568.839,
      "duration": 4.321,
      "text": "に合わせて一息つく目安とされていました"
    },
    {
      "start": 571.079,
      "duration": 4.32,
      "text": "。ま、今はね、ほとんどの人がタウはし"
    },
    {
      "start": 573.16,
      "duration": 4.52,
      "text": "ないんですが、言いたいのは頑張った後は"
    },
    {
      "start": 575.399,
      "duration": 4.44,
      "text": "ちゃんと休もうね。これが大事ってことを"
    },
    {
      "start": 577.68,
      "duration": 5.36,
      "text": "昔の人が教えてくれてるんですよね。あと"
    },
    {
      "start": 579.839,
      "duration": 6.44,
      "text": "ですね、7月12日から8月6日頃の暑さ"
    },
    {
      "start": 583.04,
      "duration": 5.44,
      "text": "が最も厳しくなる対処の12席には無理し"
    },
    {
      "start": 586.279,
      "duration": 4.881,
      "text": "た絶対ダメと書かれています。雑音を"
    },
    {
      "start": 588.48,
      "duration": 5.28,
      "text": "遠ざけて睡眠と栄養の質を優先しましょう"
    },
    {
      "start": 591.16,
      "duration": 4.64,
      "text": "。そうめや日汁はほてった体を癒して"
    },
    {
      "start": 593.76,
      "duration": 5.079,
      "text": "くれるのでおすすめだと書かれています。"
    },
    {
      "start": 595.8,
      "duration": 5.32,
      "text": "あと里いも良くて一応を整えてミネラルも"
    },
    {
      "start": 598.839,
      "duration": 5.0,
      "text": "補給できるので是非ね試してみてください"
    },
    {
      "start": 601.12,
      "duration": 5.36,
      "text": "ね。今年の夏はスマホなんて川にぶん投げ"
    },
    {
      "start": 603.839,
      "duration": 4.881,
      "text": "て浴衣着きてぼ踊りとか花火大会とか言っ"
    },
    {
      "start": 606.48,
      "duration": 5.72,
      "text": "て季節を感じながら癒されちゃいましょう"
    },
    {
      "start": 608.72,
      "duration": 6.04,
      "text": "。こんな感じで12席や住2のさやかな"
    },
    {
      "start": 612.2,
      "duration": 5.36,
      "text": "サインと具体的な日付に合わせて食べる"
    },
    {
      "start": 614.76,
      "duration": 5.0,
      "text": "ものを変え行事に乗っかる。特に旬のもの"
    },
    {
      "start": 617.56,
      "duration": 4.36,
      "text": "を食べるのは今日からスーパーでできる"
    },
    {
      "start": 619.76,
      "duration": 5.759,
      "text": "最高のアクションなので是非ねやってみて"
    },
    {
      "start": 621.92,
      "duration": 6.159,
      "text": "ください。3つ目、毎日をご利役に変える"
    },
    {
      "start": 625.519,
      "duration": 5.32,
      "text": "小さな変化を見つけるコツという話です。"
    },
    {
      "start": 628.079,
      "duration": 5.401,
      "text": "最後に1番お伝えしたい考え方を話します"
    },
    {
      "start": 630.839,
      "duration": 5.44,
      "text": "。ぶっちゃけ今の世の中便利になってるの"
    },
    {
      "start": 633.48,
      "duration": 5.56,
      "text": "に全く働く量が減ってないですよね。"
    },
    {
      "start": 636.279,
      "duration": 5.36,
      "text": "むしろ忙しくなってるみたいな。毎日満員"
    },
    {
      "start": 639.04,
      "duration": 5.039,
      "text": "連車で通勤して効率や結果ばかりを求め"
    },
    {
      "start": 641.639,
      "duration": 4.681,
      "text": "られる。有給取るのだって罪悪感がある"
    },
    {
      "start": 644.079,
      "duration": 5.041,
      "text": "会社員の人多いと思います。でもですね、"
    },
    {
      "start": 646.32,
      "duration": 5.24,
      "text": "だからこそこの72を見ると立ち止まる"
    },
    {
      "start": 649.12,
      "duration": 4.56,
      "text": "ことやすぐ結果が出ないことにも意味が"
    },
    {
      "start": 651.56,
      "duration": 4.92,
      "text": "あると教えてくれているんです。例えば"
    },
    {
      "start": 653.68,
      "duration": 4.44,
      "text": "ですけど9月22日から10月7日頃"
    },
    {
      "start": 656.48,
      "duration": 4.24,
      "text": "の二重分"
    },
    {
      "start": 658.12,
      "duration": 4.959,
      "text": "にある水初めてかかるという言葉があるん"
    },
    {
      "start": 660.72,
      "duration": 5.52,
      "text": "ですが、これは田ぼの水が減る時期でこの"
    },
    {
      "start": 663.079,
      "duration": 5.361,
      "text": "本には失うのではなく余が生まれるという"
    },
    {
      "start": 666.24,
      "duration": 4.36,
      "text": "意味で書かれています。仕事で心身が"
    },
    {
      "start": 668.44,
      "duration": 4.48,
      "text": "すりってるのではなく、新しいものを"
    },
    {
      "start": 670.6,
      "duration": 4.52,
      "text": "受け入れる余白を作ってる時期なんだと"
    },
    {
      "start": 672.92,
      "duration": 5.08,
      "text": "思えば、ちょっとだけ心軽くなったりし"
    },
    {
      "start": 675.12,
      "duration": 5.839,
      "text": "ませんかね。他にも12月7日から12月"
    },
    {
      "start": 678.0,
      "duration": 5.48,
      "text": "20日頃の大切にはクマ穴にこもるという"
    },
    {
      "start": 680.959,
      "duration": 5.0,
      "text": "言葉があります。クが当民するように人間"
    },
    {
      "start": 683.48,
      "duration": 5.0,
      "text": "も休む時間が必要ってことなんですよね。"
    },
    {
      "start": 685.959,
      "duration": 4.721,
      "text": "だからこそ有気を取って1日中寝てい"
    },
    {
      "start": 688.48,
      "duration": 3.919,
      "text": "たっていいんですよ。休むことをしっかり"
    },
    {
      "start": 690.68,
      "duration": 4.159,
      "text": "肯定してあげましょう。いや、どうでした"
    },
    {
      "start": 692.399,
      "duration": 4.88,
      "text": "かね?あなたも猫のように自然に寄り添っ"
    },
    {
      "start": 694.839,
      "duration": 4.881,
      "text": "ていければ、毎日がご利役に満ちたものに"
    },
    {
      "start": 697.279,
      "duration": 4.441,
      "text": "変わること間違いなしです。やってみて、"
    },
    {
      "start": 699.72,
      "duration": 4.0,
      "text": "あ、最近いいことばっか送るなって感じ"
    },
    {
      "start": 701.72,
      "duration": 4.359,
      "text": "られるようになった人は続ければいいだけ"
    },
    {
      "start": 703.72,
      "duration": 4.679,
      "text": "なんですから、季節を感じながら丁寧な"
    },
    {
      "start": 706.079,
      "duration": 4.521,
      "text": "暮らし、私もね、本当に憧れるんで、この"
    },
    {
      "start": 708.399,
      "duration": 5.361,
      "text": "本読んで実践したいと思っています。この"
    },
    {
      "start": 710.6,
      "duration": 5.32,
      "text": "本には他にも心癒される言葉や可愛い猫の"
    },
    {
      "start": 713.76,
      "duration": 4.319,
      "text": "姿がたくさん書かれているので、さらに気"
    },
    {
      "start": 715.92,
      "duration": 4.159,
      "text": "になるという方は説明欄のリンクから是非"
    },
    {
      "start": 718.079,
      "duration": 4.921,
      "text": "ね、ポチってみてください。ちなみに藤本"
    },
    {
      "start": 720.079,
      "duration": 5.041,
      "text": "さんの書いた神社ご利役1万枚の参り方。"
    },
    {
      "start": 723.0,
      "duration": 4.36,
      "text": "これについてはこちらの過去動画でも"
    },
    {
      "start": 725.12,
      "duration": 5.04,
      "text": "詳しく解説していますので説明欄から"
    },
    {
      "start": 727.36,
      "duration": 4.56,
      "text": "チェックしてみてください。今回の話どう"
    },
    {
      "start": 730.16,
      "duration": 3.679,
      "text": "でしたでしょうか?ごリア役の話って"
    },
    {
      "start": 731.92,
      "duration": 4.159,
      "text": "おそらくね信じない人もいると思うんです"
    },
    {
      "start": 733.839,
      "duration": 4.481,
      "text": "がそれは人それぞれで本当いいと思うん"
    },
    {
      "start": 736.079,
      "duration": 4.161,
      "text": "ですよ。やってみて効果がある人ない人"
    },
    {
      "start": 738.32,
      "duration": 5.24,
      "text": "おそらくねやっぱりいると思いますから。"
    },
    {
      "start": 740.24,
      "duration": 5.36,
      "text": "私はですね神社見つけたらお賽銭とお参り"
    },
    {
      "start": 743.56,
      "duration": 4.24,
      "text": "。これはねいつもやっています。でも季節"
    },
    {
      "start": 745.6,
      "duration": 3.76,
      "text": "ごとのお話はとってもいいと思っていて"
    },
    {
      "start": 747.8,
      "duration": 3.64,
      "text": "できる範囲でやっていきたいんですよね。"
    },
    {
      "start": 749.36,
      "duration": 4.68,
      "text": "というのも今まであんまりやってなかった"
    },
    {
      "start": 751.44,
      "duration": 5.399,
      "text": "んですよ。正直ね、毎日12時間とか15"
    },
    {
      "start": 754.04,
      "duration": 4.799,
      "text": "時間してお金稼ぐんじゃみたいなマインド"
    },
    {
      "start": 756.839,
      "duration": 4.841,
      "text": "だったんで。でも最近は子供と遊ぶように"
    },
    {
      "start": 758.839,
      "duration": 5.641,
      "text": "なって、これ行事とかイベント食べ物って"
    },
    {
      "start": 761.68,
      "duration": 4.48,
      "text": "1つ1つ子供にとっては新しい思い出に"
    },
    {
      "start": 764.48,
      "duration": 3.919,
      "text": "なるんだなって感じてるんです。だから"
    },
    {
      "start": 766.16,
      "duration": 4.16,
      "text": "ですね、いろんな経験させてあげたいなと"
    },
    {
      "start": 768.399,
      "duration": 4.481,
      "text": "思って結構ね、やるようにしてるんですよ"
    },
    {
      "start": 770.32,
      "duration": 4.68,
      "text": "ね。案外ですね、その季節にやるやつなの"
    },
    {
      "start": 772.88,
      "duration": 5.319,
      "text": "にやらない瞬間ってないですか?うちで"
    },
    {
      "start": 775.0,
      "duration": 5.48,
      "text": "言うと今年に入ってすぐ草が人生で初めて"
    },
    {
      "start": 778.199,
      "duration": 4.44,
      "text": "作りました。正直ね、子供からの評判は"
    },
    {
      "start": 780.48,
      "duration": 4.32,
      "text": "最悪でしたが、これもね大事なイベントな"
    },
    {
      "start": 782.639,
      "duration": 5.0,
      "text": "んですよね。あと去年やったのはおつきみ"
    },
    {
      "start": 784.8,
      "duration": 4.839,
      "text": "とかやりました。案外わざわざみする習慣"
    },
    {
      "start": 787.639,
      "duration": 4.281,
      "text": "ってないじゃないですか。でもこれも"
    },
    {
      "start": 789.639,
      "duration": 4.64,
      "text": "思い出の1つだと思ってあえてねやったり"
    },
    {
      "start": 791.92,
      "duration": 5.0,
      "text": "しています。何かあなたが毎年やっている"
    },
    {
      "start": 794.279,
      "duration": 4.521,
      "text": "あなた1家の週慣とか行事ありますかね?"
    },
    {
      "start": 796.92,
      "duration": 4.039,
      "text": "クリスマスとかハロウィンじゃなくて"
    },
    {
      "start": 798.8,
      "duration": 4.44,
      "text": "マイナーなやつ是非ね教えて欲しいです。"
    },
    {
      "start": 800.959,
      "duration": 4.44,
      "text": "私も絶対やりますのでコメント欄で教えて"
    },
    {
      "start": 803.24,
      "duration": 4.279,
      "text": "ください。学式サノはYouTuber"
    },
    {
      "start": 805.399,
      "duration": 4.401,
      "text": "さんのためのオンラインサロンを運営して"
    },
    {
      "start": 807.519,
      "duration": 4.801,
      "text": "います。おかげ様で運営3年以上、"
    },
    {
      "start": 809.8,
      "duration": 5.2,
      "text": "メンバー300名以上。その他にも登録者"
    },
    {
      "start": 812.32,
      "duration": 4.959,
      "text": "5万人以上の運営者は150名以上参加し"
    },
    {
      "start": 815.0,
      "duration": 4.519,
      "text": "ています。YouTubeは本当に難しく"
    },
    {
      "start": 817.279,
      "duration": 4.68,
      "text": "て難易度はどんどん上がっています。でも"
    },
    {
      "start": 819.519,
      "duration": 4.481,
      "text": "実はYouTubeには明確なコツがある"
    },
    {
      "start": 821.959,
      "duration": 4.44,
      "text": "んです。それに気づけないで運営してい"
    },
    {
      "start": 824.0,
      "duration": 4.279,
      "text": "たら1年経っても登録者1000人達成"
    },
    {
      "start": 826.399,
      "duration": 3.761,
      "text": "できないことがリアルに起こってしまうん"
    },
    {
      "start": 828.279,
      "duration": 3.761,
      "text": "ですよね。そこでこのサロンでは"
    },
    {
      "start": 830.16,
      "duration": 4.239,
      "text": "YouTubeのノンハウをみんなで学ぶ"
    },
    {
      "start": 832.04,
      "duration": 4.4,
      "text": "ためにこういったコの得典を用意してい"
    },
    {
      "start": 834.399,
      "duration": 4.481,
      "text": "ます。私からの直接アドバイスも"
    },
    {
      "start": 836.44,
      "duration": 4.68,
      "text": "もちろんOKですし、今このサロンに参加"
    },
    {
      "start": 838.88,
      "duration": 5.04,
      "text": "した人限定で伸び悩んでるチャンネルを"
    },
    {
      "start": 841.12,
      "duration": 5.68,
      "text": "劇的に改善する裏技7000。これを無料"
    },
    {
      "start": 843.92,
      "duration": 5.919,
      "text": "でプレゼント中です。実際2ヶ月で収益化"
    },
    {
      "start": 846.8,
      "duration": 5.719,
      "text": "達成できた人、3ヶ月で月20万円稼げた"
    },
    {
      "start": 849.839,
      "duration": 4.601,
      "text": "人、さらにその上の金額を稼いでいる人も"
    },
    {
      "start": 852.519,
      "duration": 4.32,
      "text": "たくさん生まれています。本当にね、"
    },
    {
      "start": 854.44,
      "duration": 4.079,
      "text": "すごいメンバーが揃ってるんですよ。ただ"
    },
    {
      "start": 856.839,
      "duration": 4.161,
      "text": "YouTubeは簡単ではありません。"
    },
    {
      "start": 858.519,
      "duration": 4.24,
      "text": "本気でやらないと成果は絶対出ませんので"
    },
    {
      "start": 861.0,
      "duration": 4.32,
      "text": "、これからね、本気でYouTube"
    },
    {
      "start": 862.759,
      "duration": 4.361,
      "text": "頑張りたい、副業で稼いでみたいという方"
    },
    {
      "start": 865.32,
      "duration": 3.4,
      "text": "のみお待ちしております。一緒に"
    },
    {
      "start": 867.12,
      "duration": 5.959,
      "text": "YouTube頑張ってみませんか?"
    },
    {
      "start": 868.72,
      "duration": 4.359,
      "text": "さよなら。さよなら。さよなら。"
    }
  ]
}