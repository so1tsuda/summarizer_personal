    {
      "start": 1889.2,
      "duration": 4.959,
      "text": "話政権だったら私こんなこと期待しませんよ。"
    },
    {
      "start": 1891.159,
      "duration": 3.0,
      "text": "当初からね。だから高一政権だからこそ是非やってもらいたいなと思いますね。"
    },
    {
      "start": 1895.36,
      "duration": 3.08,
      "text": "うん。"
    },
    {
      "start": 1895.96,
      "duration": 5.48,
      "text": "確かにあの日だけで終わるものではないわけですから。"
    },
    {
      "start": 1898.44,
      "duration": 3.0,
      "text": "違いますよ。だってもう今日本経済首しめられてるようなもんでしょ。"
    },
    {
      "start": 1904.0,
      "duration": 3.0,
      "text": "ある照者の大者の人とこの前話してたらね、やっぱり照者マの立場から見ると今回の事態っていうのはかつてのオイルショックとそれからリーマンショック"
    },
    {
      "start": 1915.0,
