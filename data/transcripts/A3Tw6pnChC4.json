    {
      "start": 413.919,
      "duration": 5.361,
      "text": "時間をデザインすることなんですよね。"
    },
    {
      "start": 416.84,
      "duration": 4.72,
      "text": "あの、問題解決です。だからこれは本当に"
    },
    {
      "start": 419.28,
      "duration": 4.4,
      "text": "時間がないっていうことの問題解決として"
    },
    {
      "start": 421.56,
      "duration": 4.079,
      "text": "の時間のデザインなんです。で、僕にとっ"
    },
    {
      "start": 423.68,
      "duration": 5.56,
      "text": "てのその時間のデザインっていうのはその"
    },
    {
      "start": 425.639,
      "duration": 5.24,
      "text": "いつ何をどれぐらいやるかっていうことを"
    },
    {
      "start": 429.24,
      "duration": 3.44,
      "text": "ルール化することだったんですね。で、"
    },
    {
      "start": 430.879,
      "duration": 3.961,
      "text": "それで時間もデザインしていくっていう"
    },
    {
      "start": 432.68,
      "duration": 6.16,
      "text": "ことで、そのいつ何をどれぐらいやる"
    },
    {
      "start": 434.84,
      "duration": 6.12,
      "text": "かっていうのは実習慣なんですよ。あの、"
    },
    {
      "start": 438.84,
      "duration": 4.4,
      "text": "習慣ってそれないです。いつ何をどの"
    },
    {
      "start": 440.96,
      "duration": 5.6,
      "text": "ぐらいやるかっていうことさえ決めて配置"
    },
    {
      "start": 443.24,
      "duration": 6.679,
      "text": "するとそれが習慣になるんです。で、僕が"
    },
    {
      "start": 446.56,
      "duration": 5.88,
      "text": "あの心がけてることというか、あの問題"
    },
    {
      "start": 449.919,
      "duration": 4.801,
      "text": "解決としてやってることは、あの、"
    },
    {
      "start": 452.44,
      "duration": 5.319,
      "text": "あらゆること、全てを習慣化するっていう"
    },
    {
      "start": 454.72,
      "duration": 5.759,
      "text": "ことです。だ、やるべきこと、まだ仕事"
    },
    {
      "start": 457.759,
      "duration": 4.641,
      "text": "だったり、ま、筋トレもそうだし、掃除も"
    },
    {
      "start": 460.479,
      "duration": 4.12,
      "text": "そうだし、ま、こうなんかやらなきゃいけ"
    },
    {
      "start": 462.4,
      "duration": 5.32,
      "text": "ないなっていうこと。ま、これ全部習慣に"
    },
    {
      "start": 464.599,
      "duration": 6.121,
      "text": "します。で、やりたいこと例えば、ま、"
    },
    {
      "start": 467.72,
      "duration": 4.84,
      "text": "勉強とか、ま、読書とか、ま、漫画読むと"
    },
    {
      "start": 470.72,
      "duration": 5.879,
      "text": "か、ま、あとゲームするとか、ま、あと"
    },
    {
      "start": 472.56,
      "duration": 8.199,
      "text": "ダンス踊るとか、今習慣として、え、やっ"
    },
    {
      "start": 476.599,
      "duration": 6.761,
      "text": "てること、僕が毎日やってることが今、え"
    },
    {
      "start": 480.759,
      "duration": 4.601,
      "text": "、これ大体一部ですね。はい。全部では"
    },
    {
      "start": 483.36,
      "duration": 4.64,
      "text": "ないですけど、大体これぐらいのこと今"
    },
    {
      "start": 485.36,
      "duration": 6.48,
      "text": "毎日やってますっていうので、ま、中には"
    },
    {
      "start": 488.0,
      "duration": 6.36,
      "text": "だから、ま、本のデザインを作るのも、え"
    },
    {
      "start": 491.84,
      "duration": 4.919,
      "text": "、毎日の習慣でやってます。で、ま、週慣"
    },
    {
      "start": 494.36,
      "duration": 5.88,
      "text": "にしててできるようになったこと、ま、"
    },
    {
      "start": 496.759,
      "duration": 5.681,
      "text": "あの、160冊。ま、これはあの、僕が、"
    },
    {
      "start": 500.24,
      "duration": 4.799,
      "text": "え、毎年大体これぐらいデザインしてるで"
    },
    {
      "start": 502.44,
      "duration": 5.159,
      "text": "、多い時は200冊ぐらいあるし、ま、"
    },
    {
      "start": 505.039,
      "duration": 5.28,
      "text": "少ない時でも150ぐらいやってるかな、"
    },
    {
      "start": 507.599,
      "duration": 4.721,
      "text": "あの、最近は。ま、でも、あの、大体"
    },
    {
      "start": 510.319,
      "duration": 4.52,
      "text": "アベレージで160冊ぐらいかなという"
    },
    {
      "start": 512.32,
      "duration": 5.0,
      "text": "感じです。ま、あの、だから2日に1冊"
    },
    {
      "start": 514.839,
      "duration": 6.961,
      "text": "ぐらいは必ず入行してるかなという体感"
    },
    {
      "start": 517.32,
      "duration": 7.36,
      "text": "ですね。で、365冊っていうのは、えっ"
    },
    {
      "start": 521.8,
      "duration": 5.44,
      "text": "と、1年間で読んでる本の数です。えっと"
    },
    {
      "start": 524.68,
      "duration": 5.08,
      "text": "、1日1冊必ず本読むんで、あの、すごい"
    },
    {
      "start": 527.24,
      "duration": 4.92,
      "text": "計算しやすいです。365冊年間に読んで"
    },
    {
      "start": 529.76,
      "duration": 4.88,
      "text": "ます。あの、1日1冊読むことのメリット"
    },
    {
      "start": 532.16,
      "duration": 4.64,
      "text": "はこれだけです。あの、年にどれぐらい本"
    },
    {
      "start": 534.64,
      "duration": 4.04,
      "text": "読むんですすかって言われた時に365冊"
    },
    {
      "start": 536.8,
      "duration": 5.52,
      "text": "ですって答えられるっていうこれしか"
    },
    {
      "start": 538.68,
      "duration": 5.839,
      "text": "メリットはないです。はい。で、285本"
    },
    {
      "start": 542.32,
      "duration": 4.92,
      "text": "っていうのはこれはあの、去年映画館で見"
    },
    {
      "start": 544.519,
      "duration": 5.361,
      "text": "た映画の本数ですね。はい。映画館に"
    },
    {
      "start": 547.24,
      "duration": 5.32,
      "text": "285本行ってますね。で、まあ、だから"
    },
    {
      "start": 549.88,
      "duration": 4.639,
      "text": "それぐらいのことが、まあ大体何でも習慣"
    },
    {
      "start": 552.56,
      "duration": 4.04,
      "text": "にしちゃうとできると。で、これも映画館"
    },
    {
      "start": 554.519,
      "duration": 4.201,
      "text": "に行くっていう習慣にしてるからいけでき"
    },
    {
      "start": 556.6,
      "duration": 3.88,
      "text": "てる感じです。ま、そんな時間ないよって"
    },
    {
      "start": 558.72,
      "duration": 5.32,
      "text": "人もいるかもしんないですけど、作れば"
    },
    {
      "start": 560.48,
      "duration": 6.08,
      "text": "意外と作れます。で、ま、時間は有限なん"
    },
    {
      "start": 564.04,
      "duration": 4.919,
      "text": "ですけど、あの、ま、時間ってデザイン"
    },
    {
      "start": 566.56,
      "duration": 4.519,
      "text": "すれば、ま、増えてくものだということ"
    },
    {
      "start": 568.959,
      "duration": 4.56,
      "text": "です。で、ま、その習慣っていうのは時間"
    },
    {
      "start": 571.079,
      "duration": 4.521,
      "text": "のデザインのことで、で、時間をデザイン"
    },
    {
      "start": 573.519,
      "duration": 4.76,
      "text": "してくと、ま、時間っていうのは増えてき"
    },
    {
      "start": 575.6,
      "duration": 5.2,
      "text": "ます。あの、実際に増えてるわけではない"
    },
    {
      "start": 578.279,
      "duration": 4.8,
      "text": "ですけどね。あの、分かりやすく整理して"
    },
    {
      "start": 580.8,
      "duration": 5.039,
      "text": "あげると時間っていうのは使い方次第で、"
    },
    {
      "start": 583.079,
      "duration": 5.2,
      "text": "あの、すごく倍ぐらいには、え、使える"
    },
    {
      "start": 585.839,
      "duration": 5.041,
      "text": "ようになってくと。で、ま、そのために何"
    },
    {
      "start": 588.279,
      "duration": 5.321,
      "text": "をするかって言うと、習慣なんですけど、"
    },
    {
      "start": 590.88,
      "duration": 6.76,
      "text": "ま、習慣に1番大事なことって1つしか"
    },
    {
      "start": 593.6,
      "duration": 7.28,
      "text": "なくて、もう毎日やるです。もう毎日やる"
    },
    {
      "start": 597.64,
      "duration": 7.8,
      "text": "しかない。週慣って。毎日やることを習慣"
    },
    {
      "start": 600.88,
      "duration": 6.959,
      "text": "って言います。大体で毎日やることが絶対"
    },
    {
      "start": 605.44,
      "duration": 5.2,
      "text": "大事かって言うとそうじゃなくて毎日や"
    },
    {
      "start": 607.839,
      "duration": 4.761,
      "text": "るって決めておくことだけが大事です。だ"
    },
    {
      "start": 610.64,
      "duration": 5.6,
      "text": "できない日はしょうがないす。それはだっ"
    },
    {
      "start": 612.6,
      "duration": 6.2,
      "text": "てあのどっか行っててあの歯ブらしなけれ"
    },
    {
      "start": 616.24,
      "duration": 4.719,
      "text": "ば歯磨きできないでそれをじゃあ習慣って"
    },
    {
      "start": 618.8,
      "duration": 4.44,
      "text": "呼ばないかつったらそんなことはないので"
    },
    {
      "start": 620.959,
      "duration": 4.841,
      "text": "あのできない日はできない。ただやる日は"
    },
    {
      "start": 623.24,
      "duration": 6.719,
      "text": "やるっていうかやらない日を考えないこと"
    },
    {
      "start": 625.8,
      "duration": 7.479,
      "text": "なんです。1つ確実なことってのは毎日"
    },
    {
      "start": 629.959,
      "duration": 6.921,
      "text": "やれば絶対続くんです。はい。あの、やめ"
    },
    {
      "start": 633.279,
      "duration": 5.56,
      "text": "ない限り絶対続いてくんで、あの、なん"
    },
    {
      "start": 636.88,
      "duration": 4.6,
      "text": "だろう、毎日やるっていうこと以外に本当"
    },
    {
      "start": 638.839,
      "duration": 5.201,
      "text": "に何もないのが習慣です。だけど、ま、"
    },
    {
      "start": 641.48,
      "duration": 4.359,
      "text": "こっからあの、どうしたらそれができる"
    },
    {
      "start": 644.04,
      "duration": 3.799,
      "text": "ようになってくかっていうか、どうしたら"
    },
    {
      "start": 645.839,
      "duration": 3.961,
      "text": "やりやすくなってくかっていうのと、ま、"
    },
    {
      "start": 647.839,
      "duration": 4.761,
      "text": "あとそれを応用してどういう風に時間を"
    },
    {
      "start": 649.8,
      "duration": 8.32,
      "text": "こう増やしてくかの話を少ししていく感じ"
    },
    {
      "start": 652.6,
      "duration": 8.32,
      "text": "になってきます。で、ま、僕がその習慣に"
    },
    {
      "start": 658.12,
      "duration": 5.36,
      "text": "気がついたというか、この法則に気がつい"
    },
    {
      "start": 660.92,
      "duration": 5.24,
      "text": "た。法則と言っていいほど大したもんじゃ"
    },
    {
      "start": 663.48,
      "duration": 4.28,
      "text": "ないですけど、あのきっかけはこのお"
    },
    {
      "start": 666.16,
      "duration": 4.0,
      "text": "いでよ動ぶつの森っていう"
    },
    {
      "start": 667.76,
      "duration": 5.16,
      "text": "Nintendo堂DSのソフトです。で"
    },
    {
      "start": 670.16,
      "duration": 6.72,
      "text": "、これ多分2003年ぐらいに出たやつか"
    },
    {
      "start": 672.92,
      "duration": 7.0,
      "text": "な。そっからえっと9年ぐらい僕は毎日"
    },
    {
      "start": 676.88,
      "duration": 6.72,
      "text": "このゲームを20分間ぐらい遊んでました"
    },
    {
      "start": 679.92,
      "duration": 6.719,
      "text": "。で、もう本当にそれは1日も欠かすこと"
    },
    {
      "start": 683.6,
      "duration": 6.039,
      "text": "なく、海外旅行とか行ってる時も、えっと"
    },
    {
      "start": 686.639,
      "duration": 4.801,
      "text": "、20分間必ずやってました。で、仕事"
    },
    {
      "start": 689.639,
      "duration": 4.281,
      "text": "その間にどんどん忙しくなってったんです"
    },
    {
      "start": 691.44,
      "duration": 6.04,
      "text": "よ。で、めっちゃ忙しくて、いろんなこと"
    },
    {
      "start": 693.92,
      "duration": 6.359,
      "text": "できなくなってったにも関わらず、なぜか"
    },
    {
      "start": 697.48,
      "duration": 6.28,
      "text": "この動物の森の20分だけは毎日の中に"
    },
    {
      "start": 700.279,
      "duration": 7.0,
      "text": "必ずあったんですね。で、そん時に思った"
    },
    {
      "start": 703.76,
      "duration": 6.36,
      "text": "のはどんなに忙しくても20分時間が"
    },
    {
      "start": 707.279,
      "duration": 6.0,
      "text": "作れるというか、あ、毎日やってることっ"
    },
    {
      "start": 710.12,
      "duration": 5.24,
      "text": "て続くじゃん。だったんですよ。で、ま、"
    },
    {
      "start": 713.279,
      "duration": 4.761,
      "text": "そのお用じゃないですけど、ま、最近の"
    },
    {
      "start": 715.36,
      "duration": 5.84,
      "text": "気づきで言うと、あの、はてなブログって"
    },
    {
      "start": 718.04,
      "duration": 7.599,
      "text": "いうのも毎日書いてるんですけど、あの、"
    },
    {
      "start": 721.2,
      "duration": 7.639,
      "text": "10年前の2016年の1月18日に投稿"
    },
    {
      "start": 725.639,
      "duration": 6.88,
      "text": "したこれが結構きっかけになって、"
    },
    {
      "start": 728.839,
      "duration": 6.281,
      "text": "えっとるんですけど、その前年まで"
    },
    {
      "start": 732.519,
      "duration": 5.961,
      "text": "2016年の前、2015年、2014年"
    },
    {
      "start": 735.12,
      "duration": 6.8,
      "text": "、2013年ってこれ横に書いてある数値"
    },
    {
      "start": 738.48,
      "duration": 8.039,
      "text": "で投稿した数なんですよ。ま、1ヶ月に1"
    },
    {
      "start": 741.92,
      "duration": 7.0,
      "text": "回ぐらいしかブログ書いてなくて、要は"
    },
    {
      "start": 746.519,
      "duration": 5.921,
      "text": "なんかお知らせだったりとか、もうなんか"
    },
    {
      "start": 748.92,
      "duration": 5.2,
      "text": "本当にろでもないことだったり、本当に"
    },
    {
      "start": 752.44,
      "duration": 5.28,
      "text": "大したことないことしか書いてないんです"
    },
    {
      "start": 754.12,
      "duration": 5.519,
      "text": "けど全然続いてないですよ。全くやる気が"
    },
    {
      "start": 757.72,
      "duration": 6.119,
      "text": "ないブログだったんですけど、その"
    },
    {
      "start": 759.639,
      "duration": 6.0,
      "text": "2016年の1月18日になぜか毎日やっ"
    },
    {
      "start": 763.839,
      "duration": 4.56,
      "text": "てみようかなって思ったんですよ。で、"
    },
    {
      "start": 765.639,
      "duration": 5.601,
      "text": "毎日やってからがこれです。えっと、"
    },
    {
      "start": 768.399,
      "duration": 5.361,
      "text": "2016年は、あの、18日に始めたので"
    },
    {
      "start": 771.24,
      "duration": 4.599,
      "text": "、あの、ちょっと少ないです。あの、正月"
    },
    {
      "start": 773.76,
      "duration": 5.0,
      "text": "に投稿して、18日に投稿してみたいな"
    },
    {
      "start": 775.839,
      "duration": 4.68,
      "text": "感じだったんで、本当に365日毎日書い"
    },
    {
      "start": 778.76,
      "duration": 4.36,
      "text": "てます。で、毎日やることってのはこう"
    },
    {
      "start": 780.519,
      "duration": 5.281,
      "text": "いう風に続いてくんです。はい。これは"
    },
    {
      "start": 783.12,
      "duration": 4.959,
      "text": "毎日やったことの成果です。これを本当に"
    },
    {
      "start": 785.8,
      "duration": 4.039,
      "text": "2日に1回やろうとか思ってたら絶対続い"
    },
    {
      "start": 788.079,
      "duration": 6.361,
      "text": "てないです。あの、年間10何回になり"
    },
    {
      "start": 789.839,
      "duration": 7.761,
      "text": "ます。またで、要するに週に3回やろうっ"
    },
    {
      "start": 794.44,
      "duration": 6.399,
      "text": "て決めるじゃないですか。週に3回やると"
    },
    {
      "start": 797.6,
      "duration": 6.359,
      "text": "やる日やらない日できるのであの今日いい"
    },
    {
      "start": 800.839,
      "duration": 5.24,
      "text": "かな忙しいからってやらない日作るじゃ"
    },
    {
      "start": 803.959,
      "duration": 4.201,
      "text": "ないですか。そうするとどんどんその日が"
    },
    {
      "start": 806.079,
      "duration": 5.401,
      "text": "増えてくんですよ。週に3回やろうと思っ"
    },
    {
      "start": 808.16,
      "duration": 5.679,
      "text": "てたのが大体週1回になります。で数ヶ月"
    },
    {
      "start": 811.48,
      "duration": 4.4,
      "text": "経ったら大体1ヶ月に1回ぐらいになり"
    },
    {
      "start": 813.839,
      "duration": 4.24,
      "text": "ます。ま、1ヶ月に2、3回やるかな"
    },
    {
      "start": 815.88,
      "duration": 5.639,
      "text": "ぐらいな感じになっててどんどん減ってき"
    },
    {
      "start": 818.079,
      "duration": 5.041,
      "text": "ます。毎日やると本当に10年でえっとま"
    },
    {
      "start": 821.519,
      "duration": 3.641,
      "text": "、この回数になってくっていうことなん"
    },
    {
      "start": 823.12,
      "duration": 4.0,
      "text": "ですよ。でも本当になんで続いたかって、"
    },
    {
      "start": 825.16,
      "duration": 4.32,
      "text": "もう単純です。本当に毎日書いたからです"
    },
    {
      "start": 827.12,
      "duration": 4.159,
      "text": "。毎日書いたから続いてるっていうこと"
    },
    {
      "start": 829.48,
      "duration": 4.159,
      "text": "だけです。で、続けようなんて思ってない"
    },
    {
      "start": 831.279,
      "duration": 4.56,
      "text": "です。あれもたまたま今年10年続きまし"
    },
    {
      "start": 833.639,
      "duration": 4.281,
      "text": "たけど、ちょうど10年なんで今年で10"
    },
    {
      "start": 835.839,
      "duration": 4.56,
      "text": "年間前に続きましたけど、10年続けよう"
    },
    {
      "start": 837.92,
      "duration": 5.52,
      "text": "とか1回も考えたことないんで、あの、"
    },
    {
      "start": 840.399,
      "duration": 5.44,
      "text": "ただ毎日ただ淡々と書いてだから続いた"
    },
    {
      "start": 843.44,
      "duration": 6.079,
      "text": "だけです。10年後なんか考えてたら多分"
    },
    {
      "start": 845.839,
      "duration": 3.68,
      "text": "続いてないんで。"
    },
    {
      "start": 852.399,
      "duration": 7.401,
      "text": "で、ま、毎日続けるための6つのコツが"
    },
    {
      "start": 855.72,
      "duration": 6.52,
      "text": "あります。はい。あの、すごいシンプルな"
    },
    {
      "start": 859.8,
      "duration": 5.64,
      "text": "6つのコツがあって、ま、それを守ると、"
    },
    {
      "start": 862.24,
      "duration": 5.92,
      "text": "ま、大体さっきみたいなあのなんか大体人"
    },
    {
      "start": 865.44,
      "duration": 4.8,
      "text": "が引くような結果が出てくるという感じに"
    },
    {
      "start": 868.16,
      "duration": 4.119,
      "text": "はなると思うんですけど、ま、コツさっき"
    },
    {
      "start": 870.24,
      "duration": 4.24,
      "text": "からこれしか言ってないんで、実はこれ"
    },
    {
      "start": 872.279,
      "duration": 4.68,
      "text": "しかないかもしれないんですけど、あの、"
    },
    {
      "start": 874.48,
      "duration": 4.76,
      "text": "続けるためのコツは1つです、本当に。で"
    },
    {
      "start": 876.959,
      "duration": 5.24,
      "text": "も、ま、コツの1個目です。毎日やると"
    },
    {
      "start": 879.24,
      "duration": 5.68,
      "text": "決めることです。で、ま、本当にやる人"
    },
    {
      "start": 882.199,
      "duration": 4.361,
      "text": "やらない日を作らないことです。で、でき"
    },
    {
      "start": 884.92,
      "duration": 5.919,
      "text": "なかった日はできなかった日でしょうが"
    },
    {
      "start": 886.56,
      "duration": 7.519,
      "text": "ないと思うのがあの続けるコツというか"
    },
    {
      "start": 890.839,
      "duration": 5.521,
      "text": "本当に続けようと思わない方がいいと思い"
    },
    {
      "start": 894.079,
      "duration": 5.0,
      "text": "ます。今日やるっていうことだけを考えた"
    },
    {
      "start": 896.36,
      "duration": 4.919,
      "text": "方がいいです。いつまで続けようとか"
    },
    {
      "start": 899.079,
      "duration": 3.841,
      "text": "なんか1ヶ月続けたらいいことあるかもと"
    },
    {
      "start": 901.279,
      "duration": 4.841,
      "text": "かっていうのはあんまり考えない方が良く"
    },
    {
      "start": 902.92,
      "duration": 5.719,
      "text": "て今日やることだけを考える。休もうか"
    },
    {
      "start": 906.12,
      "duration": 6.2,
      "text": "なって思ったら明日休むと思ってください"
    },
    {
      "start": 908.639,
      "duration": 5.681,
      "text": "。明日休もうって思って、明日が来たら"
    },
    {
      "start": 912.32,
      "duration": 4.28,
      "text": "明日休もうって思ってください。で、それ"
    },
    {
      "start": 914.32,
      "duration": 4.28,
      "text": "をずっと続けていくと、あの、前に続き"
    },
    {
      "start": 916.6,
      "duration": 4.08,
      "text": "ます。できない日はしょうがないと思う"
    },
    {
      "start": 918.6,
      "duration": 4.039,
      "text": "しかないです。なんか取り戻そうとか思わ"
    },
    {
      "start": 920.68,
      "duration": 3.88,
      "text": "ない方がいいです。なんか昨日できなかっ"
    },
    {
      "start": 922.639,
      "duration": 4.161,
      "text": "たから2日分やろうとかってやると負担"
    },
    {
      "start": 924.56,
      "duration": 3.759,
      "text": "増えるので、あんまりそれはもうしない方"
    },
    {
      "start": 926.8,
      "duration": 4.56,
      "text": "がいいかなと思うんです。今日からまた"
    },
    {
      "start": 928.319,
      "duration": 4.921,
      "text": "やればいいかなっていう。で、あの、その"
    },
    {
      "start": 931.36,
      "duration": 4.44,
      "text": "負担を減らすためにすることは、ま、"
    },
    {
      "start": 933.24,
      "duration": 5.56,
      "text": "小さくやることです。とにかく負担をかけ"
    },
    {
      "start": 935.8,
      "duration": 5.959,
      "text": "ない。最初はとにかく小さくやることです"
    },
    {
      "start": 938.8,
      "duration": 6.399,
      "text": "ね。あの、本読もうと思ったら、えっと、"
    },
    {
      "start": 941.759,
      "duration": 6.76,
      "text": "1文字でいいから読むとか。ま、1文字"
    },
    {
      "start": 945.199,
      "duration": 6.76,
      "text": "じゃ多分ね、2日で2文字じゃ進まないす"
    },
    {
      "start": 948.519,
      "duration": 6.8,
      "text": "からね。全く進まないんで。あんまりそれ"
    },
    {
      "start": 951.959,
      "duration": 6.081,
      "text": "はお勧めしませんけど。でもそれぐらい本"
    },
    {
      "start": 955.319,
      "duration": 4.921,
      "text": "読むのが苦手だったら、えっと、1ヶ月"
    },
    {
      "start": 958.04,
      "duration": 4.919,
      "text": "かけて1ページ読むとかも全然ありだと"
    },
    {
      "start": 960.24,
      "duration": 4.88,
      "text": "思います。要は本に触るっていう行為"
    },
    {
      "start": 962.959,
      "duration": 3.841,
      "text": "ぐらいからスタートしてもいいので、"
    },
    {
      "start": 965.12,
      "duration": 4.079,
      "text": "とにかく最初は負担をかけないぐらい"
    },
    {
      "start": 966.8,
      "duration": 6.2,
      "text": "小さくやる。そのうち絶対読むようになる"
    },
    {
      "start": 969.199,
      "duration": 6.721,
      "text": "んで、僕も本当に始める時は絶対自分にし"
    },
    {
      "start": 973.0,
      "duration": 5.6,
      "text": "ます。あの、本とかで毎日10分続け"
    },
    {
      "start": 975.92,
      "duration": 5.839,
      "text": "ましょうって書いてあっても10分絶対"
    },
    {
      "start": 978.6,
      "duration": 6.32,
      "text": "続かないと思うんで、大体"
    },
    {
      "start": 981.759,
      "duration": 6.041,
      "text": "10分って書いてあったら30秒か10秒"
    },
    {
      "start": 984.92,
      "duration": 5.44,
      "text": "のことに自分で変換しちゃいます。で、"
    },
    {
      "start": 987.8,
      "duration": 4.68,
      "text": "気持ちよく続けられそうだなと思ったら、"
    },
    {
      "start": 990.36,
      "duration": 6.2,
      "text": "ちょっとずつ伸ばします。最初から10分"
    },
    {
      "start": 992.48,
      "duration": 8.76,
      "text": "やって1ヶ月で終わるよりは、えっと、1"
    },
    {
      "start": 996.56,
      "duration": 7.839,
      "text": "分しかやらないことを1年続けた方が多分"
    },
    {
      "start": 1001.24,
      "duration": 6.32,
      "text": "長持ちするというか、いいかなっていう気"
    },
    {
      "start": 1004.399,
      "duration": 5.92,
      "text": "がしますね。で、ま、あの、3つ目のコツ"
    },
    {
      "start": 1007.56,
      "duration": 5.519,
      "text": "は、ま、いつやるか決めるですね。これは"
    },
    {
      "start": 1010.319,
      "duration": 5.2,
      "text": "ものすごい重要です。7時になったら"
    },
    {
      "start": 1013.079,
      "duration": 5.56,
      "text": "やろうとか、7時半になったらこれをする"
    },
    {
      "start": 1015.519,
      "duration": 5.281,
      "text": "みたいな時間では決めない方がいいです。"
    },
    {
      "start": 1018.639,
      "duration": 4.68,
      "text": "それは起きれなかった時とかずれてしまっ"
    },
    {
      "start": 1020.8,
      "duration": 5.96,
      "text": "た時にできなくなるから、ま、いつやるか"
    },
    {
      "start": 1023.319,
      "duration": 6.24,
      "text": "は絶対何かの行動に紐付けた方が良くて、"
    },
    {
      "start": 1026.76,
      "duration": 5.679,
      "text": "起きたらやるとか、仕事をする前に"
    },
    {
      "start": 1029.559,
      "duration": 6.12,
      "text": "コーヒーを入れるみたいな紐付けはすごく"
    },
    {
      "start": 1032.439,
      "duration": 5.801,
      "text": "重要で、必ず固定する場所ってのを作って"
    },
    {
      "start": 1035.679,
      "duration": 4.921,
      "text": "おく。で、そのタイミングが来たら必ずや"
    },
    {
      "start": 1038.24,
      "duration": 6.64,
      "text": "るっていう風にする。そ、そういういつ"
    },
    {
      "start": 1040.6,
      "duration": 5.76,
      "text": "やるかですね。で、例えば、あの、毎日"
    },
    {
      "start": 1044.88,
      "duration": 4.36,
      "text": "できないことってのもあるんですよ。僕も"
    },
    {
      "start": 1046.36,
      "duration": 5.88,
      "text": "毎日できないことあるので、月に1回必ず"
    },
    {
      "start": 1049.24,
      "duration": 5.2,
      "text": "写真店に行くって決めてるんですけど、"
    },
    {
      "start": 1052.24,
      "duration": 5.04,
      "text": "都内に会議に行く日っていうのが、ま、"
    },
    {
      "start": 1054.44,
      "duration": 5.88,
      "text": "大体定例で決まってるので、その都内に"
    },
    {
      "start": 1057.28,
      "duration": 5.56,
      "text": "会議に行く日は写真店も行くっていう風に"
    },
    {
      "start": 1060.32,
      "duration": 4.92,
      "text": "決めておくと、あの、必ず会議に行った日"
    },
    {
      "start": 1062.84,
      "duration": 4.56,
      "text": "に写真店が紐づくので、そういういつやる"
    },
    {
      "start": 1065.24,
      "duration": 4.96,
      "text": "かなんですよ。決められるタイミングを"
    },
    {
      "start": 1067.4,
      "duration": 7.159,
      "text": "作っとくことですね。あの、掃除とかもだ"
    },
    {
      "start": 1070.2,
      "duration": 7.479,
      "text": "から僕はもうその1週間の中で、えっと、"
    },
    {
      "start": 1074.559,
      "duration": 6.36,
      "text": "ま、日曜日と水曜日はトイレ掃除とか、"
    },
    {
      "start": 1077.679,
      "duration": 7.24,
      "text": "あの、月曜日はお風呂掃除、火曜日は台所"
    },
    {
      "start": 1080.919,
      "duration": 6.321,
      "text": "掃除、え、木曜日は洗面所、金曜日はあの"
    },
    {
      "start": 1084.919,
      "duration": 4.281,
      "text": "床掃除、土曜日は仕事ベアみたいに決め"
    },
    {
      "start": 1087.24,
      "duration": 4.52,
      "text": "てるんですけど、そういういつやるかを"
    },
    {
      "start": 1089.2,
      "duration": 5.2,
      "text": "必ず決めておく。で、これは、ま、毎日"
    },
    {
      "start": 1091.76,
      "duration": 4.72,
      "text": "掃除をやるんですけど、あの、そういう"
    },
    {
      "start": 1094.4,
      "duration": 5.159,
      "text": "振り分けをしてくことによって漏れなく"
    },
    {
      "start": 1096.48,
      "duration": 6.84,
      "text": "全部ができるっていういつやるかを必ず"
    },
    {
      "start": 1099.559,
      "duration": 7.681,
      "text": "こう全部に対してルール設定しておくと、"
    },
    {
      "start": 1103.32,
      "duration": 6.479,
      "text": "ま、漏れなくできるという。で、ま、その"
    },
    {
      "start": 1107.24,
      "duration": 4.319,
      "text": "紐付けにすごく近いことなんですけど、"
    },
    {
      "start": 1109.799,
      "duration": 4.88,
      "text": "あの、セットにするっていうのも1つ"
    },
    {
      "start": 1111.559,
      "duration": 5.36,
      "text": "大きな考え方の1つで、小さくいろんな"
    },
    {
      "start": 1114.679,
      "duration": 4.961,
      "text": "ことを小分けしちゃうので、その小さい"
    },
    {
      "start": 1116.919,
      "duration": 5.161,
      "text": "もって意外と忘れちゃうんですよ。小さい"
    },
    {
      "start": 1119.64,
      "duration": 4.399,
      "text": "ことって忘れがちなんですけど、2つ3つ"
    },
    {
      "start": 1122.08,
      "duration": 5.079,
      "text": "セットにしとくと必ず覚えてられるんです"
    },
    {
      "start": 1124.039,
      "duration": 3.12,
      "text": "よ。"
    }
  ]
}