      "start": 811.519,
      "duration": 3.361,
      "text": "うん。"
    },
    {
      "start": 811.88,
      "duration": 3.0,
      "text": "はい。あ、とにかくのこんな冬の大変な時に"
    },
    {
      "start": 816.48,
      "duration": 4.039,
