      "start": 949.8,
      "duration": 3.8,
      "text": "うん。"
    },
    {
      "start": 950.88,
      "duration": 5.72,
      "text": "はい。次行きましょうか。その国民主党かな。"
    },
    {
      "start": 953.6,
      "duration": 3.0,
      "text": "次見てみましょうか。こちらはもう極端ですね。"
    },
    {
      "start": 959.319,
      "duration": 1.32,
      "text": "分かりやすいですよね。"
    },
    {
      "start": 960.199,
      "duration": 1.2,
      "text": "はい。"
