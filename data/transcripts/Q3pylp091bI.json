      "start": 343.479,
      "duration": 5.16,
      "text": "入らない。仕入れ先にもお金が回らない"
    },
    {
      "start": 345.919,
      "duration": 4.881,
      "text": "経済が止まるんです。で、結局自分の給料"
    },
    {
      "start": 348.639,
      "duration": 4.081,
      "text": "も上がっていかない。いいことって何も"
    },
    {
      "start": 350.8,
      "duration": 4.08,
      "text": "起きないんですよ。だからですね、別に"
    },
    {
      "start": 352.72,
      "duration": 4.039,
      "text": "高級車買おうとかマンション買おうとか"
    },
    {
      "start": 354.88,
      "duration": 3.92,
      "text": "いう話じゃなくていつもよりちょっといい"
    },
    {
      "start": 356.759,
      "duration": 3.88,
      "text": "食材を買う。ランチでいつもよりちょっと"
    },
    {
      "start": 358.8,
      "duration": 4.0,
      "text": "上のメニューを頼んでみる。日帰りで"
    },
    {
      "start": 360.639,
      "duration": 3.721,
      "text": "ちょっと足を伸ばして遊びに行く。この"
    },
    {
      "start": 362.8,
      "duration": 4.239,
      "text": "ちょっとだけでいいんです。それを無理の"
    },
    {
      "start": 364.36,
      "duration": 5.44,
      "text": "ない範囲で続けることが結果的に回り回っ"
    },
    {
      "start": 367.039,
      "duration": 4.88,
      "text": "てあなたの人生を幸せにしてくれるものに"
    },
    {
      "start": 369.8,
      "duration": 4.519,
      "text": "なっていくんです。私もですね、新橋の"
    },
    {
      "start": 371.919,
      "duration": 4.0,
      "text": "ビジネスバー、GSバーを去年の9月から"
    },
    {
      "start": 374.319,
      "duration": 3.961,
      "text": "やっているから分かるんですけど、お客"
    },
    {
      "start": 375.919,
      "duration": 4.601,
      "text": "さんで本当にいい人だなっていう人は"
    },
    {
      "start": 378.28,
      "duration": 4.319,
      "text": "やっぱりね、お金の使い方も気持ちがいい"
    },
    {
      "start": 380.52,
      "duration": 4.239,
      "text": "んですよ。ケチなんじゃなくて出すところ"
    },
    {
      "start": 382.599,
      "duration": 4.561,
      "text": "ですっと出す。そういう人のところには"
    },
    {
      "start": 384.759,
      "duration": 4.241,
      "text": "やっぱりまた人が集まってその人に仕事を"
    },
    {
      "start": 387.16,
      "duration": 4.2,
      "text": "振りたいっていう人も増えている印象なん"
    },
    {
      "start": 389.0,
      "duration": 4.759,
      "text": "ですよね。で、話を戻してこのお金を回"
    },
    {
      "start": 391.36,
      "duration": 5.08,
      "text": "すって考え方をもっと広げてみると寄付も"
    },
    {
      "start": 393.759,
      "duration": 5.321,
      "text": "その一部です。著者はこの考えで学生の"
    },
    {
      "start": 396.44,
      "duration": 4.92,
      "text": "支援団体とか子供食堂とかに寄付をして"
    },
    {
      "start": 399.08,
      "duration": 4.6,
      "text": "いるそうです。困ってる人間を助けるのは"
    },
    {
      "start": 401.36,
      "duration": 4.119,
      "text": "お金持ちだけの仕事じゃない。お前ら誰で"
    },
    {
      "start": 403.68,
      "duration": 4.32,
      "text": "もできるとおじさんはこの本で言ってい"
    },
    {
      "start": 405.479,
      "duration": 4.681,
      "text": "ます。相手の人生を丸ごと処い込む必要は"
    },
    {
      "start": 408.0,
      "duration": 4.44,
      "text": "ないんです。困ってる部分を少しだけ"
    },
    {
      "start": 410.16,
      "duration": 4.56,
      "text": "助ければそれだけでOK。今はね、ネット"
    },
    {
      "start": 412.44,
      "duration": 5.08,
      "text": "でも数百円から寄付できる時代ですからね"
    },
    {
      "start": 414.72,
      "duration": 5.4,
      "text": "。私もですね、自動用語施設に寄付とあと"
    },
    {
      "start": 417.52,
      "duration": 4.6,
      "text": "海外の支援団体へ毎月5000円だけやっ"
    },
    {
      "start": 420.12,
      "duration": 3.72,
      "text": "ているんですが、そんなに何万とか何十万"
    },
    {
      "start": 422.12,
      "duration": 3.519,
      "text": "ではないんですよ。でもそれやってるだけ"
    },
    {
      "start": 423.84,
      "duration": 3.52,
      "text": "でもなんかいいことしたなって気分になれ"
    },
    {
      "start": 425.639,
      "duration": 3.601,
      "text": "てポジティブになれるんですよね。"
    },
    {
      "start": 427.36,
      "duration": 3.92,
      "text": "ぶっちゃけね、簡単なのはコンビニとか"
    },
    {
      "start": 429.24,
      "duration": 3.359,
      "text": "駅前の母金あるじゃないですか。あれ"
    },
    {
      "start": 431.28,
      "duration": 3.16,
      "text": "10円でもいいんです。やってみて"
    },
    {
      "start": 432.599,
      "duration": 3.88,
      "text": "ください。本当にね、いいことしたなって"
    },
    {
      "start": 434.44,
      "duration": 3.92,
      "text": "気分が上がって正直ですね。これね、"
    },
    {
      "start": 436.479,
      "duration": 4.56,
      "text": "こっちの自己満足の話でもあるんですが、"
    },
    {
      "start": 438.36,
      "duration": 4.48,
      "text": "10円寄付したら10円以上の交付感"
    },
    {
      "start": 441.039,
      "duration": 5.201,
      "text": "いただけます。金額はね、何でもいいん"
    },
    {
      "start": 442.84,
      "duration": 5.639,
      "text": "ですよ。ただここで1番伝えたいのはお金"
    },
    {
      "start": 446.24,
      "duration": 4.359,
      "text": "の話だけじゃないということ。おじさんが"
    },
    {
      "start": 448.479,
      "duration": 4.201,
      "text": "言ってるのはちょっといいことを先に誰か"
    },
    {
      "start": 450.599,
      "duration": 4.081,
      "text": "にすればちょっといいことが自分にも"
    },
    {
      "start": 452.68,
      "duration": 4.48,
      "text": "起きるということ。ただし大事なポイント"
    },
    {
      "start": 454.68,
      "duration": 4.48,
      "text": "があって相手が本当に喜ぶことじゃないと"
    },
    {
      "start": 457.16,
      "duration": 4.4,
      "text": "意味がないんです。特に嬉しくないことを"
    },
    {
      "start": 459.16,
      "duration": 4.319,
      "text": "されても誰も喜びません。だから注意を"
    },
    {
      "start": 461.56,
      "duration": 3.96,
      "text": "よく観察することが大事になってくるん"
    },
    {
      "start": 463.479,
      "duration": 4.081,
      "text": "ですよ。あ、あの人困ってるなって時に"
    },
    {
      "start": 465.52,
      "duration": 4.28,
      "text": "すかさずサポートしてあげる人。やっぱり"
    },
    {
      "start": 467.56,
      "duration": 4.319,
      "text": "誰からも疲れますよね。これ営業やってた"
    },
    {
      "start": 469.8,
      "duration": 4.88,
      "text": "時の私もまさにそうだったんですけど、"
    },
    {
      "start": 471.879,
      "duration": 5.201,
      "text": "商品が売れる時ってまず相手の困り事を"
    },
    {
      "start": 474.68,
      "duration": 3.959,
      "text": "解決してあげることが先なんですよ。最近"
    },
    {
      "start": 477.08,
      "duration": 4.28,
      "text": "こういうの困ってるんだよねって言われ"
    },
    {
      "start": 478.639,
      "duration": 4.881,
      "text": "たら自社の商品と関係なくてもそれなら"
    },
    {
      "start": 481.36,
      "duration": 4.239,
      "text": "こういうやり方ありますよで情報を渡して"
    },
    {
      "start": 483.52,
      "duration": 4.48,
      "text": "あげる。別にそれで一円にもなりません。"
    },
    {
      "start": 485.599,
      "duration": 5.0,
      "text": "でもそうやって先に出してる人のところに"
    },
    {
      "start": 488.0,
      "duration": 5.039,
      "text": "結局仕事が集まってくるんです。職場でも"
    },
    {
      "start": 490.599,
      "duration": 4.801,
      "text": "同じで忙しそうな同僚になんか手伝おう"
    },
    {
      "start": 493.039,
      "duration": 4.6,
      "text": "かって一言声をかけてあげる。後輩がミス"
    },
    {
      "start": 495.4,
      "duration": 3.68,
      "text": "して落ち込んでいたら大丈夫?自分も昔"
    },
    {
      "start": 497.639,
      "duration": 2.56,
      "text": "やったよってフォローしてあげる。"
    },
    {
      "start": 499.08,
      "duration": 3.72,
      "text": "ちょっとでいいんです。ちょっとを"
    },
    {
      "start": 500.199,
      "duration": 4.84,
      "text": "先い出す。そしてそれをコツコツ続ける。"
    },
    {
      "start": 502.8,
      "duration": 4.839,
      "text": "それだけであなたの周りの流れがどんどん"
    },
    {
      "start": 505.039,
      "duration": 4.88,
      "text": "良くなって結果必ずあなたに帰ってきて"
    },
    {
      "start": 507.639,
      "duration": 4.201,
      "text": "幸せになれますから。これね1つや2つ"
    },
    {
      "start": 509.919,
      "duration": 3.92,
      "text": "やってあ、やっぱ帰ってこなかったな。"
    },
    {
      "start": 511.84,
      "duration": 3.879,
      "text": "面倒ダめだ。やめちべりだわ。もう"
    },
    {
      "start": 513.839,
      "duration": 4.361,
      "text": "やめようっていうのは本当ダメでこれね。"
    },
    {
      "start": 515.719,
      "duration": 4.641,
      "text": "見返りを求めちゃ絶対にダめ。基本はもう"
    },
    {
      "start": 518.2,
      "duration": 4.04,
      "text": "何も帰ってこない。でも自分がやりたい"
    },
    {
      "start": 520.36,
      "duration": 4.599,
      "text": "からやった。それだけで満足しておいた方"
    },
    {
      "start": 522.24,
      "duration": 4.64,
      "text": "が個人的には継続できたんでその緩い"
    },
    {
      "start": 524.959,
      "duration": 4.481,
      "text": "スタンスでやるのがおすすめです。ちなみ"
    },
    {
      "start": 526.88,
      "duration": 5.32,
      "text": "にこちらの過去動画では1日1分やるだけ"
    },
    {
      "start": 529.44,
      "duration": 5.0,
      "text": "で運が良くなっていく方法を具体的に解説"
    },
    {
      "start": 532.2,
      "duration": 5.4,
      "text": "していますので興味がある人は説明欄から"
    },
    {
      "start": 534.44,
      "duration": 5.519,
      "text": "覗いてみてください。3つ目逃げ道を作れ"
    },
    {
      "start": 537.6,
      "duration": 4.84,
      "text": "という話。職場で誰かと意見がぶつかった"
    },
    {
      "start": 539.959,
      "duration": 4.521,
      "text": "時相手の矛盾を見つけていやそれおかしく"
    },
    {
      "start": 542.44,
      "duration": 4.2,
      "text": "ないですかってぐさっとさしたくなること"
    },
    {
      "start": 544.48,
      "duration": 4.16,
      "text": "ありませんかね?SNSとかまさにそうだ"
    },
    {
      "start": 546.64,
      "duration": 3.439,
      "text": "と思うんですよ。のコメント欄とか"
    },
    {
      "start": 548.64,
      "duration": 3.879,
      "text": "Yahooニュースのコメント欄とか見"
    },
    {
      "start": 550.079,
      "duration": 4.801,
      "text": "てるともう追い詰め合戦ですよね。ロパし"
    },
    {
      "start": 552.519,
      "duration": 4.88,
      "text": "て引用音リツイートで晒らしてコメントで"
    },
    {
      "start": 554.88,
      "duration": 4.72,
      "text": "畳みかけるこれですね。実際に言い任すと"
    },
    {
      "start": 557.399,
      "duration": 4.68,
      "text": "その人は気持ちがいいそうなんです。でも"
    },
    {
      "start": 559.6,
      "duration": 4.479,
      "text": "ねその後ってなんか嫌な感じ残りそうじゃ"
    },
    {
      "start": 562.079,
      "duration": 3.76,
      "text": "ありません?勝ったはずなのにすっきりし"
    },
    {
      "start": 564.079,
      "duration": 3.88,
      "text": "ない。あのモヤっとした感じ。これですね"
    },
    {
      "start": 565.839,
      "duration": 4.401,
      "text": "。おじいさんが面白いこと言っててあの"
    },
    {
      "start": 567.959,
      "duration": 5.0,
      "text": "もやっとした感じの正体は追い詰めたこと"
    },
    {
      "start": 570.24,
      "duration": 4.599,
      "text": "で自分の中にも黒いエネルギーが溜まる"
    },
    {
      "start": 572.959,
      "duration": 4.281,
      "text": "からなんだそうです。追い詰めた側も"
    },
    {
      "start": 574.839,
      "duration": 4.361,
      "text": "追い詰められた側も両方不幸になる。だ"
    },
    {
      "start": 577.24,
      "duration": 4.279,
      "text": "からおじさんはですね、どんな理由であれ"
    },
    {
      "start": 579.2,
      "duration": 4.52,
      "text": "、どんな相手であれ、絶対に追い詰めるな"
    },
    {
      "start": 581.519,
      "duration": 4.361,
      "text": "。逃げ道を作れって言ってるんです。で、"
    },
    {
      "start": 583.72,
      "duration": 4.4,
      "text": "ここからがまた深いんですけど、逃げ道を"
    },
    {
      "start": 585.88,
      "duration": 4.44,
      "text": "作るのは相手のためじゃないんです。自分"
    },
    {
      "start": 588.12,
      "duration": 4.839,
      "text": "のためなんですよ。追い詰めると恨まれる"
    },
    {
      "start": 590.32,
      "duration": 5.04,
      "text": "。恨みを買った相手っていつか必ず反撃し"
    },
    {
      "start": 592.959,
      "duration": 4.0,
      "text": "てきます。しかも大体自分が一番きつい"
    },
    {
      "start": 595.36,
      "duration": 3.4,
      "text": "タイミングで来たりしますからね。"
    },
    {
      "start": 596.959,
      "duration": 3.761,
      "text": "追い詰めたくなる気持ちは分かるけど、"
    },
    {
      "start": 598.76,
      "duration": 4.079,
      "text": "それ全部自分に帰ってくるんで、それは"
    },
    {
      "start": 600.72,
      "duration": 4.4,
      "text": "もう今、この瞬間からやめましょう。私も"
    },
    {
      "start": 602.839,
      "duration": 5.24,
      "text": "ね、反省してる部分あって、20代は本当"
    },
    {
      "start": 605.12,
      "duration": 4.8,
      "text": "に仕事人間で売上を上げるために本気だっ"
    },
    {
      "start": 608.079,
      "duration": 3.641,
      "text": "たんです。それこそ同僚とかにめっちゃ"
    },
    {
      "start": 609.92,
      "duration": 5.039,
      "text": "詰めてなんでこれやってないんですか?で"
    },
    {
      "start": 611.72,
      "duration": 5.08,
      "text": "ももう今で言うゾスの性格、逃げ道の橋を"
    },
    {
      "start": 614.959,
      "duration": 3.801,
      "text": "チェーン層で切り落として仕事している"
    },
    {
      "start": 616.8,
      "duration": 4.279,
      "text": "感じでした。その結果どうなったのか。"
    },
    {
      "start": 618.76,
      "duration": 4.96,
      "text": "仕事上で確かに売上がって結果は出たん"
    },
    {
      "start": 621.079,
      "duration": 4.76,
      "text": "ですが、おそらく当時職場全員から嫌われ"
    },
    {
      "start": 623.72,
      "duration": 4.16,
      "text": "てました。当時はね、必死だったんで自分"
    },
    {
      "start": 625.839,
      "duration": 4.24,
      "text": "も気づかなかったんですが、やっぱり恨み"
    },
    {
      "start": 627.88,
      "duration": 4.519,
      "text": "を買うような言動、行動はしちゃダめだ"
    },
    {
      "start": 630.079,
      "duration": 4.2,
      "text": "なって改めて過去の失敗から学んでおり"
    },
    {
      "start": 632.399,
      "duration": 4.361,
      "text": "ます。だからですね、YouTube始め"
    },
    {
      "start": 634.279,
      "duration": 4.521,
      "text": "てからは人が変わったように穏やかに仕事"
    },
    {
      "start": 636.76,
      "duration": 4.199,
      "text": "をするようにしています。ここ7年間"
    },
    {
      "start": 638.8,
      "duration": 4.24,
      "text": "YouTube関係の仕事ではたった2回"
    },
    {
      "start": 640.959,
      "duration": 4.041,
      "text": "しか人にぶち入れしていません。ま、2回"
    },
    {
      "start": 643.04,
      "duration": 3.64,
      "text": "しちゃったのもね、反省なんですけど、私"
    },
    {
      "start": 645.0,
      "duration": 3.959,
      "text": "ね、起こるきっかけがあって、自分のこと"
    },
    {
      "start": 646.68,
      "duration": 5.32,
      "text": "は我慢できるんですよ。私が嫌だなと思っ"
    },
    {
      "start": 648.959,
      "duration": 5.361,
      "text": "てる人が私が大好きだと思ってる人の影口"
    },
    {
      "start": 652.0,
      "duration": 4.36,
      "text": "を言った時にすぐにね怒っちゃうんですよ"
    },
    {
      "start": 654.32,
      "duration": 3.8,
      "text": "ね。これもね直さなきゃと反省しています"
    },
    {
      "start": 656.36,
      "duration": 4.96,
      "text": "。あとおじさんはこうも言っています。"
    },
    {
      "start": 658.12,
      "duration": 6.08,
      "text": "この世界は全て物語だ。お前はお前の物語"
    },
    {
      "start": 661.32,
      "duration": 5.84,
      "text": "を楽しめばいいって。イライラする状況も"
    },
    {
      "start": 664.2,
      "duration": 5.12,
      "text": "面倒な人間関係も全部あなたの物語の"
    },
    {
      "start": 667.16,
      "duration": 4.32,
      "text": "エピソードなんです。追い詰めて恨みを"
    },
    {
      "start": 669.32,
      "duration": 4.56,
      "text": "買うより人間を作ってあげて次の"
    },
    {
      "start": 671.48,
      "duration": 4.799,
      "text": "エピソードに進んだ方がよっぽどいい物語"
    },
    {
      "start": 673.88,
      "duration": 4.759,
      "text": "になると私は思います。ですから、次に誰"
    },
    {
      "start": 676.279,
      "duration": 4.441,
      "text": "かにカチンと来た時、言い任したくなった"
    },
    {
      "start": 678.639,
      "duration": 4.76,
      "text": "時、その前に1つだけ意識してみて"
    },
    {
      "start": 680.72,
      "duration": 4.88,
      "text": "ください。逃げ道を1本残す。相手を完全"
    },
    {
      "start": 683.399,
      "duration": 4.56,
      "text": "に追い詰めない。それだけで相手との関係"
    },
    {
      "start": 685.6,
      "duration": 4.52,
      "text": "も自分の気持ちも驚くほど変わっていき"
    },
    {
      "start": 687.959,
      "duration": 4.601,
      "text": "ますから。今回紹介した以外にもこの本に"
    },
    {
      "start": 690.12,
      "duration": 4.279,
      "text": "は人生で大切なことが分かりやすく書かれ"
    },
    {
      "start": 692.56,
      "duration": 4.68,
      "text": "ています。説明欄にリンクは与ありますの"
    },
    {
      "start": 694.399,
      "duration": 4.921,
      "text": "で是非ねポチってみてください。誰かに"
    },
    {
      "start": 697.24,
      "duration": 4.08,
      "text": "何かをしたことがいつか返ってくるという"
    },
    {
      "start": 699.32,
      "duration": 4.519,
      "text": "話がこの本であったじゃないですか。その"
    },
    {
      "start": 701.32,
      "duration": 4.68,
      "text": "エピソードで、ちょうどこの前私にも話が"
    },
    {
      "start": 703.839,
      "duration": 3.641,
      "text": "ありまして、私2020年に"
    },
    {
      "start": 706.0,
      "duration": 3.92,
      "text": "YouTubeを教えた子がいるんですが"
    },
    {
      "start": 707.48,
      "duration": 4.479,
      "text": "、その人は私より年下でYouTubeを"
    },
    {
      "start": 709.92,
      "duration": 4.32,
      "text": "教えてあげていたんです。その時、その人"
    },
    {
      "start": 711.959,
      "duration": 4.721,
      "text": "サラリーマンで関西の方にいたんですが、"
    },
    {
      "start": 714.24,
      "duration": 4.599,
      "text": "相談があるんですって言って東京まで来て"
    },
    {
      "start": 716.68,
      "duration": 4.68,
      "text": "相談に乗ったんですよ。内容はブラック"
    },
    {
      "start": 718.839,
      "duration": 4.161,
      "text": "企業にいて今度広島に転勤しなきゃいけ"
    },
    {
      "start": 721.36,
      "duration": 3.479,
      "text": "ない。YouTubeは稼げるようになっ"
    },
    {
      "start": 723.0,
      "duration": 4.36,
      "text": "たけど不安です。どうしたらいいでしょう"
    },
    {
      "start": 724.839,
      "duration": 4.321,
      "text": "かっていう相談で私はですね、そん時その"
    },
    {
      "start": 727.36,
      "duration": 3.96,
      "text": "人がめちゃくちゃYouTube優秀なの"
    },
    {
      "start": 729.16,
      "duration": 4.2,
      "text": "分かっていたんで実家に戻って固定費を"
    },
    {
      "start": 731.32,
      "duration": 3.879,
      "text": "落としてYouTube本気であれば君"
    },
    {
      "start": 733.36,
      "duration": 4.32,
      "text": "なら食べていけるよってアドバイスをした"
    },
    {
      "start": 735.199,
      "duration": 4.401,
      "text": "んです。教え始めて確か3ヶ月くらいで"
    },
    {
      "start": 737.68,
      "duration": 3.839,
      "text": "30万円とか稼げるようになっていたんで"
    },
    {
      "start": 739.6,
      "duration": 3.88,
      "text": "本当優秀だからそうやってアドバイスした"
    },
    {
      "start": 741.519,
      "duration": 4.56,
      "text": "んですよ。普通はもう専業YouTube"
    },
    {
      "start": 743.48,
      "duration": 4.84,
      "text": "は収入安定しないんでマジでお勧めしてい"
    },
    {
      "start": 746.079,
      "duration": 5.2,
      "text": "ません。で、その時にご飯を奢ってあげて"
    },
    {
      "start": 748.32,
      "duration": 4.72,
      "text": "大阪から東京の交通費をね、私茶ブー島で"
    },
    {
      "start": 751.279,
      "duration": 3.881,
      "text": "渡したそうなんです。それ向こうからこの"
    },
    {
      "start": 753.04,
      "duration": 4.239,
      "text": "前言われて私あんまり覚えてなかったん"
    },
    {
      "start": 755.16,
      "duration": 4.6,
      "text": "ですが、その人が今YouTube関連"
    },
    {
      "start": 757.279,
      "duration": 5.201,
      "text": "事業で年少2億の社長やってるんですよ。"
    },
    {
      "start": 759.76,
      "duration": 4.639,
      "text": "で、ここからがすごいのが私が去年新橋に"
    },
    {
      "start": 762.48,
      "duration": 3.76,
      "text": "ビジネスバー、GSバーを作ろうと"
    },
    {
      "start": 764.399,
      "duration": 3.68,
      "text": "クラウドファンディングをやった時、1番"
    },
    {
      "start": 766.24,
      "duration": 3.76,
      "text": "高いやつ正直値段あんまり言いたくないん"
    },
    {
      "start": 768.079,
      "duration": 3.801,
      "text": "ですが、100万円のやつをその人が"
    },
    {
      "start": 770.0,
      "duration": 3.839,
      "text": "ポンって振り込んでくれたんですよ。"
    },
    {
      "start": 771.88,
      "duration": 4.079,
      "text": "そして一言、まさんにはお世話になったん"
    },
    {
      "start": 773.839,
      "duration": 4.401,
      "text": "でお返しは何もいりません。いや、かっこ"
    },
    {
      "start": 775.959,
      "duration": 4.201,
      "text": "よすぎません?あの数万円の茶ブートが5"
    },
    {
      "start": 778.24,
      "duration": 3.52,
      "text": "年後めちゃくちゃ大きくなって帰ってきた"
    },
    {
      "start": 780.16,
      "duration": 3.239,
      "text": "みたいな。まあね、この本でもお金じゃな"
    },
    {
      "start": 781.76,
      "duration": 3.68,
      "text": "いっていう話はあったんですけど、その"
    },
    {
      "start": 783.399,
      "duration": 4.201,
      "text": "気持ちが嬉しかったんですよね。ちなみに"
    },
    {
      "start": 785.44,
      "duration": 3.959,
      "text": "その人とは2021年に一緒に"
    },
    {
      "start": 787.6,
      "duration": 4.16,
      "text": "YouTuberのオンラインサロン、学"
    },
    {
      "start": 789.399,
      "duration": 4.041,
      "text": "を作って今も仲良くしております。あなた"
    },
    {
      "start": 791.76,
      "duration": 3.759,
      "text": "もね、小さいことでもいいと思うんです。"
    },
    {
      "start": 793.44,
      "duration": 4.6,
      "text": "誰かにギブ積み上げておきましょう。その"
    },
    {
      "start": 795.519,
      "duration": 4.32,
      "text": "積み上げが絶対あなたが困った時助けて"
    },
    {
      "start": 798.04,
      "duration": 4.4,
      "text": "くれるきっかけになりますから、あなたを"
    },
    {
      "start": 799.839,
      "duration": 4.401,
      "text": "助けてくれる人は必ず出てきます。学式"
    },
    {
      "start": 802.44,
      "duration": 3.72,
      "text": "サロンはYouTuberさんのための"
    },
    {
      "start": 804.24,
      "duration": 4.399,
      "text": "オンラインサロンを運営しています。"
    },
    {
      "start": 806.16,
      "duration": 4.96,
      "text": "おかげ様で運営3年以上、メンバー300"
    },
    {
      "start": 808.639,
      "duration": 5.161,
      "text": "名以上、その他にも登録者5万人以上の"
    },
    {
      "start": 811.12,
      "duration": 5.12,
      "text": "運営者は150名以上参加しています。"
    },
    {
      "start": 813.8,
      "duration": 4.32,
      "text": "YouTubeは本当に難しくて難易度は"
    },
    {
      "start": 816.24,
      "duration": 3.88,
      "text": "どんどん上がっています。でも実は"
    },
    {
      "start": 818.12,
      "duration": 4.279,
      "text": "YouTubeには明確なコツがあるん"
    },
    {
      "start": 820.12,
      "duration": 4.519,
      "text": "です。それに気づけないで運営していたら"
    },
    {
      "start": 822.399,
      "duration": 4.041,
      "text": "1年経っても登録者1000人達成でき"
    },
    {
      "start": 824.639,
      "duration": 3.601,
      "text": "ないことがリアルに起こってしまうんです"
    },
    {
      "start": 826.44,
      "duration": 3.68,
      "text": "よね。そこでこのサロンでは"
    },
    {
      "start": 828.24,
      "duration": 4.159,
      "text": "YouTubeのノンハウをみんなで学ぶ"
    },
    {
      "start": 830.12,
      "duration": 4.36,
      "text": "ためにこういったコのツの得典を用意して"
    },
    {
      "start": 832.399,
      "duration": 4.56,
      "text": "います。私からの直接アドバイスも"
    },
    {
      "start": 834.48,
      "duration": 4.719,
      "text": "もちろんOKですし、今このサロンに参加"
    },
    {
      "start": 836.959,
      "duration": 5.201,
      "text": "した人限定で伸び悩んでるチャンネルを"
    },
    {
      "start": 839.199,
      "duration": 5.681,
      "text": "劇的に改善する裏技700。これを無料で"
    },
    {
      "start": 842.16,
      "duration": 5.76,
      "text": "プレゼント中です。実際2ヶ月で収益化"
    },
    {
      "start": 844.88,
      "duration": 5.72,
      "text": "達成できた人、3ヶ月で月20万円稼げた"
    },
    {
      "start": 847.92,
      "duration": 4.599,
      "text": "人、さらにその上の金額を稼いでいる人も"
    },
    {
      "start": 850.6,
      "duration": 4.32,
      "text": "たくさん生まれています。本当にね、"
    },
    {
      "start": 852.519,
      "duration": 4.081,
      "text": "すごいメンバーが揃ってるんですよ。ただ"
    },
    {
      "start": 854.92,
      "duration": 4.159,
      "text": "YouTubeは簡単ではありません。"
    },
    {
      "start": 856.6,
      "duration": 4.239,
      "text": "本気でやらないと成果は絶対出ませんので"
    },
    {
      "start": 859.079,
      "duration": 4.361,
      "text": "、これからね、本気でYouTube"
    },
    {
      "start": 860.839,
      "duration": 4.36,
      "text": "頑張りたい。副業で稼いでみたいという方"
    },
    {
      "start": 863.44,
      "duration": 3.36,
      "text": "のみお待ちております。一緒に"
    },
    {
      "start": 865.199,
      "duration": 6.0,
      "text": "YouTube頑張ってみませんか?"
    },
    {
      "start": 866.8,
      "duration": 4.399,
      "text": "さよなら。さよなら。さよなら。"
    }
  ]
}