    {
      "start": 768.88,
      "duration": 5.0,
      "text": "して可能な限りダメージコントロールを"
    },
    {
      "start": 771.92,
      "duration": 4.359,
      "text": "しっかりしたいという風に考えている点。"
    },
    {
      "start": 773.88,
      "duration": 5.24,
      "text": "これが1点目だと思います。中国はですね"
    },
    {
      "start": 776.279,
      "duration": 6.041,
      "text": "、近年このエネルギー安全保障という観点"
    },
    {
      "start": 779.12,
      "duration": 6.159,
      "text": "からも原油の輸入先を多化化してきたと。"
    },
    {
      "start": 782.32,
      "duration": 5.079,
      "text": "当然その中東もあれば、ロシアもあれば、"
    },
    {
      "start": 785.279,
      "duration": 4.041,
      "text": "東南アジアもあれば、アフリカもあればと"
    },
    {
      "start": 787.399,
      "duration": 3.12,
      "text": "いうことで、ま、一点集中しないってこと"
    },
    {
      "start": 789.32,
      "duration": 2.84,
      "text": "ですね。ま、これある意味ですね、ま、"
    },
    {
      "start": 790.519,
      "duration": 2.88,
      "text": "投資と一緒で、ま、分散させ"
    },
    {
      "start": 792.16,
      "duration": 3.96,
      "text": "るっていうのはこれ当然だという風に思う"
    },
    {
      "start": 793.399,
      "duration": 5.44,
      "text": "んですけれども、あの、多化してきたと"
    },
    {
      "start": 796.12,
      "duration": 7.12,
      "text": "いう経緯がまず特徴としてあると。えっと"
    },
    {
      "start": 798.839,
      "duration": 6.841,
      "text": "、2025年の時点で中国がホルムズ海峡"
    },
    {
      "start": 803.24,
      "duration": 5.68,
      "text": "、ま、今話題になってるホルムズ海峡から"
    },
    {
      "start": 805.68,
      "duration": 7.959,
      "text": "輸入している原油の割合というのは全輸入"
    },
    {
      "start": 808.92,
      "duration": 8.52,
      "text": "料の4割弱、4割弱であると、これは日本"
    },
    {
      "start": 813.639,
      "duration": 6.081,
      "text": "の9割と比べても、ま、相当程度抑えられ"
    },
    {
      "start": 817.44,
      "duration": 5.199,
      "text": "ているという風に言えると思います。です"
    },
    {
      "start": 819.72,
      "duration": 5.72,
      "text": "から、ま、4割弱でもですね、それなりの"
    },
    {
      "start": 822.639,
      "duration": 5.2,
      "text": "、え、量非重ですけれども、ただ日本の9"
    },
    {
      "start": 825.44,
      "duration": 4.12,
      "text": "割以上と比べればですね、ま、ダメージは"
    },
    {
      "start": 827.839,
      "duration": 3.961,
      "text": "コントロールされやすいっていうところが"
    },
    {
      "start": 829.56,
      "duration": 4.519,
      "text": "ありますし、またエネルギー源、"
    },
    {
      "start": 831.8,
      "duration": 4.8,
      "text": "エネルギー源という観点から見てもですね"
    },
    {
      "start": 834.079,
      "duration": 4.721,
      "text": "、中国はこれもあのすごくもう言われて"
    },
    {
      "start": 836.6,
      "duration": 5.08,
      "text": "ますけれども、近年電力化が進んでると"
    },
    {
      "start": 838.8,
      "duration": 6.32,
      "text": "電力化。ま、例えばその2025年におけ"
    },
    {
      "start": 841.68,
      "duration": 6.8,
      "text": "る新エネルギー車の販売の割合というのは"
    },
    {
      "start": 845.12,
      "duration": 5.2,
      "text": "新車の販売全体の約5割に足していると。"
    },
    {
      "start": 848.48,
      "duration": 5.159,
      "text": "ま、つまり、ま、非常に大雑把にいれば、"
    },
    {
      "start": 850.32,
      "duration": 5.6,
      "text": "ま、道端で都市中心にですね、道端で走っ"
    },
    {
      "start": 853.639,
      "duration": 5.081,
      "text": "てる自動車の5割は電気自動車ってこと"
    },
    {
      "start": 855.92,
      "duration": 4.8,
      "text": "です。ま、つまりこう石油とかガソリンに"
    },
    {
      "start": 858.72,
      "duration": 4.16,
      "text": "頼らなくていいってことですね。電力で"
    },
    {
      "start": 860.72,
      "duration": 4.6,
      "text": "こう自動車を回すっていう、ま、こういう"
    },
    {
      "start": 862.88,
      "duration": 4.319,
      "text": "社会構造、経済構造になってきてい"
    },
    {
      "start": 865.32,
      "duration": 4.0,
      "text": "るっていうことですね。その割合は今後も"
    },
    {
      "start": 867.199,
      "duration": 3.681,
      "text": "ですね、ま、増えることはあっても、ま、"
    },
    {
      "start": 869.32,
      "duration": 2.92,
      "text": "どっかピークアウトする可能性あります"
    },
    {
      "start": 870.88,
      "duration": 4.24,
      "text": "けれども、ま、減ることはないんじゃない"
    },
    {
      "start": 872.24,
      "duration": 5.68,
      "text": "かなという風に思うと。またですね、この"
    },
    {
      "start": 875.12,
      "duration": 6.32,
      "text": "中国は世界最大の原油の輸入国ですけれど"
    },
    {
      "start": 877.92,
      "duration": 6.039,
      "text": "も約14億バレルの石油を備蓄していると"
    },
    {
      "start": 881.44,
      "duration": 4.88,
      "text": "。この備蓄というのも1つのテーマキー"
    },
    {
      "start": 883.959,
      "duration": 4.44,
      "text": "ワードであって、ま、国内消費の、ま、"
    },
    {
      "start": 886.32,
      "duration": 5.92,
      "text": "これだけ14億というですね、ま、この"
    },
    {
      "start": 888.399,
      "duration": 6.68,
      "text": "巨大国家の国内消費の約180分、約半年"
    },
    {
      "start": 892.24,
      "duration": 5.0,
      "text": "分に相当する規模を確保しているという"
    },
    {
      "start": 895.079,
      "duration": 4.281,
      "text": "状況もありますし、この備蓄もですね、"
    },
    {
      "start": 897.24,
      "duration": 4.64,
      "text": "簡単には切り崩さないっていう、こういう"
    },
    {
      "start": 899.36,
      "duration": 4.56,
      "text": "、え、スタンスでいるということです。ま"
    },
    {
      "start": 901.88,
      "duration": 4.12,
      "text": "、ただですね、ま、これだけの備えをして"
    },
    {
      "start": 903.92,
      "duration": 3.96,
      "text": "きているとしても、ま、仮にこのイラン"
    },
    {
      "start": 906.0,
      "duration": 5.399,
      "text": "戦争がですね、このウクライナ戦争みたい"
    },
    {
      "start": 907.88,
      "duration": 7.6,
      "text": "にこの長期化すれば当然ですね、中国国内"
    },
    {
      "start": 911.399,
      "duration": 7.841,
      "text": "の経済活動、国民生活の影響は予測不能と"
    },
    {
      "start": 915.48,
      "duration": 7.4,
      "text": "なり、中東情勢全体がさらなる混乱に陥れ"
    },
    {
      "start": 919.24,
      "duration": 5.76,
      "text": "ば制御不能になるという観点から懸念をし"
    },
    {
      "start": 922.88,
      "duration": 3.639,
      "text": "ている。だからしっかり中止をして"
    },
    {
      "start": 925.0,
      "duration": 2.72,
      "text": "ダメージコントロールはやっていこうって"
    },
    {
      "start": 926.519,
      "duration": 5.041,
      "text": "いう、これが1つ目だと思います。これは"
    },
    {
      "start": 927.72,
      "duration": 6.28,
      "text": "1つ目。2つ目が中国として泥沼化しつつ"
    },
    {
      "start": 931.56,
      "duration": 4.6,
      "text": "ある。ま、これもわかんないです。金迫化"
    },
    {
      "start": 934.0,
      "duration": 4.0,
      "text": "長期か泥沼かいろんな言葉があります"
    },
    {
      "start": 936.16,
      "duration": 5.28,
      "text": "けれども、ま、泥沼化しつつある。この"
    },
    {
      "start": 938.0,
      "duration": 5.36,
      "text": "イラン情勢には中視をしつつも深入りには"
    },
    {
      "start": 941.44,
      "duration": 3.959,
      "text": "慎重になると。深入りはしないってこと"
    },
    {
      "start": 943.36,
      "duration": 3.959,
      "text": "です。キーワード深入りはしないと。ま、"
    },
    {
      "start": 945.399,
      "duration": 3.68,
      "text": "しないというよりは不入りには慎重に"
    },
    {
      "start": 947.319,
      "duration": 3.76,
      "text": "なろうとしている点。これも非常に重要だ"
    },
    {
      "start": 949.079,
      "duration": 5.12,
      "text": "という風に思いますね。トランプ大統領が"
    },
    {
      "start": 951.079,
      "duration": 6.641,
      "text": "ですね、この宣言したように米軍がですね"
    },
    {
      "start": 954.199,
      "duration": 6.44,
      "text": "、米海軍がホルムズ海峡を封鎖すべく動き"
    },
    {
      "start": 957.72,
      "duration": 6.4,
      "text": "始めて以降ですね、ま、少なくとも空母1"
    },
    {
      "start": 960.639,
      "duration": 7.32,
      "text": "隻と駆逐間11隻を含む少なくとも15隻"
    },
    {
      "start": 964.12,
      "duration": 6.56,
      "text": "の米鑑邸がフォルムズ海峡付近に配置され"
    },
    {
      "start": 967.959,
      "duration": 5.24,
      "text": "たという風に言われてますと。ま、中国と"
    },
    {
      "start": 970.68,
      "duration": 5.959,
      "text": "してはですね、そんな米軍やイランの反応"
    },
    {
      "start": 973.199,
      "duration": 6.44,
      "text": "を見つつ時国のタンカーがホルムズ海峡を"
    },
    {
      "start": 976.639,
      "duration": 5.56,
      "text": "通過できるように、ま、各方面と交渉行動"
    },
    {
      "start": 979.639,
      "duration": 4.801,
      "text": "はしていくという風に思います。と同時に"
    },
    {
      "start": 982.199,
      "duration": 4.801,
      "text": "ですね、先ほど私が整理したこの対面と"
    },
    {
      "start": 984.44,
      "duration": 6.16,
      "text": "電話のハイブリッドによるこの外交的圧線"
    },
    {
      "start": 987.0,
      "duration": 5.88,
      "text": "を通じて特に中国であるパキスタンを水面"
    },
    {
      "start": 990.6,
      "duration": 4.479,
      "text": "化で支援すべく動いていく。これはあの"
    },
    {
      "start": 992.88,
      "duration": 6.68,
      "text": "規定路線だという風に思いますと。それで"
    },
    {
      "start": 995.079,
      "duration": 6.921,
      "text": "も特に軍事的な行動には慎重に慎重を"
    },
    {
      "start": 999.56,
      "duration": 5.32,
      "text": "重ねるということだという風に思います。"
    },
    {
      "start": 1002.0,
      "duration": 5.48,
      "text": "それはあの不快りをすることでボケを"
    },
    {
      "start": 1004.88,
      "duration": 4.959,
      "text": "掘るていう事態を避けるためだから"
    },
    {
      "start": 1007.48,
      "duration": 5.479,
      "text": "しっかり見ていく。ダメージコントロール"
    },
    {
      "start": 1009.839,
      "duration": 6.161,
      "text": "もしていく。可能な限り予測可能な形で"
    },
    {
      "start": 1012.959,
      "duration": 4.481,
      "text": "制御不能な不教に陥ることを避ける。ただ"
    },
    {
      "start": 1016.0,
      "duration": 3.839,
      "text": "不快りはしないっていう、ま、こういう"
    },
    {
      "start": 1017.44,
      "duration": 4.12,
      "text": "ですね、ま、バランス感覚というか距離感"
    },
    {
      "start": 1019.839,
      "duration": 3.881,
      "text": "で動いていくんじゃないかなという風に"
    },
    {
      "start": 1021.56,
      "duration": 4.6,
      "text": "思います。最後3つ目ですけれども、"
    },
    {
      "start": 1023.72,
      "duration": 4.719,
      "text": "イラン戦争の、ま、まだついてるという"
    },
    {
      "start": 1026.16,
      "duration": 5.2,
      "text": "ことですけれども、このイラン戦争を受け"
    },
    {
      "start": 1028.439,
      "duration": 5.24,
      "text": "てのアメリカ、アメリカの動きを密に"
    },
    {
      "start": 1031.36,
      "duration": 6.12,
      "text": "ウォッチするとアメリカの動きを3つに"
    },
    {
      "start": 1033.679,
      "duration": 5.561,
      "text": "ウォッチするしながら次の一手、次の一手"
    },
    {
      "start": 1037.48,
      "duration": 5.0,
      "text": "、ま、将棋じゃないですけれども、次の"
    },
    {
      "start": 1039.24,
      "duration": 5.559,
      "text": "一手を10行しているという点じゃないか"
    },
    {
      "start": 1042.48,
      "duration": 4.199,
      "text": "なという風に思います。先ほど私はボケを"
    },
    {
      "start": 1044.799,
      "duration": 4.681,
      "text": "掘る、ま、意思のオ運ゴールですよね。"
    },
    {
      "start": 1046.679,
      "duration": 4.281,
      "text": "ボケ血を掘るという観点からすれば中国と"
    },
    {
      "start": 1049.48,
      "duration": 4.24,
      "text": "してはですね、このライバルである"
    },
    {
      "start": 1050.96,
      "duration": 5.36,
      "text": "アメリカがボケを掘るようなオ運ゴールを"
    },
    {
      "start": 1053.72,
      "duration": 4.319,
      "text": "繰り返すような境地にアメリカが陥ること"
    },
    {
      "start": 1056.32,
      "duration": 3.56,
      "text": "をま、これ当然ある意味望んでると思うん"
    },
    {
      "start": 1058.039,
      "duration": 5.361,
      "text": "ですね。ライバルですから。これ競争関係"
    },
    {
      "start": 1059.88,
      "duration": 6.64,
      "text": "ですから。そして米国が中東での戦争に"
    },
    {
      "start": 1063.4,
      "duration": 6.44,
      "text": "明けくれて財政とか軍事とかいった"
    },
    {
      "start": 1066.52,
      "duration": 6.6,
      "text": "キャパシティ及び国内外での指示率、信用"
    },
    {
      "start": 1069.84,
      "duration": 5.8,
      "text": "力を失うようなそれが低下していくような"
    },
    {
      "start": 1073.12,
      "duration": 3.919,
      "text": "ことになればですね、中国としても、え、"
    },
    {
      "start": 1075.64,
      "duration": 3.32,
      "text": "ま、これ必ずしもですね、これ、ま、"
    },
    {
      "start": 1077.039,
      "duration": 5.041,
      "text": "ゼロサムではないですけれども、中国とし"
    },
    {
      "start": 1078.96,
      "duration": 5.8,
      "text": "ても国際社会でですね、より大きな影響力"
    },
    {
      "start": 1082.08,
      "duration": 4.04,
      "text": "と発言権を持つことにつがるという風に"
    },
    {
      "start": 1084.76,
      "duration": 3.08,
      "text": "踏んでいるんじゃないかなという風に思い"
    },
    {
      "start": 1086.12,
      "duration": 5.12,
      "text": "ます。ですからアメリカの動きはしっかり"
    },
    {
      "start": 1087.84,
      "duration": 7.16,
      "text": "見ていくと、ま、ですから不りせずとも非"
    },
    {
      "start": 1091.24,
      "duration": 5.48,
      "text": "軍事的な手段としての外交的に尽力して"
    },
    {
      "start": 1095.0,
      "duration": 4.72,
      "text": "いるのはそのためなんじゃないかなという"
    },
    {
      "start": 1096.72,
      "duration": 6.04,
      "text": "風に思います。イランのこの情勢、イラン"
    },
    {
      "start": 1099.72,
      "duration": 6.24,
      "text": "情勢の推移を見ながらですね、この米中、"
    },
    {
      "start": 1102.76,
      "duration": 5.48,
      "text": "え、2大国間の攻防が関係がどうなって"
    },
    {
      "start": 1105.96,
      "duration": 3.48,
      "text": "いくのかというところは非常に注目"
    },
    {
      "start": 1108.24,
      "duration": 3.559,
      "text": "ポイントだという風に思います。あの、"
    },
    {
      "start": 1109.44,
      "duration": 4.119,
      "text": "イラン情勢に対してですね、ま、米国、ま"
    },
    {
      "start": 1111.799,
      "duration": 4.161,
      "text": "、アメリカアルミこう当事者ですけれども"
    },
    {
      "start": 1113.559,
      "duration": 4.6,
      "text": "、中国は中国で今日ですね、私がこう整理"
    },
    {
      "start": 1115.96,
      "duration": 4.32,
      "text": "してきたように、ま、しっかりと見る。"
    },
    {
      "start": 1118.159,
      "duration": 3.721,
      "text": "ただ不快りはしない。そしてアメリカどう"
    },
    {
      "start": 1120.28,
      "duration": 3.2,
      "text": "かっていうところを見ながら次の一手を"
    },
    {
      "start": 1121.88,
      "duration": 3.159,
      "text": "考えるっていうま、こういう風に、ま、"
    },
    {
      "start": 1123.48,
      "duration": 4.199,
      "text": "整理ができるという風に思うんですけれど"
    },
    {
      "start": 1125.039,
      "duration": 5.321,
      "text": "も、ま、そんな中ですね、この約1ヶ月後"
    },
    {
      "start": 1127.679,
      "duration": 5.081,
      "text": "、ま、5月14から15という風に言われ"
    },
    {
      "start": 1130.36,
      "duration": 5.12,
      "text": "てますけれども、約1ヶ月後に迫った"
    },
    {
      "start": 1132.76,
      "duration": 5.159,
      "text": "トランプ大統領の中国訪問、これを占う上"
    },
    {
      "start": 1135.48,
      "duration": 5.0,
      "text": "でもイラン情勢そのものがどう推移して"
    },
    {
      "start": 1137.919,
      "duration": 4.681,
      "text": "いくのか、イラン情勢の中でアメリカが"
    },
    {
      "start": 1140.48,
      "duration": 4.64,
      "text": "どういう行動を取っていくのか、それを"
    },
    {
      "start": 1142.6,
      "duration": 4.84,
      "text": "中国がどういう風に見て動いていくのか、"
    },
    {
      "start": 1145.12,
      "duration": 4.559,
      "text": "ま、こういったですね、非常にこう複雑な"
    },
    {
      "start": 1147.44,
      "duration": 4.56,
      "text": "状況が現状あるということですけれども、"
    },
    {
      "start": 1149.679,
      "duration": 5.88,
      "text": "これらの状況が当然ですね、こうトランプ"
    },
    {
      "start": 1152.0,
      "duration": 6.6,
      "text": "大統領の放中に影響していきますし、逆に"
    },
    {
      "start": 1155.559,
      "duration": 5.48,
      "text": "トランプ大統領の放が、ま、予定通り行わ"
    },
    {
      "start": 1158.6,
      "duration": 4.319,
      "text": "れるのか、あるいはまたしても延期される"
    },
    {
      "start": 1161.039,
      "duration": 4.921,
      "text": "のか、ま、そういったところも含めてです"
    },
    {
      "start": 1162.919,
      "duration": 5.921,
      "text": "ね、このイラン情勢、昨のこの世界情勢は"
    },
    {
      "start": 1165.96,
      "duration": 5.16,
      "text": "このイラン情勢を1つの起点としてこの"
    },
    {
      "start": 1168.84,
      "duration": 4.839,
      "text": "米中というですね、この二大国の関係まで"
    },
    {
      "start": 1171.12,
      "duration": 5.6,
      "text": "もはですね、よくも悪くもこう翻弄されて"
    },
    {
      "start": 1173.679,
      "duration": 4.761,
      "text": "、その翻弄具合がまたこの世界情勢、世界"
    },
    {
      "start": 1176.72,
      "duration": 4.079,
      "text": "経済を含めてそっちに跳ね返っていくって"
    },
    {
      "start": 1178.44,
      "duration": 4.239,
      "text": "いうですですね、こういう非常に難しい、"
    },
    {
      "start": 1180.799,
      "duration": 4.0,
      "text": "え、状況にあるんじゃないかなというのが"
    },
    {
      "start": 1182.679,
      "duration": 3.561,
      "text": "、ま、私の現時点での分析です。ま、また"
    },
    {
      "start": 1184.799,
      "duration": 3.24,
      "text": "ですね、イラン情勢、あの、非常にもう"
    },
    {
      "start": 1186.24,
      "duration": 3.76,
      "text": "動きは流動的で、日々いろんなことが起き"
    },
    {
      "start": 1188.039,
      "duration": 4.361,
      "text": "て変わってますけれども、また可能な範囲"
    },
    {
      "start": 1190.0,
      "duration": 4.08,
      "text": "でですね、この中国の動きも含めて私なり"
    },
    {
      "start": 1192.4,
      "duration": 4.04,
      "text": "にこのフォローモニタリングをして、え、"
    },
    {
      "start": 1194.08,
      "duration": 3.959,
      "text": "この動画でもですね、適々、え、共有報告"
    },
    {
      "start": 1196.44,
      "duration": 4.52,
      "text": "をしていければいいかなという風に思って"
    },
    {
      "start": 1198.039,
      "duration": 4.921,
      "text": "ます。はい。え、楽天証券の投資場情報"
    },
    {
      "start": 1200.96,
      "duration": 4.12,
      "text": "メリア投シルがお送りしております。仮に"
    },
    {
      "start": 1202.96,
      "duration": 3.68,
      "text": "私の先ほどの話少しはためになったなと"
    },
    {
      "start": 1205.08,
      "duration": 4.12,
      "text": "思われた方はですね、え、チャンネル登録"
    },
    {
      "start": 1206.64,
      "duration": 4.32,
      "text": "そしていいねと大変幸いでございます。"
    },
    {
      "start": 1209.2,
      "duration": 5.16,
      "text": "まともにかかります。ご成聴ありがとう"
    },
    {
      "start": 1210.96,
      "duration": 3.4,
      "text": "ございました。"
    }
  ]
}