      "duration": 5.521,
      "text": "知り合い。大体この辺の例えばどんな趣味"
    },
    {
      "start": 412.24,
      "duration": 5.079,
      "text": "ですか?どこのご出身ですか?何かお"
    },
    {
      "start": 415.0,
      "duration": 4.28,
      "text": "悩み事ありますかとかね。え、どんなお"
    },
    {
      "start": 417.319,
      "duration": 3.88,
      "text": "食べ物好きですか?ま、大体そんな話で"
    },
    {
      "start": 419.28,
      "duration": 4.52,
      "text": "なんかは出てきますよね。楽しく会話"
    },
    {
      "start": 421.199,
      "duration": 5.241,
      "text": "できるんじゃないでしょうか。なので質問"
    },
    {
      "start": 423.8,
      "duration": 6.16,
      "text": "はどしどししていただきたいということで"
    },
    {
      "start": 426.44,
      "duration": 5.8,
      "text": "どしですね。さっきの年でドシドと言って"
    },
    {
      "start": 429.96,
      "duration": 4.359,
      "text": "んですけれども、例えばどんなだったら次"
    },
    {
      "start": 432.24,
      "duration": 4.0,
      "text": "どの人とやるんですか?こ、どこでやるん"
    },
    {
      "start": 434.319,
      "duration": 5.16,
      "text": "ですかっていう風にこう回していくと次の"
    },
    {
      "start": 436.24,
      "duration": 6.2,
      "text": "質問色々出てきますという風にこう回して"
    },
    {
      "start": 439.479,
      "duration": 6.72,
      "text": "いくと無現代に質問は生まれていきます。"
    },
    {
      "start": 442.44,
      "duration": 6.64,
      "text": "じゃあ雑談のダメということでこの会話A"
    },
    {
      "start": 446.199,
      "duration": 5.4,
      "text": "さん読書好きなんです。Bさん私食べ歩き"
    },
    {
      "start": 449.08,
      "duration": 4.839,
      "text": "なんです。これはどこがちょっといけない"
    },
    {
      "start": 451.599,
      "duration": 4.361,
      "text": "でしょうかね。私せっかく読書好きなん"
    },
    {
      "start": 453.919,
      "duration": 3.72,
      "text": "ですよって話したらいきなりもうそっちの"
    },
    {
      "start": 455.96,
      "duration": 3.44,
      "text": "食べ歩きの話になっちゃったりしたら"
    },
    {
      "start": 457.639,
      "duration": 3.4,
      "text": "なんか話があれ持って帰れちゃったなって"
    },
    {
      "start": 459.4,
      "duration": 4.199,
      "text": "感じになるじゃないですか。あのなので"
    },
    {
      "start": 461.039,
      "duration": 4.681,
      "text": "まずはこういう話したらあ、それどういう"
    },
    {
      "start": 463.599,
      "duration": 4.761,
      "text": "本なんですか?最近読んだ本で面白かった"
    },
    {
      "start": 465.72,
      "duration": 5.56,
      "text": "本あります?おすめありますっていうよう"
    },
    {
      "start": 468.36,
      "duration": 5.0,
      "text": "な話に持っていってあげてください。あの"
    },
    {
      "start": 471.28,
      "duration": 5.08,
      "text": "、ミー法とUFO法っていうことなんです"
    },
    {
      "start": 473.36,
      "duration": 4.88,
      "text": "けれども、こう私もね、私のすに、常に"
    },
    {
      "start": 476.36,
      "duration": 4.519,
      "text": "こうスイッチ、自分の方にスイッチして"
    },
    {
      "start": 478.24,
      "duration": 5.079,
      "text": "しまうやり方と、あ、それで、え、どんな"
    },
    {
      "start": 480.879,
      "duration": 5.121,
      "text": "本で、それからっていう相手にマイクを"
    },
    {
      "start": 483.319,
      "duration": 6.0,
      "text": "渡してあげるような話し方、相手が話し"
    },
    {
      "start": 486.0,
      "duration": 5.8,
      "text": "やすくなるように質問をしてあげましょう"
    },
    {
      "start": 489.319,
      "duration": 4.32,
      "text": "ということです。え、簡単なのはもう"
    },
    {
      "start": 491.8,
      "duration": 4.2,
      "text": "ヒーローインタビューをしてみようという"
    },
    {
      "start": 493.639,
      "duration": 5.12,
      "text": "ことなんですね。ま、私は元々新聞記者"
    },
    {
      "start": 496.0,
      "duration": 4.68,
      "text": "だったので、非常にその相手の人生の"
    },
    {
      "start": 498.759,
      "duration": 5.241,
      "text": "ストーリーとかにとても興味がありまして"
    },
    {
      "start": 500.68,
      "duration": 5.32,
      "text": "、いろんな人と話してると思いがけない"
    },
    {
      "start": 504.0,
      "duration": 4.599,
      "text": "素晴らしい素敵なストーリーを持ってる方"
    },
    {
      "start": 506.0,
      "duration": 4.759,
      "text": "ってたくさんいまして、そのストーリーを"
    },
    {
      "start": 508.599,
      "duration": 6.401,
      "text": "聞くのが私大好きなんですよね。なので"
    },
    {
      "start": 510.759,
      "duration": 6.921,
      "text": "旅行で、もう地元の方とかとお話してると"
    },
    {
      "start": 515.0,
      "duration": 5.279,
      "text": "こんなレス美味しいとかあるよとか、もう"
    },
    {
      "start": 517.68,
      "duration": 5.64,
      "text": "情報の方向なわけですよ。今の時代情報"
    },
    {
      "start": 520.279,
      "duration": 5.721,
      "text": "こそがお金と同じぐらいの価値を持つわけ"
    },
    {
      "start": 523.32,
      "duration": 4.84,
      "text": "で、やっぱり人に対して自分の話してると"
    },
    {
      "start": 526.0,
      "duration": 4.2,
      "text": "もちろん気持ちいいんですけど、それじゃ"
    },
    {
      "start": 528.16,
      "duration": 4.16,
      "text": "全然自分は学べないんですよね。例えばね"
    },
    {
      "start": 530.2,
      "duration": 4.28,
      "text": "、ま、セールスマンだったとしてもなんか"
    },
    {
      "start": 532.32,
      "duration": 4.12,
      "text": "金融商品売ろうとしたとしてもですよ。"
    },
    {
      "start": 534.48,
      "duration": 4.24,
      "text": "その人がいくらぐらい持ってて、どれ"
    },
    {
      "start": 536.44,
      "duration": 4.36,
      "text": "ぐらいのリスク回避思考があってとかって"
    },
    {
      "start": 538.72,
      "duration": 3.64,
      "text": "いうことを知らないでこの商品はって言っ"
    },
    {
      "start": 540.8,
      "duration": 3.64,
      "text": "てもしょうがないわけですよね。あ、この"
    },
    {
      "start": 542.36,
      "duration": 4.4,
      "text": "人はこういうことに悩んでんだ。どういう"
    },
    {
      "start": 544.44,
      "duration": 4.76,
      "text": "ぐらいのお金持ってんだなとかいう情報を"
    },
    {
      "start": 546.76,
      "duration": 4.8,
      "text": "いかに掘り出すかっていうことがやっぱり"
    },
    {
      "start": 549.2,
      "duration": 5.28,
      "text": "これからのビジネスにも生きてきますし、"
    },
    {
      "start": 551.56,
      "duration": 4.959,
      "text": "それからやはりその人脈という意味でも"
    },
    {
      "start": 554.48,
      "duration": 4.76,
      "text": "どんどんと話を聞いてあげることによって"
    },
    {
      "start": 556.519,
      "duration": 6.801,
      "text": "相手が自分に心を開いてくれるような状態"
    },
    {
      "start": 559.24,
      "duration": 8.2,
      "text": "になると聞く力をベースにすれば苦手な人"
    },
    {
      "start": 563.32,
      "duration": 7.12,
      "text": "も雑談会話力を高めることができる。"
    },
    {
      "start": 567.44,
      "duration": 4.76,
      "text": "続いては相手が自分の話を聞きたくなる"
    },
    {
      "start": 570.44,
      "duration": 3.76,
      "text": "コミュニケーションの取り方を学んでいく"
    },
    {
      "start": 572.2,
      "duration": 3.56,
      "text": "。"
    },
    {
      "start": 574.2,
      "duration": 4.44,
      "text": "さて、じゃあここからコミュニケーション"
    },
    {
      "start": 575.76,
      "duration": 6.24,
      "text": "の3つの法則という話をしていきます。"
    },
    {
      "start": 578.64,
      "duration": 6.759,
      "text": "まずルールナンバーワン。はい。皆さんは"
    },
    {
      "start": 582.0,
      "duration": 5.56,
      "text": "何か言いたいことがあったらそれを伝える"
    },
    {
      "start": 585.399,
      "duration": 4.56,
      "text": "ことに必死になってませんかということな"
    },
    {
      "start": 587.56,
      "duration": 4.68,
      "text": "んですけど、言いたいこと、皆さんが言い"
    },
    {
      "start": 589.959,
      "duration": 5.521,
      "text": "たいことは大抵相手が聞きたいことであり"
    },
    {
      "start": 592.24,
      "duration": 5.52,
      "text": "ません。なのでまず自分が何を言いたいの"
    },
    {
      "start": 595.48,
      "duration": 5.599,
      "text": "かということはちょっと置いといて"
    },
    {
      "start": 597.76,
      "duration": 6.4,
      "text": "ください。まずは自分の言いたいことを"
    },
    {
      "start": 601.079,
      "duration": 4.721,
      "text": "こう手放す。話すというのは自分を手放す"
    },
    {
      "start": 604.16,
      "duration": 3.76,
      "text": "ことであるというのを私はよく言ってい"
    },
    {
      "start": 605.8,
      "duration": 3.76,
      "text": "ます。まずは自分が何を言いたいのか"
    },
    {
      "start": 607.92,
      "duration": 5.919,
      "text": "ちょっと置いといていただきたいんですね"
    },
    {
      "start": 609.56,
      "duration": 6.279,
      "text": "。だって相手はね、自分が聞きたい話しか"
    },
    {
      "start": 613.839,
      "duration": 5.041,
      "text": "聞かないですよね、皆さん。そうですよね"
    },
    {
      "start": 615.839,
      "duration": 6.24,
      "text": "。で、ま、ファクトやエビデンスだから"
    },
    {
      "start": 618.88,
      "duration": 4.76,
      "text": "これ正しいから伝えればと思って一生懸命"
    },
    {
      "start": 622.079,
      "duration": 4.281,
      "text": "言ってるんでしょうけど、聞き手にして"
    },
    {
      "start": 623.64,
      "duration": 5.8,
      "text": "みるとね、自分が信じていること以外は"
    },
    {
      "start": 626.36,
      "duration": 5.4,
      "text": "全部鼻のけちゃうもんなんですよ。高一"
    },
    {
      "start": 629.44,
      "duration": 5.16,
      "text": "さん大好きとか人にいや高一さんってさと"
    },
    {
      "start": 631.76,
      "duration": 6.56,
      "text": "か色々言ったって多分聞かないですし色々"
    },
    {
      "start": 634.6,
      "duration": 7.12,
      "text": "人の信念ってありますよね。それにこうち"
    },
    {
      "start": 638.32,
      "duration": 5.28,
      "text": "それとこう一致しない情報をいやこんなに"
    },
    {
      "start": 641.72,
      "duration": 4.64,
      "text": "エビデンスありますよ。こんなんなんです"
    },
    {
      "start": 643.6,
      "duration": 4.76,
      "text": "よって色々伝えたところで多分人の気持"
    },
    {
      "start": 646.36,
      "duration": 3.719,
      "text": "ちって全く変わらないわけですよね。それ"
    },
    {
      "start": 648.36,
      "duration": 5.44,
      "text": "でもやっぱりファクトだからエビデンスだ"
    },
    {
      "start": 650.079,
      "duration": 5.56,
      "text": "からと言って伝えてしまうという傾向が"
    },
    {
      "start": 653.8,
      "duration": 4.839,
      "text": "やっぱりあるわけですよ。"
    },
    {
      "start": 655.639,
      "duration": 3.0,
      "text": "正論は残念ながら本当に響かないファクトやビデンス。これを"
    },
    {
      "start": 659.6,
      "duration": 3.0,
      "text": "確証バイアスと言います。コンファメーションバイアス。人は自分が信じている情報、求めている情報以外は全部跳ねのけてしまうということなわけです。なのでコミュニケーションにおいてとても大事なのは相手の鍵穴の形を見つけるということです。自分の鍵をですね鍵穴の形がどうでなんかねじ込めばねくんじゃないか。"
    },
    {
      "start": 682.36,
      "duration": 6.599,
      "text": "心の扉と思っていたら大間違い。相手の心"
    },
    {
      "start": 685.56,
      "duration": 5.8,
      "text": "の扉がの鍵穴がですね、丸だったら自分の"
    },
    {
      "start": 688.959,
      "duration": 3.68,
      "text": "鍵の先っぽ丸にするしかない。コミュニ"
    },
    {
      "start": 691.36,
      "duration": 4.159,
      "text": "ケーショーションっていうのはそもそも"
    },
    {
      "start": 692.639,
      "duration": 5.721,
      "text": "まず発信者最初にことなんか伝えようと"
    },
    {
      "start": 695.519,
      "duration": 5.481,
      "text": "する人がまず最初の責任を持つわけですよ"
    },
    {
      "start": 698.36,
      "duration": 5.32,
      "text": "ね。その人がどういうボールを投げるかで"
    },
    {
      "start": 701.0,
      "duration": 6.16,
      "text": "始まるか始まらないか決まるわけです。な"
    },
    {
      "start": 703.68,
      "duration": 5.88,
      "text": "ので皆さん自分がこうボールを投げる時に"
    },
    {
      "start": 707.16,
      "duration": 4.4,
      "text": "相手がちゃんとここに投げてくださいよと"
    },
    {
      "start": 709.56,
      "duration": 3.519,
      "text": "いうボールを投げてあげて欲しいわけです"
    },
    {
      "start": 711.56,
      "duration": 3.959,
      "text": "。"
    },
    {
      "start": 713.079,
      "duration": 4.56,
      "text": "ではどういう話だったら相手が聞いて"
    },
    {
      "start": 715.519,
      "duration": 4.161,
      "text": "くれるでしょうかね。なかなか伝わってる"
    },
    {
      "start": 717.639,
      "duration": 3.64,
      "text": "感じしませんっておっしゃってる方"
    },
    {
      "start": 719.68,
      "duration": 3.959,
      "text": "いっぱいいましたけど、そりそうですよ。"
    },
    {
      "start": 721.279,
      "duration": 5.321,
      "text": "多分相手聞きたくないと思ってる話を一生"
    },
    {
      "start": 723.639,
      "duration": 7.64,
      "text": "懸命しなきゃいけない。でも聞きたいと"
    },
    {
      "start": 726.6,
      "duration": 7.28,
      "text": "思ってる話に絡めてこう話をしていけば"
    },
    {
      "start": 731.279,
      "duration": 7.041,
      "text": "相手は受け取ってくれるはずなんです。で"
    },
    {
      "start": 733.88,
      "duration": 6.759,
      "text": "はどういう話かと言うと価値と関係と関心"
    },
    {
      "start": 738.32,
      "duration": 6.199,
      "text": "というこの3つの座用軸で覚えてください"
    },
    {
      "start": 740.639,
      "duration": 6.801,
      "text": "。相手の価値です。で、この価値という"
    },
    {
      "start": 744.519,
      "duration": 4.601,
      "text": "ことではみか保管と覚えてください。私は"
    },
    {
      "start": 747.44,
      "duration": 4.12,
      "text": "あのコミュニケーションの法則をあの"
    },
    {
      "start": 749.12,
      "duration": 5.0,
      "text": "ゴロ合わせでなるべく皆さんが覚えやすい"
    },
    {
      "start": 751.56,
      "duration": 5.48,
      "text": "ように考えるのが趣味なんですが、え、"
    },
    {
      "start": 754.12,
      "duration": 5.839,
      "text": "みか保管。これは認める、共感する、"
    },
    {
      "start": 757.04,
      "duration": 6.599,
      "text": "褒める、感謝する。この組み合わせです。"
    },
    {
      "start": 759.959,
      "duration": 5.68,
      "text": "これ相手にの例えばですね、ま、子供でも"
    },
    {
      "start": 763.639,
      "duration": 4.161,
      "text": "いいですよ。それから部下でもいいです。"
    },
    {
      "start": 765.639,
      "duration": 4.88,
      "text": "あ、こういうとこ朝早く人やったんだねと"
    },
    {
      "start": 767.8,
      "duration": 4.599,
      "text": "かちょっと認めてあげるね。その、あの、"
    },
    {
      "start": 770.519,
      "duration": 4.241,
      "text": "こうすごいねって褒める必要なくて、"
    },
    {
      "start": 772.399,
      "duration": 4.88,
      "text": "ちょっとした変化に気づいてあげて認めて"
    },
    {
      "start": 774.76,
      "duration": 5.56,
      "text": "あげる。そして相手に共感してあげる。"
    },
    {
      "start": 777.279,
      "duration": 5.8,
      "text": "辛かったですね。それは面白かったですよ"
    },
    {
      "start": 780.32,
      "duration": 5.84,
      "text": "ね。よくやりましたよねって。相手の感情"
    },
    {
      "start": 783.079,
      "duration": 6.401,
      "text": "に寄り添う。これは本当に大事。そして"
    },
    {
      "start": 786.16,
      "duration": 6.08,
      "text": "褒めてあげて、そして感謝をする。この4"
    },
    {
      "start": 789.48,
      "duration": 5.76,
      "text": "点セットで相手の価値を伝えてあげると"
    },
    {
      "start": 792.24,
      "duration": 4.959,
      "text": "いうこと。そして相手に関係がある話にし"
    },
    {
      "start": 795.24,
      "duration": 5.32,
      "text": "ていくということ。自分に関係ある話じゃ"
    },
    {
      "start": 797.199,
      "duration": 5.721,
      "text": "なくて、相手の相手がやっぱり関係ある話"
    },
    {
      "start": 800.56,
      "duration": 5.12,
      "text": "。それどういうことかというと、金回りに"
    },
    {
      "start": 802.92,
      "duration": 4.96,
      "text": "困る役員ということで、お金の話どうです"
    },
    {
      "start": 805.68,
      "duration": 5.36,
      "text": "か皆さん?お金の話を聞きたいですよね。"
    },
    {
      "start": 807.88,
      "duration": 5.399,
      "text": "保険の話とか、え、あとは年金の話である"
    },
    {
      "start": 811.04,
      "duration": 4.0,
      "text": "とか、お給料の話とかそういうのが上がる"
    },
    {
      "start": 813.279,
      "duration": 4.641,
      "text": "とか下がるとか、そういうのに皆さん興味"
    },
    {
      "start": 815.04,
      "duration": 4.96,
      "text": "あるでしょう。あとは身の周りの話、お隣"
    },
    {
      "start": 817.92,
      "duration": 6.12,
      "text": "に住んでるなんとかさんがどうしたんだろ"
    },
    {
      "start": 820.0,
      "duration": 5.48,
      "text": "うって。そして悩み事、困り事。これは皆"
    },
    {
      "start": 824.04,
      "duration": 3.08,
      "text": "さんを聞きたいんじゃないね。色々聞き"
    },
    {
      "start": 825.48,
      "duration": 5.479,
      "text": "たいんじゃないですかね、皆さん。あとは"
    },
    {
      "start": 827.12,
      "duration": 6.44,
      "text": "役に立つことね。このせ、この潜在すごく"
    },
    {
      "start": 830.959,
      "duration": 4.161,
      "text": "良くてとか、このこれであの装置が"
    },
    {
      "start": 833.56,
      "duration": 3.44,
      "text": "ものすごく楽になりますよとか言ったら"
    },
    {
      "start": 835.12,
      "duration": 3.719,
      "text": "なんか聞きたいってなりますね。あとは"
    },
    {
      "start": 837.0,
      "duration": 3.639,
      "text": "インパクトがあること。皆さんの人生に"
    },
    {
      "start": 838.839,
      "duration": 4.601,
      "text": "インパクトがあること。こういう話であれ"
    },
    {
      "start": 840.639,
      "duration": 5.12,
      "text": "ばもうどうぞどうぞ投げてくださいとね。"
    },
    {
      "start": 843.44,
      "duration": 4.48,
      "text": "もうストレートこのこここの辺にあるある"
    },
    {
      "start": 845.759,
      "duration": 5.401,
      "text": "話です。まさにここがストライクゾーンと"
    },
    {
      "start": 847.92,
      "duration": 6.88,
      "text": "いうことになります。で、関心。え、これ"
    },
    {
      "start": 851.16,
      "duration": 7.28,
      "text": "は人気の有名人が失敗して心境の変化を"
    },
    {
      "start": 854.8,
      "duration": 5.279,
      "text": "告白ということですが、ま、人気のある人"
    },
    {
      "start": 858.44,
      "duration": 4.079,
      "text": "の話ってみんな聞きたいわけですよ。あの"
    },
    {
      "start": 860.079,
      "duration": 4.0,
      "text": "、大谷翔平側とかね、なんかそういう話"
    },
    {
      "start": 862.519,
      "duration": 4.521,
      "text": "聞きたいじゃないですか。もう高一さんが"
    },
    {
      "start": 864.079,
      "duration": 5.241,
      "text": "でってま、なるわけです。そ、失敗の話。"
    },
    {
      "start": 867.04,
      "duration": 4.96,
      "text": "ま、成功話も面白いですけど、やっぱ失敗"
    },
    {
      "start": 869.32,
      "duration": 6.8,
      "text": "の話ってやっぱ人を揺さぶりますよね。と"
    },
    {
      "start": 872.0,
      "duration": 7.88,
      "text": "はこ感情、心が揺れる話、大きく変化する"
    },
    {
      "start": 876.12,
      "duration": 6.0,
      "text": "話、ま、ニュースになるような話で告白と"
    },
    {
      "start": 879.88,
      "duration": 5.36,
      "text": "なので、ま、芸能人の不倫ネタがですね、"
    },
    {
      "start": 882.12,
      "duration": 5.88,
      "text": "あれだけもう色々騒がれるのは人が関心"
    },
    {
      "start": 885.24,
      "duration": 4.88,
      "text": "持つ要素が全部入ってるんですよね。ま、"
    },
    {
      "start": 888.0,
      "duration": 4.399,
      "text": "人気の有名人がまさにこういうことなんで"
    },
    {
      "start": 890.12,
      "duration": 4.44,
      "text": "、え、なんでなんでって皆さん監心を持つ"
    },
    {
      "start": 892.399,
      "duration": 5.161,
      "text": "ということなわけです。なので皆さんが"
    },
    {
      "start": 894.56,
      "duration": 4.839,
      "text": "話そうと思ってる内容がどれか1つでも"
    },
    {
      "start": 897.56,
      "duration": 4.32,
      "text": "満たしていますかということをちょっと"
    },
    {
      "start": 899.399,
      "duration": 5.0,
      "text": "考えてみてください。相手の関心時入っ"
    },
    {
      "start": 901.88,
      "duration": 5.639,
      "text": "てるかな?相手に関係する話になってるか"
    },
    {
      "start": 904.399,
      "duration": 4.921,
      "text": "な?そうじゃないともう避けられてね、"
    },
    {
      "start": 907.519,
      "duration": 3.56,
      "text": "全然受け取ってくれないんじゃないかと"
    },
    {
      "start": 909.32,
      "duration": 4.8,
      "text": "いうことを考えていきましょう。なので"
    },
    {
      "start": 911.079,
      "duration": 5.481,
      "text": "ルールナンバーワン"
    },
    {
      "start": 914.12,
      "duration": 5.6,
      "text": "だけれども相手が聞きたいことをまずは"
    },
    {
      "start": 916.56,
      "duration": 6.519,
      "text": "優先させないと人は受け取ってくれません"
    },
    {
      "start": 919.72,
      "duration": 5.52,
      "text": "よということになります。もちろんね、"
    },
    {
      "start": 923.079,
      "duration": 4.921,
      "text": "言いたいことも言う必要あるでしょう。"
    },
    {
      "start": 925.24,
      "duration": 4.24,
      "text": "ただ最初にそれ持ってくるとあ、あなたの"
    },
    {
      "start": 928.0,
      "duration": 5.36,
      "text": "話聞かなきゃいけないのねってなります"
    },
    {
      "start": 929.48,
      "duration": 6.799,
      "text": "から。まずは相手が話したい話。そこに"
    },
    {
      "start": 933.36,
      "duration": 5.0,
      "text": "上手に自分のごメッセージを潜り込ませる"
    },
    {
      "start": 936.279,
      "duration": 4.92,
      "text": "ぐらいでないとなかなか受け取ってくれ"
    },
    {
      "start": 938.36,
      "duration": 7.959,
      "text": "ません。2つ目です。え、"
    },
    {
      "start": 941.199,
      "duration": 5.12,
      "text": "インフォメーションよりエモーション。"
    }
  ]
}