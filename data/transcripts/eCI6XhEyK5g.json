    {
      "start": 1563.08,
      "duration": 3.52,
      "text": "すごい。"
    },
    {
      "start": 1563.6,
      "duration": 3.0,
      "text": "どう食べた?て中国の伝統医学も出てくるんですよ。"
    },
    {
      "start": 1567.2,
